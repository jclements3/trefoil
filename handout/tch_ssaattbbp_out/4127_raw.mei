              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 11: B c d c = 4 beats. Chords: G C#°→D D F#m
                 C#° is diminished — diatonic sub in D: vii° = C#° which IS diatonic in D major
                 But C#°: C#-E-G — only C# is altered. Use as-is but spell diatonically. -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m11n2" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m11n3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m11n4" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- G(1)=G4-B4-D5, C#°/vii°(1)=C#4-E4, D(1)=F#4-D5, F#m(1)=A4-C#5 -->
                <layer n="1">
                  <chord xml:id="m11r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m11r2" dur="4">
                    <note pname="c" oct="4" accid.ges="s"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m11r3" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m11r4" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- G(1)=G2-D3-G3-B3, vii°(1)=C#3-E3-G3, D(1)=D2-A2-D3-F#3, F#m(1)=F#2-C#3-F#3-A3 -->
                <layer n="1">
                  <chord xml:id="m11l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m11l2" dur="4">
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m11l3" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m11l4" dur="4">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Bar 12: d c B B = 4 beats. Chords: Bm A Bm7 E
                 Climax region — full 3+4 voicing, rich Bm7 -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12n1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m12n2" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m12n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m12n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Bm(1)=D4-F#4-B4, A(1)=C#4-E4-A4, Bm7(1)=D4-A4-B4, Em sub E(1)=E4-G4-B4 -->
                <layer n="1">
                  <chord xml:id="m12r1" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m12r2" dur="4">
                    <note pname="c" oct="4" accid.ges="s"/>
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m12r3" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m12r4" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Bm(1)=B2-F#3-B3-D4, A(1)=A2-E3-A3-C#4, Bm7(1)=B2-F#3-A3-D4, Em(1)=E2-B2-E3-G3 -->
                <layer n="1">
                  <chord xml:id="m12l1" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <chord xml:id="m12l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m12l3" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="a" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <chord xml:id="m12l4" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">②m7</harm>
              <harm staff="1" tstamp="4">②m7</harm>
            </measure>

            <!-- Bar 13: A B B A = 4 beats. Chords: A G D
                 A(1), G(1), G(1)→D transition, D(1) — cadential motion -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m13n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m13n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m13n4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- A(1)=E4-A4, G(2)=G4-B4-D5, D(1)=F#4-A4 -->
                <layer n="1">
