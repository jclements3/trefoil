                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- A(1)=A2-E3-A3-C#4, G(2)=G2-D3-G3-B3, D(1)=D2-A2-D3-F#3 -->
                <layer n="1">
                  <chord xml:id="m13l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m13l2" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m13l3" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 14: B G F d = 4 beats. Chords: Eb→Em  Em  Bb→Bm  Bm
                 Eb and Bb are non-diatonic in D major. Substitute:
                 Eb → Em (ii in D), Bb → Bm (vi in D... wait, Bm IS diatonic as ii)
                 Actually treating as chromatic passing chords, substitute:
                 Eb context → Em (diatonic), Bb → B (use B major = V/Em = non-diatonic but common)
                 Better: Bb → use G major (IV), Eb → Em -->
            <measure n="14">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m14n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m14n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m14n3" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m14n4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Em(2)=E4-G4-B4, Bm(2)=D4-F#4-B4 -->
                <layer n="1">
                  <chord xml:id="m14r1" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m14r2" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Em(2)=E2-B2-E3-G3, Bm(2)=B2-F#3-B3-D4 -->
                <layer n="1">
                  <chord xml:id="m14l1" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m14l2" dur="2">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Bar 15: c B A B = 4 beats. Chords: F#m G D Eb→Em
                 Same as bar 3 / 7 pattern -->
            <measure n="15">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15n1" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m15n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m15n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m15n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- F#m(1)=A4-C#5, G(1)=B4-D5, D(1)=F#4-A4, Em(1)=G4-B4 -->
                <layer n="1">
                  <chord xml:id="m15r1" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m15r2" dur="4">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m15r3" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m15r4" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- F#m(1)=F#2-C#3-F#3-A3, G(1)=G2-D3-G3-B3, D(1)=D2-A2-D3, Em(1)=E2-B2-E3-G3 -->
                <layer n="1">
                  <chord xml:id="m15l1" dur="4">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m15l2" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m15l3" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="m15l4" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">②m7</harm>
            </measure>

            <!-- Bar 16: G/2 F/2 E D = 3 beats (final bar, no pickup)
                 Chords: Em Am→Em D
                 Am is non-diatonic in D major — sub Em -->
            <measure n="16">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m16n1" pname="g" oct="4" dur="8"/>
                  <note xml:id="m16n2" pname="f" oct="4" dur="8" accid.ges="s"/>
                  <note xml:id="m16n3" pname="e" oct="4" dur="4"/>
                  <note xml:id="m16n4" pname="d" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Em→D final: E4-G4 (half), D4-F#4-A4 (half) — converging to root pos -->
                <layer n="1">
                  <chord xml:id="m16r1" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m16r2" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Em(half)=E2-B2-E3-G3, D final(half)=D2-A2-D3-F#3 root position -->
                <layer n="1">
                  <chord xml:id="m16l1" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m16l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
<!--
VOICING PLAN:
- Bars 1-4 (phrase A): D uses "33" root position (D2-A2-D3-F#3), lighter texture
- Bars 5-8 (repeat A): D uses "34" 2nd inversion for variety, A uses "333" 7th chord
- Bars 9-12 (phrase B, climax): Full 3+4 voicing every beat, richer harmonies
- Bar 11: vii° (C#°) appears as diatonic vii — C#3-E3-G3 in LH
- Bars 13-16 (final phrase): Converging, final cadence in root position

VOICE LEADING HIGHLIGHTS:
- Bar 3→4: F#m→G→D→Bm creates a descending bass line F#2→G2→D2→B2
- Bar 9: E (non-diatonic) substituted with Em — maintains diatonic integrity
- Bars 14-15: Eb/Bb (non-diatonic) substituted Em/Bm — these ARE diatonic
- Final bar: Em→D creates ii→I final resolution with smooth voice leading

TEXTURE ARC:
- Pickup (light): single RH note + 3-note LH
- Bars 1-2: 2-note RH + 3-4 note LH (building in)
- Bars 3-4: 1-2 note RH per beat + 3-note LH per beat (active movement)
- Bars 5-8: varied inversions to distinguish repeat passage
- Bars 9-12: climax — 2-3 note RH + 4-note LH on every beat
- Bars 13-16: settling, final cadence root position D major
