                    <note pname="a" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
