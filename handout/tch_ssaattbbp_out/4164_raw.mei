<?xml version="1.0" encoding="UTF-8"?>
<!-- 4164: Crown Him With Many Crowns — Key: D major, 4/4 -->
<!-- D major: 2 sharps (F#, C#). accid.ges="s" on F and C notes. -->
<!-- Diatonic: D E F# G A B C# -->
<!-- ① = I = D, ② = ii = Em, ③ = iii = F#m, ④ = IV = G, ⑤ = V = A, ⑥ = vi = Bm, ⑦ = vii° = C#° -->
<!-- Note: ^G in melody = G# chromatic, ^G# = Ab/G# (non-diatonic) -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Crown Him With Many Crowns</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="2s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!--
              Chord progression (ABC annotations):
              M1: D D/2 D/2 Bm F F   → ① ⑥
              M2: G B3 B              → ④
              M3: D A G C#°(→⑦°) D F → ① ⑤ ④ ⑦° ①
              M4: A E3 E              → ⑤
              M5: D F A Bm B D A     → ① ③ ⑤ ⑥ ①
              M6: E ^G G#ø7(→②7) A G d → ② ⑤ ④
              M7: A c D d A B E B    → ⑤ ① ⑤ ②
              M8: A A3 A             → ⑤
              M9: D A F C#°(→⑦°) D  → ① ⑤ ⑦° ①
              M10: G B3 F#7(→③+⑤)   → ④ ③
              M11: E B ^G D F E7(→②7) → ② ①
              M12: A c3 A7(→⑤7 sub)  → ⑤ ⑤7
              M13: D d3/2 c/2 G B D A → ① ④ ① ⑤
              M14: Em7 G A D F A     → ② ④ ⑤ ①
              M15: G D F A E         → ④ ① ⑤
              M16: D D4              → ①
            -->

            <!-- M1: D D/2 D/2 Bm F F → ① ⑥ -->
            <measure n="1">
