                  <note pname="d" oct="4" dur="8"/>
                  <note pname="d" oct="4" dur="8"/>
                  <note pname="f" oct="4" accid.ges="s" dur="4"/>
                  <note pname="f" oct="4" accid.ges="s" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
