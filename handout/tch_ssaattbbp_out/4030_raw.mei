<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>On What Has Now Been Sown</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="2s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!-- Pickup: 1 beat. D. Melody: D4 -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0n1" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0r1" pname="f" oct="4" accid.ges="s" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- D2 A2 — sparse opening -->
                  <chord xml:id="m0l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 1: F D A F = 4. D(F D), A(A), D(F) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m1n2" pname="d" oct="4" dur="4"/>
                  <note xml:id="m1n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m1n4" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- D major root: A4 D5 / E5 A4 -->
                  <chord xml:id="m1r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <!-- A major 1st inv: E4 A4 -->
                  <chord xml:id="m1r2" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- D open: D2 A2 D3 F3 -->
                  <chord xml:id="m1l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- A: A2 E3 A3 C3 -->
                  <chord xml:id="m1l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Bar 2: d3 c = dotted-half + qtr = 4. Bm(d3), DΔ7(c) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="d" oct="5" dur="2" dots="1"/>
                  <note xml:id="m2n2" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Bm: D5 F5 over melody high D -->
                  <chord xml:id="m2r1" dur="2" dots="1">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <!-- DΔ7: approaching C# -->
                  <note xml:id="m2r2" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Bm: B2 F3 B3 D4 -->
                  <chord xml:id="m2l1" dur="2" dots="1">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <!-- Bm sustained: hold toward C# -->
                  <chord xml:id="m2l2" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="4">①Δ7</harm>
            </measure>

            <!-- Bar 3: B A G F = 4. G(B), D(A), A7(G), D(F) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m3n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m3n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m3n4" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Contrary motion ascending: D5 E5 F5 A4 -->
                  <note xml:id="m3r1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m3r2" pname="e" oct="5" dur="4"/>
                  <note xml:id="m3r3" pname="f" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m3r4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- G: G2 D3 G3 B3 -->
                  <chord xml:id="m3l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <!-- A7: A2 E3 A3 C3 -->
                  <chord xml:id="m3l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Bar 4: E3 E = dotted-half + qtr = 4. A chord -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="e" oct="4" dur="2" dots="1"/>
                  <note xml:id="m4n2" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Suspension E4 then resolves: A4 C4 -->
                  <chord xml:id="m4r1" dur="2" dots="1">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <note xml:id="m4r2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A open: A2 E3 A3 C3 -->
                  <chord xml:id="m4l1" dur="2" dots="1">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m4l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Bar 5: F D B A = 4. D(F D), Bm(B), A(A) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m5n2" pname="d" oct="4" dur="4"/>
                  <note xml:id="m5n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m5n4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- D 1st inv: F4 A4, then Bm: D5 F5 -->
                  <chord xml:id="m5r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m5r2" dur="2">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- D: D2 A2 D3 F3 -->
                  <chord xml:id="m5l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- Bm: B2 F3 B3 D4 -->
                  <chord xml:id="m5l2" dur="2">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 6: ^G E e d = 4. E major(^G E) -> sub A (V), then e=E5, d=D5 -> D chord
                 G# is melody accidental only. Harp stays diatonic. -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="g" oct="4" dur="4" accid="s"/>
                  <note xml:id="m6n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m6n3" pname="e" oct="5" dur="4"/>
                  <note xml:id="m6n4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- A sub: E4 A4, then D: F4 A4 -->
                  <chord xml:id="m6r1" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m6r2" dur="2">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A: A2 E3 A3 C3 -->
                  <chord xml:id="m6l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- D: D2 A2 D3 F3 -->
                  <chord xml:id="m6l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 7: c2 B2 = half+half = 4. E(c2)->sub A7, A(B?) -> sub Bm or A -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="c" oct="5" dur="2" accid.ges="s"/>
                  <note xml:id="m7n2" pname="b" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- A7: E5 C5 (with C#) -->
                  <chord xml:id="m7r1" dur="2">
                    <note pname="e" oct="5"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <!-- Bm: D5 F4 -->
                  <chord xml:id="m7r2" dur="2">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A7: A2 E3 G3 C3 -->
                  <chord xml:id="m7l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- Bm: B2 F3 B3 D4 -->
                  <chord xml:id="m7l2" dur="2">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Bar 8: A3 A = dotted-half + qtr = 4. A chord -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="a" oct="4" dur="2" dots="1"/>
                  <note xml:id="m8n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Quartal A: E4 A4 -->
                  <chord xml:id="m8r1" dur="2" dots="1">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <note xml:id="m8r2" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="2" dots="1">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m8l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Bar 9: B2 c2 = half+half = 4. G(B2), C#°(c2)
                 C#° = vii° in D major — diatonic! c=C# so accid.ges=s -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="b" oct="4" dur="2"/>
                  <note xml:id="m9n2" pname="c" oct="5" dur="2" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- G 7th: D5 G4, then C#° passing: E5 A4 -->
                  <chord xml:id="m9r1" dur="2">
                    <note pname="d" oct="5"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m9r2" dur="2">
                    <note pname="e" oct="5"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- G: G2 D3 G3 B3 -->
                  <chord xml:id="m9l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <!-- C#°: C3 E3 G3 (vii° = C# E G) -->
                  <chord xml:id="m9l2" dur="2">
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
            </measure>

            <!-- Bar 10: d3 D = dotted-half+qtr = 4. D chord -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" pname="d" oct="5" dur="2" dots="1"/>
                  <note xml:id="m10n2" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Full D triad high: F5 A4 -->
                  <chord xml:id="m10r1" dur="2" dots="1">
                    <note pname="f" oct="5" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <note xml:id="m10r2" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- D full: D2 A2 D3 F3 -->
                  <chord xml:id="m10l1" dur="2" dots="1">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m10l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 11: E F G A = 4. C#°(E), D(F), G(G), D(A) -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m11n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m11n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m11n4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Walking figure: G4 A4 B4 C5 — fills in the scale -->
                  <note xml:id="m11r1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m11r2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m11r3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m11r4" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C#°: C3 E3 G3 B3 -->
                  <chord xml:id="m11l1" dur="2">
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <!-- G: G2 D3 G3 B3 -->
                  <chord xml:id="m11l2" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 12: B c d e = 4. G(B), C#°(c), D(d), Em(e) -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m12n2" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m12n3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m12n4" pname="e" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Climax — RH reaches high: D5 E5 F5 G5 -->
                  <note xml:id="m12r1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m12r2" pname="e" oct="5" dur="4"/>
                  <note xml:id="m12r3" pname="f" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m12r4" pname="g" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- G: G2 D3 G3 B3 -->
                  <chord xml:id="m12l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <!-- D: D2 A2 D3 F3 -->
                  <chord xml:id="m12l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Bar 13: d2 c2 = half+half = 4. D(d2), A(c2 = C#) -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13n1" pname="d" oct="5" dur="2"/>
                  <note xml:id="m13n2" pname="c" oct="5" dur="2" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Suspension then release: F5 A4 then E4 A4 -->
                  <chord xml:id="m13r1" dur="2">
                    <note pname="f" oct="5" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
