<?xml version="1.0" encoding="UTF-8"?>
<!-- 4163: Beautiful Savior — Key: Eb major, 4/4 -->
<!-- Eb major: 3 flats (Bb, Eb, Ab). accid.ges="f" on B, E, A -->
<!-- Diatonic: Eb F G Ab Bb C D -->
<!-- ① = I = Eb, ② = ii = Fm, ③ = iii = Gm, ④ = IV = Ab, ⑤ = V = Bb, ⑥ = vi = Cm, ⑦ = vii° = D° -->
<!-- ABC melody: E=Eb, B=Bb, A=Ab (all flatted per key sig) -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Beautiful Savior</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!--
              Chord progression by measure (from ABC chords):
              M1: Eb Cm Eb Cm
              M2: Fm Bb Eb
              M3: [Eb] Cm C7(→Fm diatonic sub=②)
              M4: Fm Bb Eb
              M5: [Eb] C(→①) Eb
              M6: Eb Eb Ab(→④) Bb
              M7: Ab Ab Bb(→⑤)
              M8: Bb Bb
              M9: Eb C(→①/⑥) Eb
              M10: C Fm
              M11: Ab(→④) Gm Ab
              M12: Ab Bb Eb
              M13: Eb EbΔ7 Eb Cm
              M14: Eb Eb C(→⑥)
              M15: Eb Bb
              M16: Eb (final)
            -->

            <!-- M1: Eb2 Cm E E → ① ⑥ -->
