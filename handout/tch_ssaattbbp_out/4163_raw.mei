                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="e" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                  <note pname="c" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑥</harm>
            </measure>

