                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <!-- ⑥ Cm: G4 Eb5 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="4"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="e" oct="4" accid.ges="f" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- ① Eb2 Bb2 Eb3 G3 open voicing -->
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <!-- ⑥ Cm: C3 G3 Eb4 -->
