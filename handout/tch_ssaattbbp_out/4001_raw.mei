<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>The Love of God</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal (raw, single-layer)</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="3" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="2s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="2s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="2s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-8): Introduction — lighter texture, build    -->
            <!-- ============================================================ -->

            <!-- Measure 1: pickup, 1.5 beats. D (I) -->
            <!-- Melody: D4(8) D4(8.) E4(16) = 1 + 0.5 + 0.25 ... wait, 8=0.5, 8.=0.75, 16=0.25: total 1.5 beats OK -->
            <measure n="1" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="8" oct="4" pname="d" />
                  <note xml:id="m1s1n2" dur="8" dots="1" oct="4" pname="d" />
                  <note xml:id="m1s1n3" dur="16" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: D4 F#4 open fifth, dotted quarter — gentle opening -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="4" dots="1">
                    <note xml:id="m1s2n1" pname="d" oct="4" />
                    <note xml:id="m1s2n2" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D3 A3 D4 open I root pos, dotted quarter -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="4" dots="1">
                    <note xml:id="m1s3n1" pname="d" oct="2" />
                    <note xml:id="m1s3n2" pname="a" oct="2" />
                    <note xml:id="m1s3n3" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: 3 beats. D→G→D (I→IV→I). Melody: F#4(4.) A4(8) B4(8.) A4(16) -->
            <!-- Beat 1: I, beat 2.5: IV, beat 3: I -->
            <!-- RH: broken chord arpeggio with passing motion -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" dots="1" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m2s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m2s1n3" dur="8" dots="1" oct="4" pname="b" />
                  <note xml:id="m2s1n4" dur="16" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: beat1 D4-A4 (I open 5th), beat2.5 G4-B4 (IV), beat3 F#4-A4 (I) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4" dots="1">
                    <note xml:id="m2s2n1" pname="d" oct="4" />
                    <note xml:id="m2s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="8">
                    <note xml:id="m2s2n3" pname="g" oct="4" />
                    <note xml:id="m2s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: beat1 D2-A2-D3 (I root pos open), beat2.5 G2-D3 (IV), beat3 A2-E3-A3 (I/V) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4" dots="1">
                    <note xml:id="m2s3n1" pname="d" oct="2" />
                    <note xml:id="m2s3n2" pname="a" oct="2" />
                    <note xml:id="m2s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="8">
                    <note xml:id="m2s3n4" pname="g" oct="2" />
                    <note xml:id="m2s3n5" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n6" pname="a" oct="2" />
                    <note xml:id="m2s3n7" pname="e" oct="3" />
                    <note xml:id="m2s3n8" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 3: 3 beats. D (I). Melody: A4(4) F#4(8) A4(8) A4(8.) F#4(16) -->
            <!-- One chord all measure — I, arpeggiate across the measure -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m3s1n2" dur="8" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m3s1n3" dur="8" oct="4" pname="a" />
                  <note xml:id="m3s1n4" dur="8" dots="1" oct="4" pname="a" />
                  <note xml:id="m3s1n5" dur="16" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: ascending I arpeggio — D4(4) F#4(4) A4(4) -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m3s2n1" dur="4" pname="d" oct="4" />
                  <note xml:id="m3s2n2" dur="4" pname="f" oct="4" accid.ges="s" />
                  <note xml:id="m3s2n3" dur="4" pname="a" oct="4" />
                </layer>
              </staff>
              <!-- LH: I in open voicing — D3-A3(4) then F#3-D3 passing, A2-D3-A3 strong -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="d" oct="3" />
                    <note xml:id="m3s3n2" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n3" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m3s3n4" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n5" pname="a" oct="2" />
                    <note xml:id="m3s3n6" pname="d" oct="3" />
                    <note xml:id="m3s3n7" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 4: 3 beats. A→D→A (V→I→V). Melody: E4(4.) G4(8) F#4(8.) E4(16) -->
            <!-- Beat 1: A (V), beat 2.5: D passing, beat 3: A (V) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" dots="1" oct="4" pname="e" />
                  <note xml:id="m4s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m4s1n3" dur="8" dots="1" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m4s1n4" dur="16" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: V chord — E4-A4(4.), pass to D-G on beat2.5, cadence C#5-E5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4" dots="1">
                    <note xml:id="m4s2n1" pname="e" oct="4" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="8">
                    <note xml:id="m4s2n3" pname="g" oct="4" />
                    <note xml:id="m4s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="4">
                    <note xml:id="m4s2n5" pname="c" oct="5" accid.ges="s" />
                    <note xml:id="m4s2n6" pname="e" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V root pos open — A2-E3-A3(4.), step G2-D3(8), resolve A2-E3(4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4" dots="1">
                    <note xml:id="m4s3n1" pname="a" oct="2" />
                    <note xml:id="m4s3n2" pname="e" oct="3" />
                    <note xml:id="m4s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="8">
                    <note xml:id="m4s3n4" pname="g" oct="2" />
                    <note xml:id="m4s3n5" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="4">
                    <note xml:id="m4s3n6" pname="a" oct="2" />
                    <note xml:id="m4s3n7" pname="c" oct="3" accid.ges="s" />
                    <note xml:id="m4s3n8" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2.5">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 5: 3 beats. D→Em→D (I→ii→I). Melody: F#4(4.) D4(8) D4(8.) E4(16) -->
            <!-- Beat 1: I, beat 2: Em (ii passing), beat 3: I -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" dots="1" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m5s1n2" dur="8" oct="4" pname="d" />
                  <note xml:id="m5s1n3" dur="8" dots="1" oct="4" pname="d" />
                  <note xml:id="m5s1n4" dur="16" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I → ii → I with step motion D4-F#4 → E4-G4 → D4-F#4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4" dots="1">
                    <note xml:id="m5s2n1" pname="d" oct="4" />
                    <note xml:id="m5s2n2" pname="f" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="8">
                    <note xml:id="m5s2n3" pname="e" oct="4" />
                    <note xml:id="m5s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c3" dur="4">
                    <note xml:id="m5s2n5" pname="d" oct="4" />
                    <note xml:id="m5s2n6" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m5s2n7" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I root pos rich — D2-A2-D3-F#3(4.), Em E2-B2-E3(8), I D2-A2-D3(4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4" dots="1">
                    <note xml:id="m5s3n1" pname="d" oct="2" />
                    <note xml:id="m5s3n2" pname="a" oct="2" />
                    <note xml:id="m5s3n3" pname="d" oct="3" />
                    <note xml:id="m5s3n4" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="8">
                    <note xml:id="m5s3n5" pname="e" oct="2" />
                    <note xml:id="m5s3n6" pname="b" oct="2" />
                    <note xml:id="m5s3n7" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n8" pname="d" oct="2" />
                    <note xml:id="m5s3n9" pname="a" oct="2" />
                    <note xml:id="m5s3n10" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 6: 3 beats. D→G→D (I→IV→I). Melody: F#4(4.) A4(8) B4(8.) A4(16) -->
            <!-- Same as m2 but with richer voicing — build texture -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" dots="1" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m6s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m6s1n3" dur="8" dots="1" oct="4" pname="b" />
                  <note xml:id="m6s1n4" dur="16" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I full triad D4-F#4-A4(4.), IV G4-B4(8), back I F#4-A4-D5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4" dots="1">
                    <note xml:id="m6s2n1" pname="d" oct="4" />
                    <note xml:id="m6s2n2" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m6s2n3" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="8">
                    <note xml:id="m6s2n4" pname="g" oct="4" />
                    <note xml:id="m6s2n5" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n6" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m6s2n7" pname="a" oct="4" />
                    <note xml:id="m6s2n8" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I D2-A2-D3-F#3(4.), IV G2-B2-D3(8), I A2-D3-A3(4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4" dots="1">
                    <note xml:id="m6s3n1" pname="d" oct="2" />
                    <note xml:id="m6s3n2" pname="a" oct="2" />
                    <note xml:id="m6s3n3" pname="d" oct="3" />
                    <note xml:id="m6s3n4" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="8">
                    <note xml:id="m6s3n5" pname="g" oct="2" />
                    <note xml:id="m6s3n6" pname="b" oct="2" />
                    <note xml:id="m6s3n7" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n8" pname="a" oct="2" />
                    <note xml:id="m6s3n9" pname="d" oct="3" />
                    <note xml:id="m6s3n10" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 7: 3 beats. A (V). Melody: A4(4) F#4(8) A4(8) A4(8.) F#4(16) -->
            <!-- Pure V chord — inner voice motion to animate -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m7s1n3" dur="8" oct="4" pname="a" />
                  <note xml:id="m7s1n4" dur="8" dots="1" oct="4" pname="a" />
                  <note xml:id="m7s1n5" dur="16" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: V broken arpeggio — E4-A4(4), C#5-E5(4), A4-C#5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="e" oct="4" />
                    <note xml:id="m7s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="c" oct="5" accid.ges="s" />
                    <note xml:id="m7s2n4" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="a" oct="4" />
                    <note xml:id="m7s2n6" pname="c" oct="5" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V open voicing — A2-E3-A3(4), E2-B2-E3(4), A2-E3(4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="a" oct="2" />
                    <note xml:id="m7s3n2" pname="e" oct="3" />
                    <note xml:id="m7s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="e" oct="2" />
                    <note xml:id="m7s3n5" pname="b" oct="2" />
                    <note xml:id="m7s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="4">
                    <note xml:id="m7s3n7" pname="a" oct="2" />
                    <note xml:id="m7s3n8" pname="c" oct="3" accid.ges="s" />
                    <note xml:id="m7s3n9" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Measure 8: 3 beats. A7→G→D→A7 (V7→IV→I→V7). Melody: E4(4.) G4(8) F#4(8.) E4(16) -->
            <!-- Cadential progression: strong V7 on beat1, IV passing, I→V7 closing -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" dots="1" oct="4" pname="e" />
                  <note xml:id="m8s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m8s1n3" dur="8" dots="1" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m8s1n4" dur="16" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: V7 — E4-G4-C#5(4.), IV G4-B4(8), I F#4-A4(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4" dots="1">
                    <note xml:id="m8s2n1" pname="e" oct="4" />
                    <note xml:id="m8s2n2" pname="g" oct="4" />
                    <note xml:id="m8s2n3" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="8">
                    <note xml:id="m8s2n4" pname="g" oct="4" />
                    <note xml:id="m8s2n5" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m8s2c3" dur="4">
                    <note xml:id="m8s2n6" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m8s2n7" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V7 open — A2-E3-G3-C#4(4.), G2-D3-G3(8), D2-A2-D3(4) -->
              <!-- Note: C# and G in V7 = diatonic in D major -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="4" dots="1">
                    <note xml:id="m8s3n1" pname="a" oct="2" />
                    <note xml:id="m8s3n2" pname="e" oct="3" />
                    <note xml:id="m8s3n3" pname="g" oct="3" />
                    <note xml:id="m8s3n4" pname="c" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="8">
                    <note xml:id="m8s3n5" pname="g" oct="2" />
                    <note xml:id="m8s3n6" pname="d" oct="3" />
                    <note xml:id="m8s3n7" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c3" dur="4">
                    <note xml:id="m8s3n8" pname="d" oct="2" />
                    <note xml:id="m8s3n9" pname="a" oct="2" />
                    <note xml:id="m8s3n10" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
