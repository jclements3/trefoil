              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 8: G whole — D5(2) rest(1) G4(1) -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="5" pname="d" />
                  <rest xml:id="m8s1r1" dur="4" />
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G ascending D4-G4-B4-D5 in quarters -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m8s2n1" dur="4" pname="d" oct="4" />
                  <note xml:id="m8s2n2" dur="4" pname="g" oct="4" />
                  <note xml:id="m8s2n3" dur="4" pname="b" oct="4" />
                  <note xml:id="m8s2n4" dur="4" pname="d" oct="5" />
                </layer>
              </staff>
              <!-- LH: G sustained G2-D3-G3-B3 whole -->
              <staff n="3">
                <layer n="1">
