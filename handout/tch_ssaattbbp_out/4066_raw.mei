<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Little Town of Bethlehem</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- F major: Bb = accid.ges="f" on every B -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Pickup + first phrase                   -->
            <!-- ============================================================ -->

            <!-- Measure 1: pickup 1 beat. F (I). Melody: A4(4) -->
            <measure n="1" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: F4-A4 3rd — gentle pickup -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="4">
                    <note xml:id="m1s2n1" pname="f" oct="4" />
                    <note xml:id="m1s2n2" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="4" />
                </layer>
              </staff>
              <!-- LH: F2-C3 open 5th -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="4">
                    <note xml:id="m1s3n1" pname="f" oct="2" />
                    <note xml:id="m1s3n2" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="4" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: 4 beats. F→G#°(→E°→vii°)→F. Melody: A4(4) A4(4) G#4(acc)→G4(4) A4(4) -->
            <!-- G#° non-diatonic → use vii° (E°) = E-G-Bb. Melody has ^G (G# = non-diatonic, keep in melody) -->
            <!-- Duration: 4 quarters = 4 beats OK -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="g" accid="s" />
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: F4-A4(I), E4-G4(vii°→dim color), F4-A4(I return), C5-E5(V over bar) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n1" pname="f" oct="4" />
                    <note xml:id="m2s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="e" oct="4" />
                    <note xml:id="m2s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="f" oct="4" />
                    <note xml:id="m2s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(I), E2-Bb2-E3(vii°), F2-C3-F3(I) — note Bb=accid.ges=f -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="f" oct="2" />
                    <note xml:id="m2s3n2" pname="c" oct="3" />
                    <note xml:id="m2s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="e" oct="2" />
                    <note xml:id="m2s3n5" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="f" oct="2" />
                    <note xml:id="m2s3n8" pname="c" oct="3" />
                    <note xml:id="m2s3n9" pname="f" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 3: 4 beats. Cø7(→Gm=ii)→Gm. Melody: c5(4) B4b(4) D4(4) G4(4) -->
            <!-- Cø7 is non-diatonic → use ii (Gm). Bb needs accid.ges=f -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="d" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G4-Bb4(ii), F4-A4(I return), D4-G4(ii), G4-Bb4(ii) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="g" oct="4" />
                    <note xml:id="m3s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="d" oct="4" />
                    <note xml:id="m3s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n5" pname="g" oct="4" />
                    <note xml:id="m3s2n6" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: G2-D3-G3(ii root), G2-Bb2-D3(ii 1st position), G2-D3-G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="g" oct="2" />
                    <note xml:id="m3s3n2" pname="d" oct="3" />
                    <note xml:id="m3s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="g" oct="2" />
                    <note xml:id="m3s3n5" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="g" oct="2" />
                    <note xml:id="m3s3n8" pname="d" oct="3" />
                    <note xml:id="m3s3n9" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">②m¹</harm>
            </measure>

            <!-- Measure 4: 4 beats. F→C. Melody: F4(4) E4-F4(8+8) G4(4) C4(4) -->
            <!-- Duration: 1 + 0.5 + 0.5 + 1 + 1 = 4 beats OK -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m4s1n2" dur="8" oct="4" pname="e" />
                  <note xml:id="m4s1n3" dur="8" oct="4" pname="f" />
                  <note xml:id="m4s1n4" dur="4" oct="4" pname="g" />
                  <note xml:id="m4s1n5" dur="4" oct="4" pname="c" />
                </layer>
              </staff>
              <!-- RH: F4-A4(I half), G4-C5(V half) — contrary motion with LH -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="f" oct="4" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="2">
                    <note xml:id="m4s2n3" pname="g" oct="4" />
                    <note xml:id="m4s2n4" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(I half), C2-G2-C3(V half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="f" oct="2" />
                    <note xml:id="m4s3n2" pname="c" oct="3" />
                    <note xml:id="m4s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="2">
                    <note xml:id="m4s3n4" pname="c" oct="2" />
                    <note xml:id="m4s3n5" pname="g" oct="2" />
                    <note xml:id="m4s3n6" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 5: 4 beats. F (I). Melody: A4(dotted-half) A4(4) -->
            <!-- dotted-half = 3 beats + qtr = 4 beats OK -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" dots="1" oct="4" pname="a" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: F4-A4-C5 full triad, whole — sustain I -->
              <staff n="2">
                <layer n="1">
                  <rest dur="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m5s2c1" dur="1">
                    <note xml:id="m5s2n1" pname="f" oct="4" />
                    <note xml:id="m5s2n2" pname="a" oct="4" />
                    <note xml:id="m5s2n3" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: F2-C3-F3 whole -->
              <staff n="3">
                <layer n="1">
                  <rest dur="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m5s3c1" dur="1">
                    <note xml:id="m5s3n1" pname="f" oct="2" />
                    <note xml:id="m5s3n2" pname="c" oct="3" />
                    <note xml:id="m5s3n3" pname="f" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 6-9): Middle section — richer, D (non-diatonic→use vi=Dm) -->
            <!-- ============================================================ -->

            <!-- Measure 6: 4 beats. D(→Dm=vi)→C→Gm. Melody: A4(4) A4(4) d5(4) c5(4) -->
            <!-- D major is non-diatonic in F → use vi (Dm) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n3" dur="4" oct="5" pname="d" />
                  <note xml:id="m6s1n4" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: F4-A4(vi=Dm starting on F?→use A4-D5 better), C4-G4(V), G4-Bb4(ii) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="2">
                    <note xml:id="m6s2n1" pname="a" oct="4" />
                    <note xml:id="m6s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="c" oct="4" />
                    <note xml:id="m6s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c5" dur="4">
                    <note xml:id="m6s2n5" pname="g" oct="4" />
                    <note xml:id="m6s2n6" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: D2-A2-D3(vi=Dm root), C2-G2-C3(V), G2-D3-G3(ii) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="2">
                    <note xml:id="m6s3n1" pname="d" oct="2" />
                    <note xml:id="m6s3n2" pname="a" oct="2" />
                    <note xml:id="m6s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="c" oct="2" />
                    <note xml:id="m6s3n5" pname="g" oct="2" />
                    <note xml:id="m6s3n6" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n7" pname="g" oct="2" />
                    <note xml:id="m6s3n8" pname="d" oct="3" />
                    <note xml:id="m6s3n9" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 7: 4 beats. C→Gm. Melody: c5(4) Bb4(4) D4(4) G4(4) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="d" />
                  <note xml:id="m7s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G4-C5(V), G4-Bb4(ii), D4-F4(vi 5th above), G4-Bb4(ii) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="g" oct="4" />
                    <note xml:id="m7s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="d" oct="4" />
                    <note xml:id="m7s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="g" oct="4" />
                    <note xml:id="m7s2n6" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C2-G2-C3(V), G2-D3-Bb3(ii open) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2">
                    <note xml:id="m7s3n1" pname="c" oct="2" />
                    <note xml:id="m7s3n2" pname="g" oct="2" />
                    <note xml:id="m7s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="2">
                    <note xml:id="m7s3n4" pname="g" oct="2" />
                    <note xml:id="m7s3n5" pname="d" oct="3" />
                    <note xml:id="m7s3n6" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 8: 4 beats. F→C+(→C)→F→Am→C7. Melody: F4(4) E4-F4(8+8) A4(4) G4(4) -->
            <!-- C+ (augmented) non-diatonic → use V(C). Am=iii(diatonic). C7=V7(diatonic). -->
            <!-- Duration: 1 + 0.5 + 0.5 + 1 + 1 = 4 beats OK -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m8s1n2" dur="8" oct="4" pname="e" />
                  <note xml:id="m8s1n3" dur="8" oct="4" pname="f" />
                  <note xml:id="m8s1n4" dur="4" oct="4" pname="a" />
                  <note xml:id="m8s1n5" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: F4-A4(I qtr), E4-G4(V→vii° qtr+qtr), A4-C5(iii), G4-Bb4(V7 partial) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4">
                    <note xml:id="m8s2n1" pname="f" oct="4" />
                    <note xml:id="m8s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="2">
                    <note xml:id="m8s2n3" pname="e" oct="4" />
                    <note xml:id="m8s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m8s2c3" dur="4">
                    <note xml:id="m8s2n5" pname="g" oct="4" />
                    <note xml:id="m8s2n6" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(I), C2-G2-E3(V 1st inv), F2-C3-F3(I), C2-G2-Bb2(V7) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="4">
                    <note xml:id="m8s3n1" pname="f" oct="2" />
                    <note xml:id="m8s3n2" pname="c" oct="3" />
                    <note xml:id="m8s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="2">
                    <note xml:id="m8s3n4" pname="c" oct="2" />
                    <note xml:id="m8s3n5" pname="g" oct="2" />
                    <note xml:id="m8s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c3" dur="4">
                    <note xml:id="m8s3n7" pname="c" oct="2" />
                    <note xml:id="m8s3n8" pname="g" oct="2" />
                    <note xml:id="m8s3n9" pname="b" oct="2" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="4">⑤7</harm>
            </measure>

            <!-- Measure 9: 4 beats. F (I). Melody: F4(dotted-half) A4(qtr) -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" dots="1" oct="4" pname="f" />
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: F4-C5 open 5th, whole -->
              <staff n="2">
                <layer n="1">
                  <rest dur="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m9s2c1" dur="1">
                    <note xml:id="m9s2n1" pname="f" oct="4" />
                    <note xml:id="m9s2n2" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: F2-C3-F3 whole -->
              <staff n="3">
                <layer n="1">
                  <rest dur="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m9s3c1" dur="1">
                    <note xml:id="m9s3n1" pname="f" oct="2" />
                    <note xml:id="m9s3n2" pname="c" oct="3" />
                    <note xml:id="m9s3n3" pname="f" oct="3" />
                  </chord>
