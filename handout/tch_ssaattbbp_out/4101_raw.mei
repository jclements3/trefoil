<?xml version="1.0" encoding="UTF-8"?>
<!-- 4101 Stricken, Smitten, and Afflicted — Key: Bb major — 6/4
     2 flats: Bb, Eb. accid.ges required on all Bb and Eb notes.

     Chord sequence (parsed from ABC):
     Pickup (2 beats): Gm D
     Bar 1 (6/4): Gm Gm Eb Eb Cm Gm
     Bar 2: G(→Gm) G(→Gm) D D Gm D
     Bar 3: Eb Eb A°(→A°=viiø) Gm D F#(→non-diatonic: use F=IV)?
       Note: "^F" = F# — non-diatonic in Bb. Use diatonic F (natural) for IV.
       Actually "^D^F" at end of bar 3 = D major chord → D is V/Gm. Sub D minor (ii) or keep as passing. Use Dm(ii in Bb).
     Bar 4: Gm Gm Gm Gm Gm D
     ... (hymn repeats bars 1-4 twice, then bridge bars 9-16)

     Key: Bb major. Scale degrees (Bb=1,C=2,D=3,Eb=4,F=5,G=6,A=7)
     Non-diatonic chords: G major → Gm(vi), D major → Dm(iii), A° → vii°(A-C-Eb)
     Eb chord IS diatonic (IV in Bb), F chord IS diatonic (V)

     Full bar count: pickup + 16 bars of 6/4
     Harp range: Bass C2-B3, Treble C4-G6
     Key sig: 2f (Bb, Eb)
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Stricken, Smitten, and Afflicted</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="6" meter.unit="4" key.sig="2f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="2f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="2f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="2f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup: 2 beats (Gm q, D q)
                 Melody: G4 A4
                 RH: Gm: Bb4 (single) | D→Dm: A4 (single, light)
                 LH: Gm: G2-D3 | Dm: D2-A2
                 Pedal: G1 | D1
            -->
            <measure n="0" right="single" metcon="false">
              <staff n="1">
                <layer n="1">
                  <note xml:id="pu_s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="pu_s1n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <note xml:id="pu_rh1" pname="b" oct="4" accid.ges="f" dur="4" stem.dir="up"/>
                  <note xml:id="pu_rh2" pname="a" oct="4" dur="4" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <rest dur="2" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="pu_lh1" dur="4" stem.dir="up">
                    <note xml:id="pu_lh1a" pname="g" oct="2"/>
                    <note xml:id="pu_lh1b" pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="pu_lh2" dur="4" stem.dir="up">
                    <note xml:id="pu_lh2a" pname="d" oct="2"/>
                    <note xml:id="pu_lh2b" pname="a" oct="2"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="pu_p1" pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note xml:id="pu_p2" pname="d" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
            </measure>

            <!-- Bar 1 (6/4): Gm Gm | Eb Eb | Cm Gm
                 Melody: B4 B4 | Bb4 Bb4 | c5 B4
                 Gm=G-Bb-D, Eb=Eb-G-Bb, Cm=C-Eb-G
                 RH: Gm:Bb4-D5(2 beats) → Eb:G4-Bb4(2 beats) → Cm:G4-Eb5(2 beats)
                 LH: Gm:G2-D3-G3-Bb3 → Eb:Eb2-Bb2-G3 → Cm:C2-G2-Eb3-G3
                 Pedal: G1(2b) Eb1(2b) C1(2b)
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="b" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m1s1n2" pname="b" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m1s1n3" pname="c" oct="5" dur="4"/>
                  <note xml:id="m1s1n4" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Gm: Bb4-D5 (2 beats) -->
                  <chord xml:id="m1rh1" dur="2" stem.dir="up">
                    <note xml:id="m1rh1a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m1rh1b" pname="d" oct="5"/>
                  </chord>
                  <!-- Eb: Bb4-Eb5 (2 beats) -->
                  <chord xml:id="m1rh2" dur="2" stem.dir="up">
                    <note xml:id="m1rh2a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m1rh2b" pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <!-- Cm: G4-C5 (2 beats) -->
                  <chord xml:id="m1rh3" dur="2" stem.dir="up">
                    <note xml:id="m1rh3a" pname="g" oct="4"/>
                    <note xml:id="m1rh3b" pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <!-- Bb4 sustained across first 4 beats (common to Gm+Eb) -->
                  <note xml:id="m1rhs1" pname="b" oct="4" accid.ges="f" dur="1" stem.dir="down"/>
                  <rest dur="2" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Gm open: G2-D3-G3-Bb3 -->
                  <chord xml:id="m1lh1" dur="2" stem.dir="up">
                    <note xml:id="m1lh1a" pname="g" oct="2"/>
                    <note xml:id="m1lh1b" pname="d" oct="3"/>
                    <note xml:id="m1lh1c" pname="g" oct="3"/>
                    <note xml:id="m1lh1d" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- Eb: Eb2-Bb2-G3-Eb3 -->
                  <chord xml:id="m1lh2" dur="2" stem.dir="up">
                    <note xml:id="m1lh2a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m1lh2b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m1lh2c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m1lh2d" pname="g" oct="3"/>
                  </chord>
                  <!-- Cm: C2-G2-Eb3-G3 -->
                  <chord xml:id="m1lh3" dur="2" stem.dir="up">
                    <note xml:id="m1lh3a" pname="c" oct="2"/>
                    <note xml:id="m1lh3b" pname="g" oct="2"/>
                    <note xml:id="m1lh3c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m1lh3d" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" pname="g" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m1p2" pname="e" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                  <note xml:id="m1p3" pname="c" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="5">②m</harm>
            </measure>

            <!-- Bar 2 (6/4): G(→Gm) G(→Gm) | D D | Gm D
                 Melody: A4 A4 A4 A4 B4 A4
                 Note: G "major" → treat as Gm (vi) diatonic sub
                 D major → Dm (iii) diatonic sub for lever harp
                 RH: Gm:G4-Bb4(2b) → Dm:F4-A4(2b) → Gm:Bb4-D5+Dm:A4(2b alternating)
                 Simpler: Gm:Bb4-D5 | Dm:A4-D5 | Gm:Bb4-D5 | Dm:A4-C5
                 LH: Gm:G2-D3-Bb3 | Dm:D2-A2-F3 | Gm:G2-D3-Bb3 | Dm:D2-A2-D3
                 Pedal: G1(2b) D1(2b) G1 D1
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m2s1n2" pname="a" oct="4" dur="2"/>
                  <note xml:id="m2s1n3" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m2s1n4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2rh1" dur="2" stem.dir="up">
                    <note xml:id="m2rh1a" pname="g" oct="4"/>
                    <note xml:id="m2rh1b" pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2rh2" dur="2" stem.dir="up">
                    <note xml:id="m2rh2a" pname="a" oct="4"/>
                    <note xml:id="m2rh2b" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m2rh3" dur="2" stem.dir="up">
                    <note xml:id="m2rh3a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m2rh3b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="breve" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2lh1" dur="2" stem.dir="up">
                    <note xml:id="m2lh1a" pname="g" oct="2"/>
                    <note xml:id="m2lh1b" pname="d" oct="3"/>
                    <note xml:id="m2lh1c" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2lh2" dur="2" stem.dir="up">
                    <note xml:id="m2lh2a" pname="d" oct="2"/>
                    <note xml:id="m2lh2b" pname="a" oct="2"/>
                    <note xml:id="m2lh2c" pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m2lh3" dur="2" stem.dir="up">
                    <note xml:id="m2lh3a" pname="g" oct="2"/>
                    <note xml:id="m2lh3b" pname="d" oct="3"/>
                    <note xml:id="m2lh3c" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" pname="g" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m2p2" pname="d" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m2p3" pname="g" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="5">⑥m</harm>
            </measure>

            <!-- Bar 3 (6/4): Eb Eb | A°(vii°) A°(vii°) | Gm Dm(^F=F# context → use Dm)
                 Melody: G4 G4 | A4 A4 | G4 ^F4 (F#4 non-diatonic — melody note only)
                 A° = A-C-Eb (vii° in Bb: actually leading-tone dim = A°)
                 Gm | Dm (for ^D^F context — D-F# melody but harp plays D minor)
                 RH: Eb:G4-Bb4 | A°:A4-C5 | Gm:Bb4-D5 | Dm:A4-D5
                 LH: Eb:Eb2-Bb2-G3 | A°:A2-Eb3-A3 | Gm:G2-D3-G3-Bb3 | Dm:D2-A2-F3
                 Pedal: Eb1(2b) A1(2b) G1 D1
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m3s1n2" pname="a" oct="4" dur="2"/>
                  <note xml:id="m3s1n3" pname="g" oct="4" dur="4"/>
                  <!-- F# in melody — accidental required, harp plays diatonic F -->
                  <note xml:id="m3s1n4" pname="f" oct="4" dur="4" accid="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3rh1" dur="2" stem.dir="up">
                    <note xml:id="m3rh1a" pname="g" oct="4"/>
                    <note xml:id="m3rh1b" pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m3rh2" dur="2" stem.dir="up">
                    <note xml:id="m3rh2a" pname="a" oct="4"/>
                    <note xml:id="m3rh2b" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m3rh3" dur="2" stem.dir="up">
                    <note xml:id="m3rh3a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m3rh3b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="breve" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3lh1" dur="2" stem.dir="up">
                    <note xml:id="m3lh1a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m3lh1b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m3lh1c" pname="g" oct="3"/>
                  </chord>
                  <!-- A°: A2-Eb3-A3 (dim triad) -->
                  <chord xml:id="m3lh2" dur="2" stem.dir="up">
                    <note xml:id="m3lh2a" pname="a" oct="2"/>
                    <note xml:id="m3lh2b" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m3lh2c" pname="a" oct="3"/>
                  </chord>
                  <!-- Gm: G2-D3-G3-Bb3 -->
                  <chord xml:id="m3lh3" dur="2" stem.dir="up">
                    <note xml:id="m3lh3a" pname="g" oct="2"/>
                    <note xml:id="m3lh3b" pname="d" oct="3"/>
                    <note xml:id="m3lh3c" pname="g" oct="3"/>
                    <note xml:id="m3lh3d" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" pname="e" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                  <note xml:id="m3p2" pname="a" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m3p3" pname="g" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="5">⑥m</harm>
            </measure>

            <!-- Bar 4 (6/4): Gm Gm Gm Gm Gm D
                 Melody: G4 G4 G4 G4 G4 A4
                 Largely static Gm harmony — use rhythmic variety (arpeggiation in layers)
                 RH: Gm sustained + moving layer arpeggiation (Bb4↔D5)
                 LH: Gm sustained bass G2, inner voices vary
            -->
            <measure n="4" right="single">
              <!-- Melody: 6 quarters = G4(5 beats) A4(1 beat) -->
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1na" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4s1nb" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4s1nc" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4s1nd" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4s1ne" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4s1nf" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Moving: articulate Gm 3x (beats 1,3,5) then Dm beat 6 -->
                  <chord xml:id="m4rh1" dur="2" stem.dir="up">
                    <note xml:id="m4rh1a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m4rh1b" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m4rh2" dur="2" stem.dir="up">
                    <note xml:id="m4rh2a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m4rh2b" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m4rh3" dur="4" stem.dir="up">
                    <note xml:id="m4rh3a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m4rh3b" pname="d" oct="5"/>
                  </chord>
                  <note xml:id="m4rh4" pname="a" oct="4" dur="4" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <!-- D5 sustained 5 beats -->
                  <note xml:id="m4rhs1" pname="d" oct="5" dur="2" dots="1" stem.dir="down"/>
                  <rest dur="4" visible="false"/>
                  <rest dur="4" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Gm full for 5 beats: G2-D3-G3-Bb3, then Dm beat 6 -->
                  <chord xml:id="m4lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m4lh1a" pname="g" oct="2"/>
                    <note xml:id="m4lh1b" pname="d" oct="3"/>
                    <note xml:id="m4lh1c" pname="g" oct="3"/>
                    <note xml:id="m4lh1d" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m4lh2" dur="4" stem.dir="up">
                    <note xml:id="m4lh2a" pname="g" oct="2"/>
                    <note xml:id="m4lh2b" pname="d" oct="3"/>
                    <note xml:id="m4lh2c" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- Dm beat 6: D2-A2-F3 -->
                  <chord xml:id="m4lh3" dur="4" stem.dir="up">
                    <note xml:id="m4lh3a" pname="d" oct="2"/>
                    <note xml:id="m4lh3b" pname="a" oct="2"/>
                    <note xml:id="m4lh3c" pname="f" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" pname="g" oct="1" dur="2" dots="1" stem.dir="down"/>
                  <note xml:id="m4p2" pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note xml:id="m4p3" pname="d" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="6">③m</harm>
            </measure>

            <!-- Bars 5-8 repeat bars 1-4 (stanza 2, slightly fuller) -->
            <!-- Bar 5 = Bar 1 repeat (same chords Gm/Eb/Cm) but RH adds 3rd note -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="b" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m5s1n2" pname="b" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m5s1n3" pname="c" oct="5" dur="4"/>
                  <note xml:id="m5s1n4" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5rh1" dur="2" stem.dir="up">
                    <note xml:id="m5rh1a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m5rh1b" pname="d" oct="5"/>
                    <note xml:id="m5rh1c" pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m5rh2" dur="2" stem.dir="up">
                    <note xml:id="m5rh2a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m5rh2b" pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5rh3" dur="2" stem.dir="up">
                    <note xml:id="m5rh3a" pname="g" oct="4"/>
                    <note xml:id="m5rh3b" pname="c" oct="5"/>
                    <note xml:id="m5rh3c" pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="breve" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5lh1" dur="2" stem.dir="up">
                    <note xml:id="m5lh1a" pname="g" oct="2"/>
                    <note xml:id="m5lh1b" pname="d" oct="3"/>
                    <note xml:id="m5lh1c" pname="g" oct="3"/>
                    <note xml:id="m5lh1d" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5lh2" dur="2" stem.dir="up">
                    <note xml:id="m5lh2a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m5lh2b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m5lh2c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m5lh2d" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m5lh3" dur="2" stem.dir="up">
                    <note xml:id="m5lh3a" pname="c" oct="2"/>
                    <note xml:id="m5lh3b" pname="g" oct="2"/>
                    <note xml:id="m5lh3c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m5lh3d" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
