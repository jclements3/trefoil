              <staff n="3">
                <layer n="1">
                  <chord xml:id="m13s3c1" dur="2">
                    <note xml:id="m13s3n1" pname="g" oct="3" />
                    <note xml:id="m13s3n2" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m13s3n3" pname="d" oct="4" />
                    <note xml:id="m13s3n4" pname="f" oct="4" />
