            <!-- Measure 13: Gm (ii) C (V) — G A/2 c/2
                 ABC: G2 "^F#°"A/2 c/2  — G=G4(half) A=A4(eighth) c=C5(eighth)
                 F#° = vii° in F, treat as V (C major chord, no 7th for simplicity)
                 G=G4 is melody. Chord G2 = G4 for 2 beats, then approach motion
                 Annotation: "^Gm" = ii, "^C" at prior...
                 m13 ABC: G2 "^F#°"A/2 c/2 — so beat 1: Gm chord on G4(half),
                 then F#° passing (A/2 = half a quarter = 1/8), then C5(eighth)
                 Use: ii (beat 1.5), V (beat 3)
            -->
            <measure n="13" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13s1n1" dur="2" oct="4" pname="g" />
