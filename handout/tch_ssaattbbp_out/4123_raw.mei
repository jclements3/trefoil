<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Holy God, We Praise Thy Name</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- F major: 1 flat (Bb) -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- F major: I=F, ii=Gm, iii=Am, IV=Bb, V=C, vi=Dm, vii°=E°    -->
            <!-- L:1/4, M:3/4 — one bar = 3 quarter notes                     -->
            <!-- Bb is key-signature note — accid.ges="f" on all B notes       -->
            <!-- Chord annotations: F=I, C7=V7, Bb=IV, Gm=ii, C=V, Em=iii    -->
            <!-- F#°=vii° (treat as C/E — 1st inv V or just V), Dm=vi         -->
            <!-- Am=iii (scale degree 3)                                        -->
            <!-- ============================================================ -->

            <!-- Measure 1: F (I) — F2 F
                 Melody: F4(half) F4(quarter) [in L:1/4 ABC: F2 F]
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="f" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: I "33": A4 C5 — open 3rd (two notes, gentle opening) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="a" oct="4" />
                    <note xml:id="m1s2n2" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m1s2n3" dur="4" pname="f" oct="4" />
                </layer>
              </staff>
              <!-- LH: I "334": F3 A3 C4 F4 dotted-half — open root position -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="f" oct="3" />
                    <note xml:id="m1s3n2" pname="a" oct="3" />
                    <note xml:id="m1s3n3" pname="c" oct="4" />
                  </chord>
                  <note xml:id="m1s3n4" dur="4" pname="f" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: F (I) — F E F (quarter motion)
                 Melody: F4(qtr) E4(qtr) F4(qtr)
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: I "43" 1st inv: C4 F4 A4 — varied from m1 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="c" oct="4" />
                    <note xml:id="m2s2n2" pname="f" oct="4" />
                    <note xml:id="m2s2n3" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n4" pname="a" oct="4" />
                    <note xml:id="m2s2n5" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n6" pname="a" oct="4" />
                    <note xml:id="m2s2n7" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "333": F3 A3 C4 E4 (F maj7) dotted-half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="f" oct="3" />
                    <note xml:id="m2s3n2" pname="a" oct="3" />
                    <note xml:id="m2s3n3" pname="c" oct="4" />
                    <note xml:id="m2s3n4" pname="e" oct="4" />
                  </chord>
                  <note xml:id="m2s3n5" dur="4" pname="a" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
            </measure>

            <!-- Measure 3: C7 (V7) — G A G
                 Melody: G4(qtr) A4(qtr) G4(qtr)
                 C7 = V7 (diatonic: C E G Bb)
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: V7 "233": Bb4 C5 E5 — 1st inv V7 for motion -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="c" oct="5" />
                    <note xml:id="m3s2n4" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n5" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V7 "333": C3 E3 G3 Bb3 — full dominant 7th -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="c" oct="3" />
                    <note xml:id="m3s3n2" pname="e" oct="3" />
                    <note xml:id="m3s3n3" pname="g" oct="3" />
                    <note xml:id="m3s3n4" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <note xml:id="m3s3n5" dur="4" pname="c" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
            </measure>

            <!-- Measure 4: F (I) whole — F3 -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="4" pname="f" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: I "33": F4 A4 C5 — root position 3-note -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="f" oct="4" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                    <note xml:id="m4s2n3" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m4s2n4" dur="4" pname="a" oct="4" />
                </layer>
              </staff>
              <!-- LH: I "334": F3 A3 C4 F4 dotted-half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="f" oct="3" />
                    <note xml:id="m4s3n2" pname="a" oct="3" />
                    <note xml:id="m4s3n3" pname="c" oct="4" />
                    <note xml:id="m4s3n4" pname="f" oct="4" />
                  </chord>
                  <note xml:id="m4s3n5" dur="4" pname="f" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 5: F (I) — A2 A -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" oct="4" pname="a" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I "34" 2nd inv: A4 C5 F5 — brighter color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="a" oct="4" />
                    <note xml:id="m5s2n2" pname="c" oct="5" />
                    <note xml:id="m5s2n3" pname="f" oct="5" />
                  </chord>
                  <note xml:id="m5s2n4" dur="4" pname="a" oct="4" />
                </layer>
              </staff>
              <!-- LH: I "333": F3 A3 C4 E4 — IΔ for color on repeat -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="f" oct="3" />
                    <note xml:id="m5s3n2" pname="a" oct="3" />
                    <note xml:id="m5s3n3" pname="c" oct="4" />
                    <note xml:id="m5s3n4" pname="e" oct="4" />
                  </chord>
                  <note xml:id="m5s3n5" dur="4" pname="c" oct="4" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①²</harm>
            </measure>

            <!-- Measure 6: F (I) — A G A (stepwise) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I "43" 1st inv: C4 F4 A4 → V "33": G4 Bb4 D5 (passing) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="c" oct="4" />
                    <note xml:id="m6s2n2" pname="f" oct="4" />
                    <note xml:id="m6s2n3" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n4" pname="g" oct="4" />
                    <note xml:id="m6s2n5" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m6s2n6" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n7" pname="a" oct="4" />
                    <note xml:id="m6s2n8" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "334": F3 A3 C4 F4 → V "334": C3 G3 C4 E4 → I: F3 C4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="f" oct="3" />
                    <note xml:id="m6s3n2" pname="a" oct="3" />
                    <note xml:id="m6s3n3" pname="c" oct="4" />
                    <note xml:id="m6s3n4" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n5" pname="c" oct="3" />
                    <note xml:id="m6s3n6" pname="g" oct="3" />
                    <note xml:id="m6s3n7" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n8" pname="f" oct="3" />
                    <note xml:id="m6s3n9" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 7: Bb C Bb A — IV V IV iii
                 Melody: c5(qtr) B4(qtr) A4(qtr) [ABC: c B A]
                 "^C" at B4 = V, "^Bb" at prior = IV...
                 ABC: c B A — note c=C5, B=Bb4(key sig), A=A4
                 Chord labels from ABC: c=C5 starts under "Bb" annotation,
                 then B4="C"(V), A4 no chord change
                 Actual: IV(C5) | V(Bb4) | I→IV
                 Reinterpret as IV | V | iii for richer motion
            -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: IV "33": Bb4 D5 (qtr); V "33": G4 Bb4 (qtr); iii "33": G4 C5 (qtr) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m7s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="g" oct="4" />
                    <note xml:id="m7s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="g" oct="4" />
                    <note xml:id="m7s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: IV "334": Bb3 D4 F4 Bb4 (qtr); V "333": C3 E3 G3 Bb3 (qtr); I "33": F3 A3 C4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m7s3n2" pname="d" oct="4" />
                    <note xml:id="m7s3n3" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="c" oct="3" />
                    <note xml:id="m7s3n5" pname="e" oct="3" />
                    <note xml:id="m7s3n6" pname="g" oct="3" />
                    <note xml:id="m7s3n7" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="4">
                    <note xml:id="m7s3n8" pname="f" oct="3" />
                    <note xml:id="m7s3n9" pname="a" oct="3" />
                    <note xml:id="m7s3n10" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 8: C (V) — A3 G2 = A4 half G4 quarter
                 ABC: A "^C"G2
            -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m8s1n2" dur="2" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: V "44" quartal: G4 C5 F5 — open quartal approach -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4">
                    <note xml:id="m8s2n1" pname="g" oct="4" />
                    <note xml:id="m8s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="2">
                    <note xml:id="m8s2n3" pname="g" oct="4" />
                    <note xml:id="m8s2n4" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m8s2n5" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V "333": C3 E3 G3 Bb3 dotted-half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="4">
                    <note xml:id="m8s3n1" pname="c" oct="3" />
                    <note xml:id="m8s3n2" pname="g" oct="3" />
                    <note xml:id="m8s3n3" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="2">
                    <note xml:id="m8s3n4" pname="c" oct="3" />
                    <note xml:id="m8s3n5" pname="e" oct="3" />
                    <note xml:id="m8s3n6" pname="g" oct="3" />
                    <note xml:id="m8s3n7" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤s4</harm>
              <harm staff="1" tstamp="2">⑤7</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 9-16): Repeat with fuller voicings             -->
            <!-- ============================================================ -->

            <!-- Measure 9: F (I) same as m1 -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" oct="4" pname="f" />
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: I "333": F4 A4 C5 — 3-voice -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="2">
                    <note xml:id="m9s2n1" pname="f" oct="4" />
                    <note xml:id="m9s2n2" pname="a" oct="4" />
                    <note xml:id="m9s2n3" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m9s2n4" dur="4" pname="a" oct="4" />
                </layer>
              </staff>
              <!-- LH: I "333": F3 A3 C4 E4 dotted-half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="f" oct="3" />
                    <note xml:id="m9s3n2" pname="a" oct="3" />
                    <note xml:id="m9s3n3" pname="c" oct="4" />
                    <note xml:id="m9s3n4" pname="e" oct="4" />
                  </chord>
                  <note xml:id="m9s3n5" dur="4" pname="f" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
            </measure>

            <!-- Measure 10: F Em F (I iii I) — same melody as m2 -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m10s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m10s1n3" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: I "34": A4 C5 F5 → iii "33": E4 G4 → I "43": C4 F4 A4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10s2c1" dur="4">
                    <note xml:id="m10s2n1" pname="a" oct="4" />
                    <note xml:id="m10s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m10s2c2" dur="4">
                    <note xml:id="m10s2n3" pname="e" oct="4" />
                    <note xml:id="m10s2n4" pname="g" oct="4" />
                    <note xml:id="m10s2n5" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m10s2c3" dur="4">
                    <note xml:id="m10s2n6" pname="a" oct="4" />
                    <note xml:id="m10s2n7" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "333": F3 A3 C4 E4 → iii "333": E3 G3 Bb3 D4 → I "334": F3 A3 C4 F4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10s3c1" dur="4">
                    <note xml:id="m10s3n1" pname="f" oct="3" />
                    <note xml:id="m10s3n2" pname="a" oct="3" />
                    <note xml:id="m10s3n3" pname="c" oct="4" />
                    <note xml:id="m10s3n4" pname="e" oct="4" />
                  </chord>
                  <chord xml:id="m10s3c2" dur="4">
                    <note xml:id="m10s3n5" pname="e" oct="3" />
                    <note xml:id="m10s3n6" pname="g" oct="3" />
                    <note xml:id="m10s3n7" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m10s3n8" pname="d" oct="4" />
                  </chord>
                  <chord xml:id="m10s3c3" dur="4">
                    <note xml:id="m10s3n9" pname="f" oct="3" />
                    <note xml:id="m10s3n10" pname="a" oct="3" />
                    <note xml:id="m10s3n11" pname="c" oct="4" />
                    <note xml:id="m10s3n12" pname="f" oct="4" />
