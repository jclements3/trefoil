                  <!-- beat 1: F-A chord (2-note, light) half note -->
                  <chord dur="2">
                    <note xml:id="m1r1a" oct="4" pname="f"/>
                    <note xml:id="m1r1b" oct="4" pname="a"/>
                  </chord>
                  <!-- beat 3: C-E (V preparation) quarter -->
                  <chord dur="4">
