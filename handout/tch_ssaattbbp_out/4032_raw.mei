                    <note xml:id="m1l1b" oct="3" pname="c"/>
                    <note xml:id="m1l1c" oct="3" pname="f"/>
                  </chord>
                  <!-- beat 4: C3-G3-C4 (V) quarter -->
                  <chord dur="4" dots="1">
                    <note xml:id="m1l2a" oct="3" pname="c"/>
                    <note xml:id="m1l2b" oct="3" pname="g"/>
                    <note xml:id="m1l2c" oct="4" pname="c"/>
                  </chord>
