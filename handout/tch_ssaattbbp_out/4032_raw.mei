                <keySig sig="1f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="1f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="1f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Measure 1: F F C F → I I V I (6/4) -->
            <!-- Melody: F2 G A2 G = beats 1-2 F, 3 G, 4-5 A, 6 G -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="2" oct="4" pname="f"/>
                  <note xml:id="m1n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1n3" dur="2" oct="4" pname="a"/>
                  <note xml:id="m1n4" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: F major "33" → F A C (beats 1-4), then C E G descend (beats 5-6) -->
              <staff n="2">
