<?xml version="1.0" encoding="UTF-8"?>
<!-- Hymn 4032: Comfort, Comfort Ye My People — F major, 6/4
     Pedal harp arrangement: Melody + RH (treble) + LH (bass) + P (pedal, C1-B1)

     VOICING PLAN:
     F major diatonic: F G A Bb C D E
     Key: F (1 flat: Bb → accid.ges="f" on every B)

     Chord progression analysis (measure by measure):
     m1:  F F C F       → I–I–V–I (6/4: beats 1-6)
     m2:  Dm Am Bb F    → vi–iii–IV–I
     m3:  Dm C F Bb     → vi–V–I–IV
     m4:  F C F         → I–V–I
     m5:  F C F C       → I–V–I–V (repeat of m1 rhythm)
     m6:  Dm Am Bb F    → vi–iii–IV–I
     m7:  Dm C F Bb     → vi–V–I–IV
     m8:  F C F         → I–V–I
     m9:  A Dm F Bb     → III–vi–I–IV (A major = non-diatonic → sub III/vi area)
     m10: F C F         → I–V–I (z2 rest in melody)
     m11: Bb d C        → IV–?–V (d = Dm, c = C)
     m12: Bb F C        → IV–I–V (z2 rest)
     m13: F Cm Gm F     → I–vm–IIm–I (Cm,Gm non-diatonic → sub V, ii)
     m14: Dm C F Bb     → vi–V–I–IV
     m15: F Dm Bb F     → I–vi–IV–I
     m16: Gm F C F      → ii–I–V–I

     Patterns chosen:
     - Opening (m1-4): "33" root pos, then "43" 1st inv for variety
     - Middle (m5-8): "44" quartal for open sound
     - Development (m9-12): "333" 7th chords for richness
     - Climax (m13-16): full "334" + pedal, converge to root pos

     TEXTURE ARC:
     - m1-4:  Light opening, 2-note RH + 3-note LH, root position
     - m5-8:  Quartal color, same weight
     - m9-12: 7th chords, richer 3-note RH + 4-note LH
     - m13-16: Fullest texture, climax at m15, close on root pos
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Comfort, Comfort Ye My People</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="6" meter.unit="4" key.sig="1f">
