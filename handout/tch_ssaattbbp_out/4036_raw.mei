<?xml version="1.0" encoding="UTF-8"?>
<!-- Hymn 4036: Lift Up Your Heads, Ye Mighty Gates — A major, 3/4, pickup + ~30 measures
     Pedal harp arrangement: Melody + RH + LH + P

     ABC melody:
     "^E"E | "^A"c2 A | A "^G#m"G "^A"A | "^E"B2 G | E2 E | E "^F#°"F "^E7"G |
     "^A"A2 "^D"F | "^A"E2 "^E7"D | "^A"C2 C | E A c | "^E"B G E | "^F#m"A F "^Eb"^D |
     "^E"E2 "^C#m"E | "^F#m"A2 "^E"B | "^A"c2 "^F#m"A | "^E"G2 "^Eb"F | "^E"E2 "^A"A |
     "^E"G2 "^E7"B | "^A"A2 c | "^E"B2 "^E7"d | "^A"c2 "^E"E | "^E7"d "^A"c "^E"B |
     "^A"A G "^D"F | "^A"E2 "^E"E | "^A"E2 e | "^E"e2 "^A"c | "^D"d2 "^E"e |
     "^A"c2 E | "^D"F "^Bm"d B | "^A"A2 "^E"G | "^A"A2 |

     A major diatonic: A B C# D E F# G#
     Key: A major (3 sharps: F→accid.ges="s", C→accid.ges="s", G→accid.ges="s")

     Diatonic substitutions:
     - G#m: vii (G# B D#) — D# non-diatonic! Sub V (E) or use V with 3rd (E-G#-B is OK: G# IS in A major)
       Actually: G#m = G# B D# — D# is not in A major. Sub with V/3rd (E-G#-B with G# as passing)
     - F#°: vii° in G major... In A major: vi = F#m (F# A C#). F#° = F# A C. C is not in A major!
       F#m is fine (vi). F#° → substitute vi (F#m) or use F# as leading tone.
     - E7: V7 (E G# B D) — D is in A major? D is the 4th degree. E7 = E-G#-B-D. All diatonic ✓
     - Eb: E-flat, very non-diatonic. Context: melody passing tone (^D = D# in one case, Eb in another).
       Treat as chromatic passing; use diatonic harmony underneath.
     - C#m: iii (C# E G#) ✓ diatonic
     - F#m: vi (F# A C#) ✓ diatonic
     - Bm: ii (B D F#) ✓ diatonic in A major
     - D: IV (D F# A) ✓ diatonic

     Duration (3/4 = 3 quarter beats per measure):

     Pickup: "^E"E = 1 beat

     Measures (beat counts from ABC):
     m1: c2 A = 2+1 = 3 ✓ (A=A5? No: in K:A, c = C5, A = A4)
     m2: A G A = 1+1+1 = 3 ✓
     m3: B2 G = 2+1 = 3 ✓
     m4: E2 E = 2+1 = 3 ✓
     m5: E F G = 1+1+1 = 3 ✓
     m6: A2 F = 2+1 = 3 ✓
     m7: E2 D = 2+1 = 3 ✓
     m8: C2 C = 2+1 = 3 ✓ (C in A major = C#, so accid.ges="s")
     m9: E A c = 1+1+1 = 3 ✓
     m10: B G E = 1+1+1 = 3 ✓
     m11: A F ^D = 1+1+1 = 3 ✓ (^D = D# non-diatonic passing tone, accid="s")
     m12: E2 E = 2+1 = 3 ✓
     m13: A2 B = 2+1 = 3 ✓
     m14: c2 A = 2+1 = 3 ✓
     m15: G2 F = 2+1 = 3 ✓ (G in A major = G#, accid.ges="s")
     m16: E2 A = 2+1 = 3 ✓
     m17: G2 B = 2+1 = 3 ✓
     m18: A2 c = 2+1 = 3 ✓
     m19: B2 d = 2+1 = 3 ✓
     m20: c2 E = 2+1 = 3 ✓
     m21: d c B = 1+1+1 = 3 ✓
     m22: A G F = 1+1+1 = 3 ✓
     m23: E2 E = 2+1 = 3 ✓
     m24: E2 e = 2+1 = 3 ✓ (e = E5)
     m25: e2 c = 2+1 = 3 ✓
     m26: d2 e = 2+1 = 3 ✓
     m27: c2 E = 2+1 = 3 ✓
     m28: F d B = 1+1+1 = 3 ✓
     m29: A2 G = 2+1 = 3 ✓
     m30: A2 (half note, final) = 2 beats... ABC has "A2|]" = half note at end

     Note: For the final measure, I'll use a dotted half note for a full close.
     All C in A major = C# (accid.ges="s")
     All G in A major = G# (accid.ges="s")
     All F in A major = F# (accid.ges="s")

     VOICING PLAN:
     - I (A): A2-E3-A3-C#4 "334" — warm A major
     - ii (Bm): B2-F#3-B3-D4 "333"
     - iii (C#m): C#3-G#3-C#4 "334"
     - IV (D): D2-A2-D3-F#3 "334"
     - V (E): E2-B2-E3-G#3 "334"
     - V7 (E7): E2-B2-E3-G#3 + D4 option
     - vi (F#m): F#2-C#3-F#3-A3 "334"
     - vii° (G#°): G#3-B3-D4 "33" (lighter)
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
