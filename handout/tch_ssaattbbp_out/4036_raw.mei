            <!-- m11: F#m A, Eb/^D F# → vi passing, D# non-diatonic in melody -->
            <!-- Melody: A4 F#4 D#4 (^D = D# = Eb4) -->
            <!-- Use vi then V harmonically; D# is a chromatic ornament -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m11n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m11n3" dur="4" oct="4" pname="d" accid="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2">
                    <note xml:id="m11r1a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m11r1b" oct="4" pname="a"/>
                  </chord>
                  <chord dur="4">
                    <note xml:id="m11r2a" oct="4" pname="e"/>
                    <note xml:id="m11r2b" oct="4" pname="g" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2">
