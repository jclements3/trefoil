<?xml version='1.0' encoding='utf-8'?>
<!-- MEI arrangement: In His Temple Now Behold Him (hymn 4075) -->
<!-- Key: G (1 sharp: F#)  Meter: 6/8  L:1/4 = quarter note -->
<!-- 6/8 = 3 quarter notes per bar (compound duple: 2 dotted-quarter beats) -->
<!-- Diatonic scale: G A B C D E F# -->
<!-- Non-diatonic substitutions: F#° → Em, C#° → Am, A-maj → Em, Eb+ → G, B-maj → D, E-maj → Em -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>In His Temple Now Behold Him</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="6" meter.unit="8" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- PHRASE 1 (mm. 1–8): Introduction, lighter texture -->

            <!-- m1: G B(half) D d(quarter) — I then V -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="b"/>
                  <note xml:id="m1s1n2" dur="4" oct="5" pname="d"/>
                </layer>
              </staff>
              <!-- RH: I open 5th (G4-D5), then V 3rd (D5-F#5) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="g" oct="4"/>
                    <note xml:id="m1s2n2" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="d" oct="5"/>
                    <note xml:id="m1s2n4" pname="f" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I root pos open G2-D3-G3, then V open A2-D3-A3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="g" oct="2"/>
                    <note xml:id="m1s3n2" pname="d" oct="3"/>
                    <note xml:id="m1s3n3" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="a" oct="2"/>
                    <note xml:id="m1s3n5" pname="d" oct="3"/>
                    <note xml:id="m1s3n6" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- m2: G B(half) G(quarter) — I all bar -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="2" oct="4" pname="b"/>
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: I arpeggio G4-B4-D5 across bar -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m2s2n1" dur="4" pname="g" oct="4"/>
                  <note xml:id="m2s2n2" dur="4" pname="b" oct="4"/>
                  <note xml:id="m2s2n3" dur="4" pname="d" oct="5"/>
                </layer>
              </staff>
              <!-- LH: I root pos G2-D3-B3, sustained -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2" dots="1">
                    <note xml:id="m2s3n1" pname="g" oct="2"/>
                    <note xml:id="m2s3n2" pname="d" oct="3"/>
                    <note xml:id="m2s3n3" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- m3: C c(half) Am A(quarter) — IV then ii -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="2" oct="5" pname="c"/>
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: IV G4-C5(half), ii A4-E5(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="g" oct="4"/>
                    <note xml:id="m3s2n2" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="a" oct="4"/>
                    <note xml:id="m3s2n4" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: IV root open C2-G2-C3(half), ii A2-E3-A3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="c" oct="3"/>
                    <note xml:id="m3s3n2" pname="g" oct="3"/>
                    <note xml:id="m3s3n3" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="a" oct="2"/>
                    <note xml:id="m3s3n5" pname="e" oct="3"/>
                    <note xml:id="m3s3n6" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- m4: D F(half) D(quarter) — V all bar -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="d"/>
                </layer>
              </staff>
              <!-- RH: V 1st inv F#4-A4-D5 broken -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m4s2n1" dur="4" pname="f" oct="4" accid.ges="s"/>
                  <note xml:id="m4s2n2" dur="4" pname="a" oct="4"/>
                  <note xml:id="m4s2n3" dur="4" pname="d" oct="5"/>
                </layer>
              </staff>
              <!-- LH: V root open D2-A2-D3-F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2" dots="1">
                    <note xml:id="m4s3n1" pname="d" oct="2"/>
                    <note xml:id="m4s3n2" pname="a" oct="2"/>
                    <note xml:id="m4s3n3" pname="d" oct="3"/>
                    <note xml:id="m4s3n4" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- m5: G G(half) Em A(quarter) — I then vi (sub F#°) -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" oct="4" pname="g"/>
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: I D4-G4(half), vi E4-B4(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="d" oct="4"/>
                    <note xml:id="m5s2n2" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="e" oct="4"/>
                    <note xml:id="m5s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I G2-D3-G3(half), vi E2-B2-E3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="g" oct="2"/>
                    <note xml:id="m5s3n2" pname="d" oct="3"/>
                    <note xml:id="m5s3n3" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="e" oct="2"/>
                    <note xml:id="m5s3n5" pname="b" oct="2"/>
                    <note xml:id="m5s3n6" pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- m6: G B(3/2) D A(1/2) Am G(1) — I (1.5) V (0.5) ii (1) -->
            <!-- 1.5 + 0.5 + 1 = 3 beats ✓ -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" dots="1" oct="4" pname="b"/>
                  <note xml:id="m6s1n2" dur="8" oct="4" pname="a"/>
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: I B4-D5(d.q), V A4-D5(8), ii A4-C5(q) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4" dots="1">
                    <note xml:id="m6s2n1" pname="b" oct="4"/>
                    <note xml:id="m6s2n2" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m6s2c2" dur="8">
                    <note xml:id="m6s2n3" pname="a" oct="4"/>
                    <note xml:id="m6s2n4" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="a" oct="4"/>
                    <note xml:id="m6s2n6" pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I G2-D3-B3(d.q), V A2-D3(8), ii A2-E3-A3(q) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4" dots="1">
                    <note xml:id="m6s3n1" pname="g" oct="2"/>
                    <note xml:id="m6s3n2" pname="d" oct="3"/>
                    <note xml:id="m6s3n3" pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c2" dur="8">
                    <note xml:id="m6s3n4" pname="a" oct="2"/>
                    <note xml:id="m6s3n5" pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n6" pname="a" oct="2"/>
                    <note xml:id="m6s3n7" pname="e" oct="3"/>
                    <note xml:id="m6s3n8" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">⑤</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- m7: D F(quarter) Em E(half) — V (1) vi (2) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m7s1n2" dur="2" oct="4" pname="e"/>
                </layer>
              </staff>
              <!-- RH: V F#4-A4(q), vi E4-B4(half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m7s2n2" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m7s2c2" dur="2">
                    <note xml:id="m7s2n3" pname="e" oct="4"/>
                    <note xml:id="m7s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: V D2-A2-F#3(q), vi E2-B2-E3-G3(half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="d" oct="2"/>
                    <note xml:id="m7s3n2" pname="a" oct="2"/>
                    <note xml:id="m7s3n3" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m7s3c2" dur="2">
                    <note xml:id="m7s3n4" pname="e" oct="2"/>
                    <note xml:id="m7s3n5" pname="b" oct="2"/>
                    <note xml:id="m7s3n6" pname="e" oct="3"/>
                    <note xml:id="m7s3n7" pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
            </measure>

            <!-- m8: D D(3 quarters) — V all bar, half cadence -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" dots="1" oct="4" pname="d"/>
                </layer>
              </staff>
              <!-- RH: V sus4 resolved D4-G4-A4 → D4-F#4-A4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4" dots="1">
                    <note xml:id="m8s2n1" pname="d" oct="4"/>
                    <note xml:id="m8s2n2" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m8s2c2" dur="4" dots="1">
                    <note xml:id="m8s2n3" pname="d" oct="4"/>
                    <note xml:id="m8s2n4" pname="f" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: V full D2-A2-D3-F#3 block -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="2" dots="1">
                    <note xml:id="m8s3n1" pname="d" oct="2"/>
                    <note xml:id="m8s3n2" pname="a" oct="2"/>
                    <note xml:id="m8s3n3" pname="d" oct="3"/>
                    <note xml:id="m8s3n4" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤s4</harm>
            </measure>

            <!-- PHRASE 2 (mm. 9–16): Sequence repeat, richer texture -->

            <!-- m9: F(half) Em A(quarter) — V implied then vi -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: V F#4-A4(half), vi A4-E5(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="2">
                    <note xml:id="m9s2n1" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m9s2n2" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m9s2c2" dur="4">
                    <note xml:id="m9s2n3" pname="a" oct="4"/>
                    <note xml:id="m9s2n4" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: V D2-A2-D3(half), vi E2-B2-E3-G3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="d" oct="2"/>
                    <note xml:id="m9s3n2" pname="a" oct="2"/>
                    <note xml:id="m9s3n3" pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
                    <note xml:id="m9s3n4" pname="e" oct="2"/>
                    <note xml:id="m9s3n5" pname="b" oct="2"/>
                    <note xml:id="m9s3n6" pname="e" oct="3"/>
                    <note xml:id="m9s3n7" pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- m10: D F(half) D(quarter) — V all bar -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="2" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m10s1n2" dur="4" oct="4" pname="d"/>
                </layer>
              </staff>
              <!-- RH: V arpeggio D4-F#4-A4 -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m10s2n1" dur="4" pname="d" oct="4"/>
                  <note xml:id="m10s2n2" dur="4" pname="f" oct="4" accid.ges="s"/>
                  <note xml:id="m10s2n3" dur="4" pname="a" oct="4"/>
                </layer>
              </staff>
              <!-- LH: V D2-A2-D3-F#3 open, sustained -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10s3c1" dur="2" dots="1">
                    <note xml:id="m10s3n1" pname="d" oct="2"/>
                    <note xml:id="m10s3n2" pname="a" oct="2"/>
                    <note xml:id="m10s3n3" pname="d" oct="3"/>
                    <note xml:id="m10s3n4" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- m11: G G(half) Em A(quarter) — I then vi -->
            <measure n="11" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" dur="2" oct="4" pname="g"/>
                  <note xml:id="m11s1n2" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: I G4-B4(half), vi E4-B4(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m11s2c1" dur="2">
                    <note xml:id="m11s2n1" pname="g" oct="4"/>
                    <note xml:id="m11s2n2" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m11s2c2" dur="4">
                    <note xml:id="m11s2n3" pname="e" oct="4"/>
                    <note xml:id="m11s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I G2-D3-G3(half), vi E2-B2-G3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11s3c1" dur="2">
                    <note xml:id="m11s3n1" pname="g" oct="2"/>
                    <note xml:id="m11s3n2" pname="d" oct="3"/>
                    <note xml:id="m11s3n3" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m11s3c2" dur="4">
                    <note xml:id="m11s3n4" pname="e" oct="2"/>
                    <note xml:id="m11s3n5" pname="b" oct="2"/>
                    <note xml:id="m11s3n6" pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- m12: G B(half) G(quarter) — I all bar -->
            <measure n="12" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12s1n1" dur="2" oct="4" pname="b"/>
                  <note xml:id="m12s1n2" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: I 7th G4-B4-D5-F#5 arpeggio -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m12s2n1" dur="4" pname="g" oct="4"/>
                  <note xml:id="m12s2n2" dur="4" pname="b" oct="4"/>
                  <note xml:id="m12s2n3" dur="4" pname="d" oct="5"/>
                </layer>
              </staff>
              <!-- LH: I root pos open G2-D3-B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12s3c1" dur="2" dots="1">
                    <note xml:id="m12s3n1" pname="g" oct="2"/>
                    <note xml:id="m12s3n2" pname="d" oct="3"/>
                    <note xml:id="m12s3n3" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
            </measure>

            <!-- m13: C c(half) Bm B(quarter) — IV then iii -->
            <measure n="13" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13s1n1" dur="2" oct="5" pname="c"/>
                  <note xml:id="m13s1n2" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <!-- RH: IV C4-E5(half), iii B4-D5(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m13s2c1" dur="2">
