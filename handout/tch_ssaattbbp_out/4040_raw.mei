              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 16: D D2 — D(D2=half + rest) final 2 beats in 3/4 -->
            <!-- ABC: "^D"D2 — 2 beats only, last beat implied rest -->
            <measure n="16" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m16s1n1" pname="d" oct="4" dur="2"/>
                  <rest dur="4"/>
