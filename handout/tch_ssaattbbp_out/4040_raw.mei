<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>On Jordan's Bank the Baptist's Cry</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB+P</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- D major: 2 sharps (F#, C#). 3/4 time. Pickup of 1 beat (D). -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="2s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup: D D4 — 1 beat, D major -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: F#4 — 3rd of D — single note pickup -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0r1" pname="f" oct="4" accid.ges="s" dur="4"/>
                </layer>
              </staff>
              <!-- LH: D2 A2 — open 5th pickup chord -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 1 (mm. 1-4): D, Bm, A, G — opening hymn statement        -->
            <!-- ================================================================ -->

            <!-- Measure 1: Bm D2 A E — Bm(D2=half), A(E=quarter) -->
            <!-- ABC: "^Bm"D2 "^A"E -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m1s1n2" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Bm D4 F#4; A C#5 E5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1r1" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m1r2" dur="4">
                    <note pname="c" oct="5" accid.ges="s"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Bm B2 F#3 B3 D4; A A2 E3 A3 C#4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1l1" dur="2">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <chord xml:id="m1l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 2: D F2 G — D(F#2=half), G(G=quarter) -->
            <!-- ABC: "^D"F2 "^G"G -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="f" oct="4" dur="2" accid.ges="s"/>
                  <note xml:id="m2s1n2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D A4 D5; G G4 B4 — descent to G -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m2r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; G G2 D3 G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m2l2" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 3: D F2 A E — D(F#2=half), A(E=quarter) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="f" oct="4" dur="2" accid.ges="s"/>
                  <note xml:id="m3s1n2" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D "43" 1st inv F#4 A4; A E4 A4 (sus4 feel) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3r1" dur="2">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; A A2 E3 A3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 4: D D2 G D — D(D2=half), G(D=quarter) -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m4s1n2" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D F#4 B4; G G4 D5 (2nd inv) — voice crossing interest -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="2">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m4r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3; G G2 D3 G3 B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="m4l2" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 2 (mm. 5-8): D, A ascending, D cadence                   -->
            <!-- ================================================================ -->

            <!-- Measure 5: D A2 A — D(A2=half), D(A=quarter) — all D -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m5s1n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D "333" Δ F#4 A4 C#5 — add 7th for richness -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5r1" dur="2" dots="1">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D "334" D2 A2 D3 F#3 whole -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5l1" dur="2" dots="1">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
            </measure>

            <!-- Measure 6: A A B c — A(A), A(B), A(c) — all A -->
            <!-- ABC: "^A"A B c -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m6s1n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m6s1n3" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: ascending figure A4→E5→A5 — arpeggiate A chord -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m6r1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m6r2" pname="e" oct="5" dur="4"/>
                  <note xml:id="m6r3" pname="a" oct="5" dur="4"/>
                </layer>
              </staff>
              <!-- LH: A "334" A2 E3 A3 C#4 — arpeggiate quarters -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m6l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m6l3" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Measure 7: D d2 G d — D(d2=D5 half), G(d=D5 quarter) -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="d" oct="5" dur="2"/>
                  <note xml:id="m7s1n2" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D F#5 A5; G B4 D5 — drop register after high A -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7r1" dur="2">
                    <note pname="f" oct="5" accid.ges="s"/>
                    <note pname="a" oct="5"/>
                  </chord>
                  <chord xml:id="m7r2" dur="4">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; G G2 D3 G3 B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m7l2" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 8: D d2 A A — D(d2=half), A(A=quarter) -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" pname="d" oct="5" dur="2"/>
                  <note xml:id="m8s1n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D "43" 1st inv B4 E5; A E5 A5 — high register maintained -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8r1" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m8r2" dur="4">
                    <note pname="e" oct="5"/>
                    <note pname="a" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; A A2 E3 A3 C#4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m8l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①¹</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 3 (mm. 9-12): Bm, E7, A, G — emotional inner section     -->
            <!-- ================================================================ -->

            <!-- Measure 9: Bm d2 E7 d — Bm(d2=D5 half), E7(d=D5 quarter) -->
            <!-- E7 is non-diatonic in D major (V/V). Diatonic sub: use A (V) or Em. -->
            <!-- The melody note is D5 which fits both Bm and D. Use Bm for full bar. -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" pname="d" oct="5" dur="2"/>
                  <note xml:id="m9s1n2" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Bm "333" F#4 A4 D5; Bm stays for full bar -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9r1" dur="2" dots="1">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Bm B2 F#3 B3 D4 — rich 7th voicing -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9l1" dur="2" dots="1">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Measure 10: A c2 D A — A(c2=C#5 half), D(A=quarter) -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" pname="c" oct="5" dur="2" accid.ges="s"/>
                  <note xml:id="m10s1n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: A E5 A5; D F#4 A4 — stepwise descent E5→A4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10r1" dur="2">
                    <note pname="e" oct="5"/>
                    <note pname="a" oct="5"/>
                  </chord>
                  <chord xml:id="m10r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: A A2 E3 A3 C#4; D D2 A2 D3 F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m10l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 11: G B2 B — G(B2=half), G(B=quarter) -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" pname="b" oct="4" dur="2"/>
                  <note xml:id="m11s1n2" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: G "44" quartal D5 G5 — open modal sound mid-hymn -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m11r1" dur="2" dots="1">
                    <note pname="d" oct="5"/>
                    <note pname="g" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2 D3 G3 B3 — IV subdominant pedal -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11l1" dur="2" dots="1">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
            </measure>

            <!-- Measure 12: D A2 Em G — D(A2=half), Em(G=quarter) -->
            <!-- ABC: "^D"A2 "^Em"G -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m12s1n2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D F#4 A4; Em G4 B4 — step down -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m12r1" dur="2">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m12r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; Em E2 B2 E3 G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m12l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 4 (mm. 13-16): A, D, G, A, D — final cadential section   -->
            <!-- ================================================================ -->

            <!-- Measure 13: A A2 D F — A(A2=half), D(F#=quarter) -->
            <!-- ABC: "^A"A2 "^D"F -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m13s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: A C#5 E5; D F#4 D5 (octave) — voice variety -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m13r1" dur="2">
                    <note pname="c" oct="5" accid.ges="s"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m13r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: A A2 E3 A3 C#4; D D2 A2 D3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m13l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m13l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 14: A E2 D F — A(E2=half), D(F#=quarter) -->
            <!-- ABC: "^A"E2 "^D"F -->
            <measure n="14">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m14s1n1" pname="e" oct="4" dur="2"/>
                  <note xml:id="m14s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: A "24" sus2 A4 B4 E5; D F#4 A4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m14r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m14r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: A A2 E3 A3; D D2 A2 D3 F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m14l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m14l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤s2</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 15: G D2 A C — G(D2=half), A(C#=quarter) -->
            <!-- ABC: "^G"D2 "^A"C -->
            <measure n="15">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15s1n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m15s1n2" pname="c" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: G B4 D5; A C#5 E5 — ascending chromatic motion -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m15r1" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m15r2" dur="4">
                    <note pname="c" oct="5" accid.ges="s"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
