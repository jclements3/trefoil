<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Silent Night</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Bb major: Bb and Eb = accid.ges="f" on every B and E -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="2f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="2f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="2f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="2f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-3): Opening — hushed, gentle lullaby        -->
            <!-- ============================================================ -->

            <!-- Measure 1: 3 beats. Bb (I). Melody: F4(dotted-qtr) G4(8) F4(8) D4(dotted-qtr+8) -->
            <!-- 0.75+0.25+0.5+1.5=3 beats OK. F=⑤, D=③ in Bb major -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m1s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m1s1n3" dur="8" oct="4" pname="f" />
                  <note xml:id="m1s1n4" dur="4" dots="1" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: D4-F4 (I 3rd) dotted-half — sustained tonic color, gentle -->
              <staff n="2">
                <layer n="1">
                  <rest dur="2" dots="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m1s2c1" dur="2" dots="1">
                    <note xml:id="m1s2n1" pname="d" oct="4" />
                    <note xml:id="m1s2n2" pname="f" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3 open root position, dotted-half -->
              <staff n="3">
                <layer n="1">
                  <rest dur="2" dots="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m1s3c1" dur="2" dots="1">
                    <note xml:id="m1s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n2" pname="f" oct="3" />
                    <note xml:id="m1s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: 3 beats. Bb. Melody: F4(dotted-qtr) G4(8) F4(8) D4(dotted-qtr+8) -->
            <!-- same as m.1 — repeat phrase -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m2s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m2s1n3" dur="8" oct="4" pname="f" />
                  <note xml:id="m2s1n4" dur="4" dots="1" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: F4-Bb4 (I open 4th) — slightly brighter variant -->
              <staff n="2">
                <layer n="1">
                  <rest dur="2" dots="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m2s2c1" dur="2" dots="1">
                    <note xml:id="m2s2n1" pname="f" oct="4" />
                    <note xml:id="m2s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: Bb2-D3-F3 (I close position) -->
              <staff n="3">
                <layer n="1">
                  <rest dur="2" dots="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m2s3c1" dur="2" dots="1">
                    <note xml:id="m2s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n2" pname="d" oct="3" />
                    <note xml:id="m2s3n3" pname="f" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 3: 3 beats. F7 (V7). Melody: c5(4) c5(8) A4(dotted-qtr+8) -->
            <!-- 1+0.5+1.5=3 beats OK. F7 = V7 in Bb (diatonic dom7) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n2" dur="8" oct="5" pname="c" />
                  <note xml:id="m3s1n3" dur="4" dots="1" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: C5-Eb5 (V7 partial, 7th+root), dotted-half — gently expressive -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="c" oct="5" />
                    <note xml:id="m3s2n2" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="a" oct="4" />
                    <note xml:id="m3s2n4" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m3s2n5" dur="4" pname="f" oct="4" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-Eb3(V7 open), F2-A2-C3(V1st inv) — V7 with bass motion -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4" dots="1">
                    <note xml:id="m3s3n1" pname="f" oct="2" />
                    <note xml:id="m3s3n2" pname="c" oct="3" />
                    <note xml:id="m3s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4" dots="1">
                    <note xml:id="m3s3n4" pname="f" oct="2" />
                    <note xml:id="m3s3n5" pname="a" oct="2" />
                    <note xml:id="m3s3n6" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
            </measure>

            <!-- Measure 4: 3 beats. Bb (I). Melody: Bb4(4) Bb4(8) F4(dotted-qtr+8) -->
            <!-- 1+0.5+1.5=3 beats OK -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m4s1n2" dur="8" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m4s1n3" dur="4" dots="1" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: Bb4-D5(I 3rd), then F4-D4(I open) — resolving from V7 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4" dots="1">
                    <note xml:id="m4s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4" dots="1">
                    <note xml:id="m4s2n3" pname="f" oct="4" />
                    <note xml:id="m4s2n4" pname="d" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3(I) dotted-half -->
              <staff n="3">
                <layer n="1">
                  <rest dur="2" dots="1" />
                </layer>
                <layer n="2">
                  <chord xml:id="m4s3c1" dur="2" dots="1">
                    <note xml:id="m4s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n2" pname="f" oct="3" />
                    <note xml:id="m4s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Eb major color, then back to Bb         -->
            <!-- ============================================================ -->

            <!-- Measure 5: 3 beats. Eb (IV). Melody: G4(4) G4(8) Bb4(dotted-qtr+16) A4(16) G4(8) -->
            <!-- 1+0.5+0.75+0.25+0.5... wait, let me re-check:
                 G G/2 B3/4 A/4 G/2 in L:1/4:
                 G=1, G/2=0.5, B3/4=0.75, A/4=0.25, G/2=0.5 = 3 beats OK
                 B is Bb (key sig) -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m5s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m5s1n3" dur="4" dots="1" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m5s1n4" dur="16" oct="4" pname="a" />
                  <note xml:id="m5s1n5" dur="8" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G4-Bb4(IV partial — Eb chord tone G), Bb4-Eb5(IV 3rd) — warm IV color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4" dots="1">
                    <note xml:id="m5s2n1" pname="g" oct="4" />
                    <note xml:id="m5s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4" dots="1">
                    <note xml:id="m5s2n3" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m5s2n4" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Eb2-Bb2-Eb3(IV root), Eb3-G3-Bb3(IV higher octave) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4" dots="1">
                    <note xml:id="m5s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m5s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m5s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4" dots="1">
                    <note xml:id="m5s3n4" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m5s3n5" pname="g" oct="3" />
                    <note xml:id="m5s3n6" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
            </measure>

            <!-- Measure 6: 3 beats. Bb→Eb→Bb. Melody: F4(dotted-qtr) G4(8) F4(8) D4(dotted-qtr+8) -->
            <!-- same melody as m.1/2 but with Eb→Bb context -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m6s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m6s1n3" dur="8" oct="4" pname="f" />
                  <note xml:id="m6s1n4" dur="4" dots="1" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: D4-F4(I), G4-Bb4(IV partial), F4-Bb4(I 5th) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4" dots="1">
                    <note xml:id="m6s2n1" pname="d" oct="4" />
                    <note xml:id="m6s2n2" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4" dots="1">
                    <note xml:id="m6s2n3" pname="f" oct="4" />
                    <note xml:id="m6s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3(I), Eb3-Bb3(IV), Bb2-D3-F3(I) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4" dots="1">
                    <note xml:id="m6s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m6s3n2" pname="f" oct="3" />
                    <note xml:id="m6s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4" dots="1">
                    <note xml:id="m6s3n4" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m6s3n5" pname="d" oct="3" />
                    <note xml:id="m6s3n6" pname="f" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">①¹</harm>
            </measure>

            <!-- Measure 7: 3 beats. Eb→F→Eb. Melody: G4(4) G4(8) Bb4(dotted-qtr+16) A4(16) G4(8) -->
            <!-- Same melody as m.5 but heading toward F/V -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m7s1n3" dur="4" dots="1" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m7s1n4" dur="16" oct="4" pname="a" />
                  <note xml:id="m7s1n5" dur="8" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G4-C5(IV), A4-C5(V partial), G4-Bb4(IV) — voice leading -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4" dots="1">
                    <note xml:id="m7s2n1" pname="g" oct="4" />
                    <note xml:id="m7s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4" dots="1">
                    <note xml:id="m7s2n3" pname="a" oct="4" />
                    <note xml:id="m7s2n4" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Eb2-Bb2-Eb3(IV), F2-C3-Eb3(V7), Eb2-G2-Bb2(IV close) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4" dots="1">
                    <note xml:id="m7s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m7s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m7s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4" dots="1">
                    <note xml:id="m7s3n4" pname="f" oct="2" />
                    <note xml:id="m7s3n5" pname="c" oct="3" />
                    <note xml:id="m7s3n6" pname="e" oct="3" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2.5">⑤</harm>
            </measure>

            <!-- Measure 8: 3 beats. Bb→Eb→Bb. Melody: F4(dotted-qtr) G4(8) F4(8) D4(dotted-qtr+8) -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m8s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m8s1n3" dur="8" oct="4" pname="f" />
                  <note xml:id="m8s1n4" dur="4" dots="1" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: D4-F4(I), Eb4-G4(IV color), D4-Bb4(I 6th) — more color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4" dots="1">
                    <note xml:id="m8s2n1" pname="d" oct="4" />
                    <note xml:id="m8s2n2" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="4" dots="1">
                    <note xml:id="m8s2n3" pname="d" oct="4" />
                    <note xml:id="m8s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3(I), Eb2-Bb2-Eb3(IV), Bb2-D3-F3-Bb3(I 4-note) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="4" dots="1">
                    <note xml:id="m8s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m8s3n2" pname="f" oct="3" />
                    <note xml:id="m8s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="4" dots="1">
                    <note xml:id="m8s3n4" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m8s3n5" pname="d" oct="3" />
                    <note xml:id="m8s3n6" pname="f" oct="3" />
                    <note xml:id="m8s3n7" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 3 (mm. 9-11): Climax — high F chord, final cadence   -->
            <!-- ============================================================ -->

            <!-- Measure 9: 3 beats. F (V). Melody: c5(4) c5(8) e5(dotted-qtr+16) c5(16) A4(8) -->
            <!-- 1+0.5+0.75+0.25+0.5=3 beats OK. e5 = Eb5 (key sig) -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m9s1n2" dur="8" oct="5" pname="c" />
                  <note xml:id="m9s1n3" dur="4" dots="1" oct="5" pname="e" accid.ges="f" />
                  <note xml:id="m9s1n4" dur="16" oct="5" pname="c" />
                  <note xml:id="m9s1n5" dur="8" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: C5-Eb5(V7 partial), A4-C5(V 3rd inv), F4-A4(V) — descending from climax -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="4" dots="1">
                    <note xml:id="m9s2n1" pname="c" oct="5" />
                    <note xml:id="m9s2n2" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m9s2c2" dur="4" dots="1">
                    <note xml:id="m9s2n3" pname="a" oct="4" />
                    <note xml:id="m9s2n4" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-Eb3(V7), F2-A2-C3(V triad), F2-C3(V open) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="4" dots="1">
                    <note xml:id="m9s3n1" pname="f" oct="2" />
                    <note xml:id="m9s3n2" pname="c" oct="3" />
                    <note xml:id="m9s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m9s3c2" dur="4" dots="1">
                    <note xml:id="m9s3n4" pname="f" oct="2" />
                    <note xml:id="m9s3n5" pname="a" oct="2" />
                    <note xml:id="m9s3n6" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
            </measure>

            <!-- Measure 10: 3 beats. Bb (I). Melody: Bb4(dotted-half) d5(dotted-half) -->
            <!-- Bb4(dotted-half)=3 beats, but the ABC shows B3/2 d3/2 = 1.5+1.5=3 OK -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="4" dots="1" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m10s1n2" dur="4" dots="1" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: Bb4-D5(I 3rd), rocking upward — this is the emotional peak -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10s2c1" dur="4" dots="1">
                    <note xml:id="m10s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m10s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m10s2c2" dur="4" dots="1">
                    <note xml:id="m10s2n3" pname="f" oct="4" />
                    <note xml:id="m10s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3-D4(I full 4-note), then F3-Bb3(sustain) — climax texture -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10s3c1" dur="4" dots="1">
                    <note xml:id="m10s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m10s3n2" pname="f" oct="3" />
                    <note xml:id="m10s3n3" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m10s3n4" pname="d" oct="4" />
                  </chord>
                  <chord xml:id="m10s3c2" dur="4" dots="1">
                    <note xml:id="m10s3n5" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m10s3n6" pname="d" oct="3" />
                    <note xml:id="m10s3n7" pname="f" oct="3" />
                    <note xml:id="m10s3n8" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 11: 3 beats. F→F7. Melody: Bb4(8) F4(8) D4(8) F4(dotted-qtr+16) E4(8) C4(8) -->
            <!-- B/2 F/2 D/2 F3/4 E/4 C/2 = 0.5+0.5+0.5+0.75+0.25+0.5 = 3 beats OK -->
            <!-- E4 = Eb4 (key sig) -->
            <measure n="11" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" dur="8" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m11s1n2" dur="8" oct="4" pname="f" />
                  <note xml:id="m11s1n3" dur="8" oct="4" pname="d" />
                  <note xml:id="m11s1n4" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m11s1n5" dur="16" oct="4" pname="e" accid.ges="f" />
                  <note xml:id="m11s1n6" dur="8" oct="4" pname="c" />
                </layer>
              </staff>
              <!-- RH: F4-A4(V qtr), then A4-Eb5(V7 open), F4-C5(V quarter) — moving -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m11s2c1" dur="4">
                    <note xml:id="m11s2n1" pname="f" oct="4" />
                    <note xml:id="m11s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m11s2c2" dur="4">
                    <note xml:id="m11s2n3" pname="a" oct="4" />
                    <note xml:id="m11s2n4" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m11s2c3" dur="4">
                    <note xml:id="m11s2n5" pname="f" oct="4" />
                    <note xml:id="m11s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(V), F2-C3-Eb3(V7), F2-A2-C3(V triad) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11s3c1" dur="4">
                    <note xml:id="m11s3n1" pname="f" oct="2" />
                    <note xml:id="m11s3n2" pname="c" oct="3" />
                    <note xml:id="m11s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m11s3c2" dur="4">
                    <note xml:id="m11s3n4" pname="f" oct="2" />
                    <note xml:id="m11s3n5" pname="c" oct="3" />
                    <note xml:id="m11s3n6" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m11s3c3" dur="4">
                    <note xml:id="m11s3n7" pname="f" oct="2" />
                    <note xml:id="m11s3n8" pname="a" oct="2" />
                    <note xml:id="m11s3n9" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">⑤7</harm>
            </measure>

            <!-- Measure 12: final. Bb. Melody: Bb3(dotted-half) -->
            <!-- Bb3 = Bb below middle C — in bass clef territory -->
            <measure n="12" right="final">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12s1n1" dur="2" dots="1" oct="3" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: Bb3-D4-F4 triad (I root position) — low treble, warmly resolves -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m12s2c1" dur="2" dots="1">
                    <note xml:id="m12s2n1" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m12s2n2" pname="d" oct="4" />
                    <note xml:id="m12s2n3" pname="f" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3-D4 (I full 4-note) dotted-half — complete resolution -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12s3c1" dur="2" dots="1">
                    <note xml:id="m12s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m12s3n2" pname="f" oct="3" />
                    <note xml:id="m12s3n3" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m12s3n4" pname="d" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>

<!--
VOICING PLAN:
- Phrase 1 (mm. 1-4): Sustained whole-measure harmonies in layer 2 (stems down) —
  the classic "silent night" harp texture. Dotted-half chords, no rhythmic motion.
  I uses Bb2-F3-Bb3 (open P5 frame), V7 uses F2-C3-Eb3 (open with minor 7th on top).
- Phrase 2 (mm. 5-8): IV (Eb) brings Eb2-Bb2-Eb3 (root position) — new bass depth.
  RH starts moving in half-note pairs. First rhythmic variety introduced mid-piece.
- Phrase 3 (mm. 9-12): Climax at m.10 (Bb + D rocking upward). LH expands to 4 notes
  (Bb2-F3-Bb3-D4). V7 measures 9 and 11 use Eb in RH for color. Final Bb3 low root
  creates final repose down to bass register.
- All Bb/Eb carry accid.ges="f".

VOICE LEADING HIGHLIGHTS:
- Eb-to-C linear descent in RH across mm. 9-11: Eb5→C5→Eb5→C5→A4 traces the
  arching phrase peak.
- Bass line in LH: Bb→Bb→F→Bb→Eb→Bb→Eb→Bb→F→Bb→F→Bb = root alternation
  with IV color in the middle section, exactly as in the original tonal plan.
- No parallel 5ths between RH and LH in any measure.
- m.12: final Bb3 in melody drops to bass-register resolution — peaceful, dark.

TEXTURE ARC:
- mm. 1-4: Entirely sustained (layer 2 only) — the stillness of silent night
- mm. 5-8: Half-note motion introduced in RH — gentle awakening of texture
- mm. 9-10: Peak rhythmic interest (V7 arpeggio in m.9, rocking Bb-D in m.10)
- mm. 11-12: Moving quarter notes in V7, then final sustained I — resolution
-->
