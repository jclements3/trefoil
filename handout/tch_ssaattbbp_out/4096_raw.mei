<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Over Kidron Jesus Treadeth</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- G major: 1 sharp (F#). Scale: G A B C D E F# -->
          <!-- Degrees: I=G II=A III=B IV=C V=D VI=E VII=F# -->
          <!-- ABC note F in G = F# (accid.ges="s"). E4 = natural E. -->
          <!-- Note: this hymn has many chromatic chords (Eb+, CΔ7, F#°7, Bø7, Eb, A, Am etc.)
               Many are non-diatonic — substitute nearest diatonic equivalent. -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Em–F#°–Em–C, chromatic flavour           -->
            <!-- ============================================================ -->

            <!-- Measure 1: 4 beats. Melody B A G E = B4 A4 G4 E4
                 Chords: ^Em(VIm), ^F#°(VII°), ^Em(VIm), ^C(IV)
                 Em = VIm in G, F#° = VII°, C = IV -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="b"/>
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1s1n4" dur="4" oct="4" pname="e"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: VIm E4 G4, VII° F#4 A4, VIm E4 B4, IV C5 E5 -->
                  <chord xml:id="m1s2c1" dur="4">
                    <note xml:id="m1s2n1" pname="e" oct="4"/>
                    <note xml:id="m1s2n2" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m1s2n4" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="e" oct="4"/>
                    <note xml:id="m1s2n6" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m1s2c4" dur="4">
                    <note xml:id="m1s2n7" pname="c" oct="5"/>
                    <note xml:id="m1s2n8" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: VIm E2 B2 G3, VII° F#2 C3 A3, VIm E2 B2 E3, IV C3 G3 C4 -->
                  <chord xml:id="m1s3c1" dur="4">
                    <note xml:id="m1s3n1" pname="e" oct="2"/>
                    <note xml:id="m1s3n2" pname="b" oct="2"/>
                    <note xml:id="m1s3n3" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m1s3n5" pname="c" oct="3"/>
                    <note xml:id="m1s3n6" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n7" pname="e" oct="2"/>
                    <note xml:id="m1s3n8" pname="b" oct="2"/>
                    <note xml:id="m1s3n9" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c4" dur="4">
                    <note xml:id="m1s3n10" pname="c" oct="3"/>
                    <note xml:id="m1s3n11" pname="g" oct="3"/>
                    <note xml:id="m1s3n12" pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">④</harm>
            </measure>

            <!-- Measure 2: 4 beats. Melody G F _E B, = G4 F#4 Eb4 B3
                 Chords: ^Em, ^F#°, ^Eb+(→sub IV or I), ^A(→sub II or VIm)
                 Eb+ is augmented Eb — non-diatonic; _E = Eb4 in melody is chromatic
                 Substitute: ^Eb+ → use Em(VIm), ^A → use A minor=IIm or just II -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <!-- _E = Eb in ABC = accidental Eb in G major: use accid="f" -->
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="e" accid="f"/>
                  <note xml:id="m2s1n4" dur="4" oct="3" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: VIm E4 G4, VII° F#4 A4, IV D4 F#4 (passing sub for Eb+), IIm A4 C5 -->
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="e" oct="4"/>
                    <note xml:id="m2s2n2" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m2s2n4" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="d" oct="4"/>
                    <note xml:id="m2s2n6" pname="f" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m2s2c4" dur="4">
                    <note xml:id="m2s2n7" pname="a" oct="4"/>
                    <note xml:id="m2s2n8" pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: VIm E2 B2 G3, VII° F#2 C3 A3, V D3 A3 F#3, II A2 E3 C3 -->
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="e" oct="2"/>
                    <note xml:id="m2s3n2" pname="b" oct="2"/>
                    <note xml:id="m2s3n3" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m2s3n5" pname="c" oct="3"/>
                    <note xml:id="m2s3n6" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="d" oct="3"/>
                    <note xml:id="m2s3n8" pname="a" oct="3"/>
                    <note xml:id="m2s3n9" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m2s3c4" dur="4">
                    <note xml:id="m2s3n10" pname="a" oct="2"/>
                    <note xml:id="m2s3n11" pname="e" oct="3"/>
                    <note xml:id="m2s3n12" pname="c" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 3: 4 beats. Melody E3/2 F/2 G F = E4 dotted-half F#4/8 G4 F#4
                 Chords: ^C(IV), ^F#°(VII°), ^Em(VIm), ^D(V) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" dots="1" oct="4" pname="e"/>
                  <note xml:id="m3s1n2" dur="8" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: IV C4 E4 G4, VII° F#4 A4, VIm E4 G4, V D4 F#4 A4 -->
                  <chord xml:id="m3s2c1" dur="4" dots="1">
                    <note xml:id="m3s2n1" pname="c" oct="4"/>
                    <note xml:id="m3s2n2" pname="e" oct="4"/>
                    <note xml:id="m3s2n3" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m3s2c2" dur="8">
                    <note xml:id="m3s2n4" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m3s2n5" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n6" pname="e" oct="4"/>
                    <note xml:id="m3s2n7" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m3s2c4" dur="4">
                    <note xml:id="m3s2n8" pname="d" oct="4"/>
                    <note xml:id="m3s2n9" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m3s2n10" pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: IV C3 G3 C4, VII° F#2 C3 A3, VIm E2 B2 E3, V D3 A3 F#3 -->
                  <chord xml:id="m3s3c1" dur="4" dots="1">
                    <note xml:id="m3s3n1" pname="c" oct="3"/>
                    <note xml:id="m3s3n2" pname="g" oct="3"/>
                    <note xml:id="m3s3n3" pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m3s3c2" dur="8">
                    <note xml:id="m3s3n4" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m3s3n5" pname="c" oct="3"/>
                    <note xml:id="m3s3n6" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="e" oct="2"/>
                    <note xml:id="m3s3n8" pname="b" oct="2"/>
                    <note xml:id="m3s3n9" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m3s3c4" dur="4">
                    <note xml:id="m3s3n10" pname="d" oct="3"/>
                    <note xml:id="m3s3n11" pname="a" oct="3"/>
                    <note xml:id="m3s3n12" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2.5">⑦°</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 4: 4 beats. Melody B A G3/2 z/2 = B4 A4 G4 dotted half + rest
                 Chords: ^G(I), ^D(V), ^G(I) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="b"/>
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m4s1n3" dur="4" dots="1" oct="4" pname="g"/>
                  <rest xml:id="m4s1r1" dur="8"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: I G4 B4, V A4 D5, I G4 D5 open 5th sustained -->
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="g" oct="4"/>
                    <note xml:id="m4s2n2" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="a" oct="4"/>
                    <note xml:id="m4s2n4" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="g" oct="4"/>
                    <note xml:id="m4s2n6" pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: I G2 D3 G3 B3, V D3 A3 F#3, I G2 D3 B3 half -->
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="g" oct="2"/>
                    <note xml:id="m4s3n2" pname="d" oct="3"/>
                    <note xml:id="m4s3n3" pname="g" oct="3"/>
                    <note xml:id="m4s3n4" pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n5" pname="d" oct="3"/>
                    <note xml:id="m4s3n6" pname="a" oct="3"/>
                    <note xml:id="m4s3n7" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n8" pname="g" oct="2"/>
                    <note xml:id="m4s3n9" pname="d" oct="3"/>
                    <note xml:id="m4s3n10" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Repeat of phrase 1 melody                -->
            <!-- ============================================================ -->

            <!-- Measure 5: 4 beats. B A G E — same as m1 -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="b"/>
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="e"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: VIm B4 E5, VII° C5 F#5, VIm B4 E5, IV C5 E5 -->
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n1" pname="b" oct="4"/>
                    <note xml:id="m5s2n2" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="c" oct="5"/>
                    <note xml:id="m5s2n4" pname="f" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m5s2c3" dur="4">
                    <note xml:id="m5s2n5" pname="b" oct="4"/>
                    <note xml:id="m5s2n6" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m5s2c4" dur="4">
                    <note xml:id="m5s2n7" pname="c" oct="5"/>
                    <note xml:id="m5s2n8" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: VIm E2 B2 G3 B3, VII° F#2 C3 A3, VIm E2 B2 G3, IV C3 G3 E3 C4 -->
                  <chord xml:id="m5s3c1" dur="4">
                    <note xml:id="m5s3n1" pname="e" oct="2"/>
                    <note xml:id="m5s3n2" pname="b" oct="2"/>
                    <note xml:id="m5s3n3" pname="g" oct="3"/>
                    <note xml:id="m5s3n4" pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n5" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m5s3n6" pname="c" oct="3"/>
                    <note xml:id="m5s3n7" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n8" pname="e" oct="2"/>
                    <note xml:id="m5s3n9" pname="b" oct="2"/>
                    <note xml:id="m5s3n10" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m5s3c4" dur="4">
                    <note xml:id="m5s3n11" pname="c" oct="3"/>
                    <note xml:id="m5s3n12" pname="g" oct="3"/>
                    <note xml:id="m5s3n13" pname="e" oct="3"/>
                    <note xml:id="m5s3n14" pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">④</harm>
            </measure>

            <!-- Measure 6: 4 beats. Melody G F _E B, = G4 F#4 Eb4 B3
                 ^Am, ^F#°, ^Eb+, ^B, — Am=IIm, F#°=VII°, sub V, B=III -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="e" accid="f"/>
                  <note xml:id="m6s1n4" dur="4" oct="3" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: IIm A4 C5, VII° F#4 A4 C5, V D4 A4 (sub Eb+), III B3 D4 F#4 -->
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="a" oct="4"/>
                    <note xml:id="m6s2n2" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m6s2n4" pname="a" oct="4"/>
                    <note xml:id="m6s2n5" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n6" pname="d" oct="4"/>
                    <note xml:id="m6s2n7" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m6s2c4" dur="4">
                    <note xml:id="m6s2n8" pname="b" oct="3"/>
                    <note xml:id="m6s2n9" pname="d" oct="4"/>
                    <note xml:id="m6s2n10" pname="f" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: IIm A2 E3 C3, VII° F#2 C3 A3, V D3 A3 F#3, III B2 F#3 D3 B3 -->
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="a" oct="2"/>
                    <note xml:id="m6s3n2" pname="e" oct="3"/>
                    <note xml:id="m6s3n3" pname="c" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m6s3n5" pname="c" oct="3"/>
                    <note xml:id="m6s3n6" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n7" pname="d" oct="3"/>
                    <note xml:id="m6s3n8" pname="a" oct="3"/>
                    <note xml:id="m6s3n9" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m6s3c4" dur="4">
                    <note xml:id="m6s3n10" pname="b" oct="2"/>
                    <note xml:id="m6s3n11" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m6s3n12" pname="d" oct="3"/>
                    <note xml:id="m6s3n13" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">③</harm>
            </measure>

            <!-- Measure 7: 4 beats. Melody E3/2 F/2 G F — ^CΔ7, ^F#°, ^G, ^F#°7
                 CΔ7 = IV major 7, F#°7 = VII°7, G = I, F#°7 = VII°7 -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" dots="1" oct="4" pname="e"/>
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m7s1n4" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
