<?xml version="1.0" encoding="UTF-8"?>
<!-- Author of All Life — Key of A (3 sharps: F# C# G#), 4/4
     Scale degrees in A: I=A ii=Bm iii=C#m IV=D V=E vi=F#m vii°=G#dim
     Non-diatonic substitutions:
       F# major chord → F#m(vi) [only note that differs is A vs A#/Bb]
       D major → IV (diatonic)
       C#m → iii (diatonic)
       F#m → vi (diatonic)
       E → V (diatonic)
       B major → use Bm(ii) or E(V) depending on context
     All F, C, G must carry accid.ges="s"
     Bars 1, 7, 13 begin with 2 quarter rests (z2 in ABC)
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Author of All Life</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="3s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3s"/>
              </staffDef>
              <staffGrp symbol="brace">
