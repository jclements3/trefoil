<!-- Measure 8: C(I) | D(V) | vi(Em)(8) A(8) | iii(Em)
     Melody: C5(4) A4(4) G4(8) A4(8) B4(4)
     "^C"c = C(I) q, "^D"A = D(V) q, "^Em"G/2 A/2 = Em(vi) eighth pair, "^Bm"B = B4 q
     Bm = non-diatonic in C. Substitute Em(vi) for the Bm.
     Beats: I q, V q, vi eighth+eighth, vi q
-->
<measure n="8" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m8s1n1" dur="4" oct="5" pname="c"/>
      <note xml:id="m8s1n2" dur="4" oct="4" pname="a"/>
      <note xml:id="m8s1n3" dur="8" oct="4" pname="g"/>
      <note xml:id="m8s1n4" dur="8" oct="4" pname="a"/>
      <note xml:id="m8s1n5" dur="4" oct="4" pname="b"/>
    </layer>
  </staff>
  <!-- RH: I→V→vi fast motion — climax approach -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: I — G4-C5 (I 4th) -->
      <chord xml:id="m8s2c1" dur="4">
        <note xml:id="m8s2n1" pname="g" oct="4"/>
        <note xml:id="m8s2n2" pname="c" oct="5"/>
      </chord>
      <!-- beat 2: V — G4-B4-D5 (V root 3-note) -->
      <chord xml:id="m8s2c2" dur="4">
        <note xml:id="m8s2n3" pname="g" oct="4"/>
        <note xml:id="m8s2n4" pname="b" oct="4"/>
        <note xml:id="m8s2n5" pname="d" oct="5"/>
      </chord>
      <!-- beat 3: vi eighth pair — E4-G4 (vi 3rd) -->
      <chord xml:id="m8s2c3" dur="8">
        <note xml:id="m8s2n6" pname="e" oct="4"/>
        <note xml:id="m8s2n7" pname="g" oct="4"/>
      </chord>
      <!-- beat 3.5: vi — G4-B4 (vi upper 3rd) -->
      <chord xml:id="m8s2c4" dur="8">
        <note xml:id="m8s2n8" pname="g" oct="4"/>
        <note xml:id="m8s2n9" pname="b" oct="4"/>
      </chord>
      <!-- beat 4: vi — E4-G4-B4 (vi full 3-note) -->
      <chord xml:id="m8s2c5" dur="4">
        <note xml:id="m8s2n10" pname="e" oct="4"/>
        <note xml:id="m8s2n11" pname="g" oct="4"/>
        <note xml:id="m8s2n12" pname="b" oct="4"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: I→V→vi full progression with growing intensity -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: I — C3-G3-C4-E4 -->
      <chord xml:id="m8s3c1" dur="4">
        <note xml:id="m8s3n1" pname="c" oct="3"/>
        <note xml:id="m8s3n2" pname="g" oct="3"/>
        <note xml:id="m8s3n3" pname="c" oct="4"/>
        <note xml:id="m8s3n4" pname="e" oct="4"/>
      </chord>
      <!-- beat 2: V — G2-D3-G3-B3 -->
      <chord xml:id="m8s3c2" dur="4">
        <note xml:id="m8s3n5" pname="g" oct="2"/>
        <note xml:id="m8s3n6" pname="d" oct="3"/>
        <note xml:id="m8s3n7" pname="g" oct="3"/>
        <note xml:id="m8s3n8" pname="b" oct="3"/>
      </chord>
      <!-- beats 3-4: vi — E3-B3-E4-G4 (vi root open P5+P4+m3) half -->
      <chord xml:id="m8s3c3" dur="2">
        <note xml:id="m8s3n9" pname="e" oct="3"/>
        <note xml:id="m8s3n10" pname="b" oct="3"/>
        <note xml:id="m8s3n11" pname="e" oct="4"/>
        <note xml:id="m8s3n12" pname="g" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">①</harm>
  <harm staff="1" tstamp="2">⑤</harm>
  <harm staff="1" tstamp="3">⑥m</harm>
</measure>

<!-- Measure 9 (near-final): D(V) | vi(Em) | G(V) | C(I).
     Melody: A4(4) G4(4) G4(4) G4(4)
     "^D"A = V q, "^Em"G = vi q, "^G"G = V(G) q, "^C"G = I q -->
<measure n="9" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m9s1n1" dur="4" oct="4" pname="a"/>
      <note xml:id="m9s1n2" dur="4" oct="4" pname="g"/>
      <note xml:id="m9s1n3" dur="4" oct="4" pname="g"/>
      <note xml:id="m9s1n4" dur="4" oct="4" pname="g"/>
    </layer>
  </staff>
  <!-- RH: descent from climax — 3-note chords, then 2-note, converging -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: V — F4-A4-D5 (V root 3-note, peak) -->
      <chord xml:id="m9s2c1" dur="4">
        <!-- no F# in C major — wait, V in C major is G B D, not D F# A. D chord non-diatonic. -->
        <!-- "^D"A = D chord (non-diatonic major). Substitute G(V) instead. -->
        <note xml:id="m9s2n1" pname="g" oct="4"/>
        <note xml:id="m9s2n2" pname="b" oct="4"/>
        <note xml:id="m9s2n3" pname="d" oct="5"/>
      </chord>
      <!-- beat 2: vi — E4-G4 (vi 3rd, stepping down) -->
      <chord xml:id="m9s2c2" dur="4">
        <note xml:id="m9s2n4" pname="e" oct="4"/>
        <note xml:id="m9s2n5" pname="g" oct="4"/>
      </chord>
      <!-- beat 3: V — G4-B4 (V 3rd) -->
      <chord xml:id="m9s2c3" dur="4">
        <note xml:id="m9s2n6" pname="g" oct="4"/>
        <note xml:id="m9s2n7" pname="b" oct="4"/>
      </chord>
      <!-- beat 4: I — E4-G4-C5 (I root 3-note arrival) -->
      <chord xml:id="m9s2c4" dur="4">
        <note xml:id="m9s2n8" pname="e" oct="4"/>
        <note xml:id="m9s2n9" pname="g" oct="4"/>
        <note xml:id="m9s2n10" pname="c" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: V→vi→V→I bass descent G→E→G→C -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: V — G2-D3-G3-B3 -->
      <chord xml:id="m9s3c1" dur="4">
        <note xml:id="m9s3n1" pname="g" oct="2"/>
        <note xml:id="m9s3n2" pname="d" oct="3"/>
        <note xml:id="m9s3n3" pname="g" oct="3"/>
        <note xml:id="m9s3n4" pname="b" oct="3"/>
      </chord>
      <!-- beat 2: vi — E3-B3-E4 -->
      <chord xml:id="m9s3c2" dur="4">
        <note xml:id="m9s3n5" pname="e" oct="3"/>
        <note xml:id="m9s3n6" pname="b" oct="3"/>
        <note xml:id="m9s3n7" pname="e" oct="4"/>
      </chord>
      <!-- beat 3: V — G2-D3-G3 -->
      <chord xml:id="m9s3c3" dur="4">
        <note xml:id="m9s3n8" pname="g" oct="2"/>
        <note xml:id="m9s3n9" pname="d" oct="3"/>
        <note xml:id="m9s3n10" pname="g" oct="3"/>
      </chord>
      <!-- beat 4: I — C3-G3-C4-E4 -->
      <chord xml:id="m9s3c4" dur="4">
        <note xml:id="m9s3n11" pname="c" oct="3"/>
        <note xml:id="m9s3n12" pname="g" oct="3"/>
        <note xml:id="m9s3n13" pname="c" oct="4"/>
        <note xml:id="m9s3n14" pname="e" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑤</harm>
  <harm staff="1" tstamp="2">⑥m</harm>
  <harm staff="1" tstamp="3">⑤</harm>
  <harm staff="1" tstamp="4">①</harm>
</measure>

<!-- Measure 10 (final): 3 beats (balances 1-beat pickup). Em(vi) q then rest.
     ABC: "^Em"G z2 — G4(4) then z2 (half rest)
     Final vi (Em) chord — this piece ends on vi, giving an open, questioning quality.
     3 beats total in last measure.
-->
<measure n="10" right="end">
  <staff n="1">
    <layer n="1">
      <note xml:id="m10s1n1" dur="4" oct="4" pname="g"/>
      <rest xml:id="m10s1r1" dur="2"/>
    </layer>
  </staff>
  <!-- RH: final vi — E4-G4-B4 (vi root 3-note) then rest -->
  <staff n="2">
    <layer n="1">
      <chord xml:id="m10s2c1" dur="4">
        <note xml:id="m10s2n1" pname="e" oct="4"/>
        <note xml:id="m10s2n2" pname="g" oct="4"/>
        <note xml:id="m10s2n3" pname="b" oct="4"/>
      </chord>
      <rest xml:id="m10s2r1" dur="2"/>
    </layer>
  </staff>
  <!-- LH: vi spread final — E3-B3-E4-G4 -->
  <staff n="3">
    <layer n="1">
      <chord xml:id="m10s3c1" dur="4">
        <note xml:id="m10s3n1" pname="e" oct="3"/>
        <note xml:id="m10s3n2" pname="b" oct="3"/>
        <note xml:id="m10s3n3" pname="e" oct="4"/>
        <note xml:id="m10s3n4" pname="g" oct="4"/>
      </chord>
      <rest xml:id="m10s3r1" dur="2"/>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑥m</harm>
</measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>

<!--
VOICING PLAN:
- Pickup + M1: Bright C-major hymn opens with V pickup anticipating I. M1 has vi-I-IV-vi
  pattern — the descending-thirds bass (E→C→F→E) is characteristic of this genre.
  All 2-note RH (3rds) and 3-note LH (P5+P4) — light and transparent at opening.
- M2-M3: ii→V→I cadential formula over two measures. M3 has V half-note sustained then
  3-note I and V chords. First 3-note RH appearance at M3 beat 3 adds texture.
- M4: V dotted half suspension → I — the long V creates anticipation. RH quartal V (G4-D5)
  gives open, spacious quality.
- M5: Eighth-note arpeggio in RH beats 2-3 (G4-B4-B4-D5) — first fast movement.
  IV on beat 1 (F full chord) then V sustained — textural contrast within the measure.
- M6: Descending sequence vi→vi(Am)→V→ii with 3-note RH from beat 3. Bass descends
  E3→A2→G2→D3 — elegant linear motion.
- M7: Am(vi) sustained half note — most peaceful moment. Then V dominant build at beat 4.
- M8: Rapid I→V→vi-eighth-pair→vi motion — fastest harmonic rhythm of piece. RH has
  5 chords in one measure. LH simplifies to 3 long chords for contrast.
- M9: Gradual convergence — G(V)→vi→G(V)→I(C) with smooth voice leading.
  RH descends from 3-note at beat 1 to 2-note at beat 3, then back to 3-note arrival.
- M10 (final): vi cadence — unexpected vi ending (not I) gives the "hallelujah" text
  its slightly unresolved, devotional quality. Deliberate score choice: "Hallowed Name"
  ends on the submediant — deferring final resolution to the listener's heart.

VOICE LEADING HIGHLIGHTS:
- M1 RH inner voice C5: appears on beats 2 and 3, held as common tone between I and IV.
- M3 bass: G2-G2-C3-G2 — LH root stays on G across beats 1-4 via different chords
  (V-V-I-V). The G pedal point ties V and I together in that measure.
- M6 bass descent: E3→A2→G2→D3 chromatic-like stepwise motion with one skip.
- M7 RH C5-E5 (half) above A4-A4-A4 melody — soprano pedal C5 creates a 7th clash
  then resolves to B4-D5 at beat 4 — elegant suspension.
- M8 RH eighth pairs: G4-B4 → (hold B4) → B4-D5 creates a stepwise inner-voice rise
  C→D→E→G within the two eighth-note pairs.
- M9: Bass line G2→E3→G2→C3 mirrors the melody's G-G-G-G — parallel outer voices.

TEXTURE ARC:
- Pickup-M2: Light — 2-note RH, 3-note LH, quarter/half note rhythm.
- M3-M4: Medium — first 3-note RH appears, V suspension (dotted half), growing openness.
- M5: Movement — eighth-note arpeggio in RH for the first time.
- M6-M7: Color — secondary chords (vi, Am), 3-note RH, Am sustained.
- M8 (climax): Dense — 5 chord changes in RH, fast eighth-note motion, I-V-vi all full.
- M9: Convergence — stepwise return through G-Em-G-I.
- M10: Open close on vi — quiet, resonant, devotional.
-->
