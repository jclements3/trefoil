<?xml version='1.0' encoding='utf-8'?>
<!-- Hymn 4048: All Praise to Jesus' Hallowed Name  Key: C  Meter: 4/4
     C major diatonic: C D E F G A B
     Scale degrees: I=C II=Dm III=Em IV=F V=G VI=Am VII°=B°

     ABC (L:1/4, K:C, pickup 1 beat):
     Pickup: "^G"G — G4(1 beat) under G(V) chord
     M1:  "^Em"G "^C"G "^F"A "^Em"G  — Em(vi) C(I) F(IV) Em(vi)
     M2:  "^Am"c "^G"d "^C"c2        — Am(ii) G(V) C(I) half
     M3:  "^G"B d "^C"e "^D"d        — G(V) pass B V pass d C(I) D(→V)pass
          Actually: "^G"B = G chord, B4 melody; d = D5 pass; "^C"e = C chord, E5; "^D"d = D pass, D5
          Beats: G(V) q, pass q, C(I) q, D-maj→V pass q
          Simplify: V beats 1-2, I beat 3, V beat 4
     M4:  "^G"B "^D"A "^G"G "^C"G   — G(V) D(V) G(V) C(I) all quarter
          Wait: "^G"B = G chord Bq, "^D"A = D chord Aq, "^G"G = G chord Gq, "^C"G = C chord Gq
          V q, V q, V q, I q
     M5:  c "^G"B d "^D"A            — pass C5, G(V) B4, pass D5, D(V) A4
          So beats 1=IV/pass, 2=V(G), 3=V(D), 4=V(D) all quarter
          Simplify: IV beat1, V beats 2-4
     M6:  "^Em"G "^A"E "^D"D "^Dm"D — Em(vi) q, A(→→vi pass, use Am) q, D(V) q, Dm(→ii) q
          A major chord — non-diatonic. Substitute Am(vi). D major — use as V. Dm = ii.
     M7:  "^A"A A "^D"A "^G"d        — A(pass→Am vi) q A4, A(vi) q A4, D(V) q A4, G(V) q D5
          Beats 1-3=vi(Am), beat 4=I(G→V)
     M8:  "^C"c "^D"A "^Em"G/2 A/2 "^Bm"B — C(I) q, D(V) q, Em(vi) 8 A(8), Bm(iii) q
          Bm = iii (B-D-F#, non-diatonic in C: use iii=Em or substitute with V)
          Actually Bm in C major is non-diatonic. Substitute Em(vi).
     M9:  "^D"A "^Em"G "^G"G "^C"G   — D(V) q, Em(vi) q, G(V) q, C(I) q
     M10: "^Em"G z2                   — Em(vi) q, rest half (piece ends)

     Pickup has 1 beat: piece is 10 measures.
     Duration in M10: G(4) z(half) = 3 beats. Balances 1-beat pickup.
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>All Praise to Jesus' Hallowed Name</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

<!-- Pickup: 1 beat. G(V) chord. Melody: G4(4) — open 5th on V -->
<measure n="0" type="pickup" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m0s1n1" dur="4" oct="4" pname="g"/>
    </layer>
  </staff>
  <!-- RH: G4-C5 (V 4th, anticipating I) -->
  <staff n="2">
    <layer n="1">
      <chord xml:id="m0s2c1" dur="4">
        <note xml:id="m0s2n1" pname="g" oct="4"/>
        <note xml:id="m0s2n2" pname="c" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: G3-D4 (V open 5th) -->
  <staff n="3">
    <layer n="1">
      <chord xml:id="m0s3c1" dur="4">
        <note xml:id="m0s3n1" pname="g" oct="3"/>
        <note xml:id="m0s3n2" pname="d" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑤</harm>
</measure>

<!-- ============================================================ -->
<!-- PHRASE 1 (mm. 1-5): Introduction — light texture, build     -->
<!-- ============================================================ -->

<!-- Measure 1: Em(vi) | C(I) | F(IV) | Em(vi). All quarter notes.
     Melody: G4(4) G4(4) A4(4) G4(4) -->
<measure n="1" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m1s1n1" dur="4" oct="4" pname="g"/>
      <note xml:id="m1s1n2" dur="4" oct="4" pname="g"/>
      <note xml:id="m1s1n3" dur="4" oct="4" pname="a"/>
      <note xml:id="m1s1n4" dur="4" oct="4" pname="g"/>
    </layer>
  </staff>
  <!-- RH: 2-note voicings, smooth stepwise motion -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: vi — E4-G4 (vi 3rd) -->
      <chord xml:id="m1s2c1" dur="4">
        <note xml:id="m1s2n1" pname="e" oct="4"/>
        <note xml:id="m1s2n2" pname="g" oct="4"/>
      </chord>
      <!-- beat 2: I — G4-C5 (I 4th) -->
      <chord xml:id="m1s2c2" dur="4">
        <note xml:id="m1s2n3" pname="g" oct="4"/>
        <note xml:id="m1s2n4" pname="c" oct="5"/>
      </chord>
      <!-- beat 3: IV — A4-C5 (IV 3rd top) -->
      <chord xml:id="m1s2c3" dur="4">
        <note xml:id="m1s2n5" pname="a" oct="4"/>
        <note xml:id="m1s2n6" pname="c" oct="5"/>
      </chord>
      <!-- beat 4: vi — E4-G4 (vi 3rd returning) -->
      <chord xml:id="m1s2c4" dur="4">
        <note xml:id="m1s2n7" pname="e" oct="4"/>
        <note xml:id="m1s2n8" pname="g" oct="4"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: open 5ths, solid foundation -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: vi — E3-B3-E4 (vi root P5+P4) -->
      <chord xml:id="m1s3c1" dur="4">
        <note xml:id="m1s3n1" pname="e" oct="3"/>
        <note xml:id="m1s3n2" pname="b" oct="3"/>
        <note xml:id="m1s3n3" pname="e" oct="4"/>
      </chord>
      <!-- beat 2: I — C3-G3-C4 (I root P5+P4) -->
      <chord xml:id="m1s3c2" dur="4">
        <note xml:id="m1s3n4" pname="c" oct="3"/>
        <note xml:id="m1s3n5" pname="g" oct="3"/>
        <note xml:id="m1s3n6" pname="c" oct="4"/>
      </chord>
      <!-- beat 3: IV — F3-C4-F4 (IV root P5+P4) -->
      <chord xml:id="m1s3c3" dur="4">
        <note xml:id="m1s3n7" pname="f" oct="3"/>
        <note xml:id="m1s3n8" pname="c" oct="4"/>
        <note xml:id="m1s3n9" pname="f" oct="4"/>
      </chord>
      <!-- beat 4: vi — E3-B3-E4 (vi returning) -->
      <chord xml:id="m1s3c4" dur="4">
        <note xml:id="m1s3n10" pname="e" oct="3"/>
        <note xml:id="m1s3n11" pname="b" oct="3"/>
        <note xml:id="m1s3n12" pname="e" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑥m</harm>
  <harm staff="1" tstamp="2">①</harm>
  <harm staff="1" tstamp="3">④</harm>
  <harm staff="1" tstamp="4">⑥m</harm>
</measure>

<!-- Measure 2: Am(ii) | G(V) | C(I) half. Melody: C5(4) D5(4) C5(half) -->
<measure n="2" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m2s1n1" dur="4" oct="5" pname="c"/>
      <note xml:id="m2s1n2" dur="4" oct="5" pname="d"/>
      <note xml:id="m2s1n3" dur="2" oct="5" pname="c"/>
    </layer>
  </staff>
  <!-- RH: ii→V→I progression with step motion -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: ii — A4-C5 (ii 3rd) -->
      <chord xml:id="m2s2c1" dur="4">
        <note xml:id="m2s2n1" pname="a" oct="4"/>
        <note xml:id="m2s2n2" pname="c" oct="5"/>
      </chord>
      <!-- beat 2: V — B4-D5 (V 3rd top = passing) -->
      <chord xml:id="m2s2c2" dur="4">
        <note xml:id="m2s2n3" pname="b" oct="4"/>
        <note xml:id="m2s2n4" pname="d" oct="5"/>
      </chord>
      <!-- beats 3-4: I — C5-E5 (I 3rd high) half -->
      <chord xml:id="m2s2c3" dur="2">
        <note xml:id="m2s2n5" pname="c" oct="5"/>
        <note xml:id="m2s2n6" pname="e" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: ii→V→I bass line A→G→C -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: ii — A2-E3-A3-C4 (ii open P5+P4+m3) -->
      <chord xml:id="m2s3c1" dur="4">
        <note xml:id="m2s3n1" pname="a" oct="2"/>
        <note xml:id="m2s3n2" pname="e" oct="3"/>
        <note xml:id="m2s3n3" pname="a" oct="3"/>
        <note xml:id="m2s3n4" pname="c" oct="4"/>
      </chord>
      <!-- beat 2: V — G2-D3-G3-B3 (V root P5+P4+m3) -->
      <chord xml:id="m2s3c2" dur="4">
        <note xml:id="m2s3n5" pname="g" oct="2"/>
        <note xml:id="m2s3n6" pname="d" oct="3"/>
        <note xml:id="m2s3n7" pname="g" oct="3"/>
        <note xml:id="m2s3n8" pname="b" oct="3"/>
      </chord>
      <!-- beats 3-4: I — C3-G3-C4-E4 (I open P5+P4+M3) half -->
      <chord xml:id="m2s3c3" dur="2">
        <note xml:id="m2s3n9" pname="c" oct="3"/>
        <note xml:id="m2s3n10" pname="g" oct="3"/>
        <note xml:id="m2s3n11" pname="c" oct="4"/>
        <note xml:id="m2s3n12" pname="e" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">②m</harm>
  <harm staff="1" tstamp="2">⑤</harm>
  <harm staff="1" tstamp="3">①</harm>
</measure>

<!-- Measure 3: G(V) beats 1-2 | C(I) beat 3 | V beat 4.
     Melody: B4(4) D5(4) E5(4) D5(4) -->
<measure n="3" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m3s1n1" dur="4" oct="4" pname="b"/>
      <note xml:id="m3s1n2" dur="4" oct="5" pname="d"/>
      <note xml:id="m3s1n3" dur="4" oct="5" pname="e"/>
      <note xml:id="m3s1n4" dur="4" oct="5" pname="d"/>
    </layer>
  </staff>
  <!-- RH: V sustained then I then V — contrary motion begins -->
  <staff n="2">
    <layer n="1">
      <!-- beats 1-2: V — G4-B4 half -->
      <chord xml:id="m3s2c1" dur="2">
        <note xml:id="m3s2n1" pname="g" oct="4"/>
        <note xml:id="m3s2n2" pname="b" oct="4"/>
      </chord>
      <!-- beat 3: I — E4-G4-C5 (I root 3-note) -->
      <chord xml:id="m3s2c2" dur="4">
        <note xml:id="m3s2n3" pname="e" oct="4"/>
        <note xml:id="m3s2n4" pname="g" oct="4"/>
        <note xml:id="m3s2n5" pname="c" oct="5"/>
      </chord>
      <!-- beat 4: V — G4-B4-D5 (V root 3-note) -->
      <chord xml:id="m3s2c3" dur="4">
        <note xml:id="m3s2n6" pname="g" oct="4"/>
        <note xml:id="m3s2n7" pname="b" oct="4"/>
        <note xml:id="m3s2n8" pname="d" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: V half → I quarter → V quarter -->
  <staff n="3">
    <layer n="1">
      <!-- beats 1-2: V — G2-D3-G3-B3 half -->
      <chord xml:id="m3s3c1" dur="2">
        <note xml:id="m3s3n1" pname="g" oct="2"/>
        <note xml:id="m3s3n2" pname="d" oct="3"/>
        <note xml:id="m3s3n3" pname="g" oct="3"/>
        <note xml:id="m3s3n4" pname="b" oct="3"/>
      </chord>
      <!-- beat 3: I — C3-G3-C4-E4 -->
      <chord xml:id="m3s3c2" dur="4">
        <note xml:id="m3s3n5" pname="c" oct="3"/>
        <note xml:id="m3s3n6" pname="g" oct="3"/>
        <note xml:id="m3s3n7" pname="c" oct="4"/>
        <note xml:id="m3s3n8" pname="e" oct="4"/>
      </chord>
      <!-- beat 4: V — G2-D3-G3 -->
      <chord xml:id="m3s3c3" dur="4">
        <note xml:id="m3s3n9" pname="g" oct="2"/>
        <note xml:id="m3s3n10" pname="d" oct="3"/>
        <note xml:id="m3s3n11" pname="g" oct="3"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑤</harm>
  <harm staff="1" tstamp="3">①</harm>
  <harm staff="1" tstamp="4">⑤</harm>
</measure>

<!-- Measure 4: G(V) | V | V | C(I) all quarter.
     Melody: B4(4) A4(4) G4(4) G4(4) — descending line under V-I -->
<measure n="4" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m4s1n1" dur="4" oct="4" pname="b"/>
      <note xml:id="m4s1n2" dur="4" oct="4" pname="a"/>
      <note xml:id="m4s1n3" dur="4" oct="4" pname="g"/>
      <note xml:id="m4s1n4" dur="4" oct="4" pname="g"/>
    </layer>
  </staff>
  <!-- RH: V sustained 3 beats then I — anticipation of resolution -->
  <staff n="2">
    <layer n="1">
      <!-- beats 1-3: V — G4-D5 (V quartal 4th+4th) dotted half -->
      <chord xml:id="m4s2c1" dur="4" dots="2">
        <note xml:id="m4s2n1" pname="g" oct="4"/>
        <note xml:id="m4s2n2" pname="d" oct="5"/>
      </chord>
      <!-- beat 4: I — E4-G4-C5 (I root pos 3-note) -->
      <chord xml:id="m4s2c2" dur="4">
        <note xml:id="m4s2n3" pname="e" oct="4"/>
        <note xml:id="m4s2n4" pname="g" oct="4"/>
        <note xml:id="m4s2n5" pname="c" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: V dotted half → I quarter -->
  <staff n="3">
    <layer n="1">
      <!-- beats 1-3: V — G2-D3-G3-B3 dotted half -->
      <chord xml:id="m4s3c1" dur="4" dots="2">
        <note xml:id="m4s3n1" pname="g" oct="2"/>
        <note xml:id="m4s3n2" pname="d" oct="3"/>
        <note xml:id="m4s3n3" pname="g" oct="3"/>
        <note xml:id="m4s3n4" pname="b" oct="3"/>
      </chord>
      <!-- beat 4: I — C3-G3-C4-E4 -->
      <chord xml:id="m4s3c2" dur="4">
        <note xml:id="m4s3n5" pname="c" oct="3"/>
        <note xml:id="m4s3n6" pname="g" oct="3"/>
        <note xml:id="m4s3n7" pname="c" oct="4"/>
        <note xml:id="m4s3n8" pname="e" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑤</harm>
  <harm staff="1" tstamp="4">①</harm>
</measure>

<!-- Measure 5: IV(F) q | G(V) q | V(D) q | V q.
     "^C"c "^G"B d "^D"A — wait, ABC "^C" = C chord, note c = C5.
     Melody: C5(4) B4(4) D5(4) A4(4)
     Chords: IV beat1, V beats 2-4
-->
<measure n="5" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m5s1n1" dur="4" oct="5" pname="c"/>
      <note xml:id="m5s1n2" dur="4" oct="4" pname="b"/>
      <note xml:id="m5s1n3" dur="4" oct="5" pname="d"/>
      <note xml:id="m5s1n4" dur="4" oct="4" pname="a"/>
    </layer>
  </staff>
  <!-- RH: IV then V arpeggio pattern — eighth-note interest -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: IV — F4-A4-C5 (IV root 3-note) -->
      <chord xml:id="m5s2c1" dur="4">
        <note xml:id="m5s2n1" pname="f" oct="4"/>
        <note xml:id="m5s2n2" pname="a" oct="4"/>
        <note xml:id="m5s2n3" pname="c" oct="5"/>
      </chord>
      <!-- beat 2: V eighth arpeg — G4(8) B4(8) -->
      <note xml:id="m5s2n4" dur="8" pname="g" oct="4"/>
      <note xml:id="m5s2n5" dur="8" pname="b" oct="4"/>
      <!-- beat 3: V — B4-D5 eighth pair up -->
      <note xml:id="m5s2n6" dur="8" pname="b" oct="4"/>
      <note xml:id="m5s2n7" dur="8" pname="d" oct="5"/>
      <!-- beat 4: V — G4-D5 (quartal, settle) -->
      <chord xml:id="m5s2c2" dur="4">
        <note xml:id="m5s2n8" pname="g" oct="4"/>
        <note xml:id="m5s2n9" pname="d" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: IV full → V full 3 beats -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: IV — F3-C4-F4-A4 (IV root P5+P4+M3) -->
      <chord xml:id="m5s3c1" dur="4">
        <note xml:id="m5s3n1" pname="f" oct="3"/>
        <note xml:id="m5s3n2" pname="c" oct="4"/>
        <note xml:id="m5s3n3" pname="f" oct="4"/>
        <note xml:id="m5s3n4" pname="a" oct="4"/>
      </chord>
      <!-- beats 2-4: V — G2-D3-G3-B3 dotted half -->
      <chord xml:id="m5s3c2" dur="4" dots="2">
        <note xml:id="m5s3n5" pname="g" oct="2"/>
        <note xml:id="m5s3n6" pname="d" oct="3"/>
        <note xml:id="m5s3n7" pname="g" oct="3"/>
        <note xml:id="m5s3n8" pname="b" oct="3"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">④</harm>
  <harm staff="1" tstamp="2">⑤</harm>
</measure>

<!-- ============================================================ -->
<!-- PHRASE 2 (mm. 6-10): Build to climax, final cadence         -->
<!-- ============================================================ -->

<!-- Measure 6: vi(Em) | vi(Am) | V(D) | ii(Dm).
     Melody: G4(4) E4(4) D4(4) D4(4)
     "^Em"G = Em/G4, "^A"E=Am→vi/E4, "^D"D=V/D4, "^Dm"D=Dm→ii/D4
     A major chord → use Am(vi). Dm(ii) is diatonic in C (D F A).
-->
<measure n="6" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m6s1n1" dur="4" oct="4" pname="g"/>
      <note xml:id="m6s1n2" dur="4" oct="4" pname="e"/>
      <note xml:id="m6s1n3" dur="4" oct="4" pname="d"/>
      <note xml:id="m6s1n4" dur="4" oct="4" pname="d"/>
    </layer>
  </staff>
  <!-- RH: descending line vi→ii with harmonic color -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: vi — E4-G4 (vi 3rd) -->
      <chord xml:id="m6s2c1" dur="4">
        <note xml:id="m6s2n1" pname="e" oct="4"/>
        <note xml:id="m6s2n2" pname="g" oct="4"/>
      </chord>
      <!-- beat 2: vi(Am) — A4-C5 (vi 3rd higher) -->
      <chord xml:id="m6s2c2" dur="4">
        <note xml:id="m6s2n3" pname="a" oct="4"/>
        <note xml:id="m6s2n4" pname="c" oct="5"/>
      </chord>
      <!-- beat 3: V — G4-B4-D5 (V root 3-note) -->
      <chord xml:id="m6s2c3" dur="4">
        <note xml:id="m6s2n5" pname="g" oct="4"/>
        <note xml:id="m6s2n6" pname="b" oct="4"/>
        <note xml:id="m6s2n7" pname="d" oct="5"/>
      </chord>
      <!-- beat 4: ii — D4-F4-A4 (ii root 3-note) -->
      <chord xml:id="m6s2c4" dur="4">
        <note xml:id="m6s2n8" pname="d" oct="4"/>
        <note xml:id="m6s2n9" pname="f" oct="4"/>
        <note xml:id="m6s2n10" pname="a" oct="4"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: vi→vi→V→ii descending bass E→A→G→D -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: vi(Em) — E3-B3-E4 (vi open P5+P4) -->
      <chord xml:id="m6s3c1" dur="4">
