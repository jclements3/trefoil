    </layer>
  </staff>
  <harm staff="1" tstamp="1">⑥m</harm>
  <harm staff="1" tstamp="2">②m</harm>
  <harm staff="1" tstamp="3">⑤</harm>
  <harm staff="1" tstamp="4">②m</harm>
</measure>

<!-- Measure 7: Am(vi) beats 1-3 | G(V)/I pass beat 4.
     Melody: A4(4) A4(4) A4(4) D5(4)
     "^A"A A "^D"A "^G"d — Am beats 1-2, V beat 3, V pass d beat 4
-->
<measure n="7" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m7s1n1" dur="4" oct="4" pname="a"/>
      <note xml:id="m7s1n2" dur="4" oct="4" pname="a"/>
      <note xml:id="m7s1n3" dur="4" oct="4" pname="a"/>
      <note xml:id="m7s1n4" dur="4" oct="5" pname="d"/>
    </layer>
  </staff>
  <!-- RH: Am sustained three beats → V rising approach to climax -->
  <staff n="2">
    <layer n="1">
      <!-- beats 1-2: Am — C5-E5 (ii 3rd top, above A4 melody) half -->
      <chord xml:id="m7s2c1" dur="2">
        <note xml:id="m7s2n1" pname="c" oct="5"/>
        <note xml:id="m7s2n2" pname="e" oct="5"/>
      </chord>
      <!-- beat 3: Am → V — A4-C5 (ii 3rd, held) -->
      <chord xml:id="m7s2c2" dur="4">
        <note xml:id="m7s2n3" pname="a" oct="4"/>
        <note xml:id="m7s2n4" pname="c" oct="5"/>
      </chord>
      <!-- beat 4: V — B4-D5 (V 3rd, ascending to melody D5) -->
      <chord xml:id="m7s2c3" dur="4">
        <note xml:id="m7s2n5" pname="b" oct="4"/>
        <note xml:id="m7s2n6" pname="d" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: Am sustained half then V approach -->
  <staff n="3">
    <layer n="1">
      <!-- beats 1-2: Am — A2-E3-A3-C4 half -->
      <chord xml:id="m7s3c1" dur="2">
        <note xml:id="m7s3n1" pname="a" oct="2"/>
        <note xml:id="m7s3n2" pname="e" oct="3"/>
        <note xml:id="m7s3n3" pname="a" oct="3"/>
        <note xml:id="m7s3n4" pname="c" oct="4"/>
      </chord>
      <!-- beat 3: V — G3-D4 (V open 5th) -->
      <chord xml:id="m7s3c2" dur="4">
        <note xml:id="m7s3n5" pname="g" oct="3"/>
        <note xml:id="m7s3n6" pname="d" oct="4"/>
      </chord>
