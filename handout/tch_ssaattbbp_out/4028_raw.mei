<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>In Peace and Joy I Now Depart</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!-- Bar 1: Dm: D2 A A (half+qtr+qtr). Dm tonic opening. -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m1n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m1n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: D minor color, light texture opening -->
                  <chord xml:id="m1r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m1r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Dm: D2 A2 D3 F3 — open 4th/5th voicing -->
                  <chord xml:id="m1l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m1l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
            </measure>

            <!-- Bar 2: Em(G) G(d) C(c) E(B) — G d c B = 4 qtrs.
                 Chords: Em, G, C, E (sub E->Am as diatonic) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m2n2" pname="d" oct="5" dur="4"/>
                  <note xml:id="m2n3" pname="c" oct="5" dur="4"/>
                  <note xml:id="m2n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Stepwise descending figure: B4 A4 G4 G4 -->
                  <note xml:id="m2r1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m2r2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m2r3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m2r4" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Em: E2 B2 E3 G3 -->
                  <chord xml:id="m2l1" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <!-- C: C2 G2 C3 E3 -->
                  <chord xml:id="m2l2" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 3: Am: A2 c2 = half+half -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m3n2" pname="c" oct="5" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Suspension figure: hold C5 then E5 -->
                  <chord xml:id="m3r1" dur="2">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m3r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am: A2 E3 A3 C4 - fuller, building -->
                  <chord xml:id="m3l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m3l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Bar 4: F(A) C(c) B°(B/2 A/2) E(B) = 1+1+1+1 beats
                 B° is diatonic vii° in C. E (non-diatonic A major) -> sub Am -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m4n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m4n3" pname="b" oct="4" dur="8"/>
                  <note xml:id="m4n4" pname="a" oct="4" dur="8"/>
                  <note xml:id="m4n5" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- F->C passing: C5 E5 D5 D5 -->
                  <note xml:id="m4r1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m4r2" pname="e" oct="5" dur="4"/>
                  <note xml:id="m4r3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m4r4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- F: F2 C3 F3 A3 -->
                  <chord xml:id="m4l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <!-- Am: A2 E3 A3 C4 (sub for E major) -->
                  <chord xml:id="m4l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 5: Am(A) z/2 A/2 c3/2 B/2 = 1+0.5+0.5+1.5+0.5 = 4 beats -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="a" oct="4" dur="4"/>
                  <rest dur="8"/>
                  <note xml:id="m5n2" pname="a" oct="4" dur="8"/>
                  <note xml:id="m5n3" pname="c" oct="5" dur="4" dots="1"/>
                  <note xml:id="m5n4" pname="b" oct="4" dur="8"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Broken chord figure: E4 up to A4 C5 -->
                  <note xml:id="m5r1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m5r2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m5r3" pname="c" oct="5" dur="2"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am sustained: A2 E3 A3 C4 -->
                  <chord xml:id="m5l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m5l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Bar 6: C(c) F(A/2) G(G) Dm(F/2) A(E) = 1+0.5+1+0.5+1 = 4 beats -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m6n2" pname="a" oct="4" dur="8"/>
                  <note xml:id="m6n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m6n4" pname="f" oct="4" dur="8"/>
                  <note xml:id="m6n5" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Contrary motion ascending: G4 A4 B4 C5 -->
                  <note xml:id="m6r1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m6r2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m6r3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m6r4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C: C2 G2 C3 E3 -->
                  <chord xml:id="m6l1" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- Dm: D2 A2 D3 F3 -->
                  <chord xml:id="m6l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Bar 7: D(D2) Dm(A3/2) Em(G/2) = 2+1.5+0.5 = 4 beats -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m7n2" pname="a" oct="4" dur="4" dots="1"/>
                  <note xml:id="m7n3" pname="g" oct="4" dur="8"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Light: F4 A4, then E4 G4 -->
                  <chord xml:id="m7r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m7r2" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Dm: D2 A2 D3 F3 -->
                  <chord xml:id="m7l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <!-- Em: E2 B2 E3 G3 -->
                  <chord xml:id="m7l2" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Bar 8: Dm(F) G(D) C(C2) = 1+1+2 = 4 beats -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m8n2" pname="d" oct="4" dur="4"/>
                  <note xml:id="m8n3" pname="c" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Descent: A4 G4 E4 E4 -->
                  <note xml:id="m8r1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m8r2" pname="g" oct="4" dur="4"/>
                  <chord xml:id="m8r3" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Dm: D2 A2 D3 F3 -->
                  <chord xml:id="m8l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <!-- G: G2 D3 G3 B3 -->
                  <chord xml:id="m8l2" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <!-- C: C2 G2 C3 E3 -->
                  <chord xml:id="m8l3" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 9: F(A3/2 G/2) Dm(F) Am(c) = 1.5+0.5+1+1 = 4 beats -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="a" oct="4" dur="4" dots="1"/>
                  <note xml:id="m9n2" pname="g" oct="4" dur="8"/>
                  <note xml:id="m9n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m9n4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- F arpeggio going up: C5 A4 then F4 A4 -->
                  <chord xml:id="m9r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m9r2" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- F: F2 C3 F3 A3 -->
                  <chord xml:id="m9l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <!-- Am: A2 E3 A3 C4 -->
                  <chord xml:id="m9l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 10: C(c/2 _B/2) Dm(A) Gm(G/2 F/2 G) = 0.5+0.5+1+0.5+0.5+1 = 4 beats
                 _B = Bb (non-diatonic, pass tone). Gm sub -> Dm or G -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" pname="c" oct="5" dur="8"/>
                  <note xml:id="m10n2" pname="b" oct="4" dur="8" accid="f"/>
                  <note xml:id="m10n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m10n4" pname="g" oct="4" dur="8"/>
                  <note xml:id="m10n5" pname="f" oct="4" dur="8"/>
                  <note xml:id="m10n6" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Chromatic passing in RH ignored; stay diatonic C and Dm -->
                  <chord xml:id="m10r1" dur="2">
                    <note pname="e" oct="5"/>
                    <note pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m10r2" dur="2">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C: C2 G2 C3 E3 -->
                  <chord xml:id="m10l1" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- Dm: D2 A2 D3 F3 (sub for Gm) -->
                  <chord xml:id="m10l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Bar 11: A(A) z/2 G(G/2) F(F) G(D) = 1+0.5+0.5+1+1 = 4 beats
                 A major (non-diatonic) sub Am, G major=diatonic V -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" pname="a" oct="4" dur="4"/>
                  <rest dur="8"/>
                  <note xml:id="m11n2" pname="g" oct="4" dur="8"/>
                  <note xml:id="m11n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m11n4" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Am -> G: E4 D4 B3 B3 -->
                  <note xml:id="m11r1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m11r2" pname="d" oct="4" dur="4"/>
                  <chord xml:id="m11r3" dur="2">
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am (sub A major): A2 E3 A3 C4 -->
                  <chord xml:id="m11l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <!-- G: G2 D3 G3 B3 -->
                  <chord xml:id="m11l2" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Bar 12: Am(C) Dm(F) A(E/2) Bb(D/2) A(E) = 1+1+0.5+0.5+1 = 4 beats
                 Bb non-diatonic sub F (IV). A major sub Am -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12n1" pname="c" oct="4" dur="4"/>
                  <note xml:id="m12n2" pname="f" oct="4" dur="4"/>
                  <note xml:id="m12n3" pname="e" oct="4" dur="8"/>
                  <note xml:id="m12n4" pname="d" oct="4" dur="8"/>
                  <note xml:id="m12n5" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Cadential buildup: E4 F4 G4 A4 ascending suspension -->
                  <note xml:id="m12r1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m12r2" pname="f" oct="4" dur="4"/>
                  <note xml:id="m12r3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m12r4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am: A2 E3 A3 C4 -->
                  <chord xml:id="m12l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <!-- Dm: D2 A2 D3 F3 (cadential approach) -->
                  <chord xml:id="m12l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 13: D(D4) = whole note final. Sub Dm -->
            <measure n="13" right="end">
              <staff n="1">
                <layer n="1">
