                  <note xml:id="m8rh2" pname="g" oct="4" dur="4" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m8lh1a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m8lh1b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m8lh1c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m8lh1d" pname="g" oct="3"/>
