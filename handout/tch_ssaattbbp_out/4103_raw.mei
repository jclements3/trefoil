<?xml version="1.0" encoding="UTF-8"?>
<!-- 4103 Awake, My Heart, With Gladness — Key: Eb major — 3/4
     3 flats: Bb, Eb, Ab. accid.ges on all Bb, Eb, Ab notes.
     Key: Eb=1, F=2, G=3, Ab=4, Bb=5, C=6, D=7

     Chord sequence from ABC (full):
     Bar 1: Eb Eb Eb  (B4b G4 B4b)
     Bar 2: C  C  Eb  (A4b A4b G4) — C minor? C chord annotated → Cm(vi)
     Bar 3: Bb Bb Bb  (F4)
     Bar 4: Eb Eb Eb  (E4b E4b B4b)
     Bar 5: C  C  Cm  (c5 d5 e5b)
     Bar 6: G  G  Gm  (d5 c5 d5) — G natural → sub G major chord (III, non-diatonic) → use Cm or Gm
     Bar 7: Cm Cm Cm  (c5)
     [Bars 1-7 repeat in bars 8-14]
     Bar 15: Eb Bb Cm  (G4 B4b E4b)
     Bar 16: Bb Bb Bb  (D4 E4b F4)
     Bar 17: Eb Eb Eb  (E4b)
     Bar 18: Fm Fm Bbm  (A4b c5 F4)  — Bbm non-diatonic → use Bb major (V)
     Bar 19: C  C  C   (=E4n F4 G4)  — C major (III non-diatonic) → use Eb or Cm
     Bar 20: F  F  Bb  (F4 F4 F4b) — F natural major (II non-diat.) → use F minor (ii)
     Bar 21: Eb Eb Bb  (G4 A4b B4b)
     Bar 22: F  F  F   (=A4n B4b c5)  — F chord again → Fm(ii)
     Bar 23: Bb Bb Eb  (B4b B4b B4b)
     Bar 24: C  C  Cm  (c5 d5 e5b)
     Bar 25: Bb Bb Bb  (d5 c5 d5)
     Bar 26: Eb Eb Eb  (e5b) — final

     Non-diatonic substitutions:
     - G major → Gm (III minor or vi of Eb)
     - C major (bars 5, 19) → Cm (vi)
     - F major (bars 20, 22) → Fm (ii)
     - Bbm (bar 18) → Bb (V)
     Eb, Bb, Cm, Fm all diatonic. C annotated as Cm(vi) already.

     Scale degrees: Eb=①, Fm=②m, Gm=③m, Ab=④, Bb=⑤, Cm=⑥m, D°=⑦°
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Awake, My Heart, With Gladness</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="3" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Bar 1: Eb  (B4b G4 B4b) — joyful opening
                 Texture: Light RH 2-note, LH 3-note open
                 RH: Bb4-Eb5 (open 4th)
                 LH: Eb2-Bb2-G3 (root-5th-3rd, open)
                 Pedal: Eb1
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m1s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1s1n3" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1rh1" dur="2" stem.dir="up">
                    <note xml:id="m1rh1a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m1rh1b" pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <note xml:id="m1rh2" pname="g" oct="4" dur="4" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m1lh1a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m1lh1b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m1lh1c" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" pname="e" oct="1" accid.ges="f" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 2: C(→Cm) C Eb  (A4b A4b G4)
                 Chords: Cm(2 beats) Eb(1 beat)
                 RH: Cm: Ab4-C5 → Eb: G4-Bb4
                 LH: Cm: C2-G2-Eb3-G3 → Eb: Eb2-Bb2-G3
                 Pedal: C1(2b) → Eb1(1b)
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="a" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m2s1n2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2rh1" dur="2" stem.dir="up">
                    <note xml:id="m2rh1a" pname="a" oct="4" accid.ges="f"/>
                    <note xml:id="m2rh1b" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m2rh2" dur="4" stem.dir="up">
                    <note xml:id="m2rh2a" pname="g" oct="4"/>
                    <note xml:id="m2rh2b" pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2lh1" dur="2" stem.dir="up">
                    <note xml:id="m2lh1a" pname="c" oct="2"/>
                    <note xml:id="m2lh1b" pname="g" oct="2"/>
                    <note xml:id="m2lh1c" pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2lh2" dur="4" stem.dir="up">
                    <note xml:id="m2lh2a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m2lh2b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m2lh2c" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" pname="c" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m2p2" pname="e" oct="1" accid.ges="f" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 3: Bb (F4 F4 F4)
                 RH: F4-Bb4 (quarter each)
                 LH: Bb2-F3-Bb3 (dotted half)
                 Pedal: Bb1 dotted half
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="f" oct="4" dur="2" dots="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3rh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m3rh1a" pname="f" oct="4"/>
                    <note xml:id="m3rh1b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3rhs1" pname="b" oct="4" accid.ges="f" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m3lh1a" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m3lh1b" pname="f" oct="3"/>
                    <note xml:id="m3lh1c" pname="b" oct="3" accid.ges="f"/>
                    <note xml:id="m3lh1d" pname="d" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" pname="b" oct="1" accid.ges="f" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Bar 4: Eb (E4b E4b B4b)
                 Lighter texture after Bb cadence
                 RH: G4-Eb5 (open 6th)
                 LH: Eb2-Bb2-Eb3-G3
                 Pedal: Eb1
            -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="e" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m4s1n2" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4rh1" dur="2" stem.dir="up">
                    <note xml:id="m4rh1a" pname="g" oct="4"/>
                    <note xml:id="m4rh1b" pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <note xml:id="m4rh2" pname="b" oct="4" accid.ges="f" dur="4" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m4lh1a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m4lh1b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m4lh1c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m4lh1d" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" pname="e" oct="1" accid.ges="f" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 5: C(→Cm) C Cm  (c5 d5 e5b) — rising phrase
                 Chords: Cm throughout
                 RH: Eb5-G5 (high treble) → Cm reaching up
                 LH: C2-G2-C3-Eb3 (7th voicing)
                 Pedal: C1
            -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="c" oct="5" dur="4" dots="1"/>
                  <note xml:id="m5s1n2" pname="d" oct="5" dur="8"/>
                  <note xml:id="m5s1n3" pname="e" oct="5" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5rh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m5rh1a" pname="e" oct="5" accid.ges="f"/>
                    <note xml:id="m5rh1b" pname="g" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5rhs1" pname="c" oct="5" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m5lh1a" pname="c" oct="2"/>
                    <note xml:id="m5lh1b" pname="g" oct="2"/>
                    <note xml:id="m5lh1c" pname="c" oct="3"/>
                    <note xml:id="m5lh1d" pname="e" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" pname="c" oct="1" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Bar 6: G(→Gm) G Gm (d5 c5 d5)
                 Gm (iii in Eb) — use Gm
                 RH: D5-G5 → C5-Eb5
                 LH: G2-D3-G3-Bb3
                 Pedal: G1
            -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="d" oct="5" dur="4" dots="1"/>
                  <note xml:id="m6s1n2" pname="c" oct="5" dur="8"/>
                  <note xml:id="m6s1n3" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6rh1" dur="4" dots="1" stem.dir="up">
                    <note xml:id="m6rh1a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m6rh1b" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m6rh2" dur="8" stem.dir="up">
                    <note xml:id="m6rh2a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m6rh2b" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m6rh3" dur="4" stem.dir="up">
                    <note xml:id="m6rh3a" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m6rh3b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m6lh1a" pname="g" oct="2"/>
                    <note xml:id="m6lh1b" pname="d" oct="3"/>
                    <note xml:id="m6lh1c" pname="g" oct="3"/>
                    <note xml:id="m6lh1d" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m6p1" pname="g" oct="1" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
            </measure>

            <!-- Bar 7: Cm (c5 dotted half)
                 Full Cm close: 4-voice LH, 2-note RH
                 RH: C5-Eb5
                 LH: C2-G2-C3-Eb3 (full close)
                 Pedal: C1
            -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="c" oct="5" dur="2" dots="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7rh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m7rh1a" pname="c" oct="5"/>
                    <note xml:id="m7rh1b" pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m7lh1a" pname="c" oct="2"/>
                    <note xml:id="m7lh1b" pname="g" oct="2"/>
                    <note xml:id="m7lh1c" pname="c" oct="3"/>
                    <note xml:id="m7lh1d" pname="e" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7p1" pname="c" oct="1" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Bars 8-14: Repeat of bars 1-7 (stanza 2), slightly fuller voicing -->
            <!-- Bar 8 = Bar 1 (Eb, B4b G4 B4b) — fuller RH now 3 notes -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m8s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m8s1n3" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8rh1" dur="2" stem.dir="up">
                    <note xml:id="m8rh1a" pname="g" oct="4"/>
                    <note xml:id="m8rh1b" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m8rh1c" pname="e" oct="5" accid.ges="f"/>
