                <layer n="2">
                  <note xml:id="m8p1" pname="e" oct="1" accid.ges="f" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 9 = Bar 2 (Cm/Eb) — same pattern -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" pname="a" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m9s1n2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9rh1" dur="2" stem.dir="up">
                    <note xml:id="m9rh1a" pname="a" oct="4" accid.ges="f"/>
                    <note xml:id="m9rh1b" pname="c" oct="5"/>
                    <note xml:id="m9rh1c" pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m9rh2" dur="4" stem.dir="up">
                    <note xml:id="m9rh2a" pname="g" oct="4"/>
                    <note xml:id="m9rh2b" pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9lh1" dur="2" stem.dir="up">
                    <note xml:id="m9lh1a" pname="c" oct="2"/>
                    <note xml:id="m9lh1b" pname="g" oct="2"/>
                    <note xml:id="m9lh1c" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m9lh1d" pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m9lh2" dur="4" stem.dir="up">
                    <note xml:id="m9lh2a" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m9lh2b" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m9lh2c" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m9p1" pname="c" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m9p2" pname="e" oct="1" accid.ges="f" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 10 = Bar 3 (Bb, F4 dotted half) -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" pname="f" oct="4" dur="2" dots="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10rh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m10rh1a" pname="f" oct="4"/>
                    <note xml:id="m10rh1b" pname="b" oct="4" accid.ges="f"/>
                    <note xml:id="m10rh1c" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m10lh1a" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m10lh1b" pname="f" oct="3"/>
                    <note xml:id="m10lh1c" pname="b" oct="3" accid.ges="f"/>
                    <note xml:id="m10lh1d" pname="d" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m10p1" pname="b" oct="1" accid.ges="f" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Bar 11 = Bar 4 (Eb, E4b E4b B4b) -->
            <measure n="11" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" pname="e" oct="4" accid.ges="f" dur="2"/>
                  <note xml:id="m11s1n2" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
