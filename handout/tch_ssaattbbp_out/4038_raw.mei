<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Magnificat</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB+P</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- G major: 1 sharp (F#). Chromatic notes (Eb, F#m) get explicit accidentals. -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ================================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Em tonal center, modal color with Eb        -->
            <!-- ================================================================ -->

            <!-- Measure 1: "^Em"E E/2 D/2 "^Am"C — Em (E.E/2 D/2), Am (C) -->
            <!-- 3/4: total 3 beats. E=1, E/2 D/2=1, C=1 -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m1s1n2" pname="e" oct="4" dur="8"/>
                  <note xml:id="m1s1n3" pname="d" oct="4" dur="8"/>
                  <note xml:id="m1s1n4" pname="c" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4; Am A4 C5 — gentle entry -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <note xml:id="m1r2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3 G3 — sparse open for opening -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1l1" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- Am: A2 E3 A3 -->
                  <chord xml:id="m1l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 2: "^Em"B,2 "^Eb"F — Em (B,=B3, 2 beats), Eb (F, 1 beat chromatic) -->
            <!-- Note: Eb is non-diatonic in G; substitute ③m (Em) or treat as bVII flavor -->
            <!-- We'll use Em for 2 beats then voice Eb as a bVII (Eb major = flat VII borrowed) -->
            <!-- On harp (diatonic): use Eb2(bVII) = Eb, G, Bb — but Bb non-diatonic in G -->
            <!-- Best diatonic substitute: keep Em for the bar, let F remain as Em chord tone -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <!-- B, = B3 in ABC (one octave below middle B) -->
                  <note xml:id="m2s1n1" pname="b" oct="3" dur="2"/>
                  <!-- Eb-annotated F: accidental on F natural, chromatic note in melody -->
                  <note xml:id="m2s1n2" pname="f" oct="4" dur="4" accid="n" accid.ges="n"/>
                </layer>
              </staff>
              <!-- RH: Em E4 G4; then F note — use C4 E4 (diatonic 2nd inv IV sub) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <!-- Chromatic bar: use Em G4 B4 — sustain harmony, let melody stand alone -->
                  <note xml:id="m2r2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3 G3 for full bar — anchor the tonal center -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="2" dots="1">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
            </measure>

            <!-- Measure 3: "^Em"G "^D"F "^CΔ7"E — Em(G), D(F), CΔ7(E) -->
            <!-- Each chord one beat. CΔ7 = C maj7 = IV Δ in G -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m3s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m3s1n3" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em B4; D A4 F#4; C E4 G4 -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m3r1" pname="b" oct="4" dur="4"/>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m3r3" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em E2 B2; D D2 A2 D3; C C2 G2 C3 E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3l1" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m3l3" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">④Δ</harm>
            </measure>

            <!-- Measure 4: "^Eb"_E3 — Eb (= _E = Eb4), 3 beats. Chromatic measure. -->
            <!-- Non-diatonic: use diatonic Em as sub (E minor = iii, shares E as root) -->
            <!-- Melody note _E = Eb4 gets accid.ges="f" (flat) -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="e" oct="4" dur="2" dots="1" accid="f"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4 — sustain diatonic harmony under chromatic melody -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="2" dots="1">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3 G3 — hold under chromatic color note -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="2" dots="1">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 2 (mm. 5-8): G major center, D, Am — brighter             -->
            <!-- ================================================================ -->

            <!-- Measure 5: "^G"B B B — G for 3 beats -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m5s1n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m5s1n3" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: arpeggiate G "43" 1st inv: D5 G5 B5 across 3 beats -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5r1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m5r2" pname="g" oct="5" dur="4"/>
                  <note xml:id="m5r3" pname="b" oct="5" dur="4"/>
                </layer>
              </staff>
              <!-- LH: G "334" half + quarter for rhythmic interest: G2 D3 | G3 B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m5l2" dur="4">
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 6: "^D"A2 "^Em"G — D(A2=half), Em(G=quarter) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m6s1n2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D F#4 A4; Em G4 B4 — stepwise -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6r1" dur="2">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m6r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; Em E2 B2 E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m6l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Measure 7: "^Am"A "^D"F2 — Am(A), D(F2=half) -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m7s1n2" pname="f" oct="4" dur="2" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: Am A4 C5; D A4 D5 (common tone A sustains) -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m7r1" pname="a" oct="4" dur="4"/>
                  <chord xml:id="m7r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Am A2 E3 A3; D D2 A2 D3 F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m7l2" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
            </measure>

            <!-- Measure 8: "^G"G3 — G for 3 beats, cadence -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" pname="g" oct="4" dur="2" dots="1"/>
                </layer>
              </staff>
              <!-- RH: G "334" B4 D5 G5 — full final-phrase chord -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8r1" dur="2" dots="1">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                    <note pname="g" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2 D3 G3 B3 — cadential resolution -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="2" dots="1">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 3 (mm. 9-12): D7, G, F#m, Em7 — emotional middle section -->
            <!-- ================================================================ -->

            <!-- Measure 9: d d "^D7"c — G(d d), D7(c) — d=D5 in ABC -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m9s1n2" pname="d" oct="5" dur="4"/>
                  <note xml:id="m9s1n3" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <!-- RH: G "43" 1st inv B4 E5; D7 "233" A4 C5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9r1" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m9r2" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2 D3 G3 B3; D7 D2 A2 C3 F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m9l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Measure 10: "^G"B2 B — G for 3 beats -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" pname="b" oct="4" dur="2"/>
                  <note xml:id="m10s1n2" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: G "333" Δ: D5 F#5 B5 — rich full bar -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10r1" dur="2" dots="1">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G "334" G2 D3 G3 B3 — whole phrase -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10l1" dur="2" dots="1">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
            </measure>

            <!-- Measure 11: B "^F#m"A "^Em7"G — G(B), F#m(A), Em7(G) -->
            <!-- F#m = #iv in G (chromatic). Diatonic sub: use Em (iii). -->
            <!-- Em7 = iii7 in G. -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m11s1n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m11s1n3" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: G→Em each quarter, descending line D5→B4→G4 -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m11r1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m11r2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m11r3" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- LH: G quarter; Em half: Em E2 B2 E3 G3 D4 (7th) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <!-- Em7 "333": E2 G2 B2 D3 -->
                  <chord xml:id="m11l2" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">③m7</harm>
            </measure>

            <!-- Measure 12: "^D"F2 "^Eb"F — D(F#2=half), Eb(F=quarter chromatic) -->
            <!-- Eb is chromatic again. Use D for full bar in harp, melody gets flat. -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12s1n1" pname="f" oct="4" dur="2" accid.ges="s"/>
                  <!-- Eb's F: this is F natural (same pitch, but "Eb" chord annotation means flat VII context) -->
                  <note xml:id="m12s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: D A4 D5 sustained — simple under melody runs -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m12r1" dur="2" dots="1">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3 — anchor V -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12l1" dur="2" dots="1">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 4 (mm. 13-16): Return to Em, Bm, C, final cadence         -->
            <!-- ================================================================ -->

            <!-- Measure 13: "^Em"G "^Bm"F "^C"E — Em(G), Bm(F#), C(E) each 1 beat -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m13s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m13s1n3" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4; Bm F#4 B4; C E4 G4 — chromatic descent -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m13r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m13r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m13r3" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3; Bm B2 F#3 B3; C C2 G2 C3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m13l1" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m13l2" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m13l3" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑦m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 14: "^Eb"_E2 "^Em"B — Eb(_E=Eb4, 2 beats), Em(B, 1 beat) -->
            <measure n="14">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m14s1n1" pname="e" oct="4" dur="2" accid="f"/>
                  <note xml:id="m14s1n2" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4 sustained — diatonic anchor under chromatic melody -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m14r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <note xml:id="m14r2" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3 G3 full bar -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m14l1" dur="2" dots="1">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
            </measure>

            <!-- Measure 15: G2 "^Eb"F/2 E/2 — G(G2), then chromatic F/2 E/2 -->
            <!-- Again Eb context but melody uses F and E — use G and Em in harp -->
            <measure n="15">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15s1n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m15s1n2" pname="f" oct="4" dur="8" accid.ges="s"/>
                  <note xml:id="m15s1n3" pname="e" oct="4" dur="8"/>
                </layer>
              </staff>
              <!-- RH: G D5 G5; Em G4 B4 — voice exchange, descent -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m15r1" dur="2">
                    <note pname="d" oct="5"/>
                    <note pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m15r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2 D3 G3 B3; Em E2 B2 E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m15l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m15l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Measure 16: "^Em"E3 — Em for 3 beats, final -->
            <measure n="16" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m16s1n1" pname="e" oct="4" dur="2" dots="1"/>
                </layer>
              </staff>
              <!-- RH: Em "33" G4 B4 E5 — full 3-note -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m16r1" dur="2" dots="1">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em "334" E2 B2 E3 G3 — resolve to Em -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m16l1" dur="2" dots="1">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
<!--
VOICING PLAN:
- Chromatic Eb notes (mm. 2, 4, 12, 14): harp stays diatonic (Em or G). Melody's Eb/F
  natural notes are annotated with accidentals but harp voices are unaffected.
- F#m (m.11) substituted by Em (iii) — shares B and E tones, smooth voice leading.
- CΔ7 (m.3) treated as IV Δ — C E G B in LH (root position with maj7 color).
- D7 (m.9) voiced with C natural in LH (C3 = 7th), creating a leading-tone resolution pull.
- RH arpeggiation in m.5 (D5→G5→B5) provides rhythmic interest in the three-beat meter.

VOICE LEADING HIGHLIGHTS:
- m.3: LH bass descends E2→D2→C2 (stepwise contrary to melody G→F#→E ascent).
- m.11: RH melodic line D5→B4→G4 mirrors melody's B→A→G descent an octave higher.
- m.13: RH inner voice descends B4→B4→G4 with chromatic parallel to bass E2→B2→C2.
- Common tone A4 held between Am and D in m.7 (RH voice).

TEXTURE ARC:
- mm. 1-4: Sparse 3-note LH, 2-note RH. Modal color via Eb creates mystical opening.
- mm. 5-8: Brighter G major register; RH arpeggiation in m.5 adds rhythmic energy.
- mm. 9-12: Richer harmony — G Δ7, D7, Em7. Emotional high point.
- mm. 13-16: Return to Em mode; diminishing texture to final hushed Em resolution.
-->
