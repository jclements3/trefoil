<?xml version="1.0" encoding="UTF-8"?>
<!-- 4158 The Gospel Shows The Father's Grace — pedal harp, key F, 6/4 -->
<!-- Key F: 1 flat — Bb. accid.ges="f" on all B notes -->
<!-- Scale: F(1) G(2) A(3) Bb(4) C(5) D(6) E(7) -->
<!-- 6/4: 6 quarter-note beats per measure -->
<!-- ABC (6/4, L=1/4):
  m0: F2 (pickup — 2 beats)
  m1: F_A2 C_c A2 C_G
  m2: F_A Bb_=B(nat) C_c2 Bb_d2   (=B means natural B — non-diatonic! → use C/V)
  m3: F_c2 A C_G2 F_F
  m4: Bb_F C_E F2 C_G2
  m5: F_A2 A C_G2 c
  m6: c G_=B(nat) C_c2 F_A2   (=B natural again → C/V)
  m7: Bb_B2 F_A C_G2 Dm_F
  m8: Bb_F C_E F2  (final)
-->
<!-- Natural B (=B in Bb key) in m.2,m.6 is non-diatonic: substitute C (V) or Bb (IV) -->
<!-- B° = B natural diminished — sub C(V) for smooth approach -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>The Gospel Shows The Father's Grace</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="6" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="1f">
                <keySig sig="1f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="1f">
                  <keySig sig="1f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="1f">
                  <keySig sig="1f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup: F2 — 2 beats -->
            <measure n="0" metcon="false">
              <staff n="1">
                <layer n="1">
                  <note xml:id="p1n1" dur="2" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <rest dur="2" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="2" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <rest dur="2" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="2" visible="false"/>
                </layer>
              </staff>
            </measure>

            <!-- Measure 1: F — melody A2 c A2 G (6 beats: A dotted-half + c + A half + G) -->
            <!-- Wait: 6/4 L=1/4 means 6 quarter beats -->
            <!-- ABC: A2 "^C"c "^F"A2 "^C"G = A(2 beats) c(1) A(2) G(1) = 6 beats total -->
            <!-- F → C → F → C -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="2" oct="4" pname="a"/>
                  <note xml:id="m1n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m1n3" dur="2" oct="4" pname="a"/>
                  <note xml:id="m1n4" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: A3 C4 → G4 E4 — "33" I then V -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh1" oct="3" pname="a"/>
                    <note xml:id="m1rh2" oct="4" pname="c"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="m1rh3" oct="4" pname="e"/>
                    <note xml:id="m1rh4" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh5" oct="4" pname="f"/>
                    <note xml:id="m1rh6" oct="4" pname="a"/>
                  </chord>
                  <rest dur="4" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="2" visible="false"/>
                  <rest dur="4" visible="false"/>
                  <rest dur="2" visible="false"/>
                  <note xml:id="m1rh7" dur="4" oct="4" pname="e" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: F2 C3 F3 A3 (I full) → C2 G2 C3 E3 (V) → F2 C3 A3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1lh1" oct="2" pname="f"/>
                    <note xml:id="m1lh2" oct="3" pname="c"/>
                    <note xml:id="m1lh3" oct="3" pname="f"/>
                    <note xml:id="m1lh4" oct="3" pname="a"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="m1lh5" oct="2" pname="c"/>
                    <note xml:id="m1lh6" oct="2" pname="g"/>
                    <note xml:id="m1lh7" oct="3" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1lh8" oct="2" pname="f"/>
                    <note xml:id="m1lh9" oct="3" pname="c"/>
                    <note xml:id="m1lh10" oct="3" pname="a"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="m1lh11" oct="2" pname="c"/>
                    <note xml:id="m1lh12" oct="2" pname="g"/>
                    <note xml:id="m1lh13" oct="3" pname="e"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m1p2" dur="4" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m1p3" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m1p4" dur="4" oct="2" pname="c" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 2: F, B°(→C/V), C — melody A =B(nat) c2 d2 -->
            <!-- =B = natural B — non-diatonic in F. Substitute C (V) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m2n2" dur="4" oct="4" pname="b" accid="n"/>
                  <note xml:id="m2n3" dur="2" oct="5" pname="c"/>
                  <note xml:id="m2n4" dur="2" oct="5" pname="d"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F4 A4 → E4 G4 → G4 D5 — ascending -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2rh1" oct="4" pname="f"/>
                    <note xml:id="m2rh2" oct="4" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2rh3" oct="4" pname="e"/>
                    <note xml:id="m2rh4" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2rh5" oct="4" pname="g"/>
                    <note xml:id="m2rh6" oct="5" pname="d"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="6" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: F2 C3 A3 → C2 G2 E3 C4 → C2 G2 C3 E3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2lh1" oct="2" pname="f"/>
                    <note xml:id="m2lh2" oct="3" pname="c"/>
                    <note xml:id="m2lh3" oct="3" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2lh4" oct="2" pname="c"/>
                    <note xml:id="m2lh5" oct="2" pname="g"/>
                    <note xml:id="m2lh6" oct="3" pname="e"/>
                    <note xml:id="m2lh7" oct="4" pname="c"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2lh8" oct="2" pname="c"/>
                    <note xml:id="m2lh9" oct="2" pname="g"/>
                    <note xml:id="m2lh10" oct="3" pname="c"/>
                    <note xml:id="m2lh11" oct="3" pname="e"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m2p2" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m2p3" dur="2" oct="2" pname="c" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 3: F, C, F — melody c2 A G2 F -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" dur="2" oct="5" pname="c"/>
                  <note xml:id="m3n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m3n3" dur="2" oct="4" pname="g"/>
                  <note xml:id="m3n4" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: A4 C5 → G4 E4 → F4 A4 — gentle descent to tonic -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh1" oct="4" pname="a"/>
                    <note xml:id="m3rh2" oct="5" pname="c"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh3" oct="4" pname="e"/>
                    <note xml:id="m3rh4" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh5" oct="4" pname="f"/>
                    <note xml:id="m3rh6" oct="4" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="6" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: F2 C3 F3 A3 → C2 G2 E3 → F2 C3 A3 F3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh1" oct="2" pname="f"/>
                    <note xml:id="m3lh2" oct="3" pname="c"/>
                    <note xml:id="m3lh3" oct="3" pname="f"/>
                    <note xml:id="m3lh4" oct="3" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh5" oct="2" pname="c"/>
                    <note xml:id="m3lh6" oct="2" pname="g"/>
                    <note xml:id="m3lh7" oct="3" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh8" oct="2" pname="f"/>
                    <note xml:id="m3lh9" oct="3" pname="c"/>
                    <note xml:id="m3lh10" oct="3" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m3p2" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m3p3" dur="2" oct="1" pname="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="5">①</harm>
            </measure>

            <!-- Measure 4: Bb, C, F, C — melody F E F2 G2 -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="4" pname="f"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="e"/>
                  <note xml:id="m4n3" dur="2" oct="4" pname="f"/>
                  <note xml:id="m4n4" dur="2" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F4 Bb4 → E4 G4 → A3 C4 — IV→V descent -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh1" oct="4" pname="f"/>
                    <note xml:id="m4rh2" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh3" oct="4" pname="e"/>
                    <note xml:id="m4rh4" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh5" oct="4" pname="e"/>
                    <note xml:id="m4rh6" oct="4" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="6" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb2 F3 Bb3 D4 → C2 G2 E3 C4 → F2 C3 F3 A3 → C2 G2 C3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh2" oct="3" pname="f"/>
                    <note xml:id="m4lh3" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh4" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh5" oct="2" pname="c"/>
                    <note xml:id="m4lh6" oct="2" pname="g"/>
                    <note xml:id="m4lh7" oct="3" pname="e"/>
                    <note xml:id="m4lh8" oct="4" pname="c"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh9" oct="2" pname="c"/>
                    <note xml:id="m4lh10" oct="2" pname="g"/>
                    <note xml:id="m4lh11" oct="3" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" dur="2" oct="2" pname="b" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m4p2" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m4p3" dur="2" oct="2" pname="c" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 5: F — melody A2 A G2 c -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="2" oct="4" pname="a"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m5n3" dur="2" oct="4" pname="g"/>
                  <note xml:id="m5n4" dur="4" oct="5" pname="c"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F4 A4 → C5 E4 — building to climax -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh1" oct="4" pname="f"/>
                    <note xml:id="m5rh2" oct="4" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh3" oct="4" pname="e"/>
                    <note xml:id="m5rh4" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh5" oct="4" pname="a"/>
                    <note xml:id="m5rh6" oct="5" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="6" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: F2 C3 F3 A3 × 3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh1" oct="2" pname="f"/>
                    <note xml:id="m5lh2" oct="3" pname="c"/>
                    <note xml:id="m5lh3" oct="3" pname="f"/>
                    <note xml:id="m5lh4" oct="3" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh5" oct="2" pname="f"/>
                    <note xml:id="m5lh6" oct="3" pname="c"/>
                    <note xml:id="m5lh7" oct="3" pname="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh8" oct="2" pname="f"/>
                    <note xml:id="m5lh9" oct="3" pname="c"/>
                    <note xml:id="m5lh10" oct="3" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m5p2" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m5p3" dur="2" oct="1" pname="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 6: C/V, B°(→C), C, F — melody c =B(nat) c2 A2 -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m6n2" dur="4" oct="4" pname="b" accid="n"/>
                  <note xml:id="m6n3" dur="2" oct="5" pname="c"/>
                  <note xml:id="m6n4" dur="2" oct="4" pname="a"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: E4 G4 → F4 A4 — C then I -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh1" oct="4" pname="e"/>
                    <note xml:id="m6rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh3" oct="4" pname="e"/>
                    <note xml:id="m6rh4" oct="5" pname="c"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh5" oct="4" pname="f"/>
                    <note xml:id="m6rh6" oct="4" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="6" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 C3 E3 → C2 G2 E3 → F2 C3 F3 A3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh1" oct="2" pname="c"/>
                    <note xml:id="m6lh2" oct="2" pname="g"/>
                    <note xml:id="m6lh3" oct="3" pname="c"/>
                    <note xml:id="m6lh4" oct="3" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh5" oct="2" pname="c"/>
                    <note xml:id="m6lh6" oct="2" pname="g"/>
                    <note xml:id="m6lh7" oct="3" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh8" oct="2" pname="f"/>
                    <note xml:id="m6lh9" oct="3" pname="c"/>
                    <note xml:id="m6lh10" oct="3" pname="f"/>
                    <note xml:id="m6lh11" oct="3" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m6p1" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m6p2" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m6p3" dur="2" oct="1" pname="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="5">①</harm>
            </measure>

            <!-- Measure 7: Bb, F, C, Dm — melody B2 A G2 F -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" dur="2" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m7n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m7n3" dur="2" oct="4" pname="g"/>
                  <note xml:id="m7n4" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F4 Bb4 D5 → A3 C4 → G4 E4 → A3 F4 — wide motion -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh1" oct="4" pname="f"/>
                    <note xml:id="m7rh2" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh3" oct="4" pname="e"/>
                    <note xml:id="m7rh4" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh5" oct="4" pname="f"/>
                    <note xml:id="m7rh6" oct="4" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="6" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb2 F3 Bb3 D4 → F2 C3 A3 → C2 G2 E3 → D2 A2 F3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m7lh2" oct="3" pname="f"/>
                    <note xml:id="m7lh3" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m7lh4" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh5" oct="2" pname="c"/>
                    <note xml:id="m7lh6" oct="2" pname="g"/>
                    <note xml:id="m7lh7" oct="3" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh8" oct="2" pname="d"/>
                    <note xml:id="m7lh9" oct="2" pname="a"/>
                    <note xml:id="m7lh10" oct="3" pname="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7p1" dur="2" oct="2" pname="b" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m7p2" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m7p3" dur="2" oct="2" pname="d" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="5">⑥m</harm>
            </measure>

            <!-- Measure 8: Bb, C, F final — melody F E F2 -->
            <!-- 4 beats: Bb→C→F half. Wait: 6/4 but ABC says F E F2 = 4 beats only -->
            <!-- Actually: "^Bb"F "^C"E "^F"F2 — that's 4 beats + 2 rest? The piece ends here -->
            <!-- The last bar in 6/4 that has 4 beats must be the final shortened bar -->
            <measure n="8" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" dur="4" oct="4" pname="f"/>
                  <note xml:id="m8n2" dur="4" oct="4" pname="e"/>
                  <note xml:id="m8n3" dur="2" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: D4 F4 Bb4 → E4 G4 → F4 A4 C5 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8rh1" oct="4" pname="d"/>
                    <note xml:id="m8rh2" oct="4" pname="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8rh3" oct="4" pname="f"/>
                    <note xml:id="m8rh4" oct="4" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="4" visible="false"/>
                  <rest dur="4" visible="false"/>
                  <rest dur="4" visible="false"/>
                  <rest dur="4" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb2 F3 Bb3 → C2 G2 E3 → F2 C3 F3 A3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m8lh2" oct="3" pname="f"/>
                    <note xml:id="m8lh3" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8lh4" oct="2" pname="f"/>
                    <note xml:id="m8lh5" oct="3" pname="c"/>
                    <note xml:id="m8lh6" oct="3" pname="f"/>
                    <note xml:id="m8lh7" oct="3" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m8p1" dur="2" oct="2" pname="b" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m8p2" dur="2" oct="1" pname="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>

<!--
VOICING PLAN — 4158 The Gospel Shows The Father's Grace (F major, 6/4)
Key: F (1 flat Bb). Stately 6/4 meter with 2+4 beat grouping.

6/4 gives room for 3 pairs of harmonies per measure: beats 1-2, 3-4, 5-6.
Natural B (=B) in m.2 and m.6 is non-diatonic to F; harp substitutes C (V).
Melody keeps the chromatic B natural as passing tone.

Bb full 4-note LH in m.4 and m.7 for IV richness (quartal subdominant feel).
F/C/F alternation dominates mm.1,3,5 — I-V-I rocking pattern.
Dm (vi) color in m.7 beat 5-6 before final cadence.

TEXTURE ARC:
mm.1-3: I/V rocking, 2-beat chords, moderate density
m.4: IV-V stretch, building
mm.5-6: sustained I, then C→I approach
m.7: IV-V-vi sequence, building to final
m.8: IV→I final cadence (shortened last bar)
-->
