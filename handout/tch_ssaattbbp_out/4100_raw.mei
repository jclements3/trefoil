                  <note xml:id="m3p2" pname="a" oct="1" dur="4" stem.dir="down"/>
                  <note xml:id="m3p3" pname="e" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="4">③m</harm>
