            <!-- Bar 4: Am A3 (dotted half)  C E (pickup quarter)
                 Beat 1-3: Am | Beat 4: C pickup to next phrase
                 RH: Am (A4-C5) held → C (G4-E5) pickup
                 LH: Am (A2-E3-A3) held → C (C3-G3-E4) beat 4
                 Pedal: A1 dotted half, C1 quarter
            -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="a" oct="4" dur="2" dots="1"/>
                  <note xml:id="m4s1n2" pname="e" oct="4" dur="4"/>
