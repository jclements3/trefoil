          <section>

            <!-- Pickup measure: 1 beat, C chord
                 Melody: E4 (quarter)
                 RH: G4 (single note, light)
                 LH: C3-G3 (open 5th)
                 Pedal: C2
            -->
            <measure n="0" right="single" metcon="false">
              <staff n="1">
                <layer n="1">
                  <note xml:id="pu_s1n1" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <note xml:id="pu_rh1" pname="g" oct="4" dur="4" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <rest dur="4" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="pu_lh1" dur="4" stem.dir="up">
                    <note xml:id="pu_lh1a" pname="c" oct="3"/>
                    <note xml:id="pu_lh1b" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="pu_p1" pname="c" oct="2" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 1: F C F C  (A G F E)
                 RH: F→C alternates: C5-F5 → G4-E5 (smooth)
                 LH: F2-C3-A3 → C2-G2-E3-G3 → F2-C3-A3 → C2-G3-E4
                 Pedal: F1 C1 F1 C1 (each beat)
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m1s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1s1n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m1s1n4" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- F: C5-A5? Too high — use A4-C5 -->
                  <chord xml:id="m1rh1" dur="2" stem.dir="up">
                    <note xml:id="m1rh1a" pname="a" oct="4"/>
                    <note xml:id="m1rh1b" pname="c" oct="5"/>
                  </chord>
                  <!-- C: G4-E5 beats 3-4 -->
                  <chord xml:id="m1rh2" dur="2" stem.dir="up">
                    <note xml:id="m1rh2a" pname="g" oct="4"/>
                    <note xml:id="m1rh2b" pname="e" oct="5"/>
