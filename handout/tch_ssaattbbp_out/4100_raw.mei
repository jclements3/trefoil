                  <!-- Em: B4-E5 beat 4 -->
                  <chord xml:id="m3rh2" dur="4" stem.dir="up">
                    <note xml:id="m3rh2a" pname="b" oct="4"/>
                    <note xml:id="m3rh2b" pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <!-- E5 common tone sustained Am→Em -->
                  <note xml:id="m3rhs1" pname="e" oct="5" dur="2" stem.dir="down"/>
                  <rest dur="4" visible="false"/>
                  <!-- need to fill: beat 3 quarter rest sustained -->
                  <note xml:id="m3rhs2" pname="e" oct="5" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am 7th: A2-E3-G3-C4 beats 1-2 -->
                  <chord xml:id="m3lh1" dur="2" stem.dir="up">
                    <note xml:id="m3lh1a" pname="a" oct="2"/>
                    <note xml:id="m3lh1b" pname="e" oct="3"/>
                    <note xml:id="m3lh1c" pname="g" oct="3"/>
                    <note xml:id="m3lh1d" pname="c" oct="4"/>
                  </chord>
                  <!-- Am→Em transition: E3-A3 half beat-3 -->
                  <chord xml:id="m3lh2" dur="4" stem.dir="up">
                    <note xml:id="m3lh2a" pname="a" oct="2"/>
                    <note xml:id="m3lh2b" pname="e" oct="3"/>
                    <note xml:id="m3lh2c" pname="a" oct="3"/>
                  </chord>
                  <!-- Em: E2-B2-E3-G3 beat 4 -->
                  <chord xml:id="m3lh3" dur="4" stem.dir="up">
                    <note xml:id="m3lh3a" pname="e" oct="2"/>
                    <note xml:id="m3lh3b" pname="b" oct="2"/>
                    <note xml:id="m3lh3c" pname="e" oct="3"/>
