              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am: A2-E3-A3-C4 dotted half -->
                  <chord xml:id="m4lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m4lh1a" pname="a" oct="2"/>
                    <note xml:id="m4lh1b" pname="e" oct="3"/>
                    <note xml:id="m4lh1c" pname="a" oct="3"/>
                  </chord>
                  <!-- C: C2-G2-E3 quarter -->
                  <chord xml:id="m4lh2" dur="4" stem.dir="up">
                    <note xml:id="m4lh2a" pname="c" oct="2"/>
                    <note xml:id="m4lh2b" pname="g" oct="2"/>
                    <note xml:id="m4lh2c" pname="e" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" pname="a" oct="1" dur="2" dots="1" stem.dir="down"/>
                  <note xml:id="m4p2" pname="c" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bars 5-8 repeat bars 1-4 (same music/chords) with slightly fuller voicing -->
            <!-- Bar 5: F C F C  (same as bar 1 but RH adds 3rd note at peak) -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m5s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m5s1n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m5s1n4" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- F: A4-C5-F5 (now 3-note RH) -->
                  <chord xml:id="m5rh1" dur="2" stem.dir="up">
                    <note xml:id="m5rh1a" pname="a" oct="4"/>
                    <note xml:id="m5rh1b" pname="c" oct="5"/>
                    <note xml:id="m5rh1c" pname="f" oct="5"/>
                  </chord>
                  <!-- C: E4-G4-C5 beats 3-4 -->
                  <chord xml:id="m5rh2" dur="2" stem.dir="up">
                    <note xml:id="m5rh2a" pname="e" oct="4"/>
                    <note xml:id="m5rh2b" pname="g" oct="4"/>
                    <note xml:id="m5rh2c" pname="c" oct="5"/>
