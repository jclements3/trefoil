              <staff n="3">
                <layer n="1">
                  <!-- F full: F2-C3-F3-A3 2 beats -->
                  <chord xml:id="m5lh1" dur="2" stem.dir="up">
                    <note xml:id="m5lh1a" pname="f" oct="2"/>
                    <note xml:id="m5lh1b" pname="c" oct="3"/>
                    <note xml:id="m5lh1c" pname="f" oct="3"/>
                    <note xml:id="m5lh1d" pname="a" oct="3"/>
                  </chord>
                  <!-- C: C2-G2-C3-E3 beats 3-4 -->
                  <chord xml:id="m5lh2" dur="2" stem.dir="up">
                    <note xml:id="m5lh2a" pname="c" oct="2"/>
                    <note xml:id="m5lh2b" pname="g" oct="2"/>
                    <note xml:id="m5lh2c" pname="c" oct="3"/>
                    <note xml:id="m5lh2d" pname="e" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" pname="f" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m5p2" pname="c" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 6: Dm7 C vii° (same chord pattern as bar 2) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m6s1n2" pname="e" oct="4" dur="4"/>
