            <!-- Bar 7: Am (c c) Am(B/2 A/2) Em(B) — same as bar 3 -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m7s1n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m7s1n3" pname="b" oct="4" dur="8"/>
                  <note xml:id="m7s1n4" pname="a" oct="4" dur="8"/>
                  <note xml:id="m7s1n5" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7rh1" dur="2" stem.dir="up">
                    <note xml:id="m7rh1a" pname="c" oct="5"/>
                    <note xml:id="m7rh1b" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m7rh2" dur="2" stem.dir="up">
