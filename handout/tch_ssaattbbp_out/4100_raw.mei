<?xml version="1.0" encoding="UTF-8"?>
<!-- 4100 O Sacred Head, Now Wounded — Key: C major — 4/4 with pickup
     Chords parsed from ABC:
     Pickup: C  |  bar1: F C F C  |  bar2: Dm7 C G#°(→B°) |
     bar3: Am Am A(→Am) E(→Em) | bar4: Am(half) C(pickup) |
     bar5: F C F C | bar6: Dm7 C G#°(→B°) | bar7: Am Am A(→Am) E(→Em) |
     bar8: Am(dotted half) C(q) | bar9: B°(→Bdim) F C F B°(→Bdim) |
     bar10: F(half) C(half) | bar11: F Eø7(→Em) Dm F |
     bar12: A(→Am) dotted-half D7(→G/D) q | bar13: G D C G |
     bar14: A7(→Am) G C E | bar15: Dm C D G | bar16: C |
     Non-diatonic subs: G#°→B°(vii°), A→Am(vi), E→Em(iii), D7→G(V), A7→Am
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Sacred Head, Now Wounded</title>
