                  <chord xml:id="m1lh1" dur="2" stem.dir="up">
                    <note xml:id="m1lh1a" pname="f" oct="2"/>
                    <note xml:id="m1lh1b" pname="c" oct="3"/>
                    <note xml:id="m1lh1c" pname="a" oct="3"/>
                  </chord>
                  <!-- C open: C2-G2-E3-G3 beats 3-4 -->
                  <chord xml:id="m1lh2" dur="2" stem.dir="up">
                    <note xml:id="m1lh2a" pname="c" oct="2"/>
                    <note xml:id="m1lh2b" pname="g" oct="2"/>
                    <note xml:id="m1lh2c" pname="e" oct="3"/>
                    <note xml:id="m1lh2d" pname="g" oct="3"/>
