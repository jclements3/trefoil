              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 2: Dm7 C  E  B°(→vii°)
                 D2 half | E quarter | B quarter
                 Chords: Dm7 (beats 1-2), C (beat 3), vii° B° (beat 4)
                 Dm7 = D-F-A-C; B° = B-D-F (in C major)
                 RH: Dm7: F4-A4-C5 → C: E4-G4 → B°: D5-F5
                 LH: Dm7: D2-A2-D3-F3 → C: C2-G2-E3 → B°: B2-F3-B3
                 Pedal: D1 half, C1, B1
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m2s1n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m2s1n3" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Dm7: A4-C5 (2 beats) -->
                  <chord xml:id="m2rh1" dur="2" stem.dir="up">
                    <note xml:id="m2rh1a" pname="a" oct="4"/>
                    <note xml:id="m2rh1b" pname="c" oct="5"/>
                  </chord>
                  <!-- C: E4-G4 (1 beat) -->
                  <chord xml:id="m2rh2" dur="4" stem.dir="up">
                    <note xml:id="m2rh2a" pname="e" oct="4"/>
                    <note xml:id="m2rh2b" pname="g" oct="4"/>
                  </chord>
                  <!-- B°: D5-F5 (1 beat) -->
                  <chord xml:id="m2rh3" dur="4" stem.dir="up">
                    <note xml:id="m2rh3a" pname="d" oct="5"/>
                    <note xml:id="m2rh3b" pname="f" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Dm7 open: D2-A2-C3-F3 2 beats -->
                  <chord xml:id="m2lh1" dur="2" stem.dir="up">
                    <note xml:id="m2lh1a" pname="d" oct="2"/>
                    <note xml:id="m2lh1b" pname="a" oct="2"/>
                    <note xml:id="m2lh1c" pname="c" oct="3"/>
                    <note xml:id="m2lh1d" pname="f" oct="3"/>
                  </chord>
                  <!-- C: C2-G2-E3 1 beat -->
                  <chord xml:id="m2lh2" dur="4" stem.dir="up">
                    <note xml:id="m2lh2a" pname="c" oct="2"/>
                    <note xml:id="m2lh2b" pname="g" oct="2"/>
                    <note xml:id="m2lh2c" pname="e" oct="3"/>
                  </chord>
                  <!-- B°: B2-F3-B3 1 beat -->
                  <chord xml:id="m2lh3" dur="4" stem.dir="up">
                    <note xml:id="m2lh3a" pname="b" oct="2"/>
                    <note xml:id="m2lh3b" pname="f" oct="3"/>
                    <note xml:id="m2lh3c" pname="d" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" pname="d" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m2p2" pname="c" oct="1" dur="4" stem.dir="down"/>
                  <note xml:id="m2p3" pname="b" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- Bar 3: Am c c  A(→Am) B/2 A/2  E(→Em) B
                 = 4 beats: Am Am(with passing) Am/Em Em
                 Chords: Am (beats 1-3), Em (beat 4)
                 Am: A-C-E; Em: E-G-B
                 RH: Am: E4-A4 → Em: E4-B4
                 LH: Am: A2-E3-A3-C4 → Em: E2-B2-E3-G3
                 Pedal: A1 (1-3) → E1 (beat 4)
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m3s1n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m3s1n3" pname="b" oct="4" dur="8"/>
                  <note xml:id="m3s1n4" pname="a" oct="4" dur="8"/>
                  <note xml:id="m3s1n5" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Am: C5-E5 beats 1-3 -->
                  <chord xml:id="m3rh1" dur="2" stem.dir="up">
                    <note xml:id="m3rh1a" pname="c" oct="5"/>
                    <note xml:id="m3rh1b" pname="e" oct="5"/>
