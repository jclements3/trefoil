<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>The Comforter Has Come</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- C major: no sharps or flats -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="0" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="0" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="0" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- C major: I=C, ii=Dm, iii=Em, IV=F, V=G, vi=Am, vii°=Bdim    -->
            <!-- ABC L:1/8, M:3/4 — one bar = 6 eighth notes = 3 beats        -->
            <!-- Melody is in octave 4 (lowercase in ABC = oct 5 in sounding)  -->
            <!-- ABC: c=C5, g=G4, e=E4, a=A4, d=D4(upper), C=C4(uppercase)    -->
            <!-- In L:1/8: dur=8 = eighth, dur=4 = quarter, dur=2 = half       -->
            <!-- ============================================================ -->

            <!-- Pickup: 2 eighths = 1 beat (G4 G4)
                 ABC: "^C"G2  (2 eighth notes on G4)
                 Chord: C (I)
            -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: I "33": E4 G4 — light two-note opening -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m0s2c1" dur="4">
                    <note xml:id="m0s2n1" pname="e" oct="4" />
                    <note xml:id="m0s2n2" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "33": C3 E3 G3 — root position -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0s3c1" dur="4">
                    <note xml:id="m0s3n1" pname="c" oct="3" />
                    <note xml:id="m0s3n2" pname="e" oct="3" />
                    <note xml:id="m0s3n3" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 1: C F C Em — I IV I iii
                 ABC: G3 "^F"A "^C"G E
                 G=G4(dotted-quarter = 3/8), A=A4(eighth), G=G4(quarter), E=E4(quarter) — wait
                 L:1/8: G3=dotted-quarter(3/8 = 1.5 beat), A(1/8=0.5beat), G(1/8=0.5), E(1/8=0.5)
                 Total: 3 beats = 6 eighths ✓
                 Chord annotations: "^C" at beat 1 (G3 duration), "^F" at beat 2.5, "^C" at beat 3, Em implied
                 Simplified: beat 1 = I (1.5 beats), beat 2.5 = IV (0.5), beat 3 = I (0.5), beat 3.5 = iii (0.5)
                 For harp, simplify to: I (beats 1-2), IV (beat 2.5), I (beat 3+)
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m1s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m1s1n3" dur="8" oct="4" pname="g" />
                  <note xml:id="m1s1n4" dur="8" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: beat 1 I "33": C5 E5 (half); beat 3 IV "33": F4 A4 (quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="c" oct="5" />
                    <note xml:id="m1s2n2" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="f" oct="4" />
                    <note xml:id="m1s2n4" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: beat 1 I "334": C3 E3 G3 C4 (half); beat 3 IV "33": F3 A3 C4 (quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="c" oct="3" />
                    <note xml:id="m1s3n2" pname="e" oct="3" />
                    <note xml:id="m1s3n3" pname="g" oct="3" />
                    <note xml:id="m1s3n4" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n5" pname="f" oct="3" />
                    <note xml:id="m1s3n6" pname="a" oct="3" />
                    <note xml:id="m1s3n7" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 2: C (I whole measure)
                 ABC: G4 c2 = G4(half) C5(quarter)
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="2" oct="4" pname="g" />
                  <note xml:id="m2s1n2" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: I "33" arpeggio: E4(quarter) G4(quarter) C5(quarter) — ascending arpeggiate -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m2s2n1" dur="4" oct="4" pname="e" />
                  <note xml:id="m2s2n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s2n3" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- LH: I "334": C3 E3 G3 C4 half, then G3(quarter) single bass -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="c" oct="3" />
                    <note xml:id="m2s3n2" pname="e" oct="3" />
                    <note xml:id="m2s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="c" oct="3" />
                    <note xml:id="m2s3n5" pname="g" oct="3" />
                    <note xml:id="m2s3n6" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 3: F Dm F — IV ii IV
                 ABC: "^F"c3 "^Dm"d "^F"c A = C5(dotted-qtr) D5(eighth) C5(eighth) A4(eighth)
                 beat 1: F (IV) 1.5 beats, beat 2.5: Dm (ii) 0.5 beat, beat 3: F (IV) 1 beat
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" dots="1" oct="5" pname="c" />
                  <note xml:id="m3s1n2" dur="8" oct="5" pname="d" />
                  <note xml:id="m3s1n3" dur="8" oct="5" pname="c" />
                  <note xml:id="m3s1n4" dur="8" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: beat 1 IV "33": A4 C5 (half); beat 3 IV "43": C4 F4 A4 (quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="a" oct="4" />
                    <note xml:id="m3s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="c" oct="4" />
                    <note xml:id="m3s2n4" pname="f" oct="4" />
                    <note xml:id="m3s2n5" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: beat 1 IV "334": F3 A3 C4 F4 (half); beat 3 ii "33": D3 F3 A3 (quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="f" oct="3" />
                    <note xml:id="m3s3n2" pname="a" oct="3" />
                    <note xml:id="m3s3n3" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="d" oct="3" />
                    <note xml:id="m3s3n5" pname="f" oct="3" />
                    <note xml:id="m3s3n6" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 4: F (IV) whole — c4 A2 = C5(half) A4(quarter) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="5" pname="c" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: IV "333": F4 A4 C5 (whole) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="f" oct="4" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                    <note xml:id="m4s2n3" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n4" pname="a" oct="4" />
                    <note xml:id="m4s2n5" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: IV "333": F3 A3 C4 E4 — full IVΔ voicing -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="f" oct="3" />
                    <note xml:id="m4s3n2" pname="a" oct="3" />
                    <note xml:id="m4s3n3" pname="c" oct="4" />
                    <note xml:id="m4s3n4" pname="e" oct="4" />
                  </chord>
                  <note xml:id="m4s3n5" dur="4" pname="f" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④Δ</harm>
            </measure>

            <!-- Measure 5: C F C (I IV I)
                 ABC: "^C"G3 "^F"A "^C"G E (same as m1)
            -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m5s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m5s1n3" dur="8" oct="4" pname="g" />
                  <note xml:id="m5s1n4" dur="8" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I "44" quartal: G4 C5 (half); IV "33": F4 A4 (quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="g" oct="4" />
                    <note xml:id="m5s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="f" oct="4" />
                    <note xml:id="m5s2n4" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "334": C3 E3 G3 C4 (half); IV "43": A3 C4 F4 (quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="c" oct="3" />
                    <note xml:id="m5s3n2" pname="e" oct="3" />
                    <note xml:id="m5s3n3" pname="g" oct="3" />
                    <note xml:id="m5s3n4" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n5" pname="a" oct="3" />
                    <note xml:id="m5s3n6" pname="c" oct="4" />
                    <note xml:id="m5s3n7" pname="f" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 6: C (I) — G4 E2 = G4(quarter) E4(half) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n2" dur="2" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I "33": E4 G4 (whole) — held -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="2">
                    <note xml:id="m6s2n1" pname="e" oct="4" />
                    <note xml:id="m6s2n2" pname="g" oct="4" />
                  </chord>
                  <note xml:id="m6s2n3" dur="4" pname="c" oct="5" />
                </layer>
              </staff>
              <!-- LH: I "333": C3 E3 G3 B3 — IΔ voicing -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="2">
                    <note xml:id="m6s3n1" pname="c" oct="3" />
                    <note xml:id="m6s3n2" pname="e" oct="3" />
                    <note xml:id="m6s3n3" pname="g" oct="3" />
                    <note xml:id="m6s3n4" pname="b" oct="3" />
                  </chord>
                  <note xml:id="m6s3n5" dur="4" pname="g" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
            </measure>

            <!-- Measure 7: Am D Dm — vi V/ii ii
                 ABC: "^Am"E3 E "^D"D "^Dm"C
                 E=E4(dotted-qtr 1.5), E=E4(0.5), D=D4(0.5), C=C4(0.5)
                 D here is secondary dominant → substitute V (G) for diatonic
                 So: Am(vi) beat 1 | V(G) beat 3 | ii(Dm) beat 3.5
                 For harp, use: vi (beats 1-2), V (beat 3), ii (beat 3+)
            -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" dots="1" oct="4" pname="e" />
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="e" />
                  <note xml:id="m7s1n3" dur="8" oct="4" pname="d" />
                  <note xml:id="m7s1n4" dur="8" oct="4" pname="c" />
                </layer>
              </staff>
              <!-- RH: vi "43": C5 E5 (half); V "33": G4 B4 (quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="c" oct="5" />
                    <note xml:id="m7s2n2" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="g" oct="4" />
                    <note xml:id="m7s2n4" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "333": A2 C3 E3 G3 (half); V "333": G2 B2 D3 F3 (quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2">
                    <note xml:id="m7s3n1" pname="a" oct="2" />
                    <note xml:id="m7s3n2" pname="c" oct="3" />
                    <note xml:id="m7s3n3" pname="e" oct="3" />
                    <note xml:id="m7s3n4" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n5" pname="g" oct="2" />
                    <note xml:id="m7s3n6" pname="b" oct="2" />
                    <note xml:id="m7s3n7" pname="d" oct="3" />
                    <note xml:id="m7s3n8" pname="f" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 8: G (V) — D4 (held, 3 beats) -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="4" pname="d" />
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: V "333": G4 B4 D5 (dotted-half) — full V7 color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="2">
                    <note xml:id="m8s2n1" pname="g" oct="4" />
                    <note xml:id="m8s2n2" pname="b" oct="4" />
                    <note xml:id="m8s2n3" pname="d" oct="5" />
                  </chord>
                  <note xml:id="m8s2n4" dur="4" pname="g" oct="4" />
                </layer>
              </staff>
              <!-- LH: V "334": G2 B2 D3 G3 (dotted-half) — open octave bass -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="2">
                    <note xml:id="m8s3n1" pname="g" oct="2" />
                    <note xml:id="m8s3n2" pname="d" oct="3" />
                    <note xml:id="m8s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="4">
                    <note xml:id="m8s3n4" pname="g" oct="2" />
                    <note xml:id="m8s3n5" pname="b" oct="2" />
                    <note xml:id="m8s3n6" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- VERSE 2 (mm. 9-16): Repeat with richer voicings              -->
            <!-- ============================================================ -->

            <!-- Measure 9-16: repeat of mm. 1-8 with varied voicings -->

            <!-- Measure 9 = m1 variant: I IV I with 7th chords -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m9s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m9s1n3" dur="8" oct="4" pname="g" />
                  <note xml:id="m9s1n4" dur="8" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I "333": E4 G4 B4 (half); IV "43": C4 F4 A4 (quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="2">
                    <note xml:id="m9s2n1" pname="e" oct="4" />
                    <note xml:id="m9s2n2" pname="g" oct="4" />
                    <note xml:id="m9s2n3" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m9s2c2" dur="4">
                    <note xml:id="m9s2n4" pname="c" oct="4" />
                    <note xml:id="m9s2n5" pname="f" oct="4" />
                    <note xml:id="m9s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "333": C3 E3 G3 B3 (half); IV "334": F3 A3 C4 F4 (quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="c" oct="3" />
                    <note xml:id="m9s3n2" pname="e" oct="3" />
                    <note xml:id="m9s3n3" pname="g" oct="3" />
                    <note xml:id="m9s3n4" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
                    <note xml:id="m9s3n5" pname="f" oct="3" />
                    <note xml:id="m9s3n6" pname="a" oct="3" />
                    <note xml:id="m9s3n7" pname="c" oct="4" />
                    <note xml:id="m9s3n8" pname="f" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 10: C (I) — G4 half, C5 quarter -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="2" oct="4" pname="g" />
                  <note xml:id="m10s1n2" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: I "34": G4 B4 E5 — 2nd inversion color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10s2c1" dur="2">
                    <note xml:id="m10s2n1" pname="g" oct="4" />
                    <note xml:id="m10s2n2" pname="b" oct="4" />
                    <note xml:id="m10s2n3" pname="e" oct="5" />
                  </chord>
                  <note xml:id="m10s2n4" dur="4" pname="c" oct="5" />
