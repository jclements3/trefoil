                  <note xml:id="m2s1n2" dur="4" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Eb dotted half Eb4-G4-Bb4 full triad, then Bb: D4-F4 quarter -->
