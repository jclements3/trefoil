<?xml version="1.0" encoding="UTF-8"?>
<!-- Within the Father's House — Key of Eb (3 flats: Bb Eb Ab), 4/4
     Scale degrees in Eb: I=Eb ii=Fm iii=Gm IV=Ab V=Bb vi=Cm vii°=Ddim
     Non-diatonic substitutions:
       C major → nearest diatonic = Cm(vi) [C-Eb-G]
       G#° (= Ab major chord or Ab°) → Ddim(vii°) [D-F-Ab]
       Gm → Gm is iii in Eb, so it IS diatonic
       F major → non-diatonic (bII), substitute Bb(V) or Fm(ii)
       Bb = V (diatonic) — keep
     Note: all Eb, Bb, Ab must carry accid.ges="f"
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Within the Father's House</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- Pickup (1 beat): Eb — melody: Eb4                            -->
            <!-- ============================================================ -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="4" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Eb4-G4 open third, gentle pickup -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m0s2c1" dur="4">
                    <note xml:id="m0s2n1" pname="e" oct="4" accid.ges="f"/>
                    <note xml:id="m0s2n2" pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Eb2-Bb2-Eb3 open voicing -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0s3c1" dur="4">
                    <note xml:id="m0s3n1" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m0s3n2" pname="b" oct="2" accid.ges="f"/>
