                    <note xml:id="m2s3n5" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m2s3n6" pname="f" oct="3"/>
                    <note xml:id="m2s3n7" pname="b" oct="3" accid.ges="f"/>
                  </chord>
