                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Opening statement                        -->
            <!-- ============================================================ -->

            <!-- Bar 1: Bb Eb C(→Cm) Bb — melody: F4 G4 Ab4 Bb4 -->
