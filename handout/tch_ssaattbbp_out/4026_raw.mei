<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>We Gather Together</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal (raw, single-layer)</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- D major: 2 sharps. F→accid.ges="s" (F#), C→accid.ges="s" (C#) -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="2s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="2s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="2s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- D major: I=D, ii=Em, iii=F#m, IV=G, V=A, vi=Bm, vii°=C#°   -->
            <!-- Non-diatonic: E7→Em (ii), A7=V7 (diatonic), Bm7=vi7         -->
            <!-- ============================================================ -->

            <!-- Pickup measure: "^D"A4 — 1 beat (anacrusis), D(I) -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: light pickup dyad A4-D5 -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0s2n1" dur="4" pname="a" oct="4" />
                </layer>
              </staff>
              <!-- LH: D3 pickup bass note -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m0s3n1" dur="4" pname="d" oct="3" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 1: "^D"A4(3/2) "^G"B4(/2) "^D"A4 -->
            <!-- = A4(dotted-q) B4(8th) A4(q) — D(I), G(IV) beat2, D(I) beat3 -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m1s1n2" dur="8" oct="4" pname="b" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: D(I) held over then G for the B4, back to D -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m1s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="d" oct="4" />
                    <note xml:id="m1s2n4" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D2-A2-D3 | G2-D3 | D2-A2 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="d" oct="2" />
                    <note xml:id="m1s3n2" pname="a" oct="2" />
                    <note xml:id="m1s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="g" oct="2" />
                    <note xml:id="m1s3n5" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 2: F#4 "^Em"G4 "^D"A4 — I, ii(Em) beat2, I beat3 -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: D(I)→Em(ii)→D(I) stepwise -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="d" oct="4" />
                    <note xml:id="m2s2n2" pname="f" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="e" oct="4" />
                    <note xml:id="m2s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D2-A2-D3 | E2-B2-E3 | A2-E3-A3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="d" oct="2" />
                    <note xml:id="m2s3n2" pname="a" oct="2" />
                    <note xml:id="m2s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="e" oct="2" />
                    <note xml:id="m2s3n5" pname="b" oct="2" />
                    <note xml:id="m2s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="a" oct="2" />
                    <note xml:id="m2s3n8" pname="e" oct="3" />
                    <note xml:id="m2s3n9" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 3: G4(3/2) F#4(/2) E4 — Em7(ii7) beat1, Bm(vi) beat2, A(V) beat3 -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m3s1n2" dur="8" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: Em7 G-B | Bm F#-D | A E-A -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="g" oct="4" />
                    <note xml:id="m3s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="e" oct="4" />
                    <note xml:id="m3s2n4" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: E2-B2-E3-G3 (ii7) | B2-F#3-B3 (vi/Bm) | A2-E3-A3 (V) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="e" oct="2" />
                    <note xml:id="m3s3n2" pname="b" oct="2" />
                    <note xml:id="m3s3n3" pname="e" oct="3" />
                    <note xml:id="m3s3n4" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n5" pname="a" oct="2" />
                    <note xml:id="m3s3n6" pname="e" oct="3" />
                    <note xml:id="m3s3n7" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 4: F#4 D4 A4 — I throughout -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="d" />
                  <note xml:id="m4s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I broken ascending D-F#-A -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m4s2n1" dur="4" pname="d" oct="4" />
                  <note xml:id="m4s2n2" dur="4" pname="f" oct="4" accid.ges="s" />
                  <note xml:id="m4s2n3" dur="4" pname="a" oct="4" />
                </layer>
              </staff>
              <!-- LH: D2-A2-D3-F#3 open I root pos -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="d" oct="2" />
                    <note xml:id="m4s3n2" pname="a" oct="2" />
                    <note xml:id="m4s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n4" pname="a" oct="2" />
                    <note xml:id="m4s3n5" pname="d" oct="3" />
                    <note xml:id="m4s3n6" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 5: "^A"A4(3/2) B4(/2) C#5 — A(V) entire -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m5s1n2" dur="8" oct="4" pname="b" />
                  <note xml:id="m5s1n3" dur="4" oct="5" pname="c" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: V broken A-C#-E ascending -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5s2n1" dur="4" pname="a" oct="4" />
                  <note xml:id="m5s2n2" dur="4" pname="c" oct="5" accid.ges="s" />
                  <note xml:id="m5s2n3" dur="4" pname="e" oct="5" />
                </layer>
              </staff>
              <!-- LH: A2-E3-A3 | A2-C#3-E3 1st inv -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="a" oct="2" />
                    <note xml:id="m5s3n2" pname="e" oct="3" />
                    <note xml:id="m5s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="e" oct="2" />
                    <note xml:id="m5s3n5" pname="a" oct="2" />
                    <note xml:id="m5s3n6" pname="c" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Measure 6: "^Bm7"D5(3/2) E5(/2) "^A"C#5 — Bm7(vi7) beats1-2, A(V) beat3 -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" dots="1" oct="5" pname="d" />
                  <note xml:id="m6s1n2" dur="8" oct="5" pname="e" />
                  <note xml:id="m6s1n3" dur="4" oct="5" pname="c" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: Bm7 D-F# then A C#-E -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="2">
                    <note xml:id="m6s2n1" pname="b" oct="4" />
                    <note xml:id="m6s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="c" oct="5" accid.ges="s" />
                    <note xml:id="m6s2n4" pname="e" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: B2-F#3-B3-D4 (vi7) | A2-E3-A3 (V) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="2">
                    <note xml:id="m6s3n1" pname="b" oct="2" />
                    <note xml:id="m6s3n2" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m6s3n3" pname="b" oct="3" />
                    <note xml:id="m6s3n4" pname="d" oct="4" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n5" pname="a" oct="2" />
                    <note xml:id="m6s3n6" pname="e" oct="3" />
                    <note xml:id="m6s3n7" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 7: "^Bm7"B4(3/2) A4(/2) "^E7"B4 — Bm7(vi7), E7(→Em=ii) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" dots="1" oct="4" pname="b" />
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: Bm7 → Em(ii) — common tone B, move to G -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m7s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="e" oct="4" />
                    <note xml:id="m7s2n4" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: B2-D3-F#3-A3 (Bm7) | E2-B2-G3 (ii) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2">
                    <note xml:id="m7s3n1" pname="b" oct="2" />
                    <note xml:id="m7s3n2" pname="d" oct="3" />
                    <note xml:id="m7s3n3" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m7s3n4" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n5" pname="e" oct="2" />
                    <note xml:id="m7s3n6" pname="b" oct="2" />
                    <note xml:id="m7s3n7" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 8: "^A"A4(2) A4 — V half + V quarter -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="4" pname="a" />
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: A(V) suspension 4-3: D-A then C#-A -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="2">
                    <note xml:id="m8s2n1" pname="d" oct="4" />
                    <note xml:id="m8s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="4">
                    <note xml:id="m8s2n3" pname="c" oct="4" accid.ges="s" />
                    <note xml:id="m8s2n4" pname="e" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3 | A2-C#3-E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="2">
                    <note xml:id="m8s3n1" pname="a" oct="2" />
                    <note xml:id="m8s3n2" pname="e" oct="3" />
                    <note xml:id="m8s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="4">
                    <note xml:id="m8s3n4" pname="a" oct="2" />
                    <note xml:id="m8s3n5" pname="c" oct="3" accid.ges="s" />
                    <note xml:id="m8s3n6" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 9-16): Second verse — fuller texture           -->
            <!-- ============================================================ -->

            <!-- Measure 9: "^A7"A4(3/2) B4(/2) C#5 — A7(V7) -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m9s1n2" dur="8" oct="4" pname="b" />
                  <note xml:id="m9s1n3" dur="4" oct="5" pname="c" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: A7(V7) — E-G-C# (7th chord) ascending -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m9s2n1" dur="4" pname="e" oct="4" />
                  <note xml:id="m9s2n2" dur="4" pname="g" oct="4" />
                  <note xml:id="m9s2n3" dur="4" pname="c" oct="5" accid.ges="s" />
                </layer>
              </staff>
              <!-- LH: A2-E3-A3-C#4 (V7 full) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="a" oct="2" />
                    <note xml:id="m9s3n2" pname="e" oct="3" />
                    <note xml:id="m9s3n3" pname="a" oct="3" />
                    <note xml:id="m9s3n4" pname="c" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
                    <note xml:id="m9s3n5" pname="e" oct="2" />
                    <note xml:id="m9s3n6" pname="a" oct="2" />
                    <note xml:id="m9s3n7" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
            </measure>

            <!-- Measure 10: "^D"D5 A4 A4 — I (D-major) -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="4" oct="5" pname="d" />
                  <note xml:id="m10s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m10s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I at full spread D-F#-A descending -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m10s2n1" dur="4" pname="d" oct="5" />
                  <note xml:id="m10s2n2" dur="4" pname="a" oct="4" />
                  <note xml:id="m10s2n3" dur="4" pname="f" oct="4" accid.ges="s" />
                </layer>
              </staff>
              <!-- LH: D2-A2-D3-F#3 open I -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10s3c1" dur="2">
                    <note xml:id="m10s3n1" pname="d" oct="2" />
                    <note xml:id="m10s3n2" pname="a" oct="2" />
                    <note xml:id="m10s3n3" pname="d" oct="3" />
                    <note xml:id="m10s3n4" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m10s3c2" dur="4">
                    <note xml:id="m10s3n5" pname="d" oct="2" />
                    <note xml:id="m10s3n6" pname="a" oct="2" />
                    <note xml:id="m10s3n7" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 11: "^Bm"A4(3/2) B4(/2) G4(/2) A4(/2) — Bm(vi) -->
            <!-- = A4(dotted-q) B4(8th) G4(8th) A4(8th) = 1.5+0.5+0.5+0.5=3 beats ✓ -->
            <measure n="11" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m11s1n2" dur="8" oct="4" pname="b" />
                  <note xml:id="m11s1n3" dur="8" oct="4" pname="g" />
                  <note xml:id="m11s1n4" dur="8" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: Bm — F#-B | B-D -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m11s2c1" dur="2">
                    <note xml:id="m11s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m11s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m11s2c2" dur="4">
                    <note xml:id="m11s2n3" pname="d" oct="4" />
                    <note xml:id="m11s2n4" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: B2-F#3-B3-D4 (Bm open) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11s3c1" dur="2">
                    <note xml:id="m11s3n1" pname="b" oct="2" />
                    <note xml:id="m11s3n2" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m11s3n3" pname="b" oct="3" />
                    <note xml:id="m11s3n4" pname="d" oct="4" />
                  </chord>
                  <chord xml:id="m11s3c2" dur="4">
                    <note xml:id="m11s3n5" pname="a" oct="2" />
                    <note xml:id="m11s3n6" pname="d" oct="3" />
                    <note xml:id="m11s3n7" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Measure 12: "^A"F#4 D4 D4 — I (A on first beat: V? but "^D" later) -->
            <!-- Annotation "^A" on F#4 means A chord here, but then stays D -->
            <!-- This measure: A(V) beat1, D(I) beats2-3 -->
            <measure n="12" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12s1n1" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m12s1n2" dur="4" oct="4" pname="d" />
                  <note xml:id="m12s1n3" dur="4" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: A(V) then D(I) — F#-A | D-F# -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m12s2c1" dur="4">
                    <note xml:id="m12s2n1" pname="e" oct="4" />
                    <note xml:id="m12s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m12s2c2" dur="2">
                    <note xml:id="m12s2n3" pname="d" oct="4" />
                    <note xml:id="m12s2n4" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3 | D2-A2-D3-F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12s3c1" dur="4">
                    <note xml:id="m12s3n1" pname="a" oct="2" />
                    <note xml:id="m12s3n2" pname="e" oct="3" />
                    <note xml:id="m12s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m12s3c2" dur="2">
                    <note xml:id="m12s3n4" pname="d" oct="2" />
                    <note xml:id="m12s3n5" pname="a" oct="2" />
                    <note xml:id="m12s3n6" pname="d" oct="3" />
                    <note xml:id="m12s3n7" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">①</harm>
            </measure>

            <!-- Measure 13: "^G"G4(3/2) "^D"A4(/2) "^G"B4(/2) G4(/2) -->
            <!-- = G4(dotted-q) A4(8th) B4(8th) G4(8th) = 1.5+0.5+0.5+0.5=3 ✓ -->
            <!-- G(IV) beat1-2.5, D(I) beat2, G(IV) beat2.5-3, into next -->
            <measure n="13" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m13s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m13s1n3" dur="8" oct="4" pname="b" />
                  <note xml:id="m13s1n4" dur="8" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G(IV) E-G | D(I) F#-A passing -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m13s2c1" dur="2">
                    <note xml:id="m13s2n1" pname="e" oct="4" />
                    <note xml:id="m13s2n2" pname="g" oct="4" />
                    <note xml:id="m13s2n3" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m13s2c2" dur="4">
                    <note xml:id="m13s2n4" pname="d" oct="4" />
                    <note xml:id="m13s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m13s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G2-D3-G3-B3 (IV) | D2-A2-D3 (I) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m13s3c1" dur="2">
                    <note xml:id="m13s3n1" pname="g" oct="2" />
                    <note xml:id="m13s3n2" pname="d" oct="3" />
                    <note xml:id="m13s3n3" pname="g" oct="3" />
                    <note xml:id="m13s3n4" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m13s3c2" dur="4">
                    <note xml:id="m13s3n5" pname="d" oct="2" />
                    <note xml:id="m13s3n6" pname="a" oct="2" />
                    <note xml:id="m13s3n7" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 14: "^A"A4(3/2) G4(/2) F#4(/2) F#4(/2) -->
            <!-- = A4(dotted-q) G4(8th) F#4(8th) F#4(8th) = 1.5+0.5+0.5+0.5=3 ✓ -->
            <!-- A(V) throughout -->
            <measure n="14" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m14s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m14s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m14s1n3" dur="8" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m14s1n4" dur="8" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: V(A) with 7th — E-A-C# then F#-A -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m14s2c1" dur="2">
                    <note xml:id="m14s2n1" pname="e" oct="4" />
                    <note xml:id="m14s2n2" pname="a" oct="4" />
                    <note xml:id="m14s2n3" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m14s2c2" dur="4">
                    <note xml:id="m14s2n4" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m14s2n5" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3-C#4 (V7) | E2-A2-C#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m14s3c1" dur="2">
                    <note xml:id="m14s3n1" pname="a" oct="2" />
                    <note xml:id="m14s3n2" pname="e" oct="3" />
                    <note xml:id="m14s3n3" pname="a" oct="3" />
                    <note xml:id="m14s3n4" pname="c" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m14s3c2" dur="4">
                    <note xml:id="m14s3n5" pname="e" oct="2" />
                    <note xml:id="m14s3n6" pname="a" oct="2" />
                    <note xml:id="m14s3n7" pname="c" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
            </measure>

            <!-- Measure 15: "^Em"G4 "^A7"E4(3/2) "^D"D4(/2) -->
            <!-- = G4(q) E4(dotted-q) D4(8th) = 1+1.5+0.5 = 3 ✓ -->
            <!-- Em(ii) beat1, A7(V7) beats2-3, D(I) on last 8th (pickup to final) -->
            <measure n="15" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m15s1n2" dur="4" dots="1" oct="4" pname="e" />
                  <note xml:id="m15s1n3" dur="8" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: Em→A7→D penultimate — stepwise descent -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m15s2c1" dur="4">
                    <note xml:id="m15s2n1" pname="e" oct="4" />
                    <note xml:id="m15s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m15s2c2" dur="4" dots="1">
                    <note xml:id="m15s2n3" pname="e" oct="4" />
                    <note xml:id="m15s2n4" pname="a" oct="4" />
                    <note xml:id="m15s2n5" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m15s2c3" dur="8">
                    <note xml:id="m15s2n6" pname="d" oct="4" />
                    <note xml:id="m15s2n7" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: E2-B2-E3 (ii) | A2-E3-A3 (V7) | D2-A2 (I approach) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m15s3c1" dur="4">
                    <note xml:id="m15s3n1" pname="e" oct="2" />
                    <note xml:id="m15s3n2" pname="b" oct="2" />
                    <note xml:id="m15s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m15s3c2" dur="4" dots="1">
                    <note xml:id="m15s3n4" pname="a" oct="2" />
                    <note xml:id="m15s3n5" pname="e" oct="3" />
                    <note xml:id="m15s3n6" pname="a" oct="3" />
                    <note xml:id="m15s3n7" pname="c" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m15s3c3" dur="8">
                    <note xml:id="m15s3n8" pname="d" oct="2" />
                    <note xml:id="m15s3n9" pname="a" oct="2" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑤7</harm>
            </measure>

            <!-- Measure 16: "^D"D4(2) + rest(4) — half note + quarter rest = 3 beats -->
            <measure n="16" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m16s1n1" dur="2" oct="4" pname="d" />
                  <rest xml:id="m16s1r1" dur="4" />
                </layer>
              </staff>
              <!-- RH: Final D(I) full spread, then rest -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m16s2c1" dur="2">
                    <note xml:id="m16s2n1" pname="d" oct="4" />
                    <note xml:id="m16s2n2" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m16s2n3" pname="a" oct="4" />
                  </chord>
                  <rest xml:id="m16s2r1" dur="4" />
                </layer>
              </staff>
              <!-- LH: D2-A2-D3-F#3-A3 full tonic, then rest -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m16s3c1" dur="2">
                    <note xml:id="m16s3n1" pname="d" oct="2" />
                    <note xml:id="m16s3n2" pname="a" oct="2" />
                    <note xml:id="m16s3n3" pname="d" oct="3" />
                    <note xml:id="m16s3n4" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <rest xml:id="m16s3r1" dur="4" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>

<!-- ============================================================
VOICING PLAN:
- D major: I=D, ii=Em, iii=F#m, IV=G, V=A, vi=Bm, vii°=C#°.
- Non-diatonic: E7 → Em (ii). A7 is diatonic (V7).
- Pickup (m.0): Single-note A4 pickup, single-note harp.
- Phrase 1 (mm.1-8): Dance-like 3/4. Half-note + quarter pattern
  in harp mirrors waltz rhythm. LH: open root-pos "33" throughout.
  RH: 2-note dyads or broken single notes. Light, sprightly.
  Bm7 (vi7) in m.6 adds richness: full 4-note LH voicing.
- Phrase 2 (mm.9-16): Fuller. RH rises to 3-note voicings.
  m.9 (A7): LH A2-E3-A3-C#4 = full V7 with 7th in top.
  m.10: RH descends D5→A4→F#4 (melodic echo of melody contour).
  m.13-14: IV→I alternation, then V7 sustained for penultimate.
  m.15: Classic ii-V7-I resolution with D4 pickup into final bar.
- m.16: Half-note D tonic with fermata-like rest. Widest chord span.

VOICE LEADING HIGHLIGHTS:
- Bm7 voicing (m.6,7,11): B2-F#3-B3-D4 in LH — P5+P4+m3 (m3 only
  at top, compliant with LH rules). Clean voice from V (A2) to vi (B2).
- m.15 penultimate: Em→A7→D with chromatic passing C#4 in LH top —
  tension resolved as D4 arrives. Inner voices move by step.
- Contrary motion in m.9-10: LH descends A2→E2, RH ascends E4→G4→C#5.
  Then m.10 reverses: RH D5→F#4, LH D2 stays firm.

TEXTURE ARC:
- mm.0-4: Sprightly, single-note RH or 2-note dyads. Light dance feel.
- mm.5-8: Half-note block chords, beginning to fill out. Bm7 (m.6).
- mm.9-12: Full A7 chords, 3-note RH + 4-note LH. Climactic D5 arrival.
- mm.13-16: IV-I-V7-I resolution sequence. Final m.16 settles root-pos D.
============================================================ -->
