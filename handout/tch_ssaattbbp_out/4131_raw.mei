            <!-- Bar 7: B A G c (= bar 3). Varied inversions -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m7n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m7n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m7n4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
