            <!-- Bar 9: A F E D = 4 quarters. Chords: F(1) Dm(1) Am(1) Bb(1)
                 New section — tonic arrival. -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m9n2" pname="f" oct="4" dur="4"/>
                  <note xml:id="m9n3" pname="e" oct="4" dur="4"/>
                  <note xml:id="m9n4" pname="d" oct="4" dur="4"/>
                </layer>
