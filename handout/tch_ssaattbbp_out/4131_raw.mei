            <!-- Bar 3: B A G c = 4 quarters. Chords: Gm(1) Dm(1) Eb→C(1) C(1) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m3n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m3n3" pname="g" oct="4" dur="4"/>
