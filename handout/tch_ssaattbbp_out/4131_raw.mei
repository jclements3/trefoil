                  <chord xml:id="m3r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m3r3" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm(1)=G2-D3-G3-Bb3, Dm(1)=D2-A2-D3, C(2)=C2-G2-C3-E3 -->
                <layer n="1">
                  <chord xml:id="m3l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="m3l3" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Bar 4: B A G G = 4 quarters. Chords: Gm(3) G→Gm(1)
                 The G chord annotation at the end = G major sub → keep Gm -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m4n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m4n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4n4" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Gm 7th: Bb4-D5-F5 for richness, then Gm plain -->
                <layer n="1">
                  <chord xml:id="m4r1" dur="2">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <chord xml:id="m4r2" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm(4)=G2-D3-G3-Bb3 -->
                <layer n="1">
                  <chord xml:id="m4l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m4l2" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Bars 5-8: repeat of bars 1-4. Varied voicings. -->

            <!-- Bar 5: B A G d (= bar 1). Varied: Gm 2nd inv, Dm 7th -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m5n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m5n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m5n4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Gm 1st inv "43": D4-G4-Bb4, Dm 1st inv: F4-A4-D5 -->
                <layer n="1">
                  <chord xml:id="m5r1" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5r2" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m5r3" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5r4" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm 2nd inv: D3-G3-Bb3, Dm7: D2-C3-F3-A3, Gm: G2-D3-G3, Dm: D2-A2-D3 -->
                <layer n="1">
                  <chord xml:id="m5l1" dur="4">
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m5l3" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m5l4" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m¹</harm>
              <harm staff="1" tstamp="2">⑥m7</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 6: d B A c (= bar 2). Varied: richer C voicing -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m6n2" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m6n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m6n4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Gm(1)=Bb4-D5, Dm(1)=F4-A4, C(2)=G4-C5-E5 -->
                <layer n="1">
                  <chord xml:id="m6r1" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m6r2" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m6r3" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm(1)=G2-D3-G3-Bb3, Dm(1)=D2-A2-D3-F3, C(2)=C2-G2-C3-E3 -->
                <layer n="1">
                  <chord xml:id="m6l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
