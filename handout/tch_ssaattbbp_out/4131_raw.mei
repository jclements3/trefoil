                <layer n="1">
                  <chord xml:id="m7l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m7l2" dur="4">
