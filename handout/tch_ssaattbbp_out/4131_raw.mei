            </measure>

            <!-- Bar 8: B A G G = 4 quarters. Chords: Gm(3) C(1)
                 C annotation at end instead of G (second time) -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m8n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m8n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m8n4" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Gm(2)=G4-Bb4-D5, C(2)=G4-C5 -->
                <layer n="1">
                  <chord xml:id="m8r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m8r2" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm(2)=G2-D3-G3-Bb3, C(2)=C2-G2-C3-E3 -->
                <layer n="1">
                  <chord xml:id="m8l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m8l2" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
