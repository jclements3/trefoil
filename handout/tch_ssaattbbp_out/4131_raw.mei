<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hymn 4131: Look Down, O Lord, From Heaven Behold
  Key: F major (1 flat: Bb)
  Meter: 4/4, L:1/4
  Has a 1-beat pickup bar (bar 0), then 14 full bars

  F major: F G A Bb C D E (Bb is in key signature)
  Diatonic degrees: I=F, ii=Gm, iii=Am, IV=Bb, V=C, vi=Dm, vii°=E°

  Non-diatonic substitutions:
    D major → Dm (vi in F, nearest diatonic minor)
    Cm      → C major (V in F, nearest diatonic)
    Eb      → C major (V in F) or Gm (ii); Eb is bVII = non-diatonic
    G major → Gm (ii in F, nearest diatonic)
    A major → Am (iii in F, nearest diatonic)

  Key-signature accidentals (accid.ges):
    B → accid.ges="f"  (Bb in key signature)
  Chromatic melody note ^F (F#) in bar 12 gets accid="s"

  Bar 0 (pickup, 1 beat): D context → A4 in melody
  Full bars 1-14.
  Bar 14 = 3 beats (final bar: c B A).

  VOICING PLAN:
  F major LH (root-P5-P8-3rd):
    F:  F2-C3-F3-A3
    Gm: G2-D3-G3-Bb3
    Am: A2-E3-A3-C4
    Bb: Bb2-F3-Bb3-D4
    C:  C2-G2-C3-E3
    Dm: D2-A2-D3-F3
    E°: E2-Bb2-E3 (diminished)
  RH (2-3 notes, treble):
    F:  A4-C5 or C4-F4-A4
    Gm: Bb4-D5 or G4-Bb4
    Am: C4-E4-A4 or E4-A4
    Bb: D4-F4-Bb4 or F4-Bb4
    C:  E4-G4-C5 or G4-C5
    Dm: F4-A4 or A4-D5
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Look Down, O Lord, From Heaven Behold</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="1f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="1f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="1f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Bar 0: pickup, 1 beat. Melody: A4. Chord context: D→Dm -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0n1" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH pickup: Dm color — F4 -->
                <layer n="1">
                  <note xml:id="m0r1" pname="f" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH pickup: Dm — D2-A2-D3 -->
                <layer n="1">
                  <chord xml:id="m0l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Bar 1: B A G d = 4 quarters. Chords: Gm(1) Dm(1) Gm(1) Dm(1)
                 B=Bb4 (in key), d=D5 -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m1n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m1n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1n4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Gm(1)=G4-Bb4, Dm(1)=F4-A4, Gm(1)=Bb4-D5, Dm(1)=A4-D5 -->
                <layer n="1">
                  <chord xml:id="m1r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m1r2" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m1r3" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m1r4" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm(1)=G2-D3-G3-Bb3, Dm(1)=D2-A2-D3-F3, Gm(1)=G2-D3-G3, Dm(1)=D2-A2-D3-F3 -->
                <layer n="1">
                  <chord xml:id="m1l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m1l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m1l3" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m1l4" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 2: d B A c = 4 quarters. Chords: Gm(1) Dm(1) C(1) substituted for Cm -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m2n2" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m2n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m2n4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Gm(1)=Bb4-D5, Dm(1)=F4-A4, C(2)=G4-C5 — Cm substituted by C -->
                <layer n="1">
                  <chord xml:id="m2r1" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m2r2" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m2r3" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Gm(1)=G2-D3-G3-Bb3, Dm(1)=D2-A2-D3-F3, C(2)=C2-G2-C3-E3 -->
                <layer n="1">
                  <chord xml:id="m2l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m2l3" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
