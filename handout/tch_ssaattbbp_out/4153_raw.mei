                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 G2 Eb3 Bb3 → Bb2 F3 Bb3 D4 (V) -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m3lh2" oct="2" pname="g"/>
                    <note xml:id="m3lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m3lh4" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m3lh6" oct="3" pname="f"/>
                    <note xml:id="m3lh7" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m3lh8" oct="4" pname="d"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" dur="2" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m3p2" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
