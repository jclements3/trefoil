                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 Bb2 Eb3 G3 → Bb2 F3 Bb3 D4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m5lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m5lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m5lh4" oct="3" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m5lh6" oct="3" pname="f"/>
                    <note xml:id="m5lh7" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m5lh8" oct="4" pname="d"/>
