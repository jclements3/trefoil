            <!-- Measure 7: Eb, Gm, Bb, Gm — melody E G B B -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m7n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m7n3" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m7n4" dur="4" oct="4" pname="b" accid.ges="f"/>
                </layer>
