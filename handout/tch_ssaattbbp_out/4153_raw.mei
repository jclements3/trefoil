            <!-- Measure 6: C(→vi=Cm), Dø7(→vii=D°→V=Bb), Eb — melody c c B2 -->
            <!-- D° = D F Ab (vii). Use V=Bb for smooth approach to Eb -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m6n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m6n3" dur="2" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 Eb5 → F4 Bb4 — stepwise descent -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh1" oct="4" pname="g"/>
                    <note xml:id="m6rh2" oct="5" pname="e" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh3" oct="4" pname="f"/>
                    <note xml:id="m6rh4" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 Eb3 G3 → Bb2 F3 Bb3 D4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh1" oct="2" pname="c"/>
                    <note xml:id="m6lh2" oct="2" pname="g"/>
                    <note xml:id="m6lh3" oct="3" pname="e" accid.ges="f"/>
