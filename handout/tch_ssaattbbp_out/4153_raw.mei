                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 Eb3 Bb3 → Bb2 F3 Bb3 → Eb2 Bb2 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh1" oct="2" pname="c"/>
                    <note xml:id="m4lh2" oct="2" pname="g"/>
                    <note xml:id="m4lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m4lh4" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh6" oct="3" pname="f"/>
                    <note xml:id="m4lh7" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m4p2" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 5: Eb, Cm, Bb, Eb — melody E G B B (climb) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m5n3" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m5n4" dur="4" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 Bb4 → Eb4 G4 → Bb4 D5 (climbing) -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh1" oct="4" pname="g"/>
                    <note xml:id="m5rh2" oct="4" pname="b" accid.ges="f"/>
