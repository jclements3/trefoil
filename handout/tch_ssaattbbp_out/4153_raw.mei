              <staff n="3">
                <!-- LH: C2 Eb2 G2 Bb3 → F2 C3 Ab3 → Bb2 F3 Bb3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8lh1" oct="2" pname="c"/>
                    <note xml:id="m8lh2" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m8lh3" oct="2" pname="g"/>
                    <note xml:id="m8lh4" oct="3" pname="b" accid.ges="f"/>
