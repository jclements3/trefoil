            <!-- Measure 8: Cm7, F(→ii=Fm), Bb — melody c c B2 -->
            <!-- F major → substitute Fm (ii): F Ab C -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m8n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m8n3" dur="2" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 → Ab4 C5 → Bb4 D4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m8rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
