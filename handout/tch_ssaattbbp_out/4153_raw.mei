                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m8lh6" oct="3" pname="f"/>
                    <note xml:id="m8lh7" oct="3" pname="b" accid.ges="f"/>
