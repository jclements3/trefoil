              </staff>
              <staff n="2">
                <!-- RH: G4 Eb4 → Ab4 C5 (Fm color) → G4 Bb4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m9rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m9rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m9rh3" oct="4" pname="f"/>
                    <note xml:id="m9rh4" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 Bb2 G3 → F2 C3 Ab3 → Eb2 Bb2 G3 -->
                <layer n="1">
