            <!-- Measure 9: Eb, G#°(→Fm/ii), Eb — melody E E F G (repeat of m1) -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m9n2" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m9n3" dur="4" oct="4" pname="f"/>
                  <note xml:id="m9n4" dur="4" oct="4" pname="g"/>
