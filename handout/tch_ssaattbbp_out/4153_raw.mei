                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2lh1" oct="2" pname="c"/>
                    <note xml:id="m2lh2" oct="2" pname="g"/>
                    <note xml:id="m2lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m2lh4" oct="3" pname="g"/>
