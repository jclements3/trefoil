              <staff n="2">
                <!-- RH: Eb4 G4 → G4 Bb4 D5 — building -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m7rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh3" oct="4" pname="g"/>
                    <note xml:id="m7rh4" oct="4" pname="b" accid.ges="f"/>
                    <note xml:id="m7rh5" oct="5" pname="d"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
