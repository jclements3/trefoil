                    <note xml:id="m6lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m6lh6" oct="3" pname="f"/>
                    <note xml:id="m6lh7" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m6lh8" oct="4" pname="d"/>
