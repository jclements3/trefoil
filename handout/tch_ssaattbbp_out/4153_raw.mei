            <!-- Measure 4: Cm7, Bb, Eb — melody F F E2 -->
            <!-- ii7 (Cm7=C Eb G Bb) → V (Bb) → I (Eb) -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="4" pname="f"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="f"/>
                  <note xml:id="m4n3" dur="2" oct="4" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 → F4 D4 (Bb/V) → Eb4 G4 (return) -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m4rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
