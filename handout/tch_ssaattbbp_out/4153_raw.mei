              <staff n="3">
                <!-- LH: Eb2 Bb2 G3 Eb4 → G2 D3 G3 Bb3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m7lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m7lh3" oct="3" pname="g"/>
