                  <note xml:id="m5p2" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
