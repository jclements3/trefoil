                    <note xml:id="m2lh5" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m2lh6" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m2lh7" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m2p2" dur="2" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
