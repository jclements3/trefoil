<?xml version="1.0" encoding="UTF-8"?>
<!-- 4153 To Avert From Men God's Wrath — pedal harp, key Eb, 4/4 -->
<!-- Key Eb: 3 flats — Bb, Eb, Ab. accid.ges="f" on B, E, A notes -->
<!-- Scale: Eb(1) F(2) G(3) Ab(4) Bb(5) C(6) D(7) -->
<!-- Chords: I=Eb, ii=Fm, iii=Gm, IV=Ab, V=Bb, vi=Cm, vii=D° -->
<!-- ABC:
  m1: Eb_E E Bb_F Eb_G
  m2: C_A3/2 A/2 Eb_G2
  m3: E Cm_E Bb_F Eb_G
  m4: Cm7_F Bb_F Eb_E2
  m5: E Cm_G Bb_B Eb_B
  m6: C_c Dm7(=Dø7)_c Eb_B2
  m7: E G Bb_B Gm_B
  m8: Cm7_c F_c Bb_B2
  m9: Eb_E E G#°_F Eb_G
  m10: C_A3/2 A/2 Eb_G2
  m11: E G#°_F Eb_G Fm_F
  m12: Eb_E Bb_D Eb_E2
-->
<!-- Non-diatonic: C major (→Cm/vi or Ab/IV sub), G#°(→D°/vii or Fm/ii sub), Dø7(→D°→vii or Bb/V) -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>To Avert From Men God's Wrath</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="3f">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="3f">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="3f">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Measure 1: Eb, Bb, Eb — melody E E F G -->
            <!-- I=Eb (Eb G Bb): "33" RH G4 Bb4; LH Eb2 Bb2 Eb3 G3 -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m1n2" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m1n3" dur="4" oct="4" pname="f"/>
                  <note xml:id="m1n4" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 Bb4 — light "33" I -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh1" oct="4" pname="g"/>
                    <note xml:id="m1rh2" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh3" oct="4" pname="f"/>
                    <note xml:id="m1rh4" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 Bb2 Eb3 G3 — "334" root+oct I -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m1lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m1lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m1lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m1lh4" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" dur="1" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: C(→vi=Cm), Eb — melody A3/2 A/2 G2 -->
            <!-- C major → substitute Cm (vi): C Eb G -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" dur="4d" oct="4" pname="a" accid.ges="f"/>
                  <note xml:id="m2n2" dur="8" oct="4" pname="a" accid.ges="f"/>
