                  <chord dur="1" stem.dir="up">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="b" oct="1" accid.ges="f" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤²</harm>
            </measure>

            <!-- M5: Eb B B/2 B/2 → ① ⑤ -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note pname="b" oct="4" accid.ges="f" dur="2"/>
                  <note pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="e" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                  <note pname="b" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
            </measure>

            <!-- M6: C c Eb B → ⑥ ① ⑤ -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note pname="c" oct="5" dur="2"/>
                  <note pname="b" oct="4" accid.ges="f" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
