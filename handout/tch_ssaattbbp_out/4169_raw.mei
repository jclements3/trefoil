                  <chord dur="2" stem.dir="up">
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="d" oct="4"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="c" oct="1" dur="2" stem.dir="down"/>
                  <note pname="b" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥</harm>
              <harm staff="1" tstamp="2">⑤</harm>
            </measure>

            <!-- M7: Cm7 A Eb G → ⑥7 ① ③ -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note pname="a" oct="4" accid.ges="f" dur="2"/>
                  <note pname="g" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- ⑥7 Cm7: Bb4 Eb5 G4 (333) -->
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <!-- ③ Gm: G4 Bb4 D5 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="4" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- ⑥7 Cm7: C2 G2 Bb2 Eb3 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- ③ Gm: G2 D3 Bb3 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="c" oct="1" dur="2" stem.dir="down"/>
                  <note pname="g" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥7</harm>
              <harm staff="1" tstamp="2">③</harm>
            </measure>

            <!-- M8: Bb F2 → ⑤ -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note pname="f" oct="4" dur="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- ⑤ Bb "333": Bb4 D5 F5 -->
                  <chord dur="1" stem.dir="up">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
