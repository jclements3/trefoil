                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <!-- ② Fm: Ab4 C5 -->
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="4" accid.ges="f"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="4" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="a" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="e" oct="1" accid.ges="f" dur="2" stem.dir="down"/>
                  <note pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note pname="f" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">③</harm>
              <harm staff="1" tstamp="2.5">②</harm>
            </measure>

            <!-- M10: Eb E/2 G/2 B/2 e/2 → ① ascending -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note pname="e" oct="4" accid.ges="f" dur="4"/>
                  <note pname="g" oct="4" dur="4"/>
                  <note pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note pname="e" oct="5" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="4"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="e" oct="4" accid.ges="f" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
