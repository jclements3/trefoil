<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Holy Spirit, Enter In</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal (raw, single-layer)</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Eb major: 3 flats. B→f, E→f, A→f everywhere (accid.ges="f") -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="3f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="3f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-10): First verse                             -->
            <!-- Eb major: I=Eb, ii=Fm, iii=Gm, IV=Ab, V=Bb, vi=Cm, vii°=D° -->
            <!-- Chord map: Bb=V, Eb=I, Cm=vi, F=II(sub→Fm=ii), Gm=iii,     -->
            <!--            F7=ii7, C=sub→Cm=vi (non-diatonic C major→Cm)    -->
            <!-- ============================================================ -->

            <!-- Measure 1: z(2) Eb4(2) — intro rests then pickup Eb4 -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <rest xml:id="m1s1r1" dur="2" />
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="e" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: rests then light Eb dyad -->
              <staff n="2">
                <layer n="1">
                  <rest xml:id="m1s2r1" dur="2" />
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="g" oct="4" />
                    <note xml:id="m1s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: rests then Eb2-Bb2 open 5th -->
              <staff n="3">
                <layer n="1">
                  <rest xml:id="m1s3r1" dur="2" />
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 2: "^Bb"Bb4(2) "^Eb"G4(2) — V→I -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="2" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m2s1n2" dur="2" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: Bb(V) F4-Bb4, then Eb(I) G4-Bb4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n1" pname="f" oct="4" />
                    <note xml:id="m2s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="2">
                    <note xml:id="m2s2n3" pname="g" oct="4" />
                    <note xml:id="m2s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3 | Eb2-Bb2-G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n2" pname="f" oct="3" />
                    <note xml:id="m2s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="2">
                    <note xml:id="m2s3n4" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n5" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n6" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 3: "^Cm"Eb4(2) "^Bb"Bb4(2) — vi→V -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="2" oct="4" pname="e" accid.ges="f" />
                  <note xml:id="m3s1n2" dur="2" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: Cm(vi) Eb-G | Bb(V) F-Bb -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="2">
                    <note xml:id="m3s2n3" pname="f" oct="4" />
                    <note xml:id="m3s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: C2-G2-Eb3 (Cm) | Bb2-F3-Bb3 (V) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="c" oct="2" />
                    <note xml:id="m3s3n2" pname="g" oct="2" />
                    <note xml:id="m3s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="2">
                    <note xml:id="m3s3n4" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n5" pname="f" oct="3" />
                    <note xml:id="m3s3n6" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 4: "^Cm7"C5 "^F"C5 "^Bb"Bb4(2) — vi7→ii→V -->
            <!-- F = ii in Eb (F minor diatonic, but "F" here might be F major chord) -->
            <!-- Sub F major with Fm (ii) to keep diatonic -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m4s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m4s1n3" dur="2" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: Cm7(vi7) G-C | Fm(ii) Ab-C | Bb(V) F-Bb -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="g" oct="4" />
                    <note xml:id="m4s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n4" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="f" oct="4" />
                    <note xml:id="m4s2n6" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: C2-G2-Eb3-G3 (Cm7) | F2-C3-F3 (Fm) | Bb2-F3-Bb3 (V) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="c" oct="2" />
                    <note xml:id="m4s3n2" pname="g" oct="2" />
                    <note xml:id="m4s3n3" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m4s3n4" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n5" pname="f" oct="2" />
                    <note xml:id="m4s3n6" pname="c" oct="3" />
                    <note xml:id="m4s3n7" pname="a" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n8" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n9" pname="f" oct="3" />
                    <note xml:id="m4s3n10" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 5: z Bb4 C5 D5 — rest + Bb4 C5 D5 (Cm7: vi, Gm: iii) -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <rest xml:id="m5s1r1" dur="4" />
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m5s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m5s1n3" dur="4" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: Cm7 then Gm — broken arpeggios -->
              <staff n="2">
                <layer n="1">
                  <rest xml:id="m5s2r1" dur="4" />
                  <note xml:id="m5s2n1" dur="4" pname="g" oct="4" />
                  <note xml:id="m5s2n2" dur="4" pname="b" oct="4" accid.ges="f" />
                  <note xml:id="m5s2n3" dur="4" pname="d" oct="5" />
                </layer>
              </staff>
              <!-- LH: Cm whole into Gm -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="c" oct="2" />
                    <note xml:id="m5s3n2" pname="g" oct="2" />
                    <note xml:id="m5s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="2">
                    <note xml:id="m5s3n4" pname="g" oct="2" />
                    <note xml:id="m5s3n5" pname="d" oct="3" />
                    <note xml:id="m5s3n6" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Measure 6: "^Eb"Eb5 "^Bb"D5 C5 "^F7"C5 — I, V, ii7 -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="5" pname="e" accid.ges="f" />
                  <note xml:id="m6s1n2" dur="4" oct="5" pname="d" />
                  <note xml:id="m6s1n3" dur="4" oct="5" pname="c" />
                  <note xml:id="m6s1n4" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: I→V→ii moving line, flowing -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="g" oct="4" />
                    <note xml:id="m6s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="f" oct="4" />
                    <note xml:id="m6s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="f" oct="4" />
                    <note xml:id="m6s2n6" pname="a" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s2c4" dur="4">
                    <note xml:id="m6s2n7" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m6s2n8" pname="a" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: Eb2-Bb2-Eb3 | Bb2-F3-Bb3 | F2-C3-Ab3 | F2-C3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m6s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m6s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m6s3n5" pname="f" oct="3" />
                    <note xml:id="m6s3n6" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n7" pname="f" oct="2" />
                    <note xml:id="m6s3n8" pname="c" oct="3" />
                    <note xml:id="m6s3n9" pname="a" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c4" dur="4">
                    <note xml:id="m6s3n10" pname="f" oct="2" />
                    <note xml:id="m6s3n11" pname="c" oct="3" />
                    <note xml:id="m6s3n12" pname="f" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">②m7</harm>
            </measure>

            <!-- Measure 7: "^Bb"Bb4(2) z Bb4 — V half, rest, V quarter -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="2" oct="4" pname="b" accid.ges="f" />
                  <rest xml:id="m7s1r1" dur="4" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: Bb(V) hold, then re-articulate -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="f" oct="4" />
                    <note xml:id="m7s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <rest xml:id="m7s2r1" dur="4" />
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="d" oct="4" />
                    <note xml:id="m7s2n4" pname="f" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: Bb2-F3-Bb3 half | rest | Bb2-D3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2">
                    <note xml:id="m7s3n1" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m7s3n2" pname="f" oct="3" />
                    <note xml:id="m7s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <rest xml:id="m7s3r1" dur="4" />
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m7s3n5" pname="d" oct="3" />
                    <note xml:id="m7s3n6" pname="f" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Measure 8: "^C"C5(2) "^Eb"Bb4(2) — C→sub Cm(vi), Eb(I) -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="5" pname="c" />
                  <note xml:id="m8s1n2" dur="2" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: Cm(vi) Eb-G→Eb(I) G-Bb -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="2">
                    <note xml:id="m8s2n1" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m8s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="2">
                    <note xml:id="m8s2n3" pname="g" oct="4" />
                    <note xml:id="m8s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: C2-G2-Eb3-G3 | Eb2-Bb2-Eb3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="2">
                    <note xml:id="m8s3n1" pname="c" oct="2" />
                    <note xml:id="m8s3n2" pname="g" oct="2" />
                    <note xml:id="m8s3n3" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m8s3n4" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="2">
                    <note xml:id="m8s3n5" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m8s3n6" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m8s3n7" pname="e" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 9: "^C"Ab4 "^Eb"G4 "^Bb"F4(2) — vi, I, V -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="4" oct="4" pname="a" accid.ges="f" />
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m9s1n3" dur="2" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: C(→Cm) Eb-G | Eb(I) G-Bb | Bb(V) F-D -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="4">
                    <note xml:id="m9s2n1" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m9s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m9s2c2" dur="4">
                    <note xml:id="m9s2n3" pname="g" oct="4" />
                    <note xml:id="m9s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m9s2c3" dur="2">
                    <note xml:id="m9s2n5" pname="f" oct="4" />
                    <note xml:id="m9s2n6" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: C2-G2-Eb3 | Eb2-Bb2-G3 | Bb2-F3-Bb3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="4">
                    <note xml:id="m9s3n1" pname="c" oct="2" />
                    <note xml:id="m9s3n2" pname="g" oct="2" />
                    <note xml:id="m9s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
                    <note xml:id="m9s3n4" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m9s3n5" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m9s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m9s3c3" dur="2">
                    <note xml:id="m9s3n7" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m9s3n8" pname="f" oct="3" />
                    <note xml:id="m9s3n9" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 10: "^Eb"Eb4(1) — I whole -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="1" oct="4" pname="e" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: Eb full spread G-Bb-Eb -->
              <staff n="2">
