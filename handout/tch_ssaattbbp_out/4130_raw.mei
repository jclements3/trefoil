                  <note xml:id="m2n1" pname="d" oct="4" dur="4"/>
                  <rest dur="8"/>
                  <note xml:id="m2n2" pname="d" oct="4" dur="8"/>
                  <note xml:id="m2n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m2n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Dm throughout: F4-A4 (2 beats), then A4-D5 (varied) -->
                <layer n="1">
                  <chord xml:id="m2r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m2r2" dur="2">
