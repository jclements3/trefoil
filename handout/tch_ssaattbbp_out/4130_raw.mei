            <!-- Bar 3: c d c B = 4 quarters. Chords: C(1) Dm(1) Am(1) (B=passing) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m3n2" pname="d" oct="5" dur="4"/>
