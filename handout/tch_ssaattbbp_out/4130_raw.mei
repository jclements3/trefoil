                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m8l4" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 9: A z/2 A/2 d d = A(1) rest(0.5) A(0.5) d(1) d(1) → 4 beats
                 Chords: Bm7→G(4) — using G throughout, bridge section -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="a" oct="4" dur="4"/>
                  <rest dur="8"/>
                  <note xml:id="m9n2" pname="a" oct="4" dur="8"/>
                  <note xml:id="m9n3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m9n4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- G(2)=B4-D5, G(2)=G4-B4 — descending RH figure -->
                <layer n="1">
                  <chord xml:id="m9r1" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m9r2" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- G(4)=G2-D3-G3-B3 sustained with rhythmic motion -->
                <layer n="1">
                  <chord xml:id="m9l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
