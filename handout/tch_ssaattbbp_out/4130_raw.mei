                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m3r3" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m3r4" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
