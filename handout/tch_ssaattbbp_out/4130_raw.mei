              <harm staff="1" tstamp="2">⑤¹</harm>
              <harm staff="1" tstamp="3">②m7</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 7: D z/2 D/2 A B (= bar 2). Dm sustained with rhythmic variety -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="d" oct="4" dur="4"/>
                  <rest dur="8"/>
                  <note xml:id="m7n2" pname="d" oct="4" dur="8"/>
