                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m1l4" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
