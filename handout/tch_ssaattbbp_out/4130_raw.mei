            <!-- Bar 1: E G F E = 4 quarters. Chords: C(1) Gm→G(1) Dm(1) A→Am(1) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1n3" pname="f" oct="4" dur="4"/>
