            <!-- Bars 5-8: repeat of bars 0-3. Varied voicings. -->

            <!-- Bar 5: D2 A A (= bar 0). Dm 1st inv, F quartal -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m5n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m5n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Dm 1st inv "43": A4-D5, F quartal "44": C5-F5 — lighter -->
                <layer n="1">
                  <chord xml:id="m5r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m5r2" dur="2">
                    <note pname="c" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
