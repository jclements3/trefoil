<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hymn 4130: If God Had Not Been on Our Side (in C)
  Key: C major (no sharps or flats)
  Meter: 4/4, L:1/4
  15 full bars

  C major scale degrees: I=C, ii=Dm, iii=Em, IV=F, V=G, vi=Am, vii°=B°

  Non-diatonic substitutions:
    Gm  → G major (V in C) — G minor not diatonic; G major is
    D major → Dm (ii in C) — secondary dominant substituted
    A major → Am (vi in C) — secondary dominant substituted
    Bm7 → G (V in C, shares common tones B-D) — Bm not diatonic in C
    Bb  → F (IV in C) — nearest diatonic below

  No key-signature accidentals needed (C major = all naturals).
  Natural signs in melody only where ABC source shows =.

  VOICING PLAN:
  LH (3-4 notes, open, root-P5-P8 with 3rd on top):
    C:  C2-G2-C3-E3
    Dm: D2-A2-D3-F3
    Em: E2-B2-E3-G3
    F:  F2-C3-F3-A3
    G:  G2-D3-G3-B3
    Am: A2-E3-A3-C4
    B°: B2-F3-B3 (diminished — omit 5th if needed)
  RH (2-3 notes, treble):
    C:  E4-G4 or G4-C5
    Dm: F4-A4 or D4-F4
    Em: G4-B4 or E4-G4
    F:  A4-C5 or F4-A4
    G:  B4-D5 or G4-B4
    Am: C4-E4-A4 or A4-C5
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>If God Had Not Been on Our Side (C major)</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Bar 0: D2 A A = D4(half) A4 A4. Chords: Dm(2) F(2) -->
            <measure n="0">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0n1" pname="d" oct="4" dur="2"/>
                  <note xml:id="m0n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m0n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- Dm(2)=F4-A4, F(2)=A4-C5 — light opening -->
                <layer n="1">
                  <chord xml:id="m0r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m0r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Dm(2)=D2-A2-D3-F3, F(2)=F2-C3-F3-A3 -->
                <layer n="1">
                  <chord xml:id="m0l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m0l2" dur="2">
