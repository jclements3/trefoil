              </staff>
              <staff n="3">
                <!-- C(1)=C2-G2-C3-E3, Dm(1)=D2-A2-D3-F3, Am(1)=A2-E3-A3-C4, C(1)=C2-G2-C3 -->
                <layer n="1">
                  <chord xml:id="m3l1" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m3l3" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m3l4" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 4: A4 = whole note A4. No chord annotation → sustain C or Am
