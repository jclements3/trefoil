            <!-- Bar 6: E G F E (= bar 1). Varied — C 1st inv, G 1st inv, Dm 7th, Am 1st inv -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m6n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m6n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m6n4" pname="e" oct="4" dur="4"/>
