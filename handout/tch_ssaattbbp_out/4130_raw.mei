                <layer n="1">
                  <chord xml:id="m4r1" dur="1">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- Am whole: A2-E3-A3-C4 -->
                <layer n="1">
                  <chord xml:id="m4l1" dur="1">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
