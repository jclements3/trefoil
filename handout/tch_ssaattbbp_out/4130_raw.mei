            <!-- Bar 8: c d c B (= bar 3). Richer 3-note RH throughout -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m8n2" pname="d" oct="5" dur="4"/>
