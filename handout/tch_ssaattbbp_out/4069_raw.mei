<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Sing, O Sing, This Blessed Morn</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- C major: no key signature accidentals; melody has chromatic passing tones (G#, F#) -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="0" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="0" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="0" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Joyful, bright — C, F, Am              -->
            <!-- ============================================================ -->

            <!-- Measure 1: 4 beats. C→B°(→vii°)→C. Melody: c5(4) B4(4) c5(4) E4(4) -->
            <!-- B°=vii° in C diatonic: B-D-F. Keep B natural in harp -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m1s1n3" dur="4" oct="5" pname="c" />
                  <note xml:id="m1s1n4" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: G4-C5(I), F4-B4(vii°), G4-C5(I), E4-G4(I 3rd) — bright open -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="4">
                    <note xml:id="m1s2n1" pname="g" oct="4" />
                    <note xml:id="m1s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="f" oct="4" />
                    <note xml:id="m1s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="g" oct="4" />
                    <note xml:id="m1s2n6" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c4" dur="4">
                    <note xml:id="m1s2n7" pname="e" oct="4" />
                    <note xml:id="m1s2n8" pname="g" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C3-G3-C4(I), B2-F3-B3(vii°), C3-G3-C4(I), C3-E3-G3(I close) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="4">
                    <note xml:id="m1s3n1" pname="c" oct="3" />
                    <note xml:id="m1s3n2" pname="g" oct="3" />
                    <note xml:id="m1s3n3" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="b" oct="2" />
                    <note xml:id="m1s3n5" pname="f" oct="3" />
                    <note xml:id="m1s3n6" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n7" pname="c" oct="3" />
                    <note xml:id="m1s3n8" pname="g" oct="3" />
                    <note xml:id="m1s3n9" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m1s3c4" dur="4">
                    <note xml:id="m1s3n10" pname="c" oct="3" />
                    <note xml:id="m1s3n11" pname="e" oct="3" />
                    <note xml:id="m1s3n12" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">①²</harm>
            </measure>

            <!-- Measure 2: 4 beats. F→C. Melody: F4(4) A4(4) G4(half) -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n3" dur="2" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: F4-A4(IV), G4-C5(I half) — F→C stepwise -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="f" oct="4" />
                    <note xml:id="m2s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="c" oct="4" />
                    <note xml:id="m2s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="2">
                    <note xml:id="m2s2n5" pname="g" oct="4" />
                    <note xml:id="m2s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(IV), C3-G3-C4(I half) — contrary motion (IV→I, ascending) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="f" oct="2" />
                    <note xml:id="m2s3n2" pname="c" oct="3" />
                    <note xml:id="m2s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="2">
                    <note xml:id="m2s3n4" pname="c" oct="3" />
                    <note xml:id="m2s3n5" pname="g" oct="3" />
                    <note xml:id="m2s3n6" pname="c" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 3: 4 beats. F→C→Am. Melody: A4(4) A4(4) G4(4) A4(4) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: F4-A4(IV), C4-A4(I2 or vi), G4-C5(I), E4-A4(vi) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="f" oct="4" />
                    <note xml:id="m3s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="e" oct="4" />
                    <note xml:id="m3s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n5" pname="g" oct="4" />
                    <note xml:id="m3s2n6" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c4" dur="4">
                    <note xml:id="m3s2n7" pname="e" oct="4" />
                    <note xml:id="m3s2n8" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(IV), C2-G2-E3(I 1st inv), C3-G3-C4(I), A2-E3-A3(vi) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="f" oct="2" />
                    <note xml:id="m3s3n2" pname="c" oct="3" />
                    <note xml:id="m3s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="c" oct="2" />
                    <note xml:id="m3s3n5" pname="g" oct="2" />
                    <note xml:id="m3s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="c" oct="3" />
                    <note xml:id="m3s3n8" pname="g" oct="3" />
                    <note xml:id="m3s3n9" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m3s3c4" dur="4">
                    <note xml:id="m3s3n10" pname="a" oct="2" />
                    <note xml:id="m3s3n11" pname="e" oct="3" />
                    <note xml:id="m3s3n12" pname="a" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Measure 4: 4 beats. G→C. Melody: G4(4) F4(4) E4(half) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="f" />
                  <note xml:id="m4s1n3" dur="2" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: G4-B4(V), F4-A4(IV), E4-G4(I→vi) — stepwise descent -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="g" oct="4" />
                    <note xml:id="m4s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="f" oct="4" />
                    <note xml:id="m4s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="e" oct="4" />
                    <note xml:id="m4s2n6" pname="g" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: G2-D3-G3(V), F2-C3-F3(IV), C3-G3-C4(I) half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="g" oct="2" />
                    <note xml:id="m4s3n2" pname="d" oct="3" />
                    <note xml:id="m4s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n4" pname="f" oct="2" />
                    <note xml:id="m4s3n5" pname="c" oct="3" />
                    <note xml:id="m4s3n6" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n7" pname="c" oct="3" />
                    <note xml:id="m4s3n8" pname="g" oct="3" />
                    <note xml:id="m4s3n9" pname="c" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Minor section — Am, E, darker color     -->
            <!-- ============================================================ -->

            <!-- Measure 5: 4 beats. Am→G#°(→vii°)→Am. Melody: c5(4) c5(4) B4(4) A4(4) -->
            <!-- G#° non-diatonic → vii°(B-D-F). Melody B is natural -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m5s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="b" />
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: A4-C5(vi), G4-B4(vii° or V), F4-B4(vii°), E4-A4(vi) — darker color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n1" pname="a" oct="4" />
                    <note xml:id="m5s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="g" oct="4" />
                    <note xml:id="m5s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c3" dur="4">
                    <note xml:id="m5s2n5" pname="f" oct="4" />
                    <note xml:id="m5s2n6" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c4" dur="4">
                    <note xml:id="m5s2n7" pname="e" oct="4" />
                    <note xml:id="m5s2n8" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: A2-E3-A3(vi), G2-D3-G3(V), B2-D3-F3(vii°), A2-E3-A3(vi) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4">
                    <note xml:id="m5s3n1" pname="a" oct="2" />
                    <note xml:id="m5s3n2" pname="e" oct="3" />
                    <note xml:id="m5s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="g" oct="2" />
                    <note xml:id="m5s3n5" pname="d" oct="3" />
                    <note xml:id="m5s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n7" pname="b" oct="2" />
                    <note xml:id="m5s3n8" pname="d" oct="3" />
                    <note xml:id="m5s3n9" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c4" dur="4">
                    <note xml:id="m5s3n10" pname="a" oct="2" />
                    <note xml:id="m5s3n11" pname="e" oct="3" />
                    <note xml:id="m5s3n12" pname="a" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Measure 6: 4 beats. E(→Em=iii)→Am. Melody: G#4(acc) B4(4) A4(half) -->
            <!-- E major non-diatonic → use iii (Em). G# is melodic chromatic — kept in melody only.
                 Harp plays Em (E-G-B) diatonically. Duration: G# has accid (sharp), B and A(half) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="g" accid="s" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m6s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: E4-G4(iii quartal 4th), B4-E5(iii sus open), A4-C5(vi) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="e" oct="4" />
                    <note xml:id="m6s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="b" oct="4" />
                    <note xml:id="m6s2n4" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="2">
                    <note xml:id="m6s2n5" pname="a" oct="4" />
                    <note xml:id="m6s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: E2-B2-E3(iii), E2-G2-B2(iii close), A2-E3-A3(vi) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="e" oct="2" />
                    <note xml:id="m6s3n2" pname="b" oct="2" />
                    <note xml:id="m6s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="e" oct="2" />
                    <note xml:id="m6s3n5" pname="g" oct="2" />
                    <note xml:id="m6s3n6" pname="b" oct="2" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="2">
                    <note xml:id="m6s3n7" pname="a" oct="2" />
                    <note xml:id="m6s3n8" pname="e" oct="3" />
                    <note xml:id="m6s3n9" pname="a" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Measure 7: 4 beats. D(→ii=Dm)→Em. Melody: A4(dotted-qtr) G4(8) F#4(acc) G4(4) -->
            <!-- D major non-diatonic → Dm (ii). F# is melodic chromatic in melody only.
                 Duration: 1.5+0.5+1+1=4 beats OK -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="f" accid="s" />
                  <note xml:id="m7s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: A4-D5(ii open), G4-B4(V), F4-A4(IV→ii passing), E4-G4(iii) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4" dots="1">
                    <note xml:id="m7s2n1" pname="a" oct="4" />
                    <note xml:id="m7s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="8">
                    <note xml:id="m7s2n3" pname="g" oct="4" />
                    <note xml:id="m7s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="f" oct="4" />
                    <note xml:id="m7s2n6" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c4" dur="4">
                    <note xml:id="m7s2n7" pname="e" oct="4" />
                    <note xml:id="m7s2n8" pname="g" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: D2-A2-D3(ii), D2-A2-F3(ii 2nd inv), F2-C3-A3(IV passing), E2-B2-E3(iii) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4" dots="1">
                    <note xml:id="m7s3n1" pname="d" oct="2" />
                    <note xml:id="m7s3n2" pname="a" oct="2" />
                    <note xml:id="m7s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="8">
                    <note xml:id="m7s3n4" pname="d" oct="2" />
                    <note xml:id="m7s3n5" pname="a" oct="2" />
                    <note xml:id="m7s3n6" pname="f" oct="3" />
                  </chord>
