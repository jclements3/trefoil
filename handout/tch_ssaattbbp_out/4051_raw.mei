<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Away In A Manger</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- F major: 1 flat (Bb). All B notes: accid.ges="f" -->
          <scoreDef meter.count="3" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1–5): Away in a manger — gentle, pastoral      -->
            <!-- ABC: "^F"c | c3/2 B/2 A | A3/2 G/2 F | "^Bb"F E D | "^F"C2 C -->
            <!-- ABC octave in F: C=C4, c=C5, B=Bb4 (key flat), D=D4, E=E4, F=F4, G=G4 -->
            <!-- ============================================================ -->

            <!-- Measure 1: 3 beats. PICKUP C5(1beat). F(I) -->
            <measure n="1" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="5" pname="c" />
                  <rest dur="2" />
                </layer>
              </staff>
              <!-- RH: single C5 anticipation note (light entry) -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m1s2n1" dur="4" pname="c" oct="5" />
                  <rest dur="2" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3 gentle open 5th -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="4">
                    <note xml:id="m1s3n1" pname="f" oct="2" />
                    <note xml:id="m1s3n2" pname="c" oct="3" />
                  </chord>
                  <rest dur="2" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: 3 beats. F(I). Melody: C5(1.5) Bb4(0.5) A4(1) -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" dots="1" oct="5" pname="c" />
                  <note xml:id="m2s1n2" dur="8" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: waltz bass pattern: F4(4) then A4-C5(4) A4(4) — light oom-pah-pah -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m2s2n1" dur="4" pname="f" oct="4" />
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n2" pname="a" oct="4" />
                    <note xml:id="m2s2n3" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m2s2n4" dur="4" pname="a" oct="4" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2(4) on beat1, C3-F3(4) on beat2, C3(4) on beat3 — waltz bass -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m2s3n1" dur="4" pname="f" oct="2" />
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n2" pname="c" oct="3" />
                    <note xml:id="m2s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="a" oct="2" />
                    <note xml:id="m2s3n5" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 3: 3 beats. F(I). Melody: A4(1.5) G4(0.5) F4(1) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m3s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: C4(4) low single, then A4-F4 descend -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m3s2n1" dur="4" pname="c" oct="5" />
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n2" pname="a" oct="4" />
                    <note xml:id="m3s2n3" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m3s2n4" dur="4" pname="f" oct="4" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2(4) A2-C3(4) F2(4) — same waltz pattern -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m3s3n1" dur="4" pname="f" oct="2" />
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n2" pname="a" oct="2" />
                    <note xml:id="m3s3n3" pname="c" oct="3" />
                  </chord>
                  <note xml:id="m3s3n4" dur="4" pname="f" oct="2" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 4: 3 beats. Bb(IV). Melody: F4(1) E4(1) D4(1) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m4s1n3" dur="4" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: Bb4(4) then D5(4) F5(4) — rising 3rds in IV -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m4s2n1" dur="4" pname="b" oct="4" accid.ges="f" />
                  <note xml:id="m4s2n2" dur="4" pname="d" oct="5" />
                  <note xml:id="m4s2n3" dur="4" pname="f" oct="5" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2(4) F3-Bb3(4) D3(4) — open IV voicing -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m4s3n1" dur="4" pname="b" oct="2" accid.ges="f" />
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n2" pname="f" oct="3" />
                    <note xml:id="m4s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <note xml:id="m4s3n4" dur="4" pname="d" oct="3" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
            </measure>

            <!-- Measure 5: 3 beats. F(I). Melody: C4(2) C4(1) — settling down low -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" oct="4" pname="c" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="c" />
                </layer>
              </staff>
              <!-- RH: F4-A4(half) then C5(4) — gentle settling -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="f" oct="4" />
                    <note xml:id="m5s2n2" pname="a" oct="4" />
                  </chord>
                  <note xml:id="m5s2n3" dur="4" pname="c" oct="5" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(half) then A2-C3(4) — back to I open root -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="f" oct="2" />
                    <note xml:id="m5s3n2" pname="c" oct="3" />
                    <note xml:id="m5s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="a" oct="2" />
                    <note xml:id="m5s3n5" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 6–9): "No crib for a bed" — C major phrase     -->
            <!-- ABC: "^C"C3/2 D/2 C | C G E | "^Bb"D C F | "^F"A2 c          -->
            <!-- ============================================================ -->

            <!-- Measure 6: 3 beats. C(V). Melody: C4(1.5) D4(0.5) C4(1) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" dots="1" oct="4" pname="c" />
                  <note xml:id="m6s1n2" dur="8" oct="4" pname="d" />
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="c" />
                </layer>
              </staff>
              <!-- RH: E4(4) then G4-C5(half) V 1st inv ascending -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m6s2n1" dur="4" pname="e" oct="4" />
                  <chord xml:id="m6s2c1" dur="2">
                    <note xml:id="m6s2n2" pname="g" oct="4" />
                    <note xml:id="m6s2n3" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: C2(4) G2-C3(4) G2-E3(4) — waltz V open bass -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m6s3n1" dur="4" pname="c" oct="2" />
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n2" pname="g" oct="2" />
                    <note xml:id="m6s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="g" oct="2" />
                    <note xml:id="m6s3n5" pname="e" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Measure 7: 3 beats. C(V). Melody: C4(1) G4(1) E4(1) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="c" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: G4(4) C5(4) E4(4) — arpeggiate V -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m7s2n1" dur="4" pname="g" oct="4" />
                  <note xml:id="m7s2n2" dur="4" pname="c" oct="5" />
                  <note xml:id="m7s2n3" dur="4" pname="e" oct="4" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: C2(4) G2-C3(4) E2-G2(4) — open V bass walk -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m7s3n1" dur="4" pname="c" oct="2" />
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n2" pname="g" oct="2" />
                    <note xml:id="m7s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="e" oct="2" />
                    <note xml:id="m7s3n5" pname="g" oct="2" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- Measure 8: 3 beats. Bb(IV). Melody: D4(1) C4(1) F4(1) -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" oct="4" pname="d" />
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="c" />
                  <note xml:id="m8s1n3" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: Bb4(4) D5(4) F4(4) — IV triad arpeggio -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m8s2n1" dur="4" pname="b" oct="4" accid.ges="f" />
                  <note xml:id="m8s2n2" dur="4" pname="d" oct="5" />
                  <note xml:id="m8s2n3" dur="4" pname="f" oct="4" />
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: Bb2(4) F3(4) D3-Bb2(4) — IV descend -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m8s3n1" dur="4" pname="b" oct="2" accid.ges="f" />
                  <chord xml:id="m8s3c1" dur="4">
                    <note xml:id="m8s3n2" pname="f" oct="3" />
                    <note xml:id="m8s3n3" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="4">
                    <note xml:id="m8s3n4" pname="d" oct="3" />
                    <note xml:id="m8s3n5" pname="b" oct="2" accid.ges="f" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
            </measure>

            <!-- Measure 9: 3 beats. F(I). Melody: A4(2) C5(1) — return high -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" oct="4" pname="a" />
                  <note xml:id="m9s1n2" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: A4-C5(half) then C5-F5(4) — ascend to refrain high -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="2">
                    <note xml:id="m9s2n1" pname="a" oct="4" />
                    <note xml:id="m9s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m9s2c2" dur="4">
                    <note xml:id="m9s2n3" pname="c" oct="5" />
                    <note xml:id="m9s2n4" pname="f" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2-C3-F3(half) then A2-F3(4) — I with A bass for color -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="f" oct="2" />
                    <note xml:id="m9s3n2" pname="c" oct="3" />
                    <note xml:id="m9s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
                    <note xml:id="m9s3n4" pname="a" oct="2" />
                    <note xml:id="m9s3n5" pname="f" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 3 (mm. 10–14): "Verse 2" — build with fuller voicing  -->
            <!-- ABC: c3/2 B/2 A | A3/2 G/2 F | "^Bb"F E D | "^F"C2 C         -->
            <!-- ============================================================ -->

            <!-- Measure 10: F(I). Melody: C5(1.5) Bb4(0.5) A4(1) — same as m.2 -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="4" dots="1" oct="5" pname="c" />
                  <note xml:id="m10s1n2" dur="8" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m10s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: richer — F4-A4-C5 (I "33" triad) with inner motion on beat2 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10s2c1" dur="4">
                    <note xml:id="m10s2n1" pname="f" oct="4" />
                    <note xml:id="m10s2n2" pname="a" oct="4" />
                    <note xml:id="m10s2n3" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m10s2c2" dur="4">
                    <note xml:id="m10s2n4" pname="a" oct="4" />
                    <note xml:id="m10s2n5" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m10s2c3" dur="4">
                    <note xml:id="m10s2n6" pname="f" oct="4" />
                    <note xml:id="m10s2n7" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2(4) C3-F3-A3(4) C3-F3(4) — fuller waltz -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m10s3n1" dur="4" pname="f" oct="2" />
                  <chord xml:id="m10s3c1" dur="4">
                    <note xml:id="m10s3n2" pname="c" oct="3" />
                    <note xml:id="m10s3n3" pname="f" oct="3" />
                    <note xml:id="m10s3n4" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m10s3c2" dur="4">
                    <note xml:id="m10s3n5" pname="a" oct="2" />
                    <note xml:id="m10s3n6" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 11: F(I). Melody: A4(1.5) G4(0.5) F4(1) -->
            <measure n="11" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m11s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m11s1n3" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: C5(4) A4-C5(4) F4-A4(4) — I descend -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m11s2n1" dur="4" pname="c" oct="5" />
                  <chord xml:id="m11s2c1" dur="4">
                    <note xml:id="m11s2n2" pname="a" oct="4" />
                    <note xml:id="m11s2n3" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m11s2c2" dur="4">
                    <note xml:id="m11s2n4" pname="f" oct="4" />
                    <note xml:id="m11s2n5" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <!-- LH: F2(4) A2-C3(4) F2-A2(4) -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m11s3n1" dur="4" pname="f" oct="2" />
                  <chord xml:id="m11s3c1" dur="4">
                    <note xml:id="m11s3n2" pname="a" oct="2" />
                    <note xml:id="m11s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m11s3c2" dur="4">
                    <note xml:id="m11s3n4" pname="f" oct="2" />
                    <note xml:id="m11s3n5" pname="a" oct="2" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" dots="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 12: Bb(IV). Melody: F4(1) E4(1) D4(1) -->
