              <!-- LH: E E2-B2-E3-G#3-B3 — widest final voicing -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m14s3c1" dur="2">
                    <note xml:id="m14s3n1" pname="e" oct="2"/>
