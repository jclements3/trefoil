            <!-- Bar 11: F#m — melody: F#4 A4. Minor color -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m11s1n2" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: F#m A4-C#5, F#m F#4-A4 — rocking inner voice -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m11s2c1" dur="4">
                    <note xml:id="m11s2n1" pname="a" oct="4"/>
                    <note xml:id="m11s2n2" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m11s2c2" dur="4">
                    <note xml:id="m11s2n3" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m11s2n4" pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: F#m F#2-C#3-F#3-A3 held -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11s3c1" dur="2">
                    <note xml:id="m11s3n1" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m11s3n2" pname="c" oct="3" accid.ges="s"/>
                    <note xml:id="m11s3n3" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m11s3n4" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 4 (mm. 12-14): Final cadence                          -->
            <!-- ============================================================ -->

            <!-- Bar 12: E Eb(→B) — melody: G#4 F#4. I→V anticipation -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12s1n1" dur="4" oct="4" pname="g" accid.ges="s"/>
                  <note xml:id="m12s1n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: E G#4-B4-E5 full, B F#4-B4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m12s2c1" dur="4">
                    <note xml:id="m12s2n1" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m12s2n2" pname="b" oct="4"/>
                    <note xml:id="m12s2n3" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m12s2c2" dur="4">
                    <note xml:id="m12s2n4" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m12s2n5" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: E E2-B2-E3-G#3, B B2-F#3-B3-D#4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12s3c1" dur="4">
                    <note xml:id="m12s3n1" pname="e" oct="2"/>
                    <note xml:id="m12s3n2" pname="b" oct="2"/>
                    <note xml:id="m12s3n3" pname="e" oct="3"/>
                    <note xml:id="m12s3n4" pname="g" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m12s3c2" dur="4">
                    <note xml:id="m12s3n5" pname="b" oct="2"/>
                    <note xml:id="m12s3n6" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m12s3n7" pname="b" oct="3"/>
                    <note xml:id="m12s3n8" pname="d" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
            </measure>

            <!-- Bar 13: E Eb(→B) — melody: G#4 F#4. Penultimate bar, mirrors bar 2 -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13s1n1" dur="4" oct="4" pname="g" accid.ges="s"/>
                  <note xml:id="m13s1n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: E E4-G#4-B4 full triad, B F#4-D#5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m13s2c1" dur="4">
                    <note xml:id="m13s2n1" pname="e" oct="4"/>
                    <note xml:id="m13s2n2" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m13s2n3" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m13s2c2" dur="4">
                    <note xml:id="m13s2n4" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m13s2n5" pname="d" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: E E2-B2-E3-G#3, B B2-F#3-B3-D#4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m13s3c1" dur="4">
                    <note xml:id="m13s3n1" pname="e" oct="2"/>
                    <note xml:id="m13s3n2" pname="b" oct="2"/>
                    <note xml:id="m13s3n3" pname="e" oct="3"/>
                    <note xml:id="m13s3n4" pname="g" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m13s3c2" dur="4">
                    <note xml:id="m13s3n5" pname="b" oct="2"/>
                    <note xml:id="m13s3n6" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m13s3n7" pname="b" oct="3"/>
                    <note xml:id="m13s3n8" pname="d" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
