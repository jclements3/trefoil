<?xml version="1.0" encoding="UTF-8"?>
<!-- Tis Good, Lord, To Be Here — Key of E (4 sharps: F# C# G# D#), 2/4
     Scale degrees in E: I=E ii=F#m iii=G#m IV=A V=B vi=C#m vii°=D#dim
     Non-diatonic substitutions:
       Eb (= D#) chord → use B(V) as dominant substitute [D# not in key, B is closest diatonic]
       Bb major → use B(V) [nearest diatonic whole step]
       C#7 → C#m(vi) [remove the 7th for diatonic purity]
       E major context: Eb in the ABC appears as a chromatic upper neighbor to E
     NOTE: Bars are 2/4 (2 beats each).
     Pickup: single quarter note E4
     All F, C, G, D must carry accid.ges="s"
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Tis Good, Lord, To Be Here</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="2" meter.unit="4" key.sig="4s">
