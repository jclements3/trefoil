                    <note xml:id="m14s3n3" pname="e" oct="3"/>
                    <note xml:id="m14s3n4" pname="g" oct="3" accid.ges="s"/>
                    <note xml:id="m14s3n5" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

          </section>
