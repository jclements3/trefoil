            <!-- Bar 14: E — melody: E4 (final). Whole-note equivalent in 2/4 = half note -->
            <measure n="14" right="final">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m14s1n1" dur="2" oct="4" pname="e"/>
