                  <note xml:id="m8s1n5" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <!-- RH: I Bb4-Eb5, vi G4-C5, ii Ab4-C5, V F4-Bb4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4">
