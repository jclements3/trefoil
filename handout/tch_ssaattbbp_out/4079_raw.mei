              <!-- LH: I Eb1 pedal + Eb2-Bb2-Eb3-G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="1">
                    <note xml:id="m9s3n1" pname="e" oct="1" accid.ges="f"/>
                    <note xml:id="m9s3n2" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m9s3n3" pname="b" oct="2" accid.ges="f"/>
                    <note xml:id="m9s3n4" pname="e" oct="3" accid.ges="f"/>
                    <note xml:id="m9s3n5" pname="g" oct="3"/>
                  </chord>
                </layer>
