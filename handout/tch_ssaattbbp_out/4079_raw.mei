                    <note xml:id="m8s2n8" pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I Eb2-Bb2-Eb3-G3, vi C2-G2-C3, ii F2-C3-Ab3-F4, V Bb2-F3-Bb3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="4">
                    <note xml:id="m8s3n1" pname="e" oct="2" accid.ges="f"/>
                    <note xml:id="m8s3n2" pname="b" oct="2" accid.ges="f"/>
