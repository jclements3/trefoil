                  </chord>
                  <chord xml:id="m7s2c4" dur="4">
                    <note xml:id="m7s2n7" pname="e" oct="4" accid.ges="f"/>
                    <note xml:id="m7s2n8" pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi C2-G2-C3-Eb3(dq), vi C2-Eb3(eq), iii G2-D3-G3-Bb3(q), vi C2-G2-C3(q) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4" dots="1">
                    <note xml:id="m7s3n1" pname="c" oct="2"/>
                    <note xml:id="m7s3n2" pname="g" oct="2"/>
                    <note xml:id="m7s3n3" pname="c" oct="3"/>
                    <note xml:id="m7s3n4" pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m7s3c2" dur="8">
                    <note xml:id="m7s3n5" pname="c" oct="2"/>
                    <note xml:id="m7s3n6" pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m7s3c3" dur="4">
                    <note xml:id="m7s3n7" pname="g" oct="2"/>
                    <note xml:id="m7s3n8" pname="d" oct="3"/>
                    <note xml:id="m7s3n9" pname="g" oct="3"/>
                    <note xml:id="m7s3n10" pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m7s3c4" dur="4">
