                    <note xml:id="m7s3n12" pname="g" oct="2"/>
                    <note xml:id="m7s3n13" pname="c" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- m8: Eb B(q) Cm c(q) Fm A/2 G/2(=1) Bb F(q) -->
            <!-- A/2 G/2 = Ab(8)+G(8) = 1 beat -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m8s1n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m8s1n3" dur="8" oct="4" pname="a" accid.ges="f"/>
