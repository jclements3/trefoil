            <!-- m7: Cm G(dq) Cm e(eq) Gm d(q) Cm c(q) -->
            <!-- "^C"G3/2 "^Cm"e/2 "^Gm"d "^C"c -->
            <!-- [Cm=vi all through: G(dq) e(eq) d(q) c(q)] — Gm = iii -->
            <!-- 1.5+0.5+1+1=4 ✓ -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" dots="1" oct="4" pname="g"/>
                  <note xml:id="m7s1n2" dur="8" oct="5" pname="e" accid.ges="f"/>
                  <note xml:id="m7s1n3" dur="4" oct="5" pname="d"/>
                  <note xml:id="m7s1n4" dur="4" oct="5" pname="c"/>
                </layer>
              </staff>
              <!-- RH: vi G4-C5(dq), vi Eb5-G5 too high use Eb4-C5(eq), iii D4-G4(q), vi C5-Eb5(q) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4" dots="1">
                    <note xml:id="m7s2n1" pname="g" oct="4"/>
                    <note xml:id="m7s2n2" pname="c" oct="5"/>
