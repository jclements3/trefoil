            </measure>

            <!-- Bar 15: Am Dm Am — Melody: B4 C5 D5 C5 — same as bar 3 -->
            <!-- Climax bar: fuller voicing, build intensity -->
            <measure n="15">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m15n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m15n3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m15n4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Richer RH: 3 notes now at climax: E4-A4-C5 (vi 7th), F4-A4-C5 (ii), E4-A4-C5 (vi) -->
                  <!-- Keep to 2 notes to not crowd melody C5 -->
                  <chord xml:id="m15r1" dur="4">
                    <note pname="e" oct="4"/>
