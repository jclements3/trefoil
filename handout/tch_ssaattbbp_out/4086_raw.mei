            <!-- Bar 11: C G F C — chords: I V IV I — Melody: G4 G4 F4 E4 -->
            <!-- RH: C4-E4, B3-D4, C4-F4, C4-E4 -->
            <!-- LH: I C2-G2-C3, V G2-D3-G3-B3, IV F2-C3-F3, I C2-G2-C3-E3 -->
