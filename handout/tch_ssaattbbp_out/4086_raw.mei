            <!-- Bar 12: D G C — Melody: D4 D4 C4(half) -->
            <!-- ABC: D "^G"D "^C"C2 -->
            <!-- Chords: ii(Dm sub D) V(G) I(C) -->
            <!-- D major is non-diatonic; use Dm(ii). -->
            <!-- RH: ii F3-A3→too low; use D4-F4, V B3-D4, I C4-E4 -->
            <!-- LH: ii D2-A2-D3-F3, V G2-D3-G3-B3, I C2-G2-C3 (2 beats) -->
