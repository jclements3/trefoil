                  <chord xml:id="m17l1" dur="1">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
            </measure>

          </section>
        </score>
      </mdiv>
