            </measure>

            <!-- Bar 16: E Am E — Melody: B4 C5 B4 B4(half) -->
            <!-- ABC: "^E"B "^Am"c "^E"B2 — E major sub Em -->
            <!-- Chords: iii(Em) vi(Am) iii(Em) -->
            <!-- Suspension: C5 from Am delayed before falling to B4 on iii -->
            <!-- RH: G4-B4, A4-C5, G4-B4 -->
            <!-- LH: iii E2-B2-E3-G3, vi A2-E3-A3-C3, iii E2-B2-E3 -->
            <measure n="16">
              <staff n="1">
                <layer n="1">
