            <!-- Bar 14: F B° E — Melody: A4 B4 G#(→G diatonic)4 E4 -->
            <!-- ABC: "^F"A "^B°"B "^E"^G E — same as bar 2 structure -->
            <!-- Chords: IV vii° iii(Em) -->
            <measure n="14">
              <staff n="1">
                <layer n="1">
