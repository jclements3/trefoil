                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m16l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <!-- iii E2-B2-E3 (2 beats) -->
                  <chord xml:id="m16l3" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Bar 17: Am whole note — final Am cadence -->
            <!-- Melody: A4 whole -->
            <!-- RH: A4-C5 whole (full 2-note chord) -->
            <!-- LH: A2-E3-A3-C3→use A2-C3-E3-A3 (root pos 7th shell) whole -->
            <measure n="17">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m17n1" pname="a" oct="4" dur="1"/>
                </layer>
