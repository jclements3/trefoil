            </measure>

            <!-- Bar 10: F E° F — chords: IV(F) vii°(E°) IV(F) -->
            <!-- Melody: F4 G4 A4(half) -->
            <!-- ABC: "^F"F "^E°"G "^F"A2 -->
            <!-- E° = E dim (E-G-Bb) — diatonic in C major; E° = vii° -->
            <!-- RH: F4-A4 (IV), E4-G4 (vii°), F4-A4 (IV) -->
            <!-- LH: IV F2-C3-F3-A3, vii° E2-B2-E3-G3, IV F2-C3-F3-A3 -->
            <measure n="10">
              <staff n="1">
