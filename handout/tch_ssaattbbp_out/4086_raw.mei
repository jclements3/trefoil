                  <note xml:id="m16n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m16n3" pname="b" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Suspension: hold G4 from iii through vi, resolves on next iii -->
                  <chord xml:id="m16r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m16r2" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <!-- iii: G4-B4 for 2 beats -->
                  <chord xml:id="m16r3" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
