<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Angels From the Realms of Glory</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- C major: no sharps or flats -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="0" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="0" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="0" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1–4): Opening — light texture, I→V7→I cadence  -->
            <!-- ============================================================ -->

            <!-- Measure 1: PICKUP, 2 beats. C major (I). Melody: G4(1) E4(1) -->
            <measure n="1" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: open 5th C5-G5 half — gentle entry -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="c" oct="5" />
                    <note xml:id="m1s2n2" pname="g" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" />
                </layer>
              </staff>
              <!-- LH: C3-G3-C4 root pos open, half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="c" oct="2" />
                    <note xml:id="m1s3n2" pname="g" oct="2" />
                    <note xml:id="m1s3n3" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="2" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: 4 beats. C(I)→G7(V7). Melody: C5(1) G4(1) E5(1.5) D5(0.5) -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n3" dur="4" dots="1" oct="5" pname="e" />
                  <note xml:id="m2s1n4" dur="8" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: beat1 E4-G4 (I), beat3 F4-A4 (passing to V7) — arpeggio feel -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n1" pname="e" oct="4" />
                    <note xml:id="m2s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="f" oct="4" />
                    <note xml:id="m2s2n4" pname="a" oct="4" />
                  </chord>
                  <note xml:id="m2s2n5" dur="4" pname="g" oct="4" />
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: beat1 C3-G3-E3 (I root), beat3 G2-D3-F3 (V7 open) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="c" oct="2" />
                    <note xml:id="m2s3n2" pname="g" oct="2" />
                    <note xml:id="m2s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="2">
                    <note xml:id="m2s3n4" pname="g" oct="2" />
                    <note xml:id="m2s3n5" pname="d" oct="3" />
                    <note xml:id="m2s3n6" pname="f" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Measure 3: 4 beats. C(I)→F(IV). Melody: C5(1) G4(1) A4(1) A4(1) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I on beat1 (E4-C5), IV on beat3 (F4-A4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="e" oct="4" />
                    <note xml:id="m3s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="2">
                    <note xml:id="m3s2n3" pname="f" oct="4" />
                    <note xml:id="m3s2n4" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: I root C2-G2-C3 (half), then IV F2-A2-C3 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="c" oct="2" />
                    <note xml:id="m3s3n2" pname="g" oct="2" />
                    <note xml:id="m3s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="2">
                    <note xml:id="m3s3n4" pname="f" oct="2" />
                    <note xml:id="m3s3n5" pname="c" oct="3" />
                    <note xml:id="m3s3n6" pname="f" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 4: 4 beats. C(I)→Am(vi)→G(V). Melody: G4(1) C5(1) G4(1) F4(1) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m4s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m4s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m4s1n4" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <!-- RH: I beat1 (E4-G4), vi beat2 (A4-C5), V beat3-4 (G4-D5) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="e" oct="4" />
                    <note xml:id="m4s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="a" oct="4" />
                    <note xml:id="m4s2n4" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="b" oct="4" />
                    <note xml:id="m4s2n6" pname="d" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C2-G2-C3(4) | A2-E3-A3(4) | G2-D3-G3(half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="c" oct="2" />
                    <note xml:id="m4s3n2" pname="g" oct="2" />
                    <note xml:id="m4s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n4" pname="a" oct="2" />
                    <note xml:id="m4s3n5" pname="e" oct="3" />
                    <note xml:id="m4s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n7" pname="g" oct="2" />
                    <note xml:id="m4s3n8" pname="d" oct="3" />
                    <note xml:id="m4s3n9" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5–8): Build — richer texture, inner motion     -->
            <!-- ============================================================ -->

            <!-- Measure 5: 4 beats. C(I). Melody: E4(2) G4(1) E4(1) -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" oct="4" pname="e" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: arpeggiate C4-E4-G4-C5 across 4 beats — ascending arp -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5s2n1" dur="4" pname="c" oct="4" />
                  <note xml:id="m5s2n2" dur="4" pname="e" oct="4" />
                  <note xml:id="m5s2n3" dur="4" pname="g" oct="4" />
                  <note xml:id="m5s2n4" dur="4" pname="c" oct="5" />
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C2-G2(half) sustained, then E3-C3 quarter-motion -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="c" oct="2" />
                    <note xml:id="m5s3n2" pname="g" oct="2" />
                    <note xml:id="m5s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="g" oct="2" />
                    <note xml:id="m5s3n5" pname="c" oct="3" />
                    <note xml:id="m5s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n7" pname="c" oct="2" />
                    <note xml:id="m5s3n8" pname="e" oct="3" />
                    <note xml:id="m5s3n9" pname="c" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 6: 4 beats. C(I)→Em(iii)→B°(vii°). Melody: C5(1) G4(1) E5(1.5) D5(0.5) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n3" dur="4" dots="1" oct="5" pname="e" />
                  <note xml:id="m6s1n4" dur="8" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: C5(4) for I, then B4-D5 (iii/vii°) beats 3-4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="2">
                    <note xml:id="m6s2n1" pname="e" oct="4" />
                    <note xml:id="m6s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="b" oct="4" />
                    <note xml:id="m6s2n4" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="b" oct="4" />
                    <note xml:id="m6s2n6" pname="d" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C2-G2-E3(half), then E2-B2-D3(half) for Em/B° -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="2">
                    <note xml:id="m6s3n1" pname="c" oct="2" />
                    <note xml:id="m6s3n2" pname="g" oct="2" />
                    <note xml:id="m6s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="2">
                    <note xml:id="m6s3n4" pname="e" oct="2" />
                    <note xml:id="m6s3n5" pname="b" oct="2" />
                    <note xml:id="m6s3n6" pname="d" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- Measure 7: 4 beats. Am(vi)→E(III)→Am(vi)→Em(iii). Melody: C5(1) B4(1) C5(1) B4(1) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m7s1n3" dur="4" oct="5" pname="c" />
                  <note xml:id="m7s1n4" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: Am=A4-C5, E=B4 (treat as diatonic B-D-G), Am again, Em=B4 -->
              <!-- Am vi: A4-C5. E non-diatonic → sub Em iii: B4-D5. Back to Am, then Em. -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="a" oct="4" />
                    <note xml:id="m7s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="b" oct="4" />
                    <note xml:id="m7s2n4" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="a" oct="4" />
                    <note xml:id="m7s2n6" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c4" dur="4">
                    <note xml:id="m7s2n7" pname="b" oct="4" />
                    <note xml:id="m7s2n8" pname="e" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: Am A2-E3-A3(4), E sub Em E2-B2-E3(4), Am A2-E3-A3(4), Em E2-G2-B2(4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="a" oct="2" />
                    <note xml:id="m7s3n2" pname="e" oct="3" />
                    <note xml:id="m7s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="e" oct="2" />
                    <note xml:id="m7s3n5" pname="b" oct="2" />
                    <note xml:id="m7s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="4">
                    <note xml:id="m7s3n7" pname="a" oct="2" />
                    <note xml:id="m7s3n8" pname="e" oct="3" />
                    <note xml:id="m7s3n9" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c4" dur="4">
                    <note xml:id="m7s3n10" pname="e" oct="2" />
                    <note xml:id="m7s3n11" pname="g" oct="2" />
                    <note xml:id="m7s3n12" pname="b" oct="2" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Measure 8: 4 beats. Am(vi)→Bm°→G(V)→D7(II7 chromatic → sub V7). -->
            <!-- Melody: A4(1) B4(0.5) C5(0.5) B4(1) A4(1) -->
            <!-- Bm is non-diatonic in C → sub ii°/vii° B-D-F. D7 is non-diatonic → sub V7 G chord -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m8s1n2" dur="8" oct="4" pname="b" />
                  <note xml:id="m8s1n3" dur="8" oct="5" pname="c" />
                  <note xml:id="m8s1n4" dur="4" oct="4" pname="b" />
                  <note xml:id="m8s1n5" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: A4-E5(4) vi, B4-D5(half) vii°, G4-D5(4) V -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="4">
                    <note xml:id="m8s2n1" pname="a" oct="4" />
                    <note xml:id="m8s2n2" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="2">
                    <note xml:id="m8s2n3" pname="b" oct="4" />
                    <note xml:id="m8s2n4" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m8s2c3" dur="4">
                    <note xml:id="m8s2n5" pname="g" oct="4" />
                    <note xml:id="m8s2n6" pname="d" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: A2-E3-A3(4), B2-D3-F3(half) vii°, G2-D3-G3(4) V -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="4">
                    <note xml:id="m8s3n1" pname="a" oct="2" />
                    <note xml:id="m8s3n2" pname="e" oct="3" />
                    <note xml:id="m8s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="2">
                    <note xml:id="m8s3n4" pname="b" oct="2" />
                    <note xml:id="m8s3n5" pname="d" oct="3" />
                    <note xml:id="m8s3n6" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c3" dur="4">
                    <note xml:id="m8s3n7" pname="g" oct="2" />
                    <note xml:id="m8s3n8" pname="d" oct="3" />
                    <note xml:id="m8s3n9" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 3 (mm. 9–13): Climax refrain — full texture           -->
            <!-- ============================================================ -->

            <!-- Measure 9: 4 beats. G(V). Melody: G4(2) D5(1.5) D5(0.5) -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" oct="4" pname="g" />
                  <note xml:id="m9s1n2" dur="4" dots="1" oct="5" pname="d" />
                  <note xml:id="m9s1n3" dur="8" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: G4-B4-D5 arpeggio across 4 beats (V root pos) -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m9s2n1" dur="4" pname="g" oct="4" />
                  <note xml:id="m9s2n2" dur="4" pname="b" oct="4" />
                  <note xml:id="m9s2n3" dur="4" pname="d" oct="5" />
