<?xml version="1.0" encoding="UTF-8"?>
<!-- 4162: Alleluia, Sing To Jesus! — Key: F major, 3/4 -->
<!-- F major: 1 flat (Bb). accid.ges="f" on all B notes. -->
<!-- This is the longest hymn (32 measures). Diatonic: F G A Bb C D E -->
<!-- ① = I = F, ② = ii = Gm, ③ = iii = Am, ④ = IV = Bb, ⑤ = V = C, ⑥ = vi = Dm, ⑦ = vii° = E° -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Alleluia, Sing To Jesus!</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="3" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="1f"/>
              </staffDef>
              <staffGrp symbol="brace">
