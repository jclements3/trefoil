                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!-- VERSE 1 (M1-8): F2 G F3/2 G/2 A Gm7 F A C Gm B F A Gm F C Gm F F3 -->
