<?xml version='1.0' encoding='utf-8'?>
<!-- MEI arrangement: O Chief of Cities Bethlehem (hymn 4076) -->
<!-- Key: D (2 sharps: F#, C#)  Meter: 3/4  L:1/4 = quarter note -->
<!-- 3/4 = 3 quarter notes per bar -->
<!-- Diatonic scale: D E F# G A B C# -->
<!-- Non-diatonic: E7→A (IV), C#°→Bm (vi) [not present actually] -->
<!-- ABC: pickup D | Bm D2 A E | D F2 G G | D F2 A E | D D2 G D | D A2 A | A A B c | D d2 G d |
         D d2 A A | Bm d2 E7 d | A c2 D A | G B2 B | D A2 Em G | A A2 D F | A E2 D F | G D2 A C | D D2 | -->
<!-- Measures and beat counts:
  Pickup: D(q) = 1 beat
  m1: Bm D(q) E(q) | A: D(h) + A E (hmm wait)
  Let me re-parse: "^D"D | "^Bm"D2 "^A"E | "^D"F2 "^G"G | "^D"F2 "^A"E | "^D"D2 "^G"D | "^D"A2 A | "^A"A B c | "^D"d2 "^G"d | "^D"d2 "^A"A | "^Bm"d2 "^E7"d | "^A"c2 "^D"A | "^G"B2 B | "^D"A2 "^Em"G | "^A"A2 "^D"F | "^A"E2 "^D"F | "^G"D2 "^A"C | "^D"D2 |]

  Pickup bar: D (q) = 1 beat
  m1: D(h) E(q) [Bm 2, A 1] = 3 beats ✓
  m2: F(h) G(q) [D 2, G 1] = 3 ✓
  m3: F(h) E(q) [D 2, A 1] = 3 ✓
  m4: D(h) D(q) [D 2, G 1] = 3 ✓
  m5: A(h) A(q) [D all] = 3 ✓
  m6: A(q) B(q) c(q) [A all] = 3 ✓
  m7: d(h) d(q) [D 2, G 1] = 3 ✓
  m8: d(h) A(q) [D 2, A 1] = 3 ✓
  m9: d(h) d(q) [Bm 2, E7→A 1] = 3 ✓
  m10: c(h) A(q) [A 2, D 1] = 3 ✓
  m11: B(h) B(q) [G all] = 3 ✓
  m12: A(h) G(q) [D 2, Em 1] = 3 ✓
  m13: A(h) F(q) [A 2, D 1] = 3 ✓
  m14: E(h) F(q) [A 2, D 1] = 3 ✓
  m15: D(h) C(q) [G 2, A 1] = 3 ✓
  m16 (final): D(h) [D] = 2 beats (open final bar)
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Chief of Cities Bethlehem</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="3" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="2s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- PHRASE 1 (mm. 0–4): Opening, light texture -->

            <!-- Pickup m0: D (q) 1 beat -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="4" pname="d"/>
                </layer>
              </staff>
              <!-- RH: D4-F#4 open 3rd -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m0s2c1" dur="4">
                    <note xml:id="m0s2n1" pname="d" oct="4"/>
                    <note xml:id="m0s2n2" pname="f" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D2-A2 open 5th pickup -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0s3c1" dur="4">
                    <note xml:id="m0s3n1" pname="d" oct="2"/>
                    <note xml:id="m0s3n2" pname="a" oct="2"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- m1: Bm D(h) A E(q) — vi(2) V(1) -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="d"/>
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="e"/>
                </layer>
              </staff>
              <!-- RH: vi D4-F#4(half), V A4-E5(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="d" oct="4"/>
                    <note xml:id="m1s2n2" pname="f" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="a" oct="4"/>
                    <note xml:id="m1s2n4" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi B2-F#3-B3(half), V A2-E3-A3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="b" oct="2"/>
                    <note xml:id="m1s3n2" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m1s3n3" pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="a" oct="2"/>
                    <note xml:id="m1s3n5" pname="e" oct="3"/>
                    <note xml:id="m1s3n6" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- m2: D F(h) G G(q) — I(2) IV(1) -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="2" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: I F#4-A4(half), IV G4-B4(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n1" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m2s2n2" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="g" oct="4"/>
                    <note xml:id="m2s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I D2-A2-D3(half), IV G2-D3-G3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="d" oct="2"/>
                    <note xml:id="m2s3n2" pname="a" oct="2"/>
                    <note xml:id="m2s3n3" pname="d" oct="3"/>
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="g" oct="2"/>
                    <note xml:id="m2s3n5" pname="d" oct="3"/>
                    <note xml:id="m2s3n6" pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- m3: D F(h) A E(q) — I(2) V(1) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="2" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="e"/>
                </layer>
              </staff>
              <!-- RH: I D4-F#4(half), V A4-C#5(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="d" oct="4"/>
                    <note xml:id="m3s2n2" pname="f" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="a" oct="4"/>
                    <note xml:id="m3s2n4" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I D2-A2-F#3(half), V A2-E3-A3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="d" oct="2"/>
                    <note xml:id="m3s3n2" pname="a" oct="2"/>
                    <note xml:id="m3s3n3" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="a" oct="2"/>
                    <note xml:id="m3s3n5" pname="e" oct="3"/>
                    <note xml:id="m3s3n6" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
