                    <note xml:id="m9s2n4" pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi B2-F#3-B3-D4(half), V A2-E3-A3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="b" oct="2"/>
                    <note xml:id="m9s3n2" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m9s3n3" pname="b" oct="3"/>
                    <note xml:id="m9s3n4" pname="d" oct="4"/>
