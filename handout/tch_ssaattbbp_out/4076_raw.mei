                    <note xml:id="m5s2n1" pname="a" oct="4"/>
                    <note xml:id="m5s2n2" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m5s2n4" pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I D2-A2-D3 open, add 7th C#3 for color -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2" dots="1">
                    <note xml:id="m5s3n1" pname="d" oct="2"/>
                    <note xml:id="m5s3n2" pname="a" oct="2"/>
                    <note xml:id="m5s3n3" pname="d" oct="3"/>
                    <note xml:id="m5s3n4" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- m6: A A(q) B(q) c(q) — V all bar, ascending line -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="b"/>
                  <note xml:id="m6s1n3" dur="4" oct="5" pname="c" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: V arpeggiate A4(q) C#5(q) E5(q) ascending -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m6s2n1" dur="4" pname="a" oct="4"/>
                  <note xml:id="m6s2n2" dur="4" pname="c" oct="5" accid.ges="s"/>
                  <note xml:id="m6s2n3" dur="4" pname="e" oct="5"/>
                </layer>
              </staff>
              <!-- LH: V A2-E3-A3 ascending arpeggio with passing -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="a" oct="2"/>
                    <note xml:id="m6s3n2" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n3" pname="a" oct="2"/>
                    <note xml:id="m6s3n4" pname="e" oct="3"/>
                    <note xml:id="m6s3n5" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n6" pname="a" oct="2"/>
                    <note xml:id="m6s3n7" pname="c" oct="3" accid.ges="s"/>
                    <note xml:id="m6s3n8" pname="e" oct="3"/>
                    <note xml:id="m6s3n9" pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- m7: D d(h) G d(q) — I(2) IV(1) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="2" oct="5" pname="d"/>
                  <note xml:id="m7s1n2" dur="4" oct="5" pname="d"/>
                </layer>
              </staff>
              <!-- RH: I D5-F#5(half), IV D5-G5(quarter) descending -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="d" oct="5"/>
                    <note xml:id="m7s2n2" pname="f" oct="5" accid.ges="s"/>
                  </chord>
