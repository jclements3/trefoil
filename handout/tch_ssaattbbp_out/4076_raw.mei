            <!-- m10: A c(h) D A(q) — V(2) I(1) -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="2" oct="5" pname="c" accid.ges="s"/>
                  <note xml:id="m10s1n2" dur="4" oct="4" pname="a"/>
