            <!-- PHRASE 3 (mm. 9–12): Secondary dominant color, richer -->

            <!-- m9: Bm d(h) A d(q) — vi(2) V(1) — E7→A substituted with vi then V -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
