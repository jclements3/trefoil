            <!-- m4: D D(h) G D(q) — I(2) IV(1) -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="4" pname="d"/>
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="d"/>
                </layer>
              </staff>
              <!-- RH: I D4-A4(half) quartal, IV G4-D5(quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="d" oct="4"/>
                    <note xml:id="m4s2n2" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="g" oct="4"/>
                    <note xml:id="m4s2n4" pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: I D2-A2-D3-F#3(half), IV G2-D3-G3(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="d" oct="2"/>
                    <note xml:id="m4s3n2" pname="a" oct="2"/>
                    <note xml:id="m4s3n3" pname="d" oct="3"/>
                    <note xml:id="m4s3n4" pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n5" pname="g" oct="2"/>
                    <note xml:id="m4s3n6" pname="d" oct="3"/>
                    <note xml:id="m4s3n7" pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- PHRASE 2 (mm. 5–8): Rising phrase, build texture -->

            <!-- m5: D A(h) A(q) — I all bar -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
