                <layer n="1">
                  <chord xml:id="m10s2c1" dur="2">
                    <note xml:id="m10s2n1" pname="a" oct="4"/>
                    <note xml:id="m10s2n2" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m10s2c2" dur="4">
                    <note xml:id="m10s2n3" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m10s2n4" pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
