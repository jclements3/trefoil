              <!-- LH: I D2-A2-D3-F#3(half), IV G2-B3-D4(quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2">
                    <note xml:id="m7s3n1" pname="d" oct="2"/>
                    <note xml:id="m7s3n2" pname="a" oct="2"/>
                    <note xml:id="m7s3n3" pname="d" oct="3"/>
