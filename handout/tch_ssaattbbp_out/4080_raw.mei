                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="d" oct="2"/>
                    <note xml:id="m5s3n2" pname="a" oct="2"/>
                    <note xml:id="m5s3n3" pname="d" oct="3"/>
                    <note xml:id="m5s3n4" pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m5s3c2" dur="2">
                    <note xml:id="m5s3n5" pname="a" oct="2"/>
                    <note xml:id="m5s3n6" pname="d" oct="3"/>
                    <note xml:id="m5s3n7" pname="f" oct="3"/>
                    <note xml:id="m5s3n8" pname="a" oct="3"/>
                  </chord>
                </layer>
