            <!-- Bar 4: C Em F C — melody: C5 B4 A4 G4. One chord per beat -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="b"/>
                  <note xml:id="m4s1n3" dur="4" oct="4" pname="a"/>
                  <note xml:id="m4s1n4" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: descending counterpoint — C: E4-G4, Em: G4-B4, F: F4-A4, C: E4-G4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="e" oct="4"/>
                    <note xml:id="m4s2n2" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="g" oct="4"/>
                    <note xml:id="m4s2n4" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m4s2c3" dur="4">
