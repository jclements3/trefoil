<?xml version="1.0" encoding="UTF-8"?>
<!-- To Jordan Came Our Lord, The Christ — Key of C, 4/4
     Non-diatonic substitutions: E→Em(iii), A→Am(vi), Bb→F(IV)/Bdim(vii°), Gm→Am(vi)
     Scale degrees in C: I=C ii=Dm iii=Em IV=F V=G vi=Am vii°=Bdim
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>To Jordan Came Our Lord, The Christ</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-5): First statement — light opening texture  -->
            <!-- ============================================================ -->

            <!-- Bar 1: Dm G — melody: D4(2) F4(1) G4(1). Chords: Dm(beat1) G(beat3) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="d"/>
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="f"/>
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <!-- RH: Dm→G, 2-note figures. Beat1: F4-A4 (Dm 3rd+5th), beat3: G4-B4 (G 1st+3rd) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="f" oct="4"/>
                    <note xml:id="m1s2n2" pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m1s2c2" dur="2">
                    <note xml:id="m1s2n3" pname="g" oct="4"/>
                    <note xml:id="m1s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Dm beat1-2: D2-A2-D3-F3 open voicing; G beat3-4: G2-D3-G3-B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="d" oct="2"/>
                    <note xml:id="m1s3n2" pname="a" oct="2"/>
                    <note xml:id="m1s3n3" pname="d" oct="3"/>
                    <note xml:id="m1s3n4" pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c2" dur="2">
                    <note xml:id="m1s3n5" pname="g" oct="2"/>
                    <note xml:id="m1s3n6" pname="d" oct="3"/>
                    <note xml:id="m1s3n7" pname="g" oct="3"/>
                    <note xml:id="m1s3n8" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Bar 2: Am Em Am E(→Em) — melody: A4 G4 C5 B4. One chord per beat -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m2s1n3" dur="4" oct="5" pname="c"/>
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <!-- RH: quarter arpeggiation — Am: A4-C5, Em: G4-B4, Am: A4-E5, Em: B4-E5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="a" oct="4"/>
                    <note xml:id="m2s2n2" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="g" oct="4"/>
                    <note xml:id="m2s2n4" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="a" oct="4"/>
                    <note xml:id="m2s2n6" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m2s2c4" dur="4">
                    <note xml:id="m2s2n7" pname="b" oct="4"/>
                    <note xml:id="m2s2n8" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Am: A2-E3-A3-C4, Em: E2-B2-E3-G3, Am: A2-E3-A3, Em: E2-B2-E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="a" oct="2"/>
                    <note xml:id="m2s3n2" pname="e" oct="3"/>
                    <note xml:id="m2s3n3" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="e" oct="2"/>
                    <note xml:id="m2s3n5" pname="b" oct="2"/>
                    <note xml:id="m2s3n6" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="a" oct="2"/>
                    <note xml:id="m2s3n8" pname="e" oct="3"/>
                    <note xml:id="m2s3n9" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m2s3c4" dur="4">
                    <note xml:id="m2s3n10" pname="e" oct="2"/>
                    <note xml:id="m2s3n11" pname="b" oct="2"/>
                    <note xml:id="m2s3n12" pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Bar 3: Am(3) Dm — melody: A4(3) A4(1). Sustained Am then Dm -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="2" dots="1" oct="4" pname="a"/>
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: Am dotted half A4-C5, then Dm F4-A4 quarter -->
              <staff n="2">
                <layer n="1">
