                  <chord xml:id="m4s3c3" dur="4">
                    <note xml:id="m4s3n8" pname="f" oct="2"/>
                    <note xml:id="m4s3n9" pname="c" oct="3"/>
                    <note xml:id="m4s3n10" pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m4s3c4" dur="4">
                    <note xml:id="m4s3n11" pname="c" oct="2"/>
                    <note xml:id="m4s3n12" pname="g" oct="2"/>
                    <note xml:id="m4s3n13" pname="c" oct="3"/>
