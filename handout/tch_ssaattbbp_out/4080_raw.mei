              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 5: Dm — melody: F4 E4 D4(2). Rocking figure on Dm -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="f"/>
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="e"/>
                  <note xml:id="m5s1n3" dur="2" oct="4" pname="d"/>
                </layer>
              </staff>
              <!-- RH: Dm arpeggio ascending F4(4) A4(4) then A4-D5 half -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5s2n1" dur="4" pname="f" oct="4"/>
                  <note xml:id="m5s2n2" dur="4" pname="a" oct="4"/>
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n3" pname="a" oct="4"/>
                    <note xml:id="m5s2n4" pname="d" oct="5"/>
                  </chord>
