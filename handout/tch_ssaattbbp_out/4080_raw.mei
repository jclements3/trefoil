                  <chord xml:id="m6s3c2" dur="2">
                    <note xml:id="m6s3n5" pname="g" oct="2"/>
                    <note xml:id="m6s3n6" pname="d" oct="3"/>
                    <note xml:id="m6s3n7" pname="g" oct="3"/>
