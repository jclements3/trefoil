                  <note xml:id="m6s1n1" dur="2" oct="4" pname="d"/>
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="f"/>
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="g"/>
