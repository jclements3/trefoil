                    <note xml:id="m3s2n1" pname="a" oct="4"/>
                    <note xml:id="m3s2n2" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="f" oct="4"/>
                    <note xml:id="m3s2n4" pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Am A2-E3-A3-C4 dotted half, Dm D3-A3-D4 quarter -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2" dots="1">
                    <note xml:id="m3s3n1" pname="a" oct="2"/>
                    <note xml:id="m3s3n2" pname="e" oct="3"/>
                    <note xml:id="m3s3n3" pname="a" oct="3"/>
                    <note xml:id="m3s3n4" pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n5" pname="d" oct="3"/>
                    <note xml:id="m3s3n6" pname="a" oct="3"/>
                    <note xml:id="m3s3n7" pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="4">②m</harm>
