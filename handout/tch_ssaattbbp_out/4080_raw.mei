            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 6-10): Repeat of phrase 1 — fuller texture     -->
            <!-- ============================================================ -->

            <!-- Bar 6: Dm G — same as bar 1 but richer -->
