<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Abide, O Dearest Jesus</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!-- Pickup measure: 1 beat. Melody: Eb4. Chord: Eb major -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0n1" pname="e" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0r1" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0l1" dur="4">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 1: G F G A = 4 beats. Chords: Eb(G), Bb(F), Eb(G), Cm(A) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1n2" pname="f" oct="4" dur="4"/>
                  <note xml:id="m1n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1n4" pname="a" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: light 2-note figures, quarter arpeggiation -->
                  <chord xml:id="m1r1" dur="2">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m1r2" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- LH: open voicing Eb: Eb2 Bb2 Eb3 G3 -->
                  <chord xml:id="m1l1" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <!-- Bb: Bb1 F2 Bb2 D3 — but P bass Bb1 is below C2, use Bb2 for lever -->
                  <chord xml:id="m1l2" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 2: B2 G c = 4 beats. Chords: Bb(B2), Eb(G), Cm(c) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="b" oct="4" dur="2" accid.ges="f"/>
                  <note xml:id="m2n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m2n3" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="2">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <chord xml:id="m2r2" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <chord xml:id="m2l2" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 3: B3/2 A/2 G F = 4 beats. Chords: Eb(B), Fm(A), Eb(G), Bb(F) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="b" oct="4" dur="4" dots="1" accid.ges="f"/>
                  <note xml:id="m3n2" pname="a" oct="4" dur="8" accid.ges="f"/>
                  <note xml:id="m3n3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m3n4" pname="f" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Varied: quarter then dotted quarter on Eb, then Bb -->
                  <chord xml:id="m3r1" dur="2">
                    <note pname="e" oct="5" accid.ges="f"/>
                    <note pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m3r2" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Eb open: Eb2 Bb2 Eb3 G3 -->
                  <chord xml:id="m3l1" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <!-- Bb: Bb2 F3 Bb3 D4 -->
                  <chord xml:id="m3l2" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 4: G2 z B = 4 beats. Chords: Eb(G2), rest, Cm(B) -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="g" oct="4" dur="2"/>
                  <rest dur="4"/>
                  <note xml:id="m4n2" pname="b" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <rest dur="4"/>
                  <!-- Pickup to next phrase: Bb5 for Cm -->
                  <note xml:id="m4r2" pname="e" oct="5" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <rest dur="4"/>
                  <!-- Cm: C2 G2 C3 Eb3 -->
                  <chord xml:id="m4l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 5: c c d e = 4 beats. Chords: C(c), Cm(c), Bb(d), Eb(e) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m5n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m5n3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m5n4" pname="e" oct="5" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Ascending figure: G4 Ab4 Bb4 C5 -->
                  <note xml:id="m5r1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m5r2" pname="a" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m5r3" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m5r4" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C minor: C2 G2 C3 Eb3 -->
                  <chord xml:id="m5l1" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- Bb: Bb2 F3 Bb3 D4 -->
                  <chord xml:id="m5l2" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 6: c2 B G = 4 beats. Chords: C(c2), Eb(B,G) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="c" oct="5" dur="2"/>
                  <note xml:id="m6n2" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m6n3" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Suspension: hold G4 then resolve to F4 -->
                  <chord xml:id="m6r1" dur="2">
                    <note pname="e" oct="5" accid.ges="f"/>
                    <note pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m6r2" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C as diatonic sub (III in Eb): C2 G2 C3 E3 — but E->Eb -->
                  <chord xml:id="m6l1" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- Eb: Eb2 Bb2 Eb3 G3 -->
                  <chord xml:id="m6l2" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 7: F E E D = 4 beats. Chords: Fm(F), Eb(E), Cm7(E), Bb(D) -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m7n2" pname="e" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m7n3" pname="e" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m7n4" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Descending chromatic-adjacent line: Ab4 G4 G4 F4 -->
                  <note xml:id="m7r1" pname="a" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m7r2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m7r3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m7r4" pname="f" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Fm: F2 C3 F3 Ab3 -->
                  <chord xml:id="m7l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- Bb: Bb2 F3 Bb3 D4 - cadential dominant -->
                  <chord xml:id="m7l2" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑥m7</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 8: E3 = 3 beats (final). Chord: Eb -->
            <measure n="8" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="e" oct="4" dur="2" dots="1" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Final Eb chord: G4 Bb4 -->
                  <chord xml:id="m8r1" dur="2" dots="1">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Full Eb: Eb2 Bb2 Eb3 G3 -->
                  <chord xml:id="m8l1" dur="2" dots="1">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>
          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
<!--
VOICING PLAN:
- Opening (pickup, bars 1-2): Eb "33" root pos in LH (Eb2-Bb2-Eb3-G3), light RH thirds. Establishes stability.
- Bars 3-4: Eb root pos sustained in LH; Bb "43" 1st inv for color variety. Rest in bar 4 opens texture.
- Bar 5 (climax approach): Stepwise ascending line in RH (G4-Ab4-Bb4-C5) over Cm/Bb bass.
- Bar 6: Suspension in RH (Eb5-G5 held, then descends) over solid Eb LH.
- Bar 7 (pre-cadence): Fm → Bb passing motion; RH mirrors melody descent.
- Bar 8 (final): Dotted half Eb tonic, full open voicing.

VOICE LEADING HIGHLIGHTS:
- RH ascending line in bar 5 (counterpoint to static melody C)
- Contrary motion bar 7: melody descends F-E-E-D, LH bass rises F→Bb
- Common tone G3 held in LH between Eb and Cm chords

TEXTURE ARC:
- Sparse pickup → growing bars 1-3 → breath (bar 4 rest) → climax bar 5 → gradual convergence → final cadence
-->
