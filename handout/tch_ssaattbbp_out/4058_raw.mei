<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>I Heard The Bells On Christmas Day</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: Eb major (3 flats: Bb, Eb, Ab). Meter: 4/4 with pickup E=Eb4 -->
          <!-- Diatonic: Eb F G Ab Bb C D -->
          <!-- Degrees: I=Eb, IIm=Fm, IIIm=Gm, IV=Ab, V=Bb, VIm=Cm, VII°=D° -->
          <!-- Non-diatonic substitutions: -->
          <!-- ^F→Fm(ii), C#°7→D°7(vii°7), G#=Ab(IV), F#°7→D°(vii°), EbΔ7→I, -->
          <!-- Dø7→vii°7(D°7), G(nat)→Gm(iii), Gm7→IIIm7, C(nat)→Cm(vi), G#=Ab=IV, F#°7→vii° -->
          <!-- NOTE: Eb is the key, so "E" in ABC = Eb4, "B" = Bb3/4, "A" = Ab3/4, etc. -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="3f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="3f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- Pickup: single Eb4 quarter note                               -->
            <!-- ABC: "^Eb"E — in Eb major, E = Eb4                           -->
            <!-- ============================================================ -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="4" pname="e" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: I open Eb4-G4 (quarter — light entry) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m0s2c1" dur="4">
                    <note xml:id="m0s2n1" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m0s2n2" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I Eb2-Bb2-Eb3 (quarter, open) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0s3c1" dur="4">
                    <note xml:id="m0s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m0s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m0s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- Measure 1: G3/2 "^Ebm"^F/2 "^Eb"G "^C#°7"G -->
            <!-- G=G4, ^F=F#4 non-diat→use Fm(ii) for F natural, G=G4, -->
            <!-- C#°7→D°7(vii°7 in Eb) -->
            <!-- Chords: Eb(I) Fm(ii) Eb(I) D°7(vii°7) -->
            <!-- Melody durations: G4 dotted quarter, F4 eighth, G4 quarter, G4 quarter -->
            <!-- ============================================================ -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <!-- ^F = F#4 in ABC but we treat as passing Fm(ii) — notate as F natural -->
                  <note xml:id="m1s1n2" dur="8" oct="4" pname="f" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m1s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: I Eb4-G4-Bb4 (dotted quarter), ii F4-Ab4 (8th), I G4-Bb4 (4), vii°7 D4-F4-Ab4 (4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="4" dots="1">
                    <note xml:id="m1s2n1" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m1s2n2" pname="g" oct="4" />
                    <note xml:id="m1s2n3" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="8">
                    <note xml:id="m1s2n4" pname="f" oct="4" />
                    <note xml:id="m1s2n5" pname="a" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n6" pname="g" oct="4" />
                    <note xml:id="m1s2n7" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s2c4" dur="4">
                    <note xml:id="m1s2n8" pname="d" oct="4" />
                    <note xml:id="m1s2n9" pname="f" oct="4" />
                    <note xml:id="m1s2n10" pname="a" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I Eb2-Bb2-Eb3 (dotted quarter), ii F2-C3-F3 (8th), I Eb2-Bb2-Eb3 (4), vii°7 D2-Ab2-D3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="4" dots="1">
                    <note xml:id="m1s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n3" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="8">
                    <note xml:id="m1s3n4" pname="f" oct="2" />
                    <note xml:id="m1s3n5" pname="c" oct="3" />
                    <note xml:id="m1s3n6" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n7" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n8" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n9" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s3c4" dur="4">
                    <note xml:id="m1s3n10" pname="d" oct="2" />
                    <note xml:id="m1s3n11" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m1s3n12" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑦°7</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- Measure 2: "^G#"A3/2 "^Gm"G/2 "^G#"A "^F#°7"=A -->
            <!-- G#=Ab(IV), Gm→IIIm(Gm), G#=Ab(IV), F#°7→D°(vii°) -->
            <!-- Melody: Ab4 dotted quarter, G4 eighth, Ab4 quarter, A(nat)4 quarter -->
            <!-- For A natural in melody: it's a chromatic passing tone — notate as A natural -->
            <!-- ============================================================ -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" dots="1" oct="4" pname="a" accid.ges="f" />
                  <note xml:id="m2s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="a" accid.ges="f" />
                  <!-- =A = A natural (accidental cancels flat) — passing tone -->
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="a" accid="n" />
                </layer>
              </staff>
              <!-- RH: IV Ab4-C5 (dotted quarter), iii G4-Bb4 (8th), IV Ab4-Eb5 (4), vii° D4-F4-Ab4 → use A nat passing (accid) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4" dots="1">
                    <note xml:id="m2s2n1" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m2s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="8">
                    <note xml:id="m2s2n3" pname="g" oct="4" />
                    <note xml:id="m2s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m2s2n6" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <!-- vii° passing: D4-F4 (just 2 voices, light) -->
                  <chord xml:id="m2s2c4" dur="4">
                    <note xml:id="m2s2n7" pname="d" oct="4" />
                    <note xml:id="m2s2n8" pname="f" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: IV Ab2-Eb3-Ab3 (dotted quarter, 4th+4th quartal), iii G2-D3-G3 (8th), IV Ab2-Eb3-Ab3 (4), D°2-Ab2-D3 (vii° 4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4" dots="1">
                    <note xml:id="m2s3n1" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n2" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n3" pname="a" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="8">
                    <note xml:id="m2s3n4" pname="g" oct="2" />
                    <note xml:id="m2s3n5" pname="d" oct="3" />
                    <note xml:id="m2s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n8" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n9" pname="a" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s3c4" dur="4">
                    <note xml:id="m2s3n10" pname="d" oct="2" />
                    <note xml:id="m2s3n11" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m2s3n12" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2.5">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- Measure 3: "^Eb"B e "^EbΔ7"d "^Cm"c -->
            <!-- Eb(I) Eb(I — e=Eb5) EbΔ7→I Cm(vi) -->
            <!-- Melody: Bb4, Eb5, D5 (Eb major 7th), C5 -->
            <!-- In ABC: B=Bb4, e=Eb5, d=D5, c=C5 -->
            <!-- ============================================================ -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m3s1n2" dur="4" oct="5" pname="e" accid.ges="f" />
                  <note xml:id="m3s1n3" dur="4" oct="5" pname="d" />
                  <note xml:id="m3s1n4" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: I G4-Bb4-Eb5 (4), I Bb4-Eb5 (4), IΔ7 G4-Bb4-D5 (4, add 7th color), vi Ab4-C5 (4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="g" oct="4" />
                    <note xml:id="m3s2n2" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n3" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n4" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n5" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n6" pname="g" oct="4" />
                    <note xml:id="m3s2n7" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n8" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c4" dur="4">
                    <note xml:id="m3s2n9" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n10" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I Eb2-Bb2-Eb3-G3 (4, rich), I Eb2-Bb2-Eb3 (4), IΔ7 Eb2-Bb2-D3-G3 (4), vi C2-G2-C3-Eb3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n2" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n3" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m3s3n4" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n5" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n6" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n7" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n8" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n9" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n10" pname="d" oct="3" />
                    <note xml:id="m3s3n11" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c4" dur="4">
                    <note xml:id="m3s3n12" pname="c" oct="2" />
                    <note xml:id="m3s3n13" pname="g" oct="2" />
                    <note xml:id="m3s3n14" pname="c" oct="3" />
                    <note xml:id="m3s3n15" pname="e" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">①Δ7</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- Measure 4: "^Dø7"c3/2 "^G#"B/2 B "^Eb"B -->
            <!-- Dø7→D°7(vii°7), G#=Ab(IV), Eb(I) -->
            <!-- Melody: C5 dotted quarter, Bb4 eighth, Bb4 quarter, Bb4 quarter -->
            <!-- ============================================================ -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" dots="1" oct="5" pname="c" />
                  <note xml:id="m4s1n2" dur="8" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m4s1n3" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m4s1n4" dur="4" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: vii°7 Ab4-C5-D4→use Ab4-C5(dotted quarter), IV Ab4-Eb5(8th), IV Bb4-Eb5(4), I Bb4-Eb5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4" dots="1">
                    <note xml:id="m4s2n1" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="8">
                    <note xml:id="m4s2n3" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n4" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="4">
                    <note xml:id="m4s2n5" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n6" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m4s2c4" dur="4">
                    <note xml:id="m4s2n7" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n8" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vii°7 D2-Ab2-C3 (dotted quarter), IV Ab2-Eb3-Ab3 (8th), IV Ab2-Eb3-Ab3 (4), I Eb2-Bb2-Eb3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4" dots="1">
                    <note xml:id="m4s3n1" pname="d" oct="2" />
                    <note xml:id="m4s3n2" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="8">
                    <note xml:id="m4s3n4" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n5" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m4s3n6" pname="a" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="4">
                    <note xml:id="m4s3n7" pname="a" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n8" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m4s3n9" pname="a" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m4s3c4" dur="4">
                    <note xml:id="m4s3n10" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n11" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m4s3n12" pname="e" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°7</harm>
              <harm staff="1" tstamp="2.5">④</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- Measure 5: "^C"B3/2 A/2 "^Eb"G A -->
            <!-- C→Cm(vi), Eb(I), Eb(I) -->
            <!-- Melody: Bb4 dotted quarter, Ab4 eighth, G4 quarter, Ab4 quarter -->
            <!-- ============================================================ -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" dots="1" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m5s1n2" dur="8" oct="4" pname="a" accid.ges="f" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="a" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: vi G4-C5(dotted quarter), I G4-Bb4(8th), I G4-Eb5(4), I Eb4-Ab4(4 - 2nd inv) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4" dots="1">
                    <note xml:id="m5s2n1" pname="g" oct="4" />
                    <note xml:id="m5s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="8">
                    <note xml:id="m5s2n3" pname="g" oct="4" />
                    <note xml:id="m5s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s2c3" dur="4">
                    <note xml:id="m5s2n5" pname="g" oct="4" />
                    <note xml:id="m5s2n6" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s2c4" dur="4">
                    <note xml:id="m5s2n7" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m5s2n8" pname="a" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi C2-G2-C3-Eb3 (dotted quarter), I Eb2-Bb2-Eb3 (8th), I Eb2-Bb2-Eb3-G3 (4), I Eb2-Bb2-Eb3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4" dots="1">
                    <note xml:id="m5s3n1" pname="c" oct="2" />
                    <note xml:id="m5s3n2" pname="g" oct="2" />
                    <note xml:id="m5s3n3" pname="c" oct="3" />
                    <note xml:id="m5s3n4" pname="e" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="8">
                    <note xml:id="m5s3n5" pname="e" oct="2" accid.ges="f" />
                    <note xml:id="m5s3n6" pname="b" oct="2" accid.ges="f" />
