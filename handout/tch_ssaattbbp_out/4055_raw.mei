                  </chord>
                </layer>
              </staff>
              <!-- LH: F#2-C#3-F#3-A3 (vi full half), D2-A2-D3-F#3 (IV full half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m16s3c1" dur="2">
                    <note xml:id="m16s3n1" pname="f" oct="2" accid.ges="s" />
