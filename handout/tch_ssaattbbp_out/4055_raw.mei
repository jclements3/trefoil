<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Gentle Mary Laid Her Child</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: A major (3 sharps: F#, C#, G#), Meter: 4/4 -->
          <!-- Diatonic scale: A B C# D E F# G# -->
          <!-- Scale degrees: I=A, II=B, IIIm=C#m, IV=D, V=E, VIm=F#m, VII°=G#° -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="3s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="3s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="3s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Opening verse — light, flowing texture   -->
            <!-- ============================================================ -->

            <!-- Measure 1: "^A"A A "^F#m"A "^E"B -->
            <!-- Chords: A(I) A(I) F#m(vi) E(V) — 4/4 -->
            <!-- ABC: A=A4, A=A4, A=A4, B=B4 -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m1s1n4" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: I open 5th A4-E5 (half note), vi C#5-E5 (quarter), V B4-E5 (quarter) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="a" oct="4" />
                    <note xml:id="m1s2n2" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="c" oct="5" accid.ges="s" />
                    <note xml:id="m1s2n4" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="b" oct="4" />
                    <note xml:id="m1s2n6" pname="e" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3 (I open half), F#2-C#3-F#3 (vi quarter), E2-B2-E3 (V quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="a" oct="2" />
                    <note xml:id="m1s3n2" pname="e" oct="3" />
                    <note xml:id="m1s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="f" oct="2" accid.ges="s" />
                    <note xml:id="m1s3n5" pname="c" oct="3" accid.ges="s" />
                    <note xml:id="m1s3n6" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n7" pname="e" oct="2" />
                    <note xml:id="m1s3n8" pname="b" oct="2" />
                    <note xml:id="m1s3n9" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 2: "^A"A "^D"A "^E"E2 -->
            <!-- Chords: A(I) D(IV) E(V) whole -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n3" dur="2" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I A4-C#5(4), IV D4-F#4-A4(4), V E4-B4 whole (half note × 2) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="a" oct="4" />
                    <note xml:id="m2s2n2" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="d" oct="4" />
                    <note xml:id="m2s2n4" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n5" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="2">
                    <note xml:id="m2s2n6" pname="e" oct="4" />
                    <note xml:id="m2s2n7" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3 (I quarter), D2-A2-D3 (IV quarter), E2-B2-E3-G#3 (V7 half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="a" oct="2" />
                    <note xml:id="m2s3n2" pname="e" oct="3" />
                    <note xml:id="m2s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="d" oct="2" />
                    <note xml:id="m2s3n5" pname="a" oct="2" />
                    <note xml:id="m2s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="2">
                    <note xml:id="m2s3n7" pname="e" oct="2" />
                    <note xml:id="m2s3n8" pname="b" oct="2" />
                    <note xml:id="m2s3n9" pname="e" oct="3" />
                    <note xml:id="m2s3n10" pname="g" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Measure 3: "^D"F "^A"E "^D"F "^G#°"G -->
            <!-- Chords: D(IV) A(I) D(IV) G#°(vii°) -->
            <!-- G#° = G#-B-D — vii° in A major -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <!-- F=F#4, E=E4, F=F#4, G=G#4 -->
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="g" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: IV D4-F#4(4), I A4-C#5(4), IV D4-A4(4), vii° G#4-B4(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="d" oct="4" />
                    <note xml:id="m3s2n2" pname="f" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="a" oct="4" />
                    <note xml:id="m3s2n4" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n5" pname="d" oct="4" />
                    <note xml:id="m3s2n6" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c4" dur="4">
                    <note xml:id="m3s2n7" pname="g" oct="4" accid.ges="s" />
                    <note xml:id="m3s2n8" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D2-A2-D3 (IV root, open), A2-E3-A3 (I), D2-A2-D3 (IV), G#2-B2-D3 (vii°) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="d" oct="2" />
                    <note xml:id="m3s3n2" pname="a" oct="2" />
                    <note xml:id="m3s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="a" oct="2" />
                    <note xml:id="m3s3n5" pname="e" oct="3" />
                    <note xml:id="m3s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="d" oct="2" />
                    <note xml:id="m3s3n8" pname="a" oct="2" />
                    <note xml:id="m3s3n9" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c4" dur="4">
                    <note xml:id="m3s3n10" pname="g" oct="2" accid.ges="s" />
                    <note xml:id="m3s3n11" pname="b" oct="2" />
                    <note xml:id="m3s3n12" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- Measure 4: "^A"A2 A2 -->
            <!-- Chord: A(I) — whole measure, two half notes in melody -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="4" pname="a" />
                  <note xml:id="m4s1n2" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I arpeggiate — A4(4) C#5(4) E5(4) then hold C#5-E5 -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m4s2n1" dur="4" pname="a" oct="4" />
                  <note xml:id="m4s2n2" dur="4" pname="c" oct="5" accid.ges="s" />
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n3" pname="c" oct="5" accid.ges="s" />
                    <note xml:id="m4s2n4" pname="e" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I root A2(4) E3(4) A3(4) then converge A2-E3-A3 held half -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m4s3n1" dur="4" pname="a" oct="2" />
                  <note xml:id="m4s3n2" dur="4" pname="e" oct="3" />
                  <note xml:id="m4s3n3" dur="4" pname="a" oct="3" />
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n4" pname="a" oct="2" />
                    <note xml:id="m4s3n5" pname="e" oct="3" />
                    <note xml:id="m4s3n6" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Repeat of opening verse (identical text) -->
            <!-- Same harmonic progression — add rhythmic interest             -->
            <!-- ============================================================ -->

            <!-- Measure 5: Same as m1 — A(I) A(I) F#m(vi) E(V) — build texture -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: now with arpeggio — A4(8) C#5(8) E5(8) back down C#5(8), vi C#5-A4, V B4 -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5s2n1" dur="8" pname="a" oct="4" />
                  <note xml:id="m5s2n2" dur="8" pname="c" oct="5" accid.ges="s" />
                  <note xml:id="m5s2n3" dur="8" pname="e" oct="5" />
                  <note xml:id="m5s2n4" dur="8" pname="c" oct="5" accid.ges="s" />
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n5" pname="a" oct="4" />
                    <note xml:id="m5s2n6" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n7" pname="b" oct="4" />
                    <note xml:id="m5s2n8" pname="e" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3-C#4 (I with 3rd, dotted half), F#2-C#3-F#3-A3 (vi full quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2" dots="1">
                    <note xml:id="m5s3n1" pname="a" oct="2" />
                    <note xml:id="m5s3n2" pname="e" oct="3" />
                    <note xml:id="m5s3n3" pname="a" oct="3" />
                    <note xml:id="m5s3n4b" pname="c" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="f" oct="2" accid.ges="s" />
                    <note xml:id="m5s3n5" pname="c" oct="3" accid.ges="s" />
                    <note xml:id="m5s3n6" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m5s3n6b" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 6: Same as m2 — A(I) D(IV) E(V) -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n3" dur="2" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I A4-C#5 dotted quarter, D4 passing (8th), IV A4-D5 quarter, V E4-B4 half -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4" dots="1">
                    <note xml:id="m6s2n1" pname="a" oct="4" />
                    <note xml:id="m6s2n2" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <note xml:id="m6s2n3" dur="8" pname="d" oct="4" />
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n4" pname="d" oct="4" />
                    <note xml:id="m6s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m6s2n6" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="2">
                    <note xml:id="m6s2n7" pname="e" oct="4" />
                    <note xml:id="m6s2n8" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: A2-E3-A3 (I quarter), D2-A2-D3 (IV quarter), E2-B2-E3-G#3 (V7 half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="a" oct="2" />
                    <note xml:id="m6s3n2" pname="e" oct="3" />
                    <note xml:id="m6s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="d" oct="2" />
                    <note xml:id="m6s3n5" pname="a" oct="2" />
                    <note xml:id="m6s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="2">
                    <note xml:id="m6s3n7" pname="e" oct="2" />
                    <note xml:id="m6s3n8" pname="b" oct="2" />
                    <note xml:id="m6s3n9" pname="e" oct="3" />
                    <note xml:id="m6s3n10" pname="g" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Measure 7: same as m3 — D(IV) A(I) D(IV) G#°(vii°) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m7s1n4" dur="4" oct="4" pname="g" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: IV D4-F#4(4), I A4-C#5(4), IV D4-A4(4), vii° B4-D5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="d" oct="4" />
                    <note xml:id="m7s2n2" pname="f" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="a" oct="4" />
                    <note xml:id="m7s2n4" pname="c" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="d" oct="4" />
                    <note xml:id="m7s2n6" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c4" dur="4">
                    <note xml:id="m7s2n7" pname="b" oct="4" />
                    <note xml:id="m7s2n8" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D2-A2-D3 (IV), A2-E3-A3 (I), D2-A2-D3 (IV), G#2-B2-D3 (vii°) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="d" oct="2" />
                    <note xml:id="m7s3n2" pname="a" oct="2" />
                    <note xml:id="m7s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="a" oct="2" />
                    <note xml:id="m7s3n5" pname="e" oct="3" />
                    <note xml:id="m7s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="4">
                    <note xml:id="m7s3n7" pname="d" oct="2" />
                    <note xml:id="m7s3n8" pname="a" oct="2" />
                    <note xml:id="m7s3n9" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c4" dur="4">
                    <note xml:id="m7s3n10" pname="g" oct="2" accid.ges="s" />
                    <note xml:id="m7s3n11" pname="b" oct="2" />
                    <note xml:id="m7s3n12" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- Measure 8: "^A"A2 A2 -->
            <!-- Chord: A(I) whole -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="4" pname="a" />
                  <note xml:id="m8s1n2" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I — fuller A4-C#5-E5 whole, with arpeggiated approach -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m8s2n1" dur="8" pname="e" oct="4" />
                  <note xml:id="m8s2n2" dur="8" pname="a" oct="4" />
