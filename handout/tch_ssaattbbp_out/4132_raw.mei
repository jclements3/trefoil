              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Bar 0: pickup, 1 beat. Melody: A4. Chord: D -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0n1" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0r1" pname="f" oct="4" dur="4" accid.ges="s"/>
