                  </chord>
                  <chord xml:id="m1r2" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m1r3" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m1r4" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
