              <staff n="2">
                <!-- G(1)=B4-D5, D(1)=F#4-A4, Em(1)=E4-G4-B4, A(1)=C#4-E4 -->
                <layer n="1">
                  <chord xml:id="m2r1" dur="4">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m2r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
