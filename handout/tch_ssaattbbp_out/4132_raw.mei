                  <note xml:id="m1n4" pname="c" oct="5" dur="4" accid="n"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- D(1)=F#4-A4, A7(1)=E4-G4, D(1)=F#4-A4, A(1)=E4-A4 -->
                <layer n="1">
                  <chord xml:id="m1r1" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
