<?xml version="1.0" encoding="UTF-8"?>
<!--
  Hymn 4132: Look Down, O Lord, From Heaven Behold (in D)
  Key: D major (2 sharps: F#, C#)
  Meter: 4/4, L:1/4
  Has a 1-beat pickup bar (bar 0), then 14 full bars

  D major scale: D E F# G A B C#
  Diatonic degrees: I=D, ii=Em, iii=F#m, IV=G, V=A, vi=Bm, vii°=C#°

  Non-diatonic substitutions:
    Am  → A major (V in D, diatonic major)
    G#° → C#° (vii° in D, true diatonic diminished)
    E major → Em (ii in D, nearest diatonic minor)

  A7 (V7) is diatonic — A-C#-E-G, all in D major scale.
  Bm7 (vi7) is diatonic — B-D-F#-A, all in D major scale.

  Key-signature accidentals (accid.ges):
    F → accid.ges="s"  (F#)
    C → accid.ges="s"  (C#)
  Chromatic melody note =c (C natural) in bars 1,5 gets accid="n"
  Chromatic melody note ^G (G#) in bars 3,7 gets accid="s"

  Bar 0 (pickup, 1 beat): D context → A4 in melody
  Full bars 1-14.
  Bar 14 = 3 beats (final bar: D E D).

  VOICING PLAN:
  D major LH (root-P5-P8-3rd):
    D:   D2-A2-D3-F#3
    Em:  E2-B2-E3-G3
    F#m: F#2-C#3-F#3-A3
    G:   G2-D3-G3-B3
    A:   A2-E3-A3-C#4
    A7:  A2-E3-G3-C#4 (includes 7th G)
    Bm:  B2-F#3-B3-D4
    Bm7: B2-F#3-A3-D4
    C#°: C#3-G3-C#4 (diminished)
  RH (2-3 notes, treble):
    D:   F#4-A4 or A4-D5
    Em:  E4-G4-B4 or G4-B4
    F#m: A4-C#5 or F#4-A4
    G:   G4-B4-D5 or B4-D5
    A:   E4-A4 or C#4-E4
    A7:  G4-C#5 or E4-G4
    Bm:  D4-F#4-B4 or F#4-B4
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Look Down, O Lord, From Heaven Behold (D major)</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="2s">
