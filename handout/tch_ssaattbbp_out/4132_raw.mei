                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 1: A A A =c = D(1) A7(1) D(1) A(1) [=c = C natural in melody]
