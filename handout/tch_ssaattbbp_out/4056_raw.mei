<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>God Rest Ye Merry Gentlemen</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: G major (1 sharp: F#). Meter: 4/4 with pickup E -->
          <!-- Diatonic: G A B C D E F# -->
          <!-- Scale degrees: I=G, IIm=Am, IIIm=Bm, IV=C, V=D, VIm=Em, VII°=F#° -->
          <!-- Non-diatonic chords in ABC: Eb→D (nearest diatonic V), A→Am (make diatonic), -->
          <!-- C#°→Bm (nearest), G7→G (use I), F#7→D/F# (V 1st inv), Eb→Em (vi sub) -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- Pickup: single E4 quarter note                                -->
            <!-- ============================================================ -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: Em open — E4-B4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m0s2c1" dur="4">
                    <note xml:id="m0s2n1" pname="e" oct="4" />
                    <note xml:id="m0s2n2" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em open E2-B2-E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0s3c1" dur="4">
                    <note xml:id="m0s3n1" pname="e" oct="2" />
                    <note xml:id="m0s3n2" pname="b" oct="2" />
                    <note xml:id="m0s3n3" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- VERSE 1 (mm. 1-4)                                            -->
            <!-- ============================================================ -->

            <!-- Measure 1: "^Em"E B "^Eb"B "^A"A -->
            <!-- ABC: E=E4, B=B4, B=B4(Eb non-diat→Em sub), A=A4(A non-diat→Am diatonic) -->
            <!-- Chord map: Em(vi) B(non-diat→vi) Eb(non-diat→Em=vi) Am(ii) -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="e" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="b" />
                  <note xml:id="m1s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: vi E4-G4(4), vi B4-G4 (open 4th down, "44"quartal), vi E4-B4(4), ii A4-C5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="4">
                    <note xml:id="m1s2n1" pname="e" oct="4" />
                    <note xml:id="m1s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="b" oct="4" />
                    <note xml:id="m1s2n4" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="e" oct="4" />
                    <note xml:id="m1s2n6" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c4" dur="4">
                    <note xml:id="m1s2n7" pname="a" oct="4" />
                    <note xml:id="m1s2n8" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi E2-B2-E3 (open half), Am A2-E3-A3 (quarter), Am C3-E3-A3 (1st inv quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="e" oct="2" />
                    <note xml:id="m1s3n2" pname="b" oct="2" />
                    <note xml:id="m1s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="a" oct="2" />
                    <note xml:id="m1s3n5" pname="e" oct="3" />
                    <note xml:id="m1s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n7" pname="a" oct="2" />
                    <note xml:id="m1s3n8" pname="e" oct="3" />
                    <note xml:id="m1s3n9" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 2: "^Em"G "^Bm"F "^C"E "^G"D -->
            <!-- Chords: Em(vi) Bm(iii) C(IV) G(I) -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <!-- G=G4, F=F#4, E=E4, D=D4 -->
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="e" />
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: vi E4-B4(4), iii F#4-A4(4), IV E4-G4-C5(4), I D4-G4(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="e" oct="4" />
                    <note xml:id="m2s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="e" oct="4" />
                    <note xml:id="m2s2n6" pname="g" oct="4" />
                    <note xml:id="m2s2n7" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m2s2c4" dur="4">
                    <note xml:id="m2s2n8" pname="d" oct="4" />
                    <note xml:id="m2s2n9" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi E2-B2-E3 (4), iii B2-F#3-B3 (4), IV C3-G3-C4 (4), I G2-D3-G3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="e" oct="2" />
                    <note xml:id="m2s3n2" pname="b" oct="2" />
                    <note xml:id="m2s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="b" oct="2" />
                    <note xml:id="m2s3n5" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m2s3n6" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="c" oct="2" />
                    <note xml:id="m2s3n8" pname="g" oct="2" />
                    <note xml:id="m2s3n9" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c4" dur="4">
                    <note xml:id="m2s3n10" pname="g" oct="2" />
                    <note xml:id="m2s3n11" pname="d" oct="3" />
                    <note xml:id="m2s3n12" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 3: "^C"E "^Eb"F "^Em"G "^Am"A -->
            <!-- Eb non-diat→D(V passing), Am diatonic ii -->
            <!-- Chords: C(IV) D(V pass) Em(vi) Am(ii) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <!-- E=E4, F=F#4, G=G4, A=A4 -->
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="e" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: IV C4-E4-G4(4), V D4-F#4(4), vi E4-G4-B4(4), ii A4-C5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="c" oct="4" />
                    <note xml:id="m3s2n2" pname="e" oct="4" />
                    <note xml:id="m3s2n3" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n4" pname="d" oct="4" />
                    <note xml:id="m3s2n5" pname="f" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n6" pname="e" oct="4" />
                    <note xml:id="m3s2n7" pname="g" oct="4" />
                    <note xml:id="m3s2n8" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c4" dur="4">
                    <note xml:id="m3s2n9" pname="a" oct="4" />
                    <note xml:id="m3s2n10" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: IV C2-G2-C3 (4), V D2-A2-D3 (4), vi E2-B2-E3 (4), ii A2-E3-A3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="c" oct="2" />
                    <note xml:id="m3s3n2" pname="g" oct="2" />
                    <note xml:id="m3s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="d" oct="2" />
                    <note xml:id="m3s3n5" pname="a" oct="2" />
                    <note xml:id="m3s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="e" oct="2" />
                    <note xml:id="m3s3n8" pname="b" oct="2" />
                    <note xml:id="m3s3n9" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c4" dur="4">
                    <note xml:id="m3s3n10" pname="a" oct="2" />
                    <note xml:id="m3s3n11" pname="e" oct="3" />
                    <note xml:id="m3s3n12" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 4: "^Eb"B3 E -->
            <!-- Eb non-diat → Em(vi). B3(dotted half) then E(quarter) pickup feel -->
            <!-- Melody: B=B4 dotted half, E=E4 quarter -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" dots="1" oct="4" pname="b" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: vi B4-D5-G5(dotted half), vi E4-B4(quarter) — prepare phrase repeat -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2" dots="1">
                    <note xml:id="m4s2n1" pname="b" oct="4" />
                    <note xml:id="m4s2n2" pname="d" oct="5" />
                    <note xml:id="m4s2n3" pname="g" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n4" pname="e" oct="4" />
                    <note xml:id="m4s2n5" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi E2-B2-E3-G3 (dotted half, all 4 notes), E2-B2-E3 (quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2" dots="1">
                    <note xml:id="m4s3n1" pname="e" oct="2" />
                    <note xml:id="m4s3n2" pname="b" oct="2" />
                    <note xml:id="m4s3n3" pname="e" oct="3" />
                    <note xml:id="m4s3n4" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n5" pname="e" oct="2" />
                    <note xml:id="m4s3n6" pname="b" oct="2" />
                    <note xml:id="m4s3n7" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- VERSE 2 (mm. 5-8): Repeat of first phrase with more texture  -->
            <!-- ============================================================ -->

            <!-- Measure 5: same chords as m1 — vi vi vi ii -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="e" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="b" />
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: vi ascending E4(8) G4(8) B4(8) D5(8), vi hold B4-E5(4), ii A4-C5(4) -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5s2n1" dur="8" pname="e" oct="4" />
                  <note xml:id="m5s2n2" dur="8" pname="g" oct="4" />
                  <note xml:id="m5s2n3" dur="8" pname="b" oct="4" />
                  <note xml:id="m5s2n4" dur="8" pname="d" oct="5" />
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n5" pname="b" oct="4" />
                    <note xml:id="m5s2n6" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n7" pname="a" oct="4" />
                    <note xml:id="m5s2n8" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi E2-B2-E3 (half), Am A2-E3-A3 (quarter), A2-C3-E3-A3 (1st inv quarter) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="e" oct="2" />
                    <note xml:id="m5s3n2" pname="b" oct="2" />
                    <note xml:id="m5s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="a" oct="2" />
                    <note xml:id="m5s3n5" pname="e" oct="3" />
                    <note xml:id="m5s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n7" pname="a" oct="2" />
                    <note xml:id="m5s3n8" pname="e" oct="3" />
                    <note xml:id="m5s3n9" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 6: same as m2 — vi iii IV I -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="e" />
                  <note xml:id="m6s1n4" dur="4" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: vi G4-B4(4), iii F#4-A4(4), IV E4-G4-C5(4), I D4-G4-B4(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="g" oct="4" />
                    <note xml:id="m6s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m6s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="e" oct="4" />
                    <note xml:id="m6s2n6" pname="g" oct="4" />
                    <note xml:id="m6s2n7" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c4" dur="4">
                    <note xml:id="m6s2n8" pname="d" oct="4" />
                    <note xml:id="m6s2n9" pname="g" oct="4" />
                    <note xml:id="m6s2n10" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi E2-B2-E3, iii B2-F#3-B3, IV C2-G2-C3, I G2-D3-G3-B3 (rich) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="e" oct="2" />
                    <note xml:id="m6s3n2" pname="b" oct="2" />
                    <note xml:id="m6s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="b" oct="2" />
                    <note xml:id="m6s3n5" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m6s3n6" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n7" pname="c" oct="2" />
                    <note xml:id="m6s3n8" pname="g" oct="2" />
                    <note xml:id="m6s3n9" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c4" dur="4">
                    <note xml:id="m6s3n10" pname="g" oct="2" />
                    <note xml:id="m6s3n11" pname="d" oct="3" />
                    <note xml:id="m6s3n12" pname="g" oct="3" />
                    <note xml:id="m6s3n13" pname="b" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 7: "^C"E "^Eb"F "^Em"G "^Am"A — same as m3 -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="e" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m7s1n4" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: IV C4-E4-G4, V D4-F#4-A4, vi G4-B4, ii A4-C5-E5 -->
              <staff n="2">
                <layer n="1">
