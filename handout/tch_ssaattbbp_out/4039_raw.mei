<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Come O Come Emmanuel</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB+P</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- G major (modal — heavily Em). 1 sharp (F#). Pickup of 1 beat. -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup: Em E4 — 1 beat -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 — single note pickup -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0r1" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3 — sparse pickup chord -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0l1" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 1 (mm. 1-5): Em modal, Bm, G, Am, D                      -->
            <!-- ================================================================ -->

            <!-- Measure 1: G Bm B B B — Em(G), Bm(B), G(B), G(B) -->
            <!-- ABC: G "^Bm"B "^G"B B — beat 1=G (Em chord), 2=B (Bm), 3=B (G), 4=B (G) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1s1n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m1s1n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m1s1n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4; Bm F#4 D5; G hold G4 B4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m1r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m1r3" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3; Bm B2 F#3 B3; G G2 D3 G3 B3 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1l1" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m1l2" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <chord xml:id="m1l3" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑦m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 2: Am7 A c, Bm B, D7 A -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m2s1n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m2s1n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m2s1n4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Am7 A4 E5; Bm D5 F#5; D7 A4 C5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m2r2" dur="4">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m2r3" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Am7 A2 E3 G3; Bm B2 F#3 B3; D7 D2 A2 C3 F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m2l2" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m2l3" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="2">⑦m</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Measure 3: G G3 D A — G(G3=dotted half), D(A=quarter) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="g" oct="4" dur="2" dots="1"/>
                  <note xml:id="m3s1n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: G "43" D5 G5 dotted half; D F#4 A4 quarter -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3r1" dur="2" dots="1">
                    <note pname="d" oct="5"/>
                    <note pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G "334" G2 D3 G3 B3 dotted half; D D2 A2 D3 F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3l1" dur="2" dots="1">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 4: G B G, C E, G G -->
            <!-- ABC: "^G"B G "^C"E "^G"G -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m4s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m4s1n3" pname="e" oct="4" dur="4"/>
                  <note xml:id="m4s1n4" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: G D4 G4; C E4 G4 — gentle 2-note harmonies -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m4r2" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2 D3 G3; C C2 G2 C3 E3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m4l2" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 5: Am A, F#° F, Em E, Bm D -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m5s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m5s1n3" pname="e" oct="4" dur="4"/>
                  <note xml:id="m5s1n4" pname="d" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: descending inner voice C5→A4→G4→F#4 — chromatic counterpoint -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m5r1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m5r2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m5r3" pname="g" oct="4" dur="4"/>
                  <note xml:id="m5r4" pname="f" oct="4" accid.ges="s" dur="4"/>
                </layer>
              </staff>
              <!-- LH: Am A2 E3 A3; F#° (vii°) F#2 A2 C3; Em E2 B2 E3; Bm B2 F#3 B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m5l2" dur="4">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                  </chord>
                  <chord xml:id="m5l3" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m5l4" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="4">⑦m</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 2 (mm. 6-10): Em center, D, Refrain build                 -->
            <!-- ================================================================ -->

            <!-- Measure 6: Em E3 Am A — Em(E3=dotted half), Am(A=quarter) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="e" oct="4" dur="2" dots="1"/>
                  <note xml:id="m6s1n2" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4 dotted half; Am C5 E5 quarter -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6r1" dur="2" dots="1">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m6r2" dur="4">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3 G3 dotted half; Am A2 E3 A3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6l1" dur="2" dots="1">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m6l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 7: A E, Em E, F#° F — Am(A E), Em(E), F#°(F) -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m7s1n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m7s1n3" pname="e" oct="4" dur="4"/>
                  <note xml:id="m7s1n4" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: Am A4 C5; Em G4 B4; F#° E4 G4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7r1" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m7r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m7r3" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Am A2 E3; Em E2 B2 E3; F#° F#2 A2 C3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m7l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m7l3" dur="2">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
            </measure>

            <!-- Measure 8: Em G2 D F, A7 E -->
            <!-- ABC: "^Em"G2 "^D"F "^A7"E -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m8s1n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <!-- A7 → treat as A chord → diatonic sub: use D (V) or Am (ii) -->
                  <!-- A7 in G = secondary dominant (V/ii). Use Am chord tones. -->
                  <note xml:id="m8s1n3" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Em G4 B4; D F#4 A4; Am/A7 C5 E5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m8r2" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m8r3" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Em E2 B2 E3; D D2 A2 D3; Am A2 E3 A3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m8l2" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m8l3" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Measure 9: D D3 Em G — D(D3=dotted half), Em(G=quarter) -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" pname="d" oct="4" dur="2" dots="1"/>
                  <note xml:id="m9s1n2" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D F#4 A4 dotted half; Em G4 B4 quarter -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9r1" dur="2" dots="1">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m9r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D "33" D2 A2 D3 F#3 dotted half; Em E2 B2 E3 quarter -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9l1" dur="2" dots="1">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m9l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 3 (mm. 10-13): Refrain — D A Bm G, brighter/stronger     -->
            <!-- ================================================================ -->

            <!-- Measure 10: D A, Bm B, G B B -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m10s1n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m10s1n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m10s1n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: D F#4 A4; Bm D5 F#5; G B4 D5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10r1" dur="4">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m10r2" dur="4">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m10r3" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2 A2 D3 F#3; Bm B2 F#3 B3; G G2 D3 G3 B3 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m10l2" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <chord xml:id="m10l3" dur="2">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">⑦m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 11: Am7 A c, Bm B, D7 A (same as m.2) -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m11s1n2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m11s1n3" pname="b" oct="4" dur="4"/>
