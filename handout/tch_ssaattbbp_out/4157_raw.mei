<?xml version="1.0" encoding="UTF-8"?>
<!-- 4157 That Men a Godly Life Might Live — pedal harp, key C, 4/4 -->
<!-- Key C: no accidentals. Bb in melody as accidental (_B) -->
<!-- Scale: C(1) D(2) E(3) F(4) G(5) A(6) B(7) -->
<!-- ABC:
  m0: z (rest beat), Em_G, CM7_G, G — pickup (3 beats + 1 rest)
  m1: G_G C_G G/2 Am_A/2 G_B
  m2: C_c2 z C
  m3: G_d Dm_d Am_c Em_G
  m4: Dm_A G_B C2
  m5: z Dm7_c Dm_d d
  m6: Am_c Em_G F_A C_G
  m7: Dm_F2 z F
  m8: A_A G_B C2
  m9: Gm_Bb G_G B2
  m10: Gm_Bb3/2 Dm_A/2 Em_G2
  m11: G4
-->
<!-- Bb = bB in ABC = scale deg 7 flatted in C major. Chord annotations Gm use Bb, so key flips briefly: substitute Gm → Am (ii) or keep Gm as color (Bb as accidental) -->
<!-- Note: _B = Bb; in C major harp, Bb is non-diatonic → for harp parts, if Gm chord appears with Bb melody, substitute Am (vi) or use F (IV) to avoid Bb on harp. Or treat Gm as IV chord in C (F A C has no Bb). Per rules: substitute nearest diatonic chord. Gm (G Bb D) → nearest diatonic: Am (A C E) or G (G B D). Use G (I→V) for smoother motion. -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>That Men a Godly Life Might Live</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="0">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="0">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="0">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup measure: z Em_G CΔ7_G G — 3 beats (Em half, CΔ7 half, G) actually: z G G G/2 A/2 B -->
            <!-- ABC says: z "^Em"G "^CΔ7"G G — 4 beats total with rest on beat 1 -->
            <!-- So pickup is 3 beats of sound after a beat rest -->
            <measure n="0" metcon="false">
              <staff n="1">
                <layer n="1">
                  <rest dur="4"/>
                  <note xml:id="p1n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="p1n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="p1n3" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 B4 — Em then C, light pickup -->
                <layer n="1">
                  <rest dur="4" visible="false"/>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="p1rh1" oct="4" pname="g"/>
                    <note xml:id="p1rh2" oct="4" pname="b"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="p1rh3" oct="4" pname="e"/>
                    <note xml:id="p1rh4" oct="4" pname="g"/>
                  </chord>
                  <rest dur="4" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: E2 B2 E3 → C2 G2 C3 E3 -->
                <layer n="1">
                  <rest dur="4" visible="false"/>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="p1lh1" oct="2" pname="e"/>
                    <note xml:id="p1lh2" oct="2" pname="b"/>
                    <note xml:id="p1lh3" oct="3" pname="e"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note xml:id="p1lh4" oct="2" pname="c"/>
                    <note xml:id="p1lh5" oct="2" pname="g"/>
                    <note xml:id="p1lh6" oct="3" pname="c"/>
                    <note xml:id="p1lh7" oct="3" pname="e"/>
                  </chord>
                  <rest dur="4" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
            </measure>

            <!-- Measure 1: G, C, G/2, Am, G — melody G G G/2 A/2 B -->
