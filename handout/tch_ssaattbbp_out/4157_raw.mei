              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Measure 4: Dm, G, C — melody A B C2 (c→C5 half) -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="b"/>
                  <note xml:id="m4n3" dur="2" oct="5" pname="c"/>
                </layer>
              </staff>
              <staff n="2">
