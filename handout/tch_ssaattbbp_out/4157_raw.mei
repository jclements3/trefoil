                  <note xml:id="m1n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1n3" dur="8" oct="4" pname="g"/>
                  <note xml:id="m1n4" dur="8" oct="4" pname="a"/>
                  <note xml:id="m1n5" dur="4" oct="4" pname="b"/>
