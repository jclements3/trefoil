                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 3: G, Dm, Am, Em — melody d d c G -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" dur="4" oct="5" pname="d"/>
                  <note xml:id="m3n2" dur="4" oct="5" pname="d"/>
                  <note xml:id="m3n3" dur="4" oct="5" pname="c"/>
                  <note xml:id="m3n4" dur="4" oct="4" pname="g"/>
