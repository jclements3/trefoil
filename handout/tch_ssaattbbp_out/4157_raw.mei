            <!-- Measure 5: Dm7, Dm, d — melody z c d d -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <rest dur="4"/>
                  <note xml:id="m5n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m5n2" dur="4" oct="5" pname="d"/>
