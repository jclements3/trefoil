                <layer n="1">
                  <note xml:id="m6n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m6n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m6n3" dur="4" oct="4" pname="a"/>
                  <note xml:id="m6n4" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: A4 C5 → G4 B4 → A4 C5 → G4 E4 (voice leading) -->
                <layer n="1">
