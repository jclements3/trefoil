            <!-- Measure 10: Gm(→G/V), Dm, Em — melody Bb3/2 A/2 G2 -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" dur="4d" oct="4" pname="b" accid="f"/>
                  <note xml:id="m10n2" dur="8" oct="4" pname="a"/>
                  <note xml:id="m10n3" dur="2" oct="4" pname="g"/>
