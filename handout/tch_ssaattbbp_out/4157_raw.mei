                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: G2 D3 B3 → D2 A2 F3 → A2 E3 C4 → E2 B2 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh1" oct="2" pname="g"/>
                    <note xml:id="m3lh2" oct="3" pname="d"/>
