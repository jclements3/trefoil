<!-- Measure 7 (climax): 4 beats. C(IV) e→vi D7→V7 G→I B→III
     ABC: "^C"e "^G"d/2 "^C"c/2 "^G"B "^D7"A
     Melody: E5(4) D5(8) C5(8) B4(4) A4(4)
     Chords: IV | I | IV | I | V7 — beat mapping:
     beat1=IV(C), beat2=I(G) passing, beat2.5=IV(C), beat3=I(G), beat4=V7(D7)
-->
<measure n="7" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m7s1n1" dur="4" oct="5" pname="e"/>
      <note xml:id="m7s1n2" dur="8" oct="5" pname="d"/>
      <note xml:id="m7s1n3" dur="8" oct="5" pname="c"/>
      <note xml:id="m7s1n4" dur="4" oct="4" pname="b"/>
      <note xml:id="m7s1n5" dur="4" oct="4" pname="a"/>
    </layer>
  </staff>
  <!-- RH: peak texture — 3-note voicings, contrary motion -->
  <staff n="2">
    <layer n="1">
      <!-- beat 1: IV — E4-G4-C5 (IV root pos 3rd+4th) -->
      <chord xml:id="m7s2c1" dur="4">
        <note xml:id="m7s2n1" pname="e" oct="4"/>
        <note xml:id="m7s2n2" pname="g" oct="4"/>
        <note xml:id="m7s2n3" pname="c" oct="5"/>
      </chord>
      <!-- beat 2: I — D4-G4 (I 4th) -->
      <chord xml:id="m7s2c2" dur="8">
        <note xml:id="m7s2n4" pname="d" oct="4"/>
        <note xml:id="m7s2n5" pname="g" oct="4"/>
      </chord>
      <!-- beat 2.5: IV — C4-E4 (IV 3rd) -->
      <chord xml:id="m7s2c3" dur="8">
        <note xml:id="m7s2n6" pname="c" oct="4"/>
        <note xml:id="m7s2n7" pname="e" oct="4"/>
      </chord>
      <!-- beat 3: I — B4-D5 (I top 3rd) -->
      <chord xml:id="m7s2c4" dur="4">
        <note xml:id="m7s2n8" pname="b" oct="4"/>
        <note xml:id="m7s2n9" pname="d" oct="5"/>
      </chord>
      <!-- beat 4: V7 — C4-F#4 (V7 tritone) -->
      <chord xml:id="m7s2c5" dur="4">
        <note xml:id="m7s2n10" pname="c" oct="4"/>
        <note xml:id="m7s2n11" pname="f" oct="4" accid.ges="s"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: climax — full 4-note chords every beat -->
  <staff n="3">
    <layer n="1">
      <!-- beat 1: IV — C3-G3-C4-E4 (IV root pos open P5+P4+M3) -->
      <chord xml:id="m7s3c1" dur="4">
        <note xml:id="m7s3n1" pname="c" oct="3"/>
        <note xml:id="m7s3n2" pname="g" oct="3"/>
        <note xml:id="m7s3n3" pname="c" oct="4"/>
        <note xml:id="m7s3n4" pname="e" oct="4"/>
      </chord>
      <!-- beat 2: I — G2-D3-G3-B3 (I full) -->
      <chord xml:id="m7s3c2" dur="4">
        <note xml:id="m7s3n5" pname="g" oct="2"/>
        <note xml:id="m7s3n6" pname="d" oct="3"/>
        <note xml:id="m7s3n7" pname="g" oct="3"/>
        <note xml:id="m7s3n8" pname="b" oct="3"/>
      </chord>
      <!-- beat 3: I — G2-D3-G3 -->
      <chord xml:id="m7s3c3" dur="4">
        <note xml:id="m7s3n9" pname="g" oct="2"/>
        <note xml:id="m7s3n10" pname="d" oct="3"/>
        <note xml:id="m7s3n11" pname="g" oct="3"/>
      </chord>
      <!-- beat 4: V7 — D3-A3-C4-F#4 (V7 full) -->
      <chord xml:id="m7s3c4" dur="4">
        <note xml:id="m7s3n12" pname="d" oct="3"/>
        <note xml:id="m7s3n13" pname="a" oct="3"/>
        <note xml:id="m7s3n14" pname="c" oct="4"/>
        <note xml:id="m7s3n15" pname="f" oct="4" accid.ges="s"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">④</harm>
  <harm staff="1" tstamp="2">①</harm>
  <harm staff="1" tstamp="2.5">④</harm>
  <harm staff="1" tstamp="3">①</harm>
  <harm staff="1" tstamp="4">⑤7</harm>
</measure>

<!-- Measure 8 (final): 4 beats. G3 (= G4 dotted half + G4 quarter? or G-whole?)
     ABC: "^G"G3 — G4(dotted half = 3 beats) then |] barline
     Wait: "G3" in ABC L:1/4 = G*(3/1) = 3 quarter beats? No: "3" after note = 3x duration.
     Actually in ABC notation "G3" = G with length 3 (3 quarter notes = dotted half in 4/4).
     But the barline "|]" ends the piece — means this measure has only 3 beats?
     With a 1-beat pickup, total = 4, so it's a standard 4/4 structure.
     The final measure has 3 beats (to balance the 1-beat pickup). G4(3 beats).
-->
<measure n="8" right="end">
  <staff n="1">
    <layer n="1">
      <note xml:id="m8s1n1" dur="4" dots="2" oct="4" pname="g"/>
    </layer>
  </staff>
  <!-- RH: convergence to root — G4-B4-D5 grand final chord -->
  <staff n="2">
    <layer n="1">
      <chord xml:id="m8s2c1" dur="4" dots="2">
        <note xml:id="m8s2n1" pname="g" oct="4"/>
        <note xml:id="m8s2n2" pname="b" oct="4"/>
        <note xml:id="m8s2n3" pname="d" oct="5"/>
      </chord>
    </layer>
  </staff>
  <!-- LH: G root pos fullest — G2-D3-G3-B3-D4 -->
  <staff n="3">
    <layer n="1">
      <chord xml:id="m8s3c1" dur="4" dots="2">
        <note xml:id="m8s3n1" pname="g" oct="2"/>
        <note xml:id="m8s3n2" pname="d" oct="3"/>
        <note xml:id="m8s3n3" pname="g" oct="3"/>
        <note xml:id="m8s3n4" pname="b" oct="3"/>
        <note xml:id="m8s3n5" pname="d" oct="4"/>
      </chord>
    </layer>
  </staff>
  <harm staff="1" tstamp="1">①</harm>
</measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>

<!--
VOICING PLAN:
- Pickup + M1-2: Very light opening — 2-note RH (thirds/fourths), 2-3 note LH open fifths.
  Pattern "44" quartal: D-G, G-D-G for I chord. "43" 1st inversion: B-D for variety.
- M3-4: Build with V7 color. LH uses full V7 chord (D-A-C-F#) at beat 2 M3 and
  dotted-half in M4 — Verovio shows long sustain against melody's dotted half.
- M5-6: Opposite directions — M5 LH descends from G2 to D2 (bass deepening),
  M6 RH flowing eighths tracking melody contour. vi (Em) open P5 in LH M6 beat 2.
- M7 (climax): IV-I alternation in fast rhythm matches melody. 3-note RH, full 4-note LH
  every beat. V7 tritone C-F# in RH beat 4 creates maximum tension before resolution.
- M8: Convergence — 3-note RH spread chord, 5-note LH spans G2-D4 (octave-plus).

VOICE LEADING HIGHLIGHTS:
- Inner tenor B4→A4→G4 in M1 RH tracks melody in parallel thirds.
- LH bass line M3: G2→D3→A2→G2 (root→V→ii→I stepwise with small leaps).
- Common-tone G3 held as inner voice across M5 beats 1-2.
- M7: contrary motion — RH E4→C4 descends while LH C3→G2 descends, both against
  melody E5→A4 descent. All three lines move in parallel descent — dramatic sweep.
- RH V7 tritone C4-F# at M7 beat4 resolves inward to G4-B4 at M8 — classic tritone resolution.

TEXTURE ARC:
- Pickup-M2: Sparkling, light — 2-note RH, 2-3 note LH. Advent arrival mood.
- M3-4: More movement, V7 color, longer sustains.
- M5-6: Contrary motion, wider range, flowing eighth-note RH in M6.
- M7 (climax): Busiest — eighth-note harmonic rhythm, 3-note RH, 4-note LH all beats.
- M8: Full resonant close — widest spread, longest notes.
-->
