<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Blessed Jesus at Thy Word</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal (raw, single-layer)</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-5): Opening phrase — G major, lighter texture -->
            <!-- ============================================================ -->

            <!-- Measure 1: G D G D — B4 G4 A4 D5 -->
            <!-- G(I) beat1, D(V) beat3 -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m1s1n4" dur="4" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: G(I) open 5th on 1, D(V) on 3 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="b" oct="4" />
                    <note xml:id="m1s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="2">
                    <note xml:id="m1s2n3" pname="a" oct="4" />
                    <note xml:id="m1s2n4" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G2-D3-G3 (I root pos open) | D2-A2-D3 (V) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="g" oct="2" />
                    <note xml:id="m1s3n2" pname="d" oct="3" />
                    <note xml:id="m1s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="2">
                    <note xml:id="m1s3n4" pname="d" oct="2" />
                    <note xml:id="m1s3n5" pname="a" oct="2" />
                    <note xml:id="m1s3n6" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 2: G Em D — B4 G4 A2 -->
            <!-- G(I) beat1, Em(vi) beat2, D(V) beat3 -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: arpeggiate G→Em→D -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="g" oct="4" />
                    <note xml:id="m2s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="e" oct="4" />
                    <note xml:id="m2s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="2">
                    <note xml:id="m2s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G2-D3-B3 | E2-B2-E3 | D2-A2-F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="g" oct="2" />
                    <note xml:id="m2s3n2" pname="d" oct="3" />
                    <note xml:id="m2s3n3" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="e" oct="2" />
                    <note xml:id="m2s3n5" pname="b" oct="2" />
                    <note xml:id="m2s3n6" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="2">
                    <note xml:id="m2s3n7" pname="d" oct="2" />
                    <note xml:id="m2s3n8" pname="a" oct="2" />
                    <note xml:id="m2s3n9" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 3: G C G — G4 G4 G4 G4 -->
            <!-- G(I) beats 1-2, C(IV) beat 3, G(I) beat 4 -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: arpeggio on G, then C -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m3s2n1" dur="4" pname="g" oct="4" />
                  <note xml:id="m3s2n2" dur="4" pname="b" oct="4" />
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n3" pname="e" oct="5" />
                    <note xml:id="m3s2n4" pname="g" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n5" pname="d" oct="5" />
                    <note xml:id="m3s2n6" pname="g" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G2-B2-D3 open | C2-G2-C3 | G2-D3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="g" oct="2" />
                    <note xml:id="m3s3n2" pname="b" oct="2" />
                    <note xml:id="m3s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="c" oct="2" />
                    <note xml:id="m3s3n5" pname="g" oct="2" />
                    <note xml:id="m3s3n6" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="g" oct="2" />
                    <note xml:id="m3s3n8" pname="d" oct="3" />
                    <note xml:id="m3s3n9" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 4: F#° G D — A4 B4 A2 -->
            <!-- vii° beat1, G(I) beat2, D(V) beat3-4 -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m4s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: vii°→I→V motion -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="g" oct="4" />
                    <note xml:id="m4s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m4s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: F#2-C3-F#3 | G2-D3-G3 | D2-A2-D3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="f" oct="2" accid.ges="s" />
                    <note xml:id="m4s3n2" pname="c" oct="3" />
                    <note xml:id="m4s3n3" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n4" pname="g" oct="2" />
                    <note xml:id="m4s3n5" pname="d" oct="3" />
                    <note xml:id="m4s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n7" pname="d" oct="2" />
                    <note xml:id="m4s3n8" pname="a" oct="2" />
                    <note xml:id="m4s3n9" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 5: G — G4 whole note -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="1" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G major full spread -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="1">
                    <note xml:id="m5s2n1" pname="d" oct="4" />
                    <note xml:id="m5s2n2" pname="g" oct="4" />
                    <note xml:id="m5s2n3" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G2-D3-G3-B3 full I chord -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="1">
                    <note xml:id="m5s3n1" pname="g" oct="2" />
                    <note xml:id="m5s3n2" pname="d" oct="3" />
                    <note xml:id="m5s3n3" pname="g" oct="3" />
                    <note xml:id="m5s3n4" pname="b" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 6-10): Repeat of phrase 1 — build texture      -->
            <!-- ============================================================ -->

            <!-- Measure 6: same as m1 but fuller texture -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n4" dur="4" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: broken arpeggio G→D ascending -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m6s2n1" dur="4" pname="d" oct="4" />
                  <note xml:id="m6s2n2" dur="4" pname="g" oct="4" />
                  <note xml:id="m6s2n3" dur="4" pname="d" oct="5" />
                  <note xml:id="m6s2n4" dur="4" pname="f" oct="5" accid.ges="s" />
                </layer>
              </staff>
              <!-- LH: G1-D2-G2-B2 | A2-D3-F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="2">
                    <note xml:id="m6s3n1" pname="g" oct="2" />
                    <note xml:id="m6s3n2" pname="d" oct="3" />
                    <note xml:id="m6s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="2">
                    <note xml:id="m6s3n4" pname="d" oct="2" />
                    <note xml:id="m6s3n5" pname="a" oct="2" />
                    <note xml:id="m6s3n6" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 7: G Em D -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m7s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: G→Em→D with 7th color -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="g" oct="4" />
                    <note xml:id="m7s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="e" oct="4" />
                    <note xml:id="m7s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="2">
                    <note xml:id="m7s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m7s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: fuller open voicings -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="g" oct="2" />
                    <note xml:id="m7s3n2" pname="d" oct="3" />
                    <note xml:id="m7s3n3" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="e" oct="2" />
                    <note xml:id="m7s3n5" pname="b" oct="2" />
                    <note xml:id="m7s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="2">
                    <note xml:id="m7s3n7" pname="d" oct="2" />
                    <note xml:id="m7s3n8" pname="a" oct="2" />
                    <note xml:id="m7s3n9" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 8: G C G -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m8s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m8s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: arpeggio wave G-B-D-G -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m8s2n1" dur="4" pname="g" oct="4" />
                  <note xml:id="m8s2n2" dur="4" pname="b" oct="4" />
                  <note xml:id="m8s2n3" dur="4" pname="c" oct="5" />
                  <note xml:id="m8s2n4" dur="4" pname="g" oct="4" />
                </layer>
              </staff>
              <!-- LH: G root position, then IV -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="2">
                    <note xml:id="m8s3n1" pname="g" oct="2" />
                    <note xml:id="m8s3n2" pname="d" oct="3" />
                    <note xml:id="m8s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m8s3c2" dur="2">
                    <note xml:id="m8s3n4" pname="c" oct="2" />
                    <note xml:id="m8s3n5" pname="g" oct="2" />
                    <note xml:id="m8s3n6" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 9: F#° G D -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m9s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: suspension on A, resolve to G over D -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="4">
                    <note xml:id="m9s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m9s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m9s2c2" dur="4">
                    <note xml:id="m9s2n3" pname="g" oct="4" />
                    <note xml:id="m9s2n4" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m9s2c3" dur="2">
                    <note xml:id="m9s2n5" pname="a" oct="4" />
                    <note xml:id="m9s2n6" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="4">
                    <note xml:id="m9s3n1" pname="f" oct="2" accid.ges="s" />
                    <note xml:id="m9s3n2" pname="c" oct="3" />
                    <note xml:id="m9s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
                    <note xml:id="m9s3n4" pname="g" oct="2" />
                    <note xml:id="m9s3n5" pname="d" oct="3" />
                    <note xml:id="m9s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m9s3c3" dur="2">
                    <note xml:id="m9s3n7" pname="d" oct="2" />
                    <note xml:id="m9s3n8" pname="a" oct="2" />
                    <note xml:id="m9s3n9" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 10: G — whole note -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="1" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G quartal for variety -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10s2c1" dur="2">
                    <note xml:id="m10s2n1" pname="d" oct="4" />
                    <note xml:id="m10s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m10s2c2" dur="2">
                    <note xml:id="m10s2n3" pname="g" oct="4" />
                    <note xml:id="m10s2n4" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G2-D3-G3-B3 full cadence -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10s3c1" dur="1">
                    <note xml:id="m10s3n1" pname="g" oct="2" />
                    <note xml:id="m10s3n2" pname="d" oct="3" />
                    <note xml:id="m10s3n3" pname="g" oct="3" />
                    <note xml:id="m10s3n4" pname="b" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 3 (mm. 11-15): Climax — fuller texture, wider range   -->
            <!-- ============================================================ -->

            <!-- Measure 11: D D C#° D — D4 D4 E4 F#4 -->
            <!-- D(V) throughout, C#° is vii°/V — use D (V) -->
            <measure n="11" right="single">
              <staff n="1">
                <layer n="1">
