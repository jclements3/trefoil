<?xml version="1.0" encoding="UTF-8"?>
<!-- 4159 The Law Of God Is Good And Wise — pedal harp, key G, 4/4 -->
<!-- Key G: 1 sharp — F#. accid.ges="s" on all F notes -->
<!-- Scale: G(1) A(2) B(3) C(4) D(5) E(6) F#(7) -->
<!-- Chords: I=G, ii=Am, iii=Bm, IV=C, V=D, vi=Em, vii=F#° -->
<!-- ABC:
  m1: Em_E2 G Am_E
  m2: Bm_D Am_E Em_G Eb_F  (Eb=non-diatonic in G → sub Em or use D)
  m3: Em_E2 C_G2
  m4: Am_A D_A G_B C_G
  m5: Am_A D_A G_B2
  m6: B2 C_c G_B
  m7: D_d Em_B Am_A D_A
  m8: G_G2 B2
  m9: C_G Am_A G_G D_F
  m10: Em_E ^D_^D Em_E2  (^D=D#, non-diatonic → substitute D or Em stay)
  m11: (end, no more bars)
-->
<!-- Eb in m.2 = non-diatonic in G → sub Em(vi) which starts on E, similar -->
<!-- ^D (D#) in m.10 = non-diatonic → substitute D or Em -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>The Law Of God Is Good And Wise</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="1s">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="1s">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="1s">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Measure 1: Em — melody E2 G E -->
            <!-- vi=Em (E G B): "33" RH G4 B4; LH E2 B2 E3 G3 -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="2" oct="4" pname="e"/>
                  <note xml:id="m1n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1n3" dur="4" oct="4" pname="e"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 B4 — open "33" vi entry -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh1" oct="4" pname="g"/>
                    <note xml:id="m1rh2" oct="4" pname="b"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh3" oct="4" pname="e"/>
                    <note xml:id="m1rh4" oct="4" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: E2 B2 E3 G3 — "334" vi open -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m1lh1" oct="2" pname="e"/>
                    <note xml:id="m1lh2" oct="2" pname="b"/>
                    <note xml:id="m1lh3" oct="3" pname="e"/>
                    <note xml:id="m1lh4" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" dur="1" oct="2" pname="e" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Measure 2: Bm, Am, Em, Eb(→Em) — melody D E G F -->
            <!-- Eb non-diatonic in G → sub Em (vi) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" dur="4" oct="4" pname="d"/>
                  <note xml:id="m2n2" dur="4" oct="4" pname="e"/>
                  <note xml:id="m2n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m2n4" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: B3 D4 → A3 C4 → G4 B4 — stepwise motion -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2rh1" oct="3" pname="b"/>
                    <note xml:id="m2rh2" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2rh3" oct="4" pname="g"/>
                    <note xml:id="m2rh4" oct="4" pname="b"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: B2 F#3 B3 D4 → A2 E3 A3 C4 → E2 B2 E3 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2lh1" oct="2" pname="b"/>
                    <note xml:id="m2lh2" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m2lh3" oct="3" pname="b"/>
                    <note xml:id="m2lh4" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2lh5" oct="2" pname="e"/>
                    <note xml:id="m2lh6" oct="2" pname="b"/>
                    <note xml:id="m2lh7" oct="3" pname="e"/>
                    <note xml:id="m2lh8" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" dur="2" oct="2" pname="b" stem.dir="down"/>
                  <note xml:id="m2p2" dur="2" oct="2" pname="e" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Measure 3: Em, C — melody E2 G2 -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" dur="2" oct="4" pname="e"/>
                  <note xml:id="m3n2" dur="2" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 B4 → C4 E4 — contrast Em/IV -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh1" oct="4" pname="g"/>
                    <note xml:id="m3rh2" oct="4" pname="b"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh3" oct="4" pname="c"/>
                    <note xml:id="m3rh4" oct="4" pname="e"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: E2 B2 G3 → C2 G2 C3 E3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh1" oct="2" pname="e"/>
                    <note xml:id="m3lh2" oct="2" pname="b"/>
                    <note xml:id="m3lh3" oct="3" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3lh4" oct="2" pname="c"/>
                    <note xml:id="m3lh5" oct="2" pname="g"/>
                    <note xml:id="m3lh6" oct="3" pname="c"/>
                    <note xml:id="m3lh7" oct="3" pname="e"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" dur="2" oct="2" pname="e" stem.dir="down"/>
                  <note xml:id="m3p2" dur="2" oct="2" pname="c" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 4: Am, D, G, C — melody A A B G -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m4n3" dur="4" oct="4" pname="b"/>
                  <note xml:id="m4n4" dur="4" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: A3 C4 → F#4 A4 → B3 D4 → G4 C5 (IV color) -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh1" oct="3" pname="a"/>
                    <note xml:id="m4rh2" oct="4" pname="c"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh3" oct="4" pname="g"/>
                    <note xml:id="m4rh4" oct="4" pname="b"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: A2 E3 A3 C4 → D2 A2 F#3 D3 → G2 D3 G3 B3 → C2 G2 E3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh1" oct="2" pname="a"/>
                    <note xml:id="m4lh2" oct="3" pname="e"/>
                    <note xml:id="m4lh3" oct="3" pname="a"/>
                    <note xml:id="m4lh4" oct="4" pname="c"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh5" oct="2" pname="g"/>
                    <note xml:id="m4lh6" oct="3" pname="d"/>
                    <note xml:id="m4lh7" oct="3" pname="g"/>
                    <note xml:id="m4lh8" oct="3" pname="b"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" dur="2" oct="2" pname="a" stem.dir="down"/>
                  <note xml:id="m4p2" dur="2" oct="2" pname="g" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 5: Am, D, G — melody A A B2 -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m5n3" dur="2" oct="4" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: C4 E4 → F#4 A4 → D4 G4 — ii→V→I -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh1" oct="4" pname="c"/>
                    <note xml:id="m5rh2" oct="4" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh3" oct="4" pname="d"/>
                    <note xml:id="m5rh4" oct="4" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: A2 E3 A3 → D2 A2 F#3 D3 → G2 D3 G3 B3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh1" oct="2" pname="a"/>
                    <note xml:id="m5lh2" oct="3" pname="e"/>
                    <note xml:id="m5lh3" oct="3" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh4" oct="2" pname="g"/>
                    <note xml:id="m5lh5" oct="3" pname="d"/>
                    <note xml:id="m5lh6" oct="3" pname="g"/>
                    <note xml:id="m5lh7" oct="3" pname="b"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" dur="2" oct="2" pname="a" stem.dir="down"/>
                  <note xml:id="m5p2" dur="2" oct="2" pname="g" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 6: (I→)B(→Bm/iii), C, G — melody B2 c B -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" dur="2" oct="4" pname="b"/>
                  <note xml:id="m6n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m6n3" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: B3 D4 → C4 E4 → B3 G4 — iii→IV→I -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh1" oct="3" pname="b"/>
                    <note xml:id="m6rh2" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh3" oct="4" pname="g"/>
                    <note xml:id="m6rh4" oct="5" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: B2 F#3 B3 D4 → C2 G2 C3 E3 → G2 D3 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh1" oct="2" pname="b"/>
                    <note xml:id="m6lh2" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m6lh3" oct="3" pname="b"/>
                    <note xml:id="m6lh4" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh5" oct="2" pname="g"/>
                    <note xml:id="m6lh6" oct="3" pname="c"/>
                    <note xml:id="m6lh7" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m6p1" dur="2" oct="2" pname="b" stem.dir="down"/>
                  <note xml:id="m6p2" dur="2" oct="2" pname="g" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 7: D, Em, Am, D — melody d B A A -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" dur="4" oct="5" pname="d"/>
                  <note xml:id="m7n2" dur="4" oct="4" pname="b"/>
                  <note xml:id="m7n3" dur="4" oct="4" pname="a"/>
                  <note xml:id="m7n4" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F#4 A4 D5 → G4 B4 → A3 C4 E4 — building -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh1" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m7rh2" oct="4" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh3" oct="4" pname="a"/>
                    <note xml:id="m7rh4" oct="4" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7rh5" dur="4" oct="5" pname="d" stem.dir="down"/>
                  <rest dur="4" visible="false"/>
                  <rest dur="2" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: D2 A2 D3 F#3 → E2 B2 E3 G3 → A2 E3 A3 C4 → D2 A2 D3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh1" oct="2" pname="d"/>
                    <note xml:id="m7lh2" oct="2" pname="a"/>
                    <note xml:id="m7lh3" oct="3" pname="d"/>
                    <note xml:id="m7lh4" oct="3" pname="f" accid.ges="s"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh5" oct="2" pname="a"/>
                    <note xml:id="m7lh6" oct="3" pname="e"/>
                    <note xml:id="m7lh7" oct="3" pname="a"/>
                    <note xml:id="m7lh8" oct="4" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7p1" dur="2" oct="2" pname="d" stem.dir="down"/>
                  <note xml:id="m7p2" dur="2" oct="2" pname="a" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 8: G — melody G2 B2 -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" dur="2" oct="4" pname="g"/>
                  <note xml:id="m8n2" dur="2" oct="4" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: D4 G4 B4 — "33" I full -->
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m8rh1" oct="4" pname="d"/>
                    <note xml:id="m8rh2" oct="4" pname="g"/>
                    <note xml:id="m8rh3" oct="4" pname="b"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: G2 D3 G3 B3 — "334" I -->
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m8lh1" oct="2" pname="g"/>
                    <note xml:id="m8lh2" oct="3" pname="d"/>
                    <note xml:id="m8lh3" oct="3" pname="g"/>
                    <note xml:id="m8lh4" oct="3" pname="b"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 9: C, Am, G, D — melody G A G F# -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m9n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m9n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m9n4" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: C4 E4 → A3 C4 → B3 D4 → A3 F#4 — descending line -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m9rh1" oct="4" pname="c"/>
                    <note xml:id="m9rh2" oct="4" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m9rh3" oct="4" pname="d"/>
                    <note xml:id="m9rh4" oct="4" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 C3 E3 → A2 E3 A3 C4 → G2 D3 G3 B3 → D2 A2 F#3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m9lh1" oct="2" pname="c"/>
                    <note xml:id="m9lh2" oct="2" pname="g"/>
                    <note xml:id="m9lh3" oct="3" pname="c"/>
                    <note xml:id="m9lh4" oct="3" pname="e"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m9lh5" oct="2" pname="d"/>
                    <note xml:id="m9lh6" oct="2" pname="a"/>
                    <note xml:id="m9lh7" oct="3" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m9p1" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m9p2" dur="2" oct="2" pname="d" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 10: Em, ^D(→D/V or Em), Em final — melody E D# E2 -->
            <!-- D# non-diatonic → sub D (V) for harp. Melody keeps D# as accidental -->
            <measure n="10" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" dur="4" oct="4" pname="e"/>
                  <note xml:id="m10n2" dur="4" oct="4" pname="d" accid="s"/>
                  <note xml:id="m10n3" dur="2" oct="4" pname="e"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 B4 → A3 F#4 → G4 B4 E5 — final climax -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m10rh1" oct="4" pname="g"/>
                    <note xml:id="m10rh2" oct="4" pname="b"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m10rh3" oct="4" pname="g"/>
                    <note xml:id="m10rh4" oct="5" pname="e"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: E2 B2 E3 G3 → D2 A2 D3 → E2 B2 E3 G3 full final -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m10lh1" oct="2" pname="e"/>
                    <note xml:id="m10lh2" oct="2" pname="b"/>
                    <note xml:id="m10lh3" oct="3" pname="e"/>
                    <note xml:id="m10lh4" oct="3" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
