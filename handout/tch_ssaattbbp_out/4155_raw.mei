<?xml version="1.0" encoding="UTF-8"?>
<!-- 4155 Jesus Loves Me — pedal harp, key Eb, 4/4 -->
<!-- Key Eb: 3 flats — Bb, Eb, Ab. -->
<!-- Scale: Eb(1) F(2) G(3) Ab(4) Bb(5) C(6) D(7) -->
<!-- ABC:
  m1: Eb_B G G Bb_F
  m2: Eb_G B B2
  m3: C_c c e c
  m4: c Eb_B B2
  m5: B G G Bb_F
  m6: Eb_G B B2
  m7: C_c c Eb_B E
  m8: G G#(→Ab/IV) Eb_F2
  m9: B2 G B
  m10: C_c e3
  m11: Eb_B2 G E
  m12: G Bb_F3
  m13: Eb_B2 G B
  m14: C_c e2 c
  m15: Eb_B E G3/2 G#(→Ab/IV)_F/2
  m16: Eb_E4
-->
<!-- G# = Ab in Eb key (enharmonic = IV scale degree) -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Jesus Loves Me</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="3f">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="3f">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="3f">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Measure 1: Eb, Bb — melody B G G F -->
            <!-- I=Eb; V=Bb(Bb D F) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m1n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1n4" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 Bb4 — light "33" I -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh1" oct="4" pname="g"/>
                    <note xml:id="m1rh2" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh3" oct="4" pname="f"/>
                    <note xml:id="m1rh4" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 Bb2 Eb3 G3 — "334" I open -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m1lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m1lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m1lh4" oct="3" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m1lh6" oct="3" pname="f"/>
                    <note xml:id="m1lh7" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" dur="2" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m1p2" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 2: Eb — melody G B B2 -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m2n2" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m2n3" dur="2" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 sustained — common tone hold -->
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m2rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m2rh2" oct="4" pname="g"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: arpeggiate Eb2 G2 Bb2 Eb3 -->
                <layer n="1">
                  <note xml:id="m2lh1" dur="4" oct="2" pname="e" accid.ges="f" stem.dir="up"/>
                  <note xml:id="m2lh2" dur="4" oct="2" pname="g" stem.dir="up"/>
                  <note xml:id="m2lh3" dur="4" oct="2" pname="b" accid.ges="f" stem.dir="up"/>
                  <note xml:id="m2lh4" dur="4" oct="3" pname="e" accid.ges="f" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" dur="1" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 3: C(→vi=Cm) — melody c c e c -->
            <!-- vi=Cm (C Eb G) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m3n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m3n3" dur="4" oct="5" pname="e" accid.ges="f"/>
                  <note xml:id="m3n4" dur="4" oct="5" pname="c"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 → Eb5 — step up into Cm higher register -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m3rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh3" oct="4" pname="g"/>
                    <note xml:id="m3rh4" oct="5" pname="e" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 Eb3 G3 — "33" vi -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m3lh1" oct="2" pname="c"/>
                    <note xml:id="m3lh2" oct="2" pname="g"/>
                    <note xml:id="m3lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m3lh4" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" dur="1" oct="2" pname="c" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Measure 4: Eb, Bb — melody c B B2 -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m4n3" dur="2" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 — return I, step down from Cm -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m4rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4rh3" oct="4" pname="f"/>
                    <note xml:id="m4rh4" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 Bb2 G3 → Bb2 F3 Bb3 D4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m4lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh3" oct="3" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m4lh4" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh5" oct="3" pname="f"/>
                    <note xml:id="m4lh6" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh7" oct="4" pname="d"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" dur="2" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m4p2" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measures 5-8: repeat of mm.1-4 with variation -->
            <!-- Measure 5: parallel to m.1 -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m5n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m5n4" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m5rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh3" oct="4" pname="d"/>
                    <note xml:id="m5rh4" oct="4" pname="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m5lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m5lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m5lh4" oct="3" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m5lh6" oct="3" pname="f"/>
                    <note xml:id="m5lh7" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" dur="2" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m5p2" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 6: Eb — melody G B B2 (like m.2) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m6n2" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m6n3" dur="2" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 Bb4 — fuller this time -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m6rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m6rh2" oct="4" pname="g"/>
                    <note xml:id="m6rh3" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <note xml:id="m6lh1" dur="4" oct="2" pname="e" accid.ges="f" stem.dir="up"/>
                  <note xml:id="m6lh2" dur="4" oct="2" pname="g" stem.dir="up"/>
                  <note xml:id="m6lh3" dur="4" oct="2" pname="b" accid.ges="f" stem.dir="up"/>
                  <note xml:id="m6lh4" dur="4" oct="3" pname="e" accid.ges="f" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <note xml:id="m6p1" dur="1" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 7: C(→Cm), Eb, E(pickup) — melody c c B E -->
            <!-- E in melody (scale deg 1 of Eb = Eb) = natural E here: it's the
                 leading tone from the pickup Eb. Treat as Bb/V for harp -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m7n2" dur="4" oct="5" pname="c"/>
                  <note xml:id="m7n3" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m7n4" dur="4" oct="4" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 Eb5 → Eb4 G4 — symmetrical -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh1" oct="4" pname="g"/>
                    <note xml:id="m7rh2" oct="5" pname="e" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh3" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m7rh4" oct="4" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 Eb3 → Eb2 Bb2 Eb3 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh1" oct="2" pname="c"/>
                    <note xml:id="m7lh2" oct="2" pname="g"/>
                    <note xml:id="m7lh3" oct="3" pname="e" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh4" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m7lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m7lh6" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m7lh7" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7p1" dur="2" oct="2" pname="c" stem.dir="down"/>
                  <note xml:id="m7p2" dur="2" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 8: G(→G sub=iii Gm), Ab(=IV), Eb — melody G Ab F2 -->
            <!-- Ab=IV (Ab C Eb) -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m8n2" dur="4" oct="4" pname="a" accid.ges="f"/>
                  <note xml:id="m8n3" dur="2" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 D4 → Ab4 C5 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8rh1" oct="4" pname="d"/>
                    <note xml:id="m8rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8rh3" oct="4" pname="a" accid.ges="f"/>
                    <note xml:id="m8rh4" oct="5" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: G2 D3 Bb3 → Ab2 Eb3 Ab3 C4 (IV "33") -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8lh1" oct="2" pname="g"/>
                    <note xml:id="m8lh2" oct="3" pname="d"/>
                    <note xml:id="m8lh3" oct="3" pname="b" accid.ges="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m8lh4" oct="2" pname="a" accid.ges="f"/>
                    <note xml:id="m8lh5" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m8lh6" oct="3" pname="a" accid.ges="f"/>
                    <note xml:id="m8lh7" oct="4" pname="c"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m8p1" dur="2" oct="2" pname="g" stem.dir="down"/>
                  <note xml:id="m8p2" dur="2" oct="2" pname="a" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Refrain: Measures 9-16 -->
            <!-- Measure 9: Eb — melody B2 G B -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" dur="2" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m9n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m9n3" dur="4" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: G4 Bb4 — refrain begins lightly -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m9rh1" oct="4" pname="g"/>
                    <note xml:id="m9rh2" oct="4" pname="b" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Eb2 Bb2 Eb3 G3 -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m9lh1" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m9lh2" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m9lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m9lh4" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m9p1" dur="1" oct="1" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 10: C(→Cm) — melody c e3 -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m10n2" dur="2" oct="5" pname="e" accid.ges="f"/>
                  <note xml:id="m10n3" dur="4" oct="5" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb5 G4 — high register, "33" Cm -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m10rh1" oct="4" pname="g"/>
                    <note xml:id="m10rh2" oct="5" pname="e" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: C2 G2 Eb3 G3 — "33" vi full -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m10lh1" oct="2" pname="c"/>
                    <note xml:id="m10lh2" oct="2" pname="g"/>
                    <note xml:id="m10lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m10lh4" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m10p1" dur="1" oct="2" pname="c" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Measure 11: Eb — melody B2 G E -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" dur="2" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m11n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m11n3" dur="4" oct="4" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m11rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m11rh2" oct="4" pname="g"/>
