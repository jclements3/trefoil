<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Now Praise We Christ, the Holy One</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: C major (no sharps or flats). No accid.ges needed except on non-diatonic notes. -->
          <!-- Meter: 4/4, L:1/4. 4 quarter beats per bar. -->
          <!-- Diatonic scale C: C D E F G A B -->
          <!-- Chord map: I=C, ii=Dm, iii=Em, IV=F, V=G, vi=Am, vii°=B° -->
          <!-- Non-diatonic: A major (^G = G# in ABC — the lead sheet has "^G" for G#), E major -->
          <!-- The ABC contains "^G" in "^Am7"G → G# below A, making Am7 with a G# = M7 (AmΔ7?) -->
          <!-- "^E"^G = E major chord with G# → substitute V (G major) or iii (Em) context -->
          <!-- "^A"^G = A major → secondary dominant V/vi, treat as Am (vi) with G natural diatonic -->
          <!-- "^E"E = E in C is natural, just E major chord annotation → substitute iii (Em) or V/vi -->
          <!--
            MEASURE PLAN:
            M1: Dm2 F G  — Dm(ii), Dm/F(ii¹), C(I), G(V) → 4 beats: D D F G
            Actually: "^Dm"D2 F "^C"G → D(half=2beats), F(1beat), G(1beat) = 4 ✓
            M2: A D G F  — Dm/A, G, Em, Dm → "^Dm"A "^G"D "^Em"G "^Dm"F = 4 quarters
            M3: E2 z G   — E(half), rest(1), G(1) → "^A"E2 z G (Am annotation on E = vi context)
            M4: A c c B  — "^Dm"A "^Am"c "^C"c "^G"B = 4 quarters
            M5: A B c2   — "^Dm"A "^G"B "^C"c2 = A(1) B(1) c(2) = 4 ✓
            M6: z G A c  — z "^Am7"G "^F"A c = rest(1) G(1) A(1) c(1) = 4 ✓
            M7: c B A ^G — "^C"c "^G"B "^Am"A "^E"^G = c(1) B(1) A(1) G#(1) = 4 ✓
            G# in M7 beat4: non-diatonic, substitute A→G (step down) or use Em→V
            Actually "^E"^G means E major chord with bass/note G# → sounds like E/G# = iii/V hybrid
            Best substitute: treat as E = ③m (Em = iii in C) for the diatonic harp
            M8: A2 z D   — "^Am"A2 z D = A(half) rest(1) D(1) = 4 ✓
            M9: A A c A  — "^F"A "^Dm"A "^C"c "^F"A = A(1) A(1) c(1) A(1) = 4 ✓
            M10: G/2 A/2 F E2  — "^Em"G/2 "^Am"A/2 "^Dm"F "^C"E2 = G/2+A/2=1 F=1 E=2 = 4 ✓
            M11: E4 — "^E"E4 = E whole → "^E" annotation = E major, substitute ③m (Em)
          -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="0" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="0" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="0" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- M1: Dm(half)/F(1bt)/C/G. Melody: D2(half) F(qtr) G(qtr) -->
            <!-- beat1-2: Dm(ii), beat3: F passing (ii 1st inv = IV approach), beat4: G(V) -->
            <!-- ============================================================ -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="d" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="f" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat1-2: F4-A4 (ii 1st inv "43") — open, lighter -->
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="f" oct="4" />
                    <note xml:id="m1s2n2" pname="a" oct="4" />
                  </chord>
                  <!-- beat3: F4-A4 (IV "33") — F chord passing -->
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="f" oct="4" />
                    <note xml:id="m1s2n4" pname="a" oct="4" />
                  </chord>
                  <!-- beat4: G4-B4 (V "33") -->
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="g" oct="4" />
                    <note xml:id="m1s2n6" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat1-2: D3-A3-F3 (ii "33" open) -->
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="d" oct="3" />
                    <note xml:id="m1s3n2" pname="f" oct="3" />
                    <note xml:id="m1s3n3" pname="a" oct="3" />
                  </chord>
                  <!-- beat3: F3-C4-A3 (IV "33") -->
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n4" pname="f" oct="3" />
                    <note xml:id="m1s3n5" pname="a" oct="3" />
                    <note xml:id="m1s3n6" pname="c" oct="4" />
                  </chord>
                  <!-- beat4: G3-D4-B3 (V "334") -->
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n7" pname="g" oct="3" />
                    <note xml:id="m1s3n8" pname="b" oct="3" />
                    <note xml:id="m1s3n9" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- M2: Dm/G/Em/Dm. Melody: A(4) D(4) G(4) F(4) -->
            <!-- ============================================================ -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="d" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="f" />
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat1: D4-F4 (ii "33") -->
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="d" oct="4" />
                    <note xml:id="m2s2n2" pname="f" oct="4" />
                  </chord>
                  <!-- beat2: D4-G4 (V 2nd inv "34") -->
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="d" oct="4" />
                    <note xml:id="m2s2n4" pname="g" oct="4" />
                  </chord>
                  <!-- beat3: E4-G4 (iii "33") -->
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="e" oct="4" />
                    <note xml:id="m2s2n6" pname="g" oct="4" />
                  </chord>
                  <!-- beat4: F4-A4 (ii 1st inv "43") -->
                  <chord xml:id="m2s2c4" dur="4">
                    <note xml:id="m2s2n7" pname="f" oct="4" />
                    <note xml:id="m2s2n8" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat1: D3-A3-F3 (ii "33") -->
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="d" oct="3" />
                    <note xml:id="m2s3n2" pname="f" oct="3" />
                    <note xml:id="m2s3n3" pname="a" oct="3" />
                  </chord>
                  <!-- beat2: G3-D4-B3 (V "334") -->
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="g" oct="3" />
                    <note xml:id="m2s3n5" pname="b" oct="3" />
                    <note xml:id="m2s3n6" pname="d" oct="4" />
                  </chord>
                  <!-- beat3: E3-B3-G3 (iii "33") -->
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n7" pname="e" oct="3" />
                    <note xml:id="m2s3n8" pname="g" oct="3" />
                    <note xml:id="m2s3n9" pname="b" oct="3" />
                  </chord>
                  <!-- beat4: D3-A3-F3-D4 (ii "334") -->
                  <chord xml:id="m2s3c4" dur="4">
                    <note xml:id="m2s3n10" pname="d" oct="3" />
                    <note xml:id="m2s3n11" pname="f" oct="3" />
                    <note xml:id="m2s3n12" pname="a" oct="3" />
                    <note xml:id="m2s3n13" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- M3: Am(2bt)/rest/G. Melody: E2(half) z(rest) G(qtr) -->
            <!-- "^A" annotation = A major → substitute Am(vi). E natural in C = ok. -->
            <!-- ============================================================ -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="2" oct="4" pname="e" />
                  <rest xml:id="m3s1r1" dur="4" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat1-2: E4-A4 (vi "43" 1st inv) -->
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="e" oct="4" />
                    <note xml:id="m3s2n2" pname="a" oct="4" />
                  </chord>
                  <!-- beat3: rest -->
                  <rest xml:id="m3s2r1" dur="4" />
                  <!-- beat4: G4-B4 (V "33") -->
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="g" oct="4" />
                    <note xml:id="m3s2n4" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat1-2: A3-E4-C4 (vi "333") open voicing -->
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="a" oct="3" />
                    <note xml:id="m3s3n2" pname="c" oct="4" />
                    <note xml:id="m3s3n3" pname="e" oct="4" />
                  </chord>
                  <!-- beat3: rest -->
                  <rest xml:id="m3s3r1" dur="4" />
                  <!-- beat4: G3-D4-B3 (V "334") -->
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="g" oct="3" />
                    <note xml:id="m3s3n5" pname="b" oct="3" />
                    <note xml:id="m3s3n6" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- M4: Dm/Am/C/G. Melody: A(4) c(4) c(4) B(4) -->
            <!-- ============================================================ -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m4s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m4s1n3" dur="4" oct="5" pname="c" />
                  <note xml:id="m4s1n4" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat1: F4-A4 (ii 1st inv) -->
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="f" oct="4" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                  </chord>
                  <!-- beat2: A4-C5 (vi "33") -->
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="a" oct="4" />
                    <note xml:id="m4s2n4" pname="c" oct="5" />
                  </chord>
                  <!-- beat3: E4-G4 (I 2nd inv context / iii "33") -->
                  <chord xml:id="m4s2c3" dur="4">
                    <note xml:id="m4s2n5" pname="e" oct="4" />
                    <note xml:id="m4s2n6" pname="g" oct="4" />
                  </chord>
                  <!-- beat4: G4-B4 (V "33") -->
                  <chord xml:id="m4s2c4" dur="4">
                    <note xml:id="m4s2n7" pname="g" oct="4" />
                    <note xml:id="m4s2n8" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat1: D3-A3-F3-D4 (ii "334") -->
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="d" oct="3" />
                    <note xml:id="m4s3n2" pname="f" oct="3" />
                    <note xml:id="m4s3n3" pname="a" oct="3" />
                    <note xml:id="m4s3n4" pname="d" oct="4" />
                  </chord>
                  <!-- beat2: A3-E4-C4 (vi "333") -->
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n5" pname="a" oct="3" />
                    <note xml:id="m4s3n6" pname="c" oct="4" />
                    <note xml:id="m4s3n7" pname="e" oct="4" />
                  </chord>
                  <!-- beat3: C3-G3-E3-C4 (I "333") -->
                  <chord xml:id="m4s3c3" dur="4">
                    <note xml:id="m4s3n8" pname="c" oct="3" />
                    <note xml:id="m4s3n9" pname="e" oct="3" />
                    <note xml:id="m4s3n10" pname="g" oct="3" />
                    <note xml:id="m4s3n11" pname="c" oct="4" />
                  </chord>
                  <!-- beat4: G3-D4-B3 (V "334") -->
                  <chord xml:id="m4s3c4" dur="4">
                    <note xml:id="m4s3n12" pname="g" oct="3" />
                    <note xml:id="m4s3n13" pname="b" oct="3" />
                    <note xml:id="m4s3n14" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- M5: Dm/G/C(half). Melody: A(4) B(4) c2 -->
            <!-- ============================================================ -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="b" />
                  <note xml:id="m5s1n3" dur="2" oct="5" pname="c" />
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat1: F4-A4 (ii 1st inv) -->
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n1" pname="f" oct="4" />
                    <note xml:id="m5s2n2" pname="a" oct="4" />
                  </chord>
                  <!-- beat2: G4-B4 (V "33") — ascending suspension: A→B→C in melody -->
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="g" oct="4" />
                    <note xml:id="m5s2n4" pname="b" oct="4" />
                  </chord>
                  <!-- beat3-4: E4-G4 (I 2nd inv / iii) -->
                  <chord xml:id="m5s2c3" dur="2">
                    <note xml:id="m5s2n5" pname="e" oct="4" />
                    <note xml:id="m5s2n6" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat1: D3-A3-F3 (ii "33") -->
                  <chord xml:id="m5s3c1" dur="4">
                    <note xml:id="m5s3n1" pname="d" oct="3" />
                    <note xml:id="m5s3n2" pname="f" oct="3" />
                    <note xml:id="m5s3n3" pname="a" oct="3" />
                  </chord>
                  <!-- beat2: G3-D4-B3 (V "334") -->
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="g" oct="3" />
                    <note xml:id="m5s3n5" pname="b" oct="3" />
                    <note xml:id="m5s3n6" pname="d" oct="4" />
                  </chord>
                  <!-- beat3-4: C3-G3-E3-C4 (I "333") -->
                  <chord xml:id="m5s3c3" dur="2">
                    <note xml:id="m5s3n7" pname="c" oct="3" />
                    <note xml:id="m5s3n8" pname="e" oct="3" />
                    <note xml:id="m5s3n9" pname="g" oct="3" />
                    <note xml:id="m5s3n10" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- M6: rest/Am7/F/C. Melody: z(rest) G(4) A(4) c(4) -->
            <!-- Am7 on G = Am7 with G as inner voice. F on A note. -->
            <!-- ============================================================ -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <rest xml:id="m6s1r1" dur="4" />
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n3" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat1: rest -->
                  <rest xml:id="m6s2r1" dur="4" />
                  <!-- beat2: E4-A4 (vi "43") -->
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="e" oct="4" />
                    <note xml:id="m6s2n2" pname="a" oct="4" />
                  </chord>
                  <!-- beat3: F4-A4 (IV "33") -->
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="f" oct="4" />
                    <note xml:id="m6s2n4" pname="a" oct="4" />
                  </chord>
                  <!-- beat4: E4-G4 (I 2nd inv "34") -->
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="e" oct="4" />
                    <note xml:id="m6s2n6" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat1: rest -->
                  <rest xml:id="m6s3r1" dur="4" />
                  <!-- beat2: A3-E4-C4-G3 (vi7 open "333") -->
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="a" oct="3" />
                    <note xml:id="m6s3n2" pname="c" oct="4" />
                    <note xml:id="m6s3n3" pname="e" oct="4" />
                  </chord>
                  <!-- beat3: F3-C4-A3 (IV "334") -->
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="f" oct="3" />
                    <note xml:id="m6s3n5" pname="a" oct="3" />
                    <note xml:id="m6s3n6" pname="c" oct="4" />
                    <note xml:id="m6s3n7" pname="f" oct="4" />
                  </chord>
                  <!-- beat4: C3-G3-E3-C4 (I "333") -->
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n8" pname="c" oct="3" />
                    <note xml:id="m6s3n9" pname="e" oct="3" />
                    <note xml:id="m6s3n10" pname="g" oct="3" />
                    <note xml:id="m6s3n11" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="2">⑥m7</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- M7: C/G/Am/Em. Melody: c(4) B(4) A(4) G#(non-diatonic→G) -->
            <!-- beat4 "^E"^G annotation: G# in ABC = non-diatonic in C. -->
            <!-- Harp plays diatonic: substitute E minor (iii) for E major context. -->
            <!-- G# in melody is omitted/approached as G natural in harp. -->
            <!-- ============================================================ -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
