<!-- Measure 7: 4 beats. E→Em | D(V) | G(I) | E/2→Em Bm→iii
     ABC: E "^D"F "^G"G/2 E/2 "^Bm"F
     Melody: E4(4) F#4(4) G4(8) E4(8) F#4(4)
     Chords: vi beat1, V beat2, I beat3, iii beat4
-->
<measure n="7" right="single">
  <staff n="1">
    <layer n="1">
      <note xml:id="m7s1n1" dur="4" oct="4" pname="e"/>
      <note xml:id="m7s1n2" dur="4" oct="4" pname="f" accid.ges="s"/>
      <note xml:id="m7s1n3" dur="8" oct="4" pname="g"/>
      <note xml:id="m7s1n4" dur="8" oct="4" pname="e"/>
      <note xml:id="m7s1n5" dur="4" oct="4" pname="f" accid.ges="s"/>
    </layer>
  </staff>
