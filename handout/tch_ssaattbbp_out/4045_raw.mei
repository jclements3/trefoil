      <chord xml:id="m7s3c4" dur="4">
        <note xml:id="m7s3n13" pname="b" oct="2"/>
        <note xml:id="m7s3n14" pname="f" oct="3" accid.ges="s"/>
        <note xml:id="m7s3n15" pname="b" oct="3"/>
        <note xml:id="m7s3n16" pname="d" oct="4"/>
