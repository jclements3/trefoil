  <staff n="3">
    <layer n="1">
      <!-- beat 1: Em — E3-B3-E4-G4 -->
      <chord xml:id="m7s3c1" dur="4">
        <note xml:id="m7s3n1" pname="e" oct="3"/>
        <note xml:id="m7s3n2" pname="b" oct="3"/>
