<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>See, The Lord Ascends In Triumph</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: A major (3 sharps: F# C# G#). 4/4 time. 32 bars.
               accid.ges="s" on all f (→F#), c (→C#), g (→G#) notes in harp staves.
               Non-diatonic chords: Eb=D#→use E(⑤); F#7→use F#m(⑥m); G#m=③m.
               Pedal bass extension: A1, E1, D1 available on pedal harp (P voice).
          -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="3s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="3s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="3s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="3s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Bar 1: A A, E E, F#m A, E B — 4 beats.
                 Melody: A4 E4 A4 B4
                 Chords: A(b1) E(b2) F#m(b3) E(b4)
                 Opening — light texture, wide spacing
            -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m1n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m1n3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m1n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: sparse, light opener — E5 B4 half values -->
                  <chord xml:id="m1r1" dur="2">
                    <note pname="e" oct="5"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m1r2" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="c" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A "33": A2 C#3 E3 A3 -->
                  <chord xml:id="m1l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <!-- E "43" 1st inv: G#2 B2 E3 G#3 -->
                  <chord xml:id="m1l2" dur="2">
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 2: A c3/2 d/2, c, E B — 4 beats.
                 c3/2 = dotted q C5, d/2 = 8th D5, then c (q C5), E B (q B4)
                 Beats: 2 + 1 + 1 = 4
                 Chords: A(b1) E(b4)
            -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="c" oct="5" dur="4" dots="1" accid.ges="s"/>
                  <note xml:id="m2n2" pname="d" oct="5" dur="8"/>
                  <note xml:id="m2n3" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m2n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: E5 C#5 quarter motion -->
                  <note xml:id="m2r1" pname="e" oct="5" dur="4" dots="1"/>
                  <note xml:id="m2r2" pname="c" oct="5" dur="8" accid.ges="s"/>
                  <note xml:id="m2r3" pname="a" oct="4" dur="4"/>
                  <note xml:id="m2r4" pname="g" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A "334": A2 E3 A3 C#4 full open -->
                  <chord xml:id="m2l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <!-- E: E2 B2 E3 G#3 -->
                  <chord xml:id="m2l2" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 3: A e, F#m A, Bm7 B, F#m c/2 d/2 — 4 beats.
                 e=E5, A=A4, B=B4, c/2 d/2 = C#5 8th + D5 8th
            -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="e" oct="5" dur="4"/>
                  <note xml:id="m3n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m3n3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m3n4" pname="c" oct="5" dur="8" accid.ges="s"/>
                  <note xml:id="m3n5" pname="d" oct="5" dur="8"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: ascending A4 C#5 E5 -->
                  <note xml:id="m3r1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m3r2" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <chord xml:id="m3r3" dur="2">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A "43" 1st inv: C#2 E3 A3 C#4 -->
                  <chord xml:id="m3l1" dur="2">
                    <note pname="c" oct="2" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <!-- F#m "334": F#2 C#3 F#3 A3 -->
                  <chord xml:id="m3l2" dur="2">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">②m7</harm>
              <harm staff="1" tstamp="4">⑥m</harm>
            </measure>

            <!-- Bar 4: A c, E B, A c2 — 4 beats. c=C5, B=B4 -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m4n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m4n3" pname="c" oct="5" dur="2" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: E5 D5 then hold C#5 E5 half -->
                  <note xml:id="m4r1" pname="e" oct="5" dur="4"/>
                  <note xml:id="m4r2" pname="d" oct="5" dur="4"/>
                  <chord xml:id="m4r3" dur="2">
                    <note pname="c" oct="5" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A "334": A2 E3 A3 C#4, then A held -->
                  <chord xml:id="m4l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m4l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 5: c, E B, A c, E e — 4 beats (no A annotation = cont. I)
                 Chords: A(b1) E(b2) A(b3) E(b4)
            -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m5n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m5n3" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m5n4" pname="e" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: rising E5 G#5 — building toward middle section climax -->
                  <note xml:id="m5r1" pname="e" oct="5" dur="4"/>
                  <note xml:id="m5r2" pname="d" oct="5" dur="4"/>
                  <note xml:id="m5r3" pname="e" oct="5" dur="4"/>
                  <note xml:id="m5r4" pname="g" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A "333" 7th: A2 C#3 E3 G#3 — AΔ7 richness -->
                  <chord xml:id="m5l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- E "333" 7th: E2 G#2 B2 D3 (E7) — richer dominant -->
                  <chord xml:id="m5l2" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="b" oct="2"/>
                    <note pname="d" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ7</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑤7</harm>
            </measure>

            <!-- Bar 6: F#m A, E G G, Bm F — 4 beats.
                 F=F#4, A=A4, G=G#4, F=F#4 (Bm root pos)
            -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m6n2" pname="g" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m6n3" pname="g" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m6n4" pname="f" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: C#5 B4 B4 A4 — stepwise descent -->
                  <note xml:id="m6r1" pname="c" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m6r2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m6r3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m6r4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- F#m "33": F#2 A2 C#3 F#3 -->
                  <chord xml:id="m6l1" dur="4">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- E "33": E2 G#2 B2 E3 -->
                  <chord xml:id="m6l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- E continued: same chord -->
                  <chord xml:id="m6l3" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- Bm "33": B2 D3 F#3 B3 -->
                  <chord xml:id="m6l4" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Bar 7: F#7 B, G#m B, C#m e, E G — 4 beats.
                 F#7 → use F#m (⑥m); G#m = ③m; C#m = ⑥m
                 B=B4, e=E5, G=G#4
            -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="b" oct="4" dur="4"/>
                  <note xml:id="m7n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m7n3" pname="e" oct="5" dur="4"/>
                  <note xml:id="m7n4" pname="g" oct="4" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: D#5 E5 G#5 B4 — chromatic passing in E region -->
                  <note xml:id="m7r1" pname="d" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m7r2" pname="e" oct="5" dur="4"/>
                  <note xml:id="m7r3" pname="g" oct="5" dur="4" accid.ges="s"/>
                  <note xml:id="m7r4" pname="e" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- F#m "43" 1st inv: A2 C#3 F#3 A3 -->
                  <chord xml:id="m7l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <!-- C#m "334": C#2 G#2 C#3 E3 — for G#m sub (closely related) -->
                  <chord xml:id="m7l2" dur="4">
                    <note pname="c" oct="2" accid.ges="s"/>
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- C#m again: C#2 G#2 C#3 E3 -->
                  <chord xml:id="m7l3" dur="4">
                    <note pname="c" oct="2" accid.ges="s"/>
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- E "43" 1st inv: G#2 B2 E3 G#3 -->
                  <chord xml:id="m7l4" dur="4">
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 8: C#m F, Eb F, E E2 — 4 beats.
                 F=F#4, Eb=D# → use E (⑤); E2 = half E4
            -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m8n2" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m8n3" pname="e" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: A4 G#4 G#4 — suspension then hold -->
                  <note xml:id="m8r1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m8r2" pname="g" oct="4" dur="4" accid.ges="s"/>
                  <chord xml:id="m8r3" dur="2">
                    <note pname="g" oct="4" accid.ges="s"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C#m "33": C#2 E3 G#3 C#4 -->
                  <chord xml:id="m8l1" dur="2">
                    <note pname="c" oct="2" accid.ges="s"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3" accid.ges="s"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <!-- E "334": E2 B2 E3 G#3 -->
                  <chord xml:id="m8l2" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Bar 9: E3/2 F#m F/2, E G, Bm B — 4 beats.
                 E3/2 = dotted q E4, F/2 = 8th F#4, G=G#4, B=B4
            -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="e" oct="4" dur="4" dots="1"/>
                  <note xml:id="m9n2" pname="f" oct="4" dur="8" accid.ges="s"/>
                  <note xml:id="m9n3" pname="g" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m9n4" pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: B4 A4 B4 D5 ascending -->
                  <note xml:id="m9r1" pname="b" oct="4" dur="4" dots="1"/>
                  <note xml:id="m9r2" pname="a" oct="4" dur="8"/>
                  <note xml:id="m9r3" pname="b" oct="4" dur="4"/>
                  <note xml:id="m9r4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- E "33": E2 G#2 B2 E3 for dotted-q figure -->
                  <chord xml:id="m9l1" dur="2">
                    <note pname="e" oct="2"/>
                    <note pname="g" oct="2" accid.ges="s"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- F#m "33": F#2 A2 C#3 F#3 -->
                  <chord xml:id="m9l2" dur="4">
                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3" accid.ges="s"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                  </chord>
                  <!-- Bm "33": B2 D3 F#3 B3 -->
                  <chord xml:id="m9l3" dur="4">
                    <note pname="b" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- Bar 10: A A, E G, D F, A E — 4 beats.
                 A=A4, G=G#4, F=F#4(D chord tone), E=E4
                 D = ④, A = ①
            -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m10n2" pname="g" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m10n3" pname="f" oct="4" dur="4" accid.ges="s"/>
                  <note xml:id="m10n4" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- RH: E5 E5 D5 C#5 — stepwise descent, contrary to rising LH bass -->
                  <note xml:id="m10r1" pname="e" oct="5" dur="4"/>
                  <note xml:id="m10r2" pname="e" oct="5" dur="4"/>
                  <note xml:id="m10r3" pname="d" oct="5" dur="4"/>
                  <note xml:id="m10r4" pname="c" oct="5" dur="4" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- A "334": A2 E3 A3 C#4 -->
                  <chord xml:id="m10l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4" accid.ges="s"/>
                  </chord>
