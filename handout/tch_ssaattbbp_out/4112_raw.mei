                  <chord xml:id="m14l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 15: Gm G, F F, Gm7 F, C E — 4 beats. Final approach cadence.
                 Gm = ②m, F = ①, Gm7 = ②m7, C = ⑤
            -->
            <measure n="15">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m15n2" pname="f" oct="4" dur="4"/>
