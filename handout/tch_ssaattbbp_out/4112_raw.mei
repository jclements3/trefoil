                  <!-- RH: descending suspension — D5→C5→Bb4→G4 -->
                  <note xml:id="m15r1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m15r2" pname="c" oct="5" dur="4"/>
                  <note xml:id="m15r3" pname="b" oct="4" dur="4" accid.ges="f"/>
