                  <!-- Gm "44" quartal: G2 C3 F3 for color, then F: F2 C3 F3 A3 -->
                  <chord xml:id="m15l1" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
