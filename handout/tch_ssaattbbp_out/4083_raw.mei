            <!-- Bar 8: (C#m implied) — melody: C#4(2) G#4. Low register break -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="4" pname="c" accid.ges="s"/>
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="g" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: C#m C#4-E4 half, G#m G#4-B4 quarter — voices rise -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="2">
                    <note xml:id="m8s2n1" pname="c" oct="4" accid.ges="s"/>
                    <note xml:id="m8s2n2" pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m8s2c2" dur="4">
                    <note xml:id="m8s2n3" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m8s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: C#m C#2-G#2-C#3-E3, then G#m G#2-D#3-G#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="2">
                    <note xml:id="m8s3n1" pname="c" oct="2" accid.ges="s"/>
                    <note xml:id="m8s3n2" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m8s3n3" pname="c" oct="3" accid.ges="s"/>
                    <note xml:id="m8s3n4" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m8s3c2" dur="4">
                    <note xml:id="m8s3n5" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m8s3n6" pname="d" oct="3" accid.ges="s"/>
                    <note xml:id="m8s3n7" pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 3 (mm. 9-12): Return — fuller texture, high register  -->
            <!-- ============================================================ -->

            <!-- Bar 9: Ebm(→B/V) E — melody: B4(2) B4 -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" oct="4" pname="b"/>
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <!-- RH: B D#5-F#5, E G#4-B4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="2">
                    <note xml:id="m9s2n1" pname="d" oct="5" accid.ges="s"/>
                    <note xml:id="m9s2n2" pname="f" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m9s2c2" dur="4">
                    <note xml:id="m9s2n3" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m9s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: B B2-F#3-B3-D#4, E E2-B2-E3-G#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="2">
                    <note xml:id="m9s3n1" pname="b" oct="2"/>
                    <note xml:id="m9s3n2" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m9s3n3" pname="b" oct="3"/>
                    <note xml:id="m9s3n4" pname="d" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m9s3c2" dur="4">
