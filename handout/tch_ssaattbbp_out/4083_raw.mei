            <!-- Bar 7: C#m — melody: E4 D#4(2). C#m settling down -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="e"/>
                  <note xml:id="m7s1n2" dur="2" oct="4" pname="d" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: C#m E4-G#4 then settle C#4-E4 — voices compress inward -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="e" oct="4"/>
                    <note xml:id="m7s2n2" pname="g" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m7s2c2" dur="2">
                    <note xml:id="m7s2n3" pname="c" oct="4" accid.ges="s"/>
                    <note xml:id="m7s2n4" pname="e" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: C#m C#2-G#2-C#3-E3 whole -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2" dots="1">
                    <note xml:id="m7s3n1" pname="c" oct="2" accid.ges="s"/>
                    <note xml:id="m7s3n2" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m7s3n3" pname="c" oct="3" accid.ges="s"/>
