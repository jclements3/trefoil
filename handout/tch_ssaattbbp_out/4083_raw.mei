<?xml version="1.0" encoding="UTF-8"?>
<!-- O Wondrous Type, O Vision Fair — Key of E (4 sharps: F# C# G# D#), 3/4
     Scale degrees in E: I=E ii=F#m iii=G#m IV=A V=B vi=C#m vii°=D#dim
     Non-diatonic substitutions:
       Ebm (= D#m) → same as D#m = iii in a different enharmonic spelling, use G#m(iii) or V(B)
       G#m → iii (diatonic)
       C#m → vi (diatonic)
       F#m → ii (diatonic)
       A → IV (diatonic)
       B → V (diatonic)
       F#ø7 → viiø7 in E is D#ø7, but F#m7b5 could be ii7. Use F#m(ii) as substitute.
     Pickup: bar 0 is 1 beat (quarter note C#5)
     All F, C, G, D must carry accid.ges="s"
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Wondrous Type, O Vision Fair</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="3" meter.unit="4" key.sig="4s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="4s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="4s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="4s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup (1 beat): C#m — melody: C#5 -->
            <measure n="0" type="pickup" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" dur="4" oct="5" pname="c" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: C#m C#5-E5 open third -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m0s2c1" dur="4">
                    <note xml:id="m0s2n1" pname="c" oct="5" accid.ges="s"/>
                    <note xml:id="m0s2n2" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: C#m C#2-G#2-C#3 open 5th -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0s3c1" dur="4">
                    <note xml:id="m0s3n1" pname="c" oct="2" accid.ges="s"/>
                    <note xml:id="m0s3n2" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m0s3n3" pname="c" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Opening — modal E-major landscape        -->
            <!-- ============================================================ -->

            <!-- Bar 1: C#m E — melody: C#5(2) B4. C#m half then E quarter -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="5" pname="c" accid.ges="s"/>
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <!-- RH: C#m half E4-C#5, E quarter G#4-B4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="e" oct="4"/>
                    <note xml:id="m1s2n2" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m1s2n4" pname="b" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: C#m C#2-G#2-C#3-E3, E E2-B2-E3-G#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="c" oct="2" accid.ges="s"/>
                    <note xml:id="m1s3n2" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m1s3n3" pname="c" oct="3" accid.ges="s"/>
                    <note xml:id="m1s3n4" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n5" pname="e" oct="2"/>
                    <note xml:id="m1s3n6" pname="b" oct="2"/>
                    <note xml:id="m1s3n7" pname="e" oct="3"/>
                    <note xml:id="m1s3n8" pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 2: A Ebm(→G#m/iii) — melody: C#5(2) B4. A then G#m -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="2" oct="5" pname="c" accid.ges="s"/>
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <!-- RH: A C#5-E5, G#m B4-D#5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n1" pname="c" oct="5" accid.ges="s"/>
                    <note xml:id="m2s2n2" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="b" oct="4"/>
                    <note xml:id="m2s2n4" pname="d" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: A A2-E3-A3-C#4, G#m G#2-D#3-G#3-B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="a" oct="2"/>
                    <note xml:id="m2s3n2" pname="e" oct="3"/>
                    <note xml:id="m2s3n3" pname="a" oct="3"/>
                    <note xml:id="m2s3n4" pname="c" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n5" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m2s3n6" pname="d" oct="3" accid.ges="s"/>
                    <note xml:id="m2s3n7" pname="g" oct="3" accid.ges="s"/>
                    <note xml:id="m2s3n8" pname="b" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Bar 3: E A — melody: B4 A4(2). Cadential E-A -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="b"/>
                  <note xml:id="m3s1n2" dur="2" oct="4" pname="a"/>
                </layer>
              </staff>
              <!-- RH: E G#4-B4, A E4-A4-C#5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m3s2n2" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m3s2c2" dur="2">
                    <note xml:id="m3s2n3" pname="e" oct="4"/>
                    <note xml:id="m3s2n4" pname="a" oct="4"/>
                    <note xml:id="m3s2n5" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: E E2-B2-E3-G#3, A A2-E3-A3-C#4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="e" oct="2"/>
                    <note xml:id="m3s3n2" pname="b" oct="2"/>
                    <note xml:id="m3s3n3" pname="e" oct="3"/>
                    <note xml:id="m3s3n4" pname="g" oct="3" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m3s3c2" dur="2">
                    <note xml:id="m3s3n5" pname="a" oct="2"/>
                    <note xml:id="m3s3n6" pname="e" oct="3"/>
                    <note xml:id="m3s3n7" pname="a" oct="3"/>
                    <note xml:id="m3s3n8" pname="c" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">④</harm>
            </measure>

            <!-- Bar 4: C#m A — melody: G#4(2) C#5. C#m then A, upward push -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="4" pname="g" accid.ges="s"/>
                  <note xml:id="m4s1n2" dur="4" oct="5" pname="c" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: C#m E4-G#4, A A4-C#5 — step up in top voice -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="e" oct="4"/>
                    <note xml:id="m4s2n2" pname="g" oct="4" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="a" oct="4"/>
                    <note xml:id="m4s2n4" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: C#m C#2-G#2-C#3-E3, A A2-E3-A3-C#4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="c" oct="2" accid.ges="s"/>
                    <note xml:id="m4s3n2" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m4s3n3" pname="c" oct="3" accid.ges="s"/>
                    <note xml:id="m4s3n4" pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n5" pname="a" oct="2"/>
                    <note xml:id="m4s3n6" pname="e" oct="3"/>
                    <note xml:id="m4s3n7" pname="a" oct="3"/>
                    <note xml:id="m4s3n8" pname="c" oct="4" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Bridge — chromatic color, G#m and F#m   -->
            <!-- ============================================================ -->

            <!-- Bar 5: G#m E — melody: C#5 B4 G#4. Stepwise descent -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="5" pname="c" accid.ges="s"/>
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="b"/>
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="g" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: G#m G#4-B4, E B4-E5 — inner voice leaps 5th (G#→B is ok) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n1" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m5s2n2" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m5s2c2" dur="2">
                    <note xml:id="m5s2n3" pname="b" oct="4"/>
                    <note xml:id="m5s2n4" pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: G#m G#2-D#3-G#3-B3, E E2-B2-E3-G#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4">
                    <note xml:id="m5s3n1" pname="g" oct="2" accid.ges="s"/>
                    <note xml:id="m5s3n2" pname="d" oct="3" accid.ges="s"/>
                    <note xml:id="m5s3n3" pname="g" oct="3" accid.ges="s"/>
                    <note xml:id="m5s3n4" pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m5s3c2" dur="2">
                    <note xml:id="m5s3n5" pname="e" oct="2"/>
                    <note xml:id="m5s3n6" pname="b" oct="2"/>
                    <note xml:id="m5s3n7" pname="e" oct="3"/>
                    <note xml:id="m5s3n8" pname="g" oct="3" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">①</harm>
            </measure>

            <!-- Bar 6: F#m E F#m — melody: F#4 G#4 F#4(1/2) C#4(1/2). Active bar -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="g" accid.ges="s"/>
                  <note xml:id="m6s1n3" dur="8" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m6s1n4" dur="8" oct="4" pname="c" accid.ges="s"/>
                </layer>
              </staff>
              <!-- RH: F#m A4-C#5, E G#4-B4, F#m F#4-A4 — clear voice leading -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="a" oct="4"/>
                    <note xml:id="m6s2n2" pname="c" oct="5" accid.ges="s"/>
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="g" oct="4" accid.ges="s"/>
                    <note xml:id="m6s2n4" pname="b" oct="4"/>
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="f" oct="4" accid.ges="s"/>
                    <note xml:id="m6s2n6" pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: F#m F#2-C#3-F#3-A3, E E2-B2-E3, F#m F#2-C#3-F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="f" oct="2" accid.ges="s"/>
                    <note xml:id="m6s3n2" pname="c" oct="3" accid.ges="s"/>
                    <note xml:id="m6s3n3" pname="f" oct="3" accid.ges="s"/>
                    <note xml:id="m6s3n4" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n5" pname="e" oct="2"/>
                    <note xml:id="m6s3n6" pname="b" oct="2"/>
                    <note xml:id="m6s3n7" pname="e" oct="3"/>
                  </chord>
