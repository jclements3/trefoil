                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m11r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m11r3" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m11r4" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
