<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Savior When In Dust To Thee</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: F major (1 flat: Bb). Meter: 4/4. -->
          <!-- This hymn is Dm-centric with frequent A major (V/Dm) tonicizations. -->
          <!-- Non-diatonic substitutions: A major → Am(iii), C#m → Am(iii), C#° → E°(vii°) -->
          <!-- G#° (in bar 12) → E°(vii°) -->
          <!-- ABC bars (16 bars total):                                                 -->
          <!--  1: Dm A Dm F  2: Dm A Dm  3: A Dm A  4: Dm A              -->
          <!--  5: Dm A Dm F  6: Dm A Dm  7: A Dm C F E°  8: Dm A Dm    -->
          <!--  9: Bb F Bb E° 10: F Am F 11: Dm A Dm C  12: F C G#° Am  -->
          <!-- 13: Bb F  14: Dm Gm A  15: Dm A Dm F  16: Dm A Dm        -->
          <!-- F major diatonic: I=F(1) ii=Gm(2) iii=Am(3) IV=Bb(4) V=C(5) vi=Dm(6) vii°=E°(7) -->
          <!-- A major → sub iii (Am), C#° → sub vii° (E°)                              -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="1f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="1f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="1f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Bar 1: Dm A Dm F — Melody: D4 D4(8th) E4(8th) F4(8th) G4(8th) A4 -->
            <!-- Durations: D=qtr, D/2=8th E/2=8th, F/2=8th G/2=8th, A=qtr -->
            <!-- Beats: 1=Dm(D4), 2=A(D/2+E/2), 3=Dm(F/2+G/2), 4=F(A4) -->
            <!-- LH keeps slow harmonic rhythm (half-note blocks) to contrast moving melody -->
            <!-- LH beat 1-2: vi Dm D2-A2-D3-F3, beat 3-4: I F2-C3-F3-A3 -->
            <!-- RH: beat 1-2 F4-A4 (vi), beat 3-4 A4-C5 (I) — light, don't crowd passing tones -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="d" oct="4" dur="4"/>
                  <note xml:id="m1n2" pname="d" oct="4" dur="8"/>
                  <note xml:id="m1n3" pname="e" oct="4" dur="8"/>
                  <note xml:id="m1n4" pname="f" oct="4" dur="8"/>
                  <note xml:id="m1n5" pname="g" oct="4" dur="8"/>
                  <note xml:id="m1n6" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- vi: F4-A4 held 2 beats, then I: A4-C5 held 2 beats -->
                  <chord xml:id="m1r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m1r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- vi Dm D2-A2-D3-F3 (half note) -->
                  <chord xml:id="m1l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <!-- I F2-C3-F3-A3 (half note) -->
                  <chord xml:id="m1l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 2: Dm A Dm — Melody: F4 E4 D4 D4(half) -->
            <!-- Chords: vi iii(A sub) vi — harmonic rhythm: 1 beat each, then half -->
            <!-- LH: vi D2-A2-D3-F3, iii A2-E3-A3, vi D2-A2-D3-F3 (half) -->
            <!-- RH: vi A4-D5→use F4-A4, iii C4-E4, vi F4-A4 (half) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m2n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m2n3" pname="d" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m2r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m2r3" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m2l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m2l3" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Bar 3: A Dm A — Melody: F4 E4 D4 C#4(→diatonic C4) -->
            <!-- ABC: F "^A"E "^Dm"D "^A"^C — C# is non-diatonic melody note, keep in staff 1 -->
            <!-- Chords: I(F) → iii(Am sub A) → vi(Dm) → iii(Am sub A) -->
            <!-- LH: I F2-C3-F3, iii A2-E3-A3, vi D2-A2-D3-F3, iii A2-E3-A3 -->
            <!-- RH: per beat C4-F4, C4-E4, D4-F4, C4-E4 -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m3n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m3n3" pname="d" oct="4" dur="4"/>
                  <!-- C# is non-diatonic melody: write with accid -->
                  <note xml:id="m3n4" pname="c" oct="4" accid="s" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3r1" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m3r3" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m3r4" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3l1" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m3l3" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m3l4" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Bar 4: Dm A — Melody: D4(8th) E4(8th) F4 E4(half) -->
            <!-- ABC: "^Dm"D/2 E/2 F "^A"E2 -->
            <!-- Chords: vi (Dm for first 2 beats), iii(Am sub A) for beats 3-4 -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="d" oct="4" dur="8"/>
                  <note xml:id="m4n2" pname="e" oct="4" dur="8"/>
                  <note xml:id="m4n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m4n4" pname="e" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m4r2" dur="2">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m4l2" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Bars 5-8: repeat of bars 1-4 (same chords / same structure) -->
            <!-- Bar 5 = bar 1 (with Dm→F melody) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="d" oct="4" dur="4"/>
                  <note xml:id="m5n2" pname="d" oct="4" dur="8"/>
                  <note xml:id="m5n3" pname="e" oct="4" dur="8"/>
                  <note xml:id="m5n4" pname="f" oct="4" dur="8"/>
                  <note xml:id="m5n5" pname="g" oct="4" dur="8"/>
                  <note xml:id="m5n6" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Vary: vi 1st inv: F2-A2→RH use A4-D5 (higher register) -->
                  <chord xml:id="m5r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m5r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m5l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 6 = bar 2 -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m6n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m6n3" pname="d" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6r1" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m6r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m6r3" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m6l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m6l3" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Bar 7: A Dm C F E° — varied chord sequence -->
            <!-- ABC: "^A"E "^Dm"F/2 "^C"G/2 "^F"A "^E°"G -->
            <!-- Melody: E4 F4(8th) G4(8th) A4 G4 -->
            <!-- Beats: 1=iii(Am), 2=vi(Dm)+V(C) running, 3=I(F), 4=vii°(E°) -->
            <!-- LH: iii A2-E3-A3, V C2-G2-C3-E3, I F2-C3-F3-A3, vii° E2-B2-E3-G3 -->
            <!-- RH: E4-A4, E4-G4, A4-C5, E4-G4 -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="e" oct="4" dur="4"/>
                  <note xml:id="m7n2" pname="f" oct="4" dur="8"/>
                  <note xml:id="m7n3" pname="g" oct="4" dur="8"/>
                  <note xml:id="m7n4" pname="a" oct="4" dur="4"/>
                  <note xml:id="m7n5" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Per-beat 2-note figures tracking chord changes -->
                  <chord xml:id="m7r1" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m7r2" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m7r3" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m7r4" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7l1" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m7l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m7l3" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m7l4" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- Bar 8: Dm A Dm — Melody: F4 E4 D4 D4(half) — same as bar 2 -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m8n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m8n3" pname="d" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8r1" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m8r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m8r3" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m8l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m8l3" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Bar 9: Bb F Bb E° — Melody: D4 C4 D4 E4 -->
            <!-- New section — IV opens with contrast, then leads back through vii° -->
            <!-- LH: IV Bb2-F3-Bb3, I F2-C3-F3-A3, IV Bb2-F3-Bb3, vii° E2-B2-E3-G3 -->
            <!-- RH: D4-F4, C4-F4, D4-F4, E4-G4 -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="d" oct="4" dur="4"/>
                  <note xml:id="m9n2" pname="c" oct="4" dur="4"/>
                  <note xml:id="m9n3" pname="d" oct="4" dur="4"/>
                  <note xml:id="m9n4" pname="e" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9r1" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m9r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m9r3" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m9r4" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9l1" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m9l2" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m9l3" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m9l4" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑦°</harm>
            </measure>

            <!-- Bar 10: F Am F — Melody: F4 A4(8th) G4(8th) F4(half) -->
            <!-- ABC: "^F"F "^Am"A/2 G/2 "^F"F2 -->
            <!-- Chords: I(F) iii(Am) I(F) -->
            <!-- LH: I F2-C3-F3-A3, iii A2-C3-E3-A3 (closed Am), I F2-C3-F3 -->
            <!-- RH: A4-C5 (I), C4-E4 (iii), A4-C5 (I) -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m10n2" pname="a" oct="4" dur="8"/>
                  <note xml:id="m10n3" pname="g" oct="4" dur="8"/>
                  <note xml:id="m10n4" pname="f" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10r1" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m10r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <chord xml:id="m10r3" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10l1" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m10l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m10l3" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 11: Dm A Dm C — Melody: F4 E4 F4 G4 -->
            <!-- ABC: "^Dm"F "^A"E "^Dm"F "^C"G -->
            <!-- Chords: vi iii vi V — all 4 beats active -->
            <!-- LH: vi D2-A2-D3-F3, iii A2-E3-A3, vi D2-A2-D3-F3, V C2-G2-C3-E3 -->
            <!-- RH: vi F4-A4, iii C4-E4, vi F4-A4, V G4-C5 -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m11n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m11n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m11n4" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
