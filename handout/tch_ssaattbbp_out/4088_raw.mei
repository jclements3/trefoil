                  <chord xml:id="m11l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m11l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m11l3" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m11l4" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 12: F C G#°→E° Am — Melody: A4 C5(8th) B4(8th→use Bb4 diatonic) A4(half) -->
            <!-- ABC: "^F"A "^C"c/2 "^G#°"=B/2 "^Am"A2 -->
            <!-- Non-diatonic: G#° → sub vii°(E°), =B is natural B (not diatonic: Bb expected) -->
            <!-- We'll use B natural in melody (it's a passing note to A); LH stays diatonic -->
            <!-- Chords: I(F), V(C), vii°(E°), iii(Am sub) -->
            <!-- LH: I F2-C3-F3-A3, V C2-G2-C3-E3, vii° E2-B2-E3-G3, iii A2-E3-A3 -->
            <!-- RH: A4-C5, E4-G4, E4-G4 (sustained vii°→iii), C4-E4 -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m12n2" pname="c" oct="5" dur="8"/>
                  <!-- B natural passing tone in melody — write as natural (cancels key-sig Bb) -->
                  <note xml:id="m12n3" pname="b" oct="4" accid="n" dur="8"/>
                  <note xml:id="m12n4" pname="a" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m12r1" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m12r2" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <!-- iii: C4-E4 for 2 beats -->
                  <chord xml:id="m12r3" dur="2">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m12l1" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m12l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- vii° → iii in LH: E2-B2-E3 then A2-E3-A3 -->
                  <chord xml:id="m12l3" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m12l4" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Bar 13: Bb F — Melody: D5 D5 C5 A4 -->
            <!-- ABC: "^Bb"d d "^F"c A -->
            <!-- Chords: IV(Bb, 2 beats) I(F, 2 beats) -->
            <!-- LH: IV Bb2-F3-Bb3-D4→use Bb2-F3-Bb3 (half), I F2-C3-F3-A3 (half) -->
            <!-- RH: IV D4-F4(half→but D5 melody: use Bb4-D5→2 notes but above melody! Use D4-F4) -->
            <!-- RH: IV D4-F4(half), I A4-C5(half) -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13n1" pname="d" oct="5" dur="4"/>
                  <note xml:id="m13n2" pname="d" oct="5" dur="4"/>
                  <note xml:id="m13n3" pname="c" oct="5" dur="4"/>
                  <note xml:id="m13n4" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Stay well below D5 melody: use F4-Bb4, then A4-C5 -->
                  <chord xml:id="m13r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m13r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m13l1" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m13l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 14: Dm Gm A — Melody: F4 G4 A4 A4(half) -->
            <!-- ABC: "^Dm"F "^Gm"G "^A"A2 -->
            <!-- Chords: vi(Dm) ii(Gm) iii(Am sub A, 2 beats) -->
            <!-- LH: vi D2-A2-D3-F3, ii G2-D3-G3-Bb3, iii A2-E3-A3 (2 beats) -->
            <!-- RH: F4-A4, D4-G4, C4-E4 -->
            <measure n="14">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m14n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m14n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m14n3" pname="a" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m14r1" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m14r2" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m14r3" dur="2">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m14l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m14l2" dur="4">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m14l3" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">③m</harm>
            </measure>

            <!-- Bars 15-16: Final repeat of opening phrase (bars 1-2 content) -->
            <!-- Bar 15 = bar 1 (Dm→F melody) -->
            <measure n="15">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m15n1" pname="d" oct="4" dur="4"/>
                  <note xml:id="m15n2" pname="d" oct="4" dur="8"/>
                  <note xml:id="m15n3" pname="e" oct="4" dur="8"/>
                  <note xml:id="m15n4" pname="f" oct="4" dur="8"/>
                  <note xml:id="m15n5" pname="g" oct="4" dur="8"/>
                  <note xml:id="m15n6" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Final verse: richer RH — add 3rd note at climax -->
                  <chord xml:id="m15r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m15r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m15l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m15l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 16: Dm A Dm — final cadence to Dm root pos -->
            <!-- Melody: F4 E4 D4(half) -->
            <measure n="16">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m16n1" pname="f" oct="4" dur="4"/>
                  <note xml:id="m16n2" pname="e" oct="4" dur="4"/>
                  <note xml:id="m16n3" pname="d" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m16r1" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m16r2" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="e" oct="4"/>
                  </chord>
                  <!-- Final Dm: D4-F4 (half, closes gently) -->
                  <chord xml:id="m16r3" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m16l1" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m16l2" dur="4">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <!-- Final Dm: full open D2-A2-D3-F3 -->
                  <chord xml:id="m16l3" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
<!--
VOICING PLAN:
- Throughout: vi(Dm) is structural home. "33" root pos on all Dm (D2-A2-D3-F3). Slow harmonic rhythm
  (half-note blocks in LH) against the faster moving melody — contrast highlights the runs.
- Non-diatonic A major → consistently substituted as iii(Am). This maintains smooth voice leading:
  Am shares E and C with F major; the shift vi→iii is a 3rd motion (very smooth in LH).
- Bar 7 (varied bar): iv(Gm) rare appearance; per-beat LH changes mirror the quicker ABC annotations.
- Bars 9-10: IV(Bb) opens new section for contrast; sustained half-note LH continues.
- Bar 12: vii°(E°) appears prominently on beat 3 as link between V(C) and iii(Am) — nice chromatic descent.
- Bar 14: Gm(ii) appears — the only ii chord in the piece. LH shows its Bb3 in the chord top.

VOICE LEADING HIGHLIGHTS:
- LH bass root descent at phrase cadences: D2→A2 (bar 2-4) models the vi→iii alternation.
- Bar 7: Complete bass-line movement through iii→V→I→vii° shows full diatonic circle.
- Bar 12: vii°→iii is a "deceptive" resolution — creates mild surprise after strong V.
- Common tone E3 held between iii(Am) and V(C) across multiple bars.

TEXTURE ARC:
- Opening phrase (bars 1-4): Sparse, steady half-note LH blocks. Modal Dm atmosphere.
- Second verse (bars 5-8): Same structure, RH raised octave (A4-D5 instead of F4-A4) for intensity.
- Middle section (bars 9-12): IV chord color, busier (bar 7 style), expanding range.
- Final verse (bars 13-16): Richest LH (Gm7 in bar 14), returns to root-pos Dm convergence.
-->
