                <layer n="2">
                  <note xml:id="m4p1" dur="1" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 5: F, Gm, Dm, A(→Am/iii) — melody F F B A A G2 G -->
            <!-- V=F, ii=Gm(G Bb D), vi=Dm(D F A), iii=Am(A C E) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="4" oct="4" pname="f"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="f"/>
                  <note xml:id="m5n3" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m5n4" dur="4" oct="4" pname="a"/>
                </layer>
