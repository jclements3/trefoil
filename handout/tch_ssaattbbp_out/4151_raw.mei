              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 2: Bb, F — melody Bb F A2 A/2 Bb/2 -->
            <!-- I=Bb then V=F (F A C) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m2n2" dur="4" oct="4" pname="f"/>
                  <note xml:id="m2n3" dur="2" oct="4" pname="a"/>
                  <note xml:id="m2n4" dur="8" oct="4" pname="a"/>
                  <note xml:id="m2n5" dur="8" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F4 Bb4 → A4 C5 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m2rh1" oct="4" pname="f"/>
                    <note xml:id="m2rh2" oct="4" pname="b" accid.ges="f"/>
                  </chord>
