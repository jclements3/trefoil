              <staff n="2">
                <!-- RH: C4 F4 → Bb3 D4 → A3 C4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh1" oct="4" pname="c"/>
                    <note xml:id="m5rh2" oct="4" pname="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5rh3" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m5rh4" oct="4" pname="d"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: F2 C3 A3 → G2 D3 G3 → D2 A2 F3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh1" oct="2" pname="f"/>
                    <note xml:id="m5lh2" oct="3" pname="c"/>
                    <note xml:id="m5lh3" oct="3" pname="a"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m5lh4" oct="2" pname="g"/>
                    <note xml:id="m5lh5" oct="3" pname="d"/>
                    <note xml:id="m5lh6" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" dur="2" oct="1" pname="f" stem.dir="down"/>
                  <note xml:id="m5p2" dur="2" oct="2" pname="g" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 6: A(→iii=Am/Dm), Eb — melody A Eb G2 G -->
            <!-- A major is non-diatonic: sub iii=Dm or Am. Use Dm (vi) -->
            <!-- IV=Eb (Eb G Bb) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m6n2" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m6n3" dur="2" oct="4" pname="g"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: A3 D4 → G4 Eb4 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh1" oct="3" pname="a"/>
                    <note xml:id="m6rh2" oct="4" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6rh3" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m6rh4" oct="4" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: D2 A2 F3 → Eb2 Bb2 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh1" oct="2" pname="d"/>
                    <note xml:id="m6lh2" oct="2" pname="a"/>
                    <note xml:id="m6lh3" oct="3" pname="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m6lh4" oct="2" pname="e" accid.ges="f"/>
                    <note xml:id="m6lh5" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m6lh6" oct="3" pname="g"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m6p1" dur="2" oct="2" pname="d" stem.dir="down"/>
                  <note xml:id="m6p2" dur="2" oct="2" pname="e" accid.ges="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 7: Bb, F, F7 — melody Bb F F7 A F7 c -->
            <!-- I→V→V7: approach to final cadence -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" dur="4" oct="4" pname="b" accid.ges="f"/>
                  <note xml:id="m7n2" dur="4" oct="4" pname="f"/>
                  <note xml:id="m7n3" dur="4" oct="4" pname="a"/>
                  <note xml:id="m7n4" dur="4" oct="5" pname="c"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: D4 F4 → A4 C5 Eb5 — building to climax -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh1" oct="4" pname="d"/>
                    <note xml:id="m7rh2" oct="4" pname="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7rh3" oct="4" pname="a"/>
                    <note xml:id="m7rh4" oct="4" pname="e" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb1 F2 D3 → F2 C3 Eb3 A3 (V7 full) -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m7lh2" oct="2" pname="f"/>
                    <note xml:id="m7lh3" oct="3" pname="d"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m7lh4" oct="2" pname="f"/>
                    <note xml:id="m7lh5" oct="3" pname="c"/>
                    <note xml:id="m7lh6" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m7lh7" oct="3" pname="a"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7p1" dur="2" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
                  <note xml:id="m7p2" dur="2" oct="1" pname="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Measure 8: Bb final — melody Bb3 (whole note) -->
            <measure n="8" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" dur="1" oct="4" pname="b" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: F4 Bb4 D5 — full "33" I root pos -->
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m8rh1" oct="4" pname="f"/>
                    <note xml:id="m8rh2" oct="4" pname="b" accid.ges="f"/>
                    <note xml:id="m8rh3" oct="5" pname="d"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb1 F2 Bb2 D3 — full root pos I -->
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m8lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m8lh2" oct="2" pname="f"/>
                    <note xml:id="m8lh3" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m8lh4" oct="3" pname="d"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
