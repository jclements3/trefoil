<?xml version="1.0" encoding="UTF-8"?>
<!-- 4151 O Lord, I Am Not Worthy — pedal harp arrangement, key Bb, 4/4 -->
<!-- Key Bb: 2 flats — Bb and Eb. accid.ges="f" on all B and E notes -->
<!-- Scale: Bb(1) C(2) D(3) Eb(4) F(5) G(6) A(7) -->
<!-- Chords: I=Bb, ii=Cm, iii=Dm, IV=Eb, V=F, vi=Gm, vii=A° -->
<!-- ABC (L=1/4, 9 bars):
  Pickup: D/2 E/2
  m1: F Eb G F  Bb  (Bb Eb Bb F)  [Bb Eb Bb F]
  m2: Bb F A2 A/2 B/2  (Bb F)
  m3: c F7 E G F  (F7: F A C Eb)
  m4: Bb D3 D/2 E/2  (Bb)
  m5: F F Gm B  Dm A  (F Gm Dm A)
  m6: A Eb G2 G  (A=non-diaton→Am/iii, Eb=IV)
  m7: Bb F  F7 A  F7 c  (Bb F F7)
  m8: Bb B3  (Bb final)
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>O Lord, I Am Not Worthy</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="2f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="2f">
                <keySig sig="2f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="2f">
                  <keySig sig="2f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="2f">
                  <keySig sig="2f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Pickup: D/2 E/2 — one beat (half-quarter + half-quarter = 1 beat) -->
            <measure n="0" metcon="false">
              <staff n="1">
                <layer n="1">
                  <note xml:id="p1n1" dur="8" oct="4" pname="d"/>
                  <note xml:id="p1n2" dur="8" oct="4" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <rest dur="4" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="4" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <rest dur="4" visible="false"/>
                </layer>
                <layer n="2">
                  <rest dur="4" visible="false"/>
                </layer>
              </staff>
            </measure>

            <!-- Measure 1: Bb — melody F Eb G F Bb -->
            <!-- I=Bb (Bb D F): LH Bb1 F2 Bb2 D3; RH D4 F4 -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="4" oct="4" pname="f"/>
                  <note xml:id="m1n2" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m1n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m1n4" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: D4 F4 — light "33" I -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh1" oct="4" pname="d"/>
                    <note xml:id="m1rh2" oct="4" pname="f"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m1rh3" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m1rh4" oct="4" pname="g"/>
