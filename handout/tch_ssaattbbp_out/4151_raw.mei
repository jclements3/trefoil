                </layer>
                <layer n="2">
                  <note xml:id="m3p1" dur="1" oct="1" pname="f" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
            </measure>

            <!-- Measure 4: Bb — melody D3 D/2 E/2 -->
            <!-- I=Bb: return to tonic, quartal color "44" for variety -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="2" oct="4" pname="d"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="d"/>
                  <note xml:id="m4n3" dur="8" oct="4" pname="d"/>
                  <note xml:id="m4n4" dur="8" oct="4" pname="e" accid.ges="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Bb3 Eb4 — quartal sus "44" I for open color -->
                <layer n="1">
                  <rest dur="1" visible="false"/>
                </layer>
                <layer n="2">
                  <chord dur="1" stem.dir="down">
                    <note xml:id="m4rh1" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m4rh2" oct="4" pname="e" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb1 F2 Bb2 D3 — "334" I root pos -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m4lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh2" oct="2" pname="f"/>
                    <note xml:id="m4lh3" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m4lh4" oct="3" pname="d"/>
