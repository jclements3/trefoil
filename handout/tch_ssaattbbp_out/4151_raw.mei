                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Bb1 F2 Bb2 D3 — "334" root+octave -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m1lh1" oct="2" pname="b" accid.ges="f"/>
                    <note xml:id="m1lh2" oct="2" pname="f"/>
                    <note xml:id="m1lh3" oct="3" pname="b" accid.ges="f"/>
                    <note xml:id="m1lh4" oct="3" pname="d"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" dur="1" oct="1" pname="b" accid.ges="f" stem.dir="down"/>
