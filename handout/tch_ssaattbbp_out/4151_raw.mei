                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 3: F7 — melody c Eb G F (F7=F A C Eb) -->
            <!-- V7 = F dominant 7th: F A C Eb -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" dur="4" oct="5" pname="c"/>
                  <note xml:id="m3n2" dur="4" oct="4" pname="e" accid.ges="f"/>
                  <note xml:id="m3n3" dur="4" oct="4" pname="g"/>
                  <note xml:id="m3n4" dur="4" oct="4" pname="f"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Eb4 G4 → C4 Eb4 (voice leading down) -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh1" oct="4" pname="e" accid.ges="f"/>
                    <note xml:id="m3rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m3rh3" oct="4" pname="c"/>
                    <note xml:id="m3rh4" oct="4" pname="e" accid.ges="f"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: F2 C3 Eb3 A3 — V7 "333" root pos -->
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note xml:id="m3lh1" oct="2" pname="f"/>
                    <note xml:id="m3lh2" oct="3" pname="c"/>
                    <note xml:id="m3lh3" oct="3" pname="e" accid.ges="f"/>
                    <note xml:id="m3lh4" oct="3" pname="a"/>
