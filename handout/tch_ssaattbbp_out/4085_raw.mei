            <!-- Bar 31: C F Bb — Melody: C5(dotted-3/2) B4 A4 Bb4 -->
            <!-- ABC: "^C"c3/2 B/2 "^F"A "^Bb"B — V for 1.5+0.5 beats, then I, IV -->
            <!-- V(C) 2 beats, I(F) 1 beat, IV(Bb) 1 beat -->
            <!-- LH: V C2-G2-C3-E3 (half), I F2-C3-F3 (qtr), IV Bb2-F3-Bb3 (qtr) -->
            <!-- RH: V E4-G4 (half), I A4-C5 (qtr), IV D4-F4 (qtr) -->
