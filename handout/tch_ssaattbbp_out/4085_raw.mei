<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>A Lamb Goes Uncomplaining Forth</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: F major (1 flat: Bb). Meter: 4/4. No pickup (starts on beat 1). -->
          <!-- Large piece: 32 bars in 3 sections.                                    -->
          <!-- Section A (bars 1-12): F major, repeated phrase (1-6, 7-12)           -->
          <!-- Section B (bars 13-19): F major, new material, ends on rest+A4        -->
          <!-- Section C (bars 20-32): modulates to Gm/Bb area (bars 20-25), returns -->
          <!-- Non-diatonic subs (F major context):                                   -->
          <!--   D major → vi(Dm), Eb major → IV(Bb), Cm → ii(Gm), G major → ii(Gm) -->
          <!--   B° → vii°(E°), Am → iii(Am), "=B" natural B → diatonic Bb(use B) -->
          <!-- LH range: C2-B3. RH range: C4-G6. All diatonic in F major.           -->
          <!-- F major scale: F G A Bb C D E (Bb = accid.ges="f")                    -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="1f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="1f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="1f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ====== SECTION A phrase 1 (bars 1-6) ====== -->

            <!-- Bar 1: F Bb C — Melody: C5 C5 D5 C5 -->
            <!-- F(I) for 2 beats, Bb(IV) beat 3, C(V) beat 4 -->
            <!-- LH: I F2-C3-F3-A3 (half), IV Bb2-F3-Bb3 (qtr), V C2-G2-C3-E3 (qtr) -->
            <!-- RH: I A4-C5 (half), IV D4-F4 (qtr), V E4-G4 (qtr) -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" pname="c" oct="5" dur="2"/>
                  <note xml:id="m1n2" pname="d" oct="5" dur="4"/>
                  <note xml:id="m1n3" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m1r2" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m1r3" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m1l2" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m1l3" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 2: Dm F — Melody: A4 A4 C5 C5 -->
            <!-- vi(Dm) 2 beats, I(F) 2 beats -->
            <!-- LH: vi D2-A2-D3-F3 (half), I F2-C3-F3-A3 (half) -->
            <!-- RH: vi F4-A4 (half), I A4-C5 (half) -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m2n2" pname="c" oct="5" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m2r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m2l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 3: Bb E° F — Melody: Bb4 B4(=Bb) A4 A4 -->
            <!-- IV(Bb) 2 beats, vii°(E°) 1 beat, I(F) 1 beat -->
            <!-- LH: IV Bb2-F3-Bb3 (half), vii° E2-B2-E3-G3 (qtr), I F2-C3-F3 (qtr) -->
            <!-- RH: IV D4-F4 (half), vii° E4-G4 (qtr), I A4-C5 (qtr) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m3n2" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m3n3" pname="a" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3r1" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m3r3" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3l1" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m3l3" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 4: C F Bb — Melody: G4 G4 A4 Bb4 -->
            <!-- V(C) 2 beats, I(F) 1 beat, IV(Bb) 1 beat -->
            <!-- LH: V C2-G2-C3-E3 (half), I F2-C3-F3 (qtr), IV Bb2-F3-Bb3 (qtr) -->
            <!-- RH: V E4-G4 (half), I A4-C5 (qtr), IV D4-Bb4 (qtr) -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m4n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m4n3" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m4r2" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m4r3" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m4l2" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m4l3" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">④</harm>
            </measure>

            <!-- Bar 5: F Bb F — Melody: C5 C5 Bb4 A4 -->
            <!-- I(F) 2 beats, IV(Bb) 1 beat, I(F) 1 beat -->
            <!-- LH: I F2-C3-F3-A3 (half), IV Bb2-F3-Bb3 (qtr), I F2-C3-F3 (qtr) -->
            <!-- RH: I A4-C5 (half), IV D4-Bb4 (qtr), I C4-F4 (qtr) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" pname="c" oct="5" dur="2"/>
                  <note xml:id="m5n2" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m5n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m5r2" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m5r3" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m5l2" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5l3" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 6: (no chord annotations = I sustained) — Melody: G4 G4 F4 F4 -->
            <!-- All F major (I). Use "43" 1st inversion for variety: A2-C3-F3 -->
            <!-- LH: I 1st inv A2-C3-F3-A3 (half), then back F2-C3-F3 (half) -->
            <!-- RH: C4-F4 (whole) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m6n2" pname="f" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- I: use quartal "44": C4-F4-Bb4 — open, modern sound for variety -->
                  <chord xml:id="m6r1" dur="2">
                    <note pname="c" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m6r2" dur="2">
                    <note pname="c" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- I 1st inv (①¹): A2-C3-F3 -->
                  <chord xml:id="m6l1" dur="2">
                    <note pname="a" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <!-- I root pos: F2-C3-F3 -->
                  <chord xml:id="m6l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">① ¹</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- ====== SECTION A phrase 2 (bars 7-12) = repeat with register variation ====== -->

            <!-- Bar 7: (Bb at start implied, then C) — Melody: C5 C5 D5 C5 -->
            <!-- ABC: c2 "^Bb"d "^C"c — same as bar 1 but Bb on beat 3 only, I for beats 1-2 -->
            <!-- Bar 1 structure reused: I(2b) IV(1b) V(1b) -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" pname="c" oct="5" dur="2"/>
                  <note xml:id="m7n2" pname="d" oct="5" dur="4"/>
                  <note xml:id="m7n3" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Vary to 1st inv RH: C5-F5 (higher) for variety in repeat -->
                  <chord xml:id="m7r1" dur="2">
                    <note pname="c" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <chord xml:id="m7r2" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m7r3" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m7l2" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m7l3" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Bar 8: Dm F — Melody: A4 A4 C5 C5 — same as bar 2 -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m8n2" pname="c" oct="5" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8r1" dur="2">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord xml:id="m8r2" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="2">
                    <note pname="d" oct="2"/>
                    <note pname="a" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m8l2" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 9: Bb E° F — same as bar 3 — Melody: Bb4 Bb4 A4 A4 -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m9n2" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m9n3" pname="a" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9r1" dur="2">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m9r2" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m9r3" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9l1" dur="2">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m9l2" dur="4">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m9l3" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑦°</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Bar 10: C F Bb — same as bar 4 — Melody: G4 G4 A4 Bb4 -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m10n2" pname="a" oct="4" dur="4"/>
                  <note xml:id="m10n3" pname="b" oct="4" accid.ges="f" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10r1" dur="2">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m10r2" dur="4">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m10r3" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m10l1" dur="2">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord xml:id="m10l2" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord xml:id="m10l3" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">④</harm>
            </measure>

            <!-- Bar 11: F Bb F — same as bar 5 — Melody: C5 C5 Bb4 A4 -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" pname="c" oct="5" dur="2"/>
                  <note xml:id="m11n2" pname="b" oct="4" accid.ges="f" dur="4"/>
                  <note xml:id="m11n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m11r1" dur="2">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m11r2" dur="4">
                    <note pname="d" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <chord xml:id="m11r3" dur="4">
                    <note pname="c" oct="4"/>
                    <note pname="f" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m11l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
