            <!-- vi I V IV all 4 beats — fastest harmonic rhythm in piece -->
            <!-- LH: vi D2-A2-D3-F3, V C2-G2-C3-E3, I F2-C3-F3-A3, IV Bb2-F3-Bb3 -->
