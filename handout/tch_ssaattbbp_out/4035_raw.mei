            <!-- m10: Bb ^A, G B, Bb c, F#m F -->
            <!-- ^A = A# non-diatonic passing. Sub Bb→G (IV) or B area -->
            <!-- Melody: A#4(1) B4(1) C5(1) F#4(1) = 4 beats -->
            <!-- A# is non-diatonic — render as Bb (accid="s" for A# would conflict) -->
            <!-- In ABC ^A is A#=Bb. As melody note we write it correctly. -->
            <!-- Actually: accid for A# not in D major key sig — needs explicit accid="s" on A -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <!-- ^A = A# written with accid -->
                  <note xml:id="m10n1" dur="4" oct="4" pname="a" accid="s"/>
