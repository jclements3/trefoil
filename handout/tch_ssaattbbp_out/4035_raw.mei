              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">③m</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- m8: F#m A, C#ø7 G, F#m F2 → iii viiø7 iii -->
            <!-- Melody: A(1) G(1) F#(2) = 4 beats -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8n1" dur="4" oct="4" pname="a"/>
