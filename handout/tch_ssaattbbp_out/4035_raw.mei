                    <note xml:id="m12r2b" oct="5" pname="d"/>
                  </chord>
                  <!-- beat 3: B-D-F# (Bm "33" full, final) half -->
                  <chord dur="2">
                    <note xml:id="m12r3a" oct="4" pname="b"/>
                    <note xml:id="m12r3b" oct="5" pname="d"/>
                    <note xml:id="m12r3c" oct="5" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
