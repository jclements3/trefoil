              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: B2-F#3-B3-D4 (Bm "333") half -->
                  <chord dur="2">
                    <note xml:id="m11l1a" oct="2" pname="b"/>
                    <note xml:id="m11l1b" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m11l1c" oct="3" pname="b"/>
                    <note xml:id="m11l1d" oct="4" pname="d"/>
                  </chord>
                  <!-- beat 3: B2-F#3-B3 (Bm) half — sub for Bb -->
                  <chord dur="2">
                    <note xml:id="m11l2a" oct="2" pname="b"/>
                    <note xml:id="m11l2b" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m11l2c" oct="3" pname="b"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">⑦ø7</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- m12: C#ø7 B, Bb ^A, Bm B2 (final) -->
            <!-- Melody: B4(1) A#4(1) B4(2) = 4 beats -->
            <measure n="12" right="end">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m12n1" dur="4" oct="4" pname="b"/>
                  <note xml:id="m12n2" dur="4" oct="4" pname="a" accid="s"/>
                  <note xml:id="m12n3" dur="2" oct="4" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: C#-E (viiø7 partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m12r1a" oct="4" pname="c" accid.ges="s"/>
                    <note xml:id="m12r1b" oct="4" pname="e"/>
                  </chord>
                  <!-- beat 2: B-D (Bm sub Bb) quarter -->
                  <chord dur="4">
