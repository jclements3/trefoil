<?xml version="1.0" encoding="UTF-8"?>
<!-- Hymn 4035: Jesus Came, the Heavens Adoring — D major, 4/4, 12 measures
     Pedal harp arrangement: Melody + RH + LH + P

     ABC melody (note: F in D major = F#, C in D major = C#):
     "^Bm"F "^F#m"F "^G"B "^Em"B | "^A"A3/2 G/2 "^D"F D | "^A"A "^D"F "^G"B "^D"A |
     "^Em7"G "^C#°"G "^D"F2 | "^A"E E "^E"E "^F#m"C | "^D"D "^A"E "^D"F F |
     "^Bm"F "^E"^G "^F#m"A "^Bm"B | "^F#m"A "^C#ø7"G "^F#m"F2 |
     "^Bb"c "^F#m"c "^Bm"d "^C#°"c/2 B/2 | "^Bb"^A "^G"B "^Bb"c "^F#m"F |
     "^Bm"d "^C#ø7"c/2 B/2 "^Bb"^A "^Bm"B | "^C#ø7"B "^Bb"^A "^Bm"B2 |

     D major diatonic: D E F# G A B C#
     Key: D major (2 sharps: F→accid.ges="s", C→accid.ges="s")

     Diatonic substitutions:
     - Bm: ii in D major (B D F#) ✓ diatonic
     - F#m: iii (F# A C#) ✓ diatonic
     - G: IV (G B D) ✓ diatonic
     - Em: ii... wait, Em is E G B — E and G are diatonic but not Em7 exactly.
       Em7 = E G B D — all diatonic in D major ✓ (ii7 area, but it's actually iiø7 in D)
       Wait: D major has F# not F. Em chord has E G B — E is 2nd, G is 4th, B is 6th.
       Em is NOT diatonic in D major! ii of D major is Em... actually yes it is:
       D major scale degrees: D(1) E(2) F#(3) G(4) A(5) B(6) C#(7)
       ii = E minor = E G B — all scale members ✓
     - C#° (vii°): C# E G ✓ diatonic
     - E (major): E G# B — G# is NOT diatonic. Substitute iii (F#m) or ii (Em).
     - Bb: VERY non-diatonic (b6). Substitute VI (Bm) or IV (G) depending on context.
     - C#ø7: C# E G B — C# is 7, E is 2, G is 4, B is 6. All diatonic ✓ (viiø7)

     Duration check per measure (4/4 = 4 quarter beats):
     m1: F(1) F(1) B(1) B(1) = 4 ✓
     m2: A3/2(1.5) G/2(0.5) F(1) D(1) = 4 ✓
     m3: A(1) F(1) B(1) A(1) = 4 ✓
     m4: G(1) G(1) F2(2) = 4 ✓
     m5: E(1) E(1) E(1) C(1) = 4 ✓
     m6: D(1) E(1) F(1) F(1) = 4 ✓
     m7: F(1) ^G(1) A(1) B(1) = 4 ✓ (^G = G# which is non-diatonic! Sub with G or A)
     m8: A(1) G(1) F2(2) = 4 ✓
     m9: c(1) c(1) d(1) c/2(0.5) B/2(0.5) = 4 ✓
     m10: ^A(1) B(1) c(1) F(1) = 4 ✓ (^A = A# non-diatonic, it's a passing tone)
     m11: d(1) c/2(0.5) B/2(0.5) ^A(1) B(1) = wait: d + c/2 + B/2 + ^A + B
           = 1 + 0.5 + 0.5 + 1 + 1 = 4 ✓
     m12: B(1) ^A(1) B2(2) = 4 ✓

     Note: ^G in m7 and ^A in m10-12 are non-diatonic passing tones in the melody.
     We use diatonic harmonies and let the melody handle chromaticism.
     Bb chords in m9-12 → substitute IV (G) or ii (Em/Bm) depending on context.

     VOICING PLAN:
     - I (D): D2-A2-D3 or D2-A2-D3-F#3 "334"
     - ii (Em): E2-B2-E3-G3 "333"
     - iii (F#m): F#2-C#3-F#3 "334" (F# and C# both need accid.ges="s")
     - IV (G): G2-D3-G3-B3 "334"
     - V (A): A2-E3-A3-C#4 "334"
     - vi (Bm): B2-F#3-B3-D4 (F# needs accid.ges="s")
     - vii° (C#°): C#3-E3-G3 "33"
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Jesus Came, the Heavens Adoring</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="2s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="2s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- m1: Bm F#m G Em → ii iii IV ii -->
            <!-- Melody: F#(1) F#(1) B(1) B(1) — all F# need accid.ges="s" -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1n1" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m1n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m1n3" dur="4" oct="4" pname="b"/>
                  <note xml:id="m1n4" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <!-- RH: Bm "33" → F#m → G → Em -->
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: B-D (Bm "33" partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m1r1a" oct="4" pname="b"/>
                    <note xml:id="m1r1b" oct="5" pname="d"/>
                  </chord>
                  <!-- beat 2: F#-A (F#m "33" partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m1r2a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m1r2b" oct="4" pname="a"/>
                  </chord>
                  <!-- beat 3: G-B (IV "33") quarter -->
                  <chord dur="4">
                    <note xml:id="m1r3a" oct="4" pname="g"/>
                    <note xml:id="m1r3b" oct="4" pname="b"/>
                  </chord>
                  <!-- beat 4: E-G (ii "33" partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m1r4a" oct="4" pname="e"/>
                    <note xml:id="m1r4b" oct="4" pname="g"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: B2-F#2-B2-D3 → F#2-C#3-F#3 → G2-D3-G3 → E2-B2-E3 -->
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: B2-F#3-B3 (Bm "334") half -->
                  <chord dur="2">
                    <note xml:id="m1l1a" oct="2" pname="b"/>
                    <note xml:id="m1l1b" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m1l1c" oct="3" pname="b"/>
                  </chord>
                  <!-- beat 3: G2-D3-G3-B3 (IV "334") half -->
                  <chord dur="2">
                    <note xml:id="m1l2a" oct="2" pname="g"/>
                    <note xml:id="m1l2b" oct="3" pname="d"/>
                    <note xml:id="m1l2c" oct="3" pname="g"/>
                    <note xml:id="m1l2d" oct="3" pname="b"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">②m</harm>
            </measure>

            <!-- m2: A3/2 G/2 F D → V then I -->
            <!-- Duration: dotted quarter A + eighth G + quarter F + quarter D = 4 -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2n1" dur="4" dots="1" oct="4" pname="a"/>
                  <note xml:id="m2n2" dur="8" oct="4" pname="g"/>
                  <note xml:id="m2n3" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m2n4" dur="4" oct="4" pname="d"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1-2: A-C# (V "33") half — A and C# both need accid.ges="s" for C# -->
                  <chord dur="2">
                    <note xml:id="m2r1a" oct="4" pname="a"/>
                    <note xml:id="m2r1b" oct="4" pname="c" accid.ges="s"/>
                  </chord>
                  <!-- beat 3: F#-A (I "43" 1st inv partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m2r2a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m2r2b" oct="4" pname="a"/>
                  </chord>
                  <!-- beat 4: D-F# (I "33" root) quarter -->
                  <chord dur="4">
                    <note xml:id="m2r3a" oct="4" pname="d"/>
                    <note xml:id="m2r3b" oct="4" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: A2-E3-A3-C#4 (V "334") half -->
                  <chord dur="2">
                    <note xml:id="m2l1a" oct="2" pname="a"/>
                    <note xml:id="m2l1b" oct="3" pname="e"/>
                    <note xml:id="m2l1c" oct="3" pname="a"/>
                    <note xml:id="m2l1d" oct="4" pname="c" accid.ges="s"/>
                  </chord>
                  <!-- beat 3: D2-A2-D3-F#3 (I "334") half -->
                  <chord dur="2">
                    <note xml:id="m2l2a" oct="2" pname="d"/>
                    <note xml:id="m2l2b" oct="3" pname="a"/>
                    <note xml:id="m2l2c" oct="3" pname="d"/>
                    <note xml:id="m2l2d" oct="3" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- m3: A F G D A → V I IV I V -->
            <!-- Melody: A(1) F#(1) B(1) A(1) = 4 beats -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3n1" dur="4" oct="4" pname="a"/>
                  <note xml:id="m3n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m3n3" dur="4" oct="4" pname="b"/>
                  <note xml:id="m3n4" dur="4" oct="4" pname="a"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: A-C# (V) quarter -->
                  <chord dur="4">
                    <note xml:id="m3r1a" oct="4" pname="a"/>
                    <note xml:id="m3r1b" oct="4" pname="c" accid.ges="s"/>
                  </chord>
                  <!-- beat 2: D-F# (I) quarter -->
                  <chord dur="4">
                    <note xml:id="m3r2a" oct="4" pname="d"/>
                    <note xml:id="m3r2b" oct="4" pname="f" accid.ges="s"/>
                  </chord>
                  <!-- beat 3: G-B (IV) quarter -->
                  <chord dur="4">
                    <note xml:id="m3r3a" oct="4" pname="g"/>
                    <note xml:id="m3r3b" oct="4" pname="b"/>
                  </chord>
                  <!-- beat 4: F#-A (I "43") quarter -->
                  <chord dur="4">
                    <note xml:id="m3r4a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m3r4b" oct="4" pname="a"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: A2-E3-A3 (V) half -->
                  <chord dur="2">
                    <note xml:id="m3l1a" oct="2" pname="a"/>
                    <note xml:id="m3l1b" oct="3" pname="e"/>
                    <note xml:id="m3l1c" oct="3" pname="a"/>
                  </chord>
                  <!-- beat 3: G2-D3-G3-B3 (IV) half -->
                  <chord dur="2">
                    <note xml:id="m3l2a" oct="2" pname="g"/>
                    <note xml:id="m3l2b" oct="3" pname="d"/>
                    <note xml:id="m3l2c" oct="3" pname="g"/>
                    <note xml:id="m3l2d" oct="3" pname="b"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- m4: Em7 G, C#° G, D F2 → ii7, vii°, I -->
            <!-- Melody: G(1) G(1) F#(2) = 4 beats -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m4n3" dur="2" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: E-G (ii "33" partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m4r1a" oct="4" pname="e"/>
                    <note xml:id="m4r1b" oct="4" pname="g"/>
                  </chord>
                  <!-- beat 2: C#-E (vii° "33" partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m4r2a" oct="4" pname="c" accid.ges="s"/>
                    <note xml:id="m4r2b" oct="4" pname="e"/>
                  </chord>
                  <!-- beat 3: D-F# (I "33") half -->
                  <chord dur="2">
                    <note xml:id="m4r3a" oct="4" pname="d"/>
                    <note xml:id="m4r3b" oct="4" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: E2-B2-E3-G3 (ii7 "333") half -->
                  <chord dur="2">
                    <note xml:id="m4l1a" oct="2" pname="e"/>
                    <note xml:id="m4l1b" oct="2" pname="b"/>
                    <note xml:id="m4l1c" oct="3" pname="e"/>
                    <note xml:id="m4l1d" oct="3" pname="g"/>
                  </chord>
                  <!-- beat 3: D2-A2-D3-F#3 (I "334") half -->
                  <chord dur="2">
                    <note xml:id="m4l2a" oct="2" pname="d"/>
                    <note xml:id="m4l2b" oct="3" pname="a"/>
                    <note xml:id="m4l2c" oct="3" pname="d"/>
                    <note xml:id="m4l2d" oct="3" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m7</harm>
              <harm staff="1" tstamp="2">⑦°</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- m5: A E, E E, F#m C → V V iii -->
            <!-- Melody: E(1) E(1) E(1) C#(1) = 4 beats, C# needs accid.ges="s" -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="4" oct="4" pname="e"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="e"/>
                  <note xml:id="m5n3" dur="4" oct="4" pname="e"/>
                  <note xml:id="m5n4" dur="4" oct="4" pname="c" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1-2: A-C# (V "33") half -->
                  <chord dur="2">
                    <note xml:id="m5r1a" oct="4" pname="a"/>
                    <note xml:id="m5r1b" oct="4" pname="c" accid.ges="s"/>
                  </chord>
                  <!-- beat 3: A-E (V "34" 2nd inv) quarter -->
                  <chord dur="4">
                    <note xml:id="m5r2a" oct="4" pname="a"/>
                    <note xml:id="m5r2b" oct="5" pname="e"/>
                  </chord>
                  <!-- beat 4: F#-A (iii "33" partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m5r3a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m5r3b" oct="4" pname="a"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: A2-E3-A3-C#4 (V "334") dotted half — 3 beats -->
                  <chord dur="2" dots="1">
                    <note xml:id="m5l1a" oct="2" pname="a"/>
                    <note xml:id="m5l1b" oct="3" pname="e"/>
                    <note xml:id="m5l1c" oct="3" pname="a"/>
                    <note xml:id="m5l1d" oct="4" pname="c" accid.ges="s"/>
                  </chord>
                  <!-- beat 4: F#2-C#3-F#3 (iii "334") quarter -->
                  <chord dur="4">
                    <note xml:id="m5l2a" oct="2" pname="f" accid.ges="s"/>
                    <note xml:id="m5l2b" oct="3" pname="c" accid.ges="s"/>
                    <note xml:id="m5l2c" oct="3" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- m6: D E, D F, D F → I V I I I -->
            <!-- Melody: D(1) E(1) F#(1) F#(1) = 4 beats -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6n1" dur="4" oct="4" pname="d"/>
                  <note xml:id="m6n2" dur="4" oct="4" pname="e"/>
                  <note xml:id="m6n3" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m6n4" dur="4" oct="4" pname="f" accid.ges="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: D-F# (I "33") quarter -->
                  <chord dur="4">
                    <note xml:id="m6r1a" oct="4" pname="d"/>
                    <note xml:id="m6r1b" oct="4" pname="f" accid.ges="s"/>
                  </chord>
                  <!-- beat 2: E-G (ii or V passing) quarter -->
                  <chord dur="4">
                    <note xml:id="m6r2a" oct="4" pname="e"/>
                    <note xml:id="m6r2b" oct="4" pname="g"/>
                  </chord>
                  <!-- beat 3-4: F#-A (I "43") half -->
                  <chord dur="2">
                    <note xml:id="m6r3a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m6r3b" oct="4" pname="a"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1-2: D2-A2-D3-F#3 (I "334") half -->
                  <chord dur="2">
                    <note xml:id="m6l1a" oct="2" pname="d"/>
                    <note xml:id="m6l1b" oct="3" pname="a"/>
                    <note xml:id="m6l1c" oct="3" pname="d"/>
                    <note xml:id="m6l1d" oct="3" pname="f" accid.ges="s"/>
                  </chord>
                  <!-- beat 3-4: A2-E3-A3 (V passing → I sustained) half -->
                  <chord dur="2">
                    <note xml:id="m6l2a" oct="2" pname="a"/>
                    <note xml:id="m6l2b" oct="3" pname="e"/>
                    <note xml:id="m6l2c" oct="3" pname="a"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- m7: Bm F, E ^G, F#m A, Bm B → ii iii iii ii -->
            <!-- ^G = G# (melody non-diatonic passing tone) — use diatonic harmony -->
            <!-- Melody: F#(1) G(1) A(1) B(1) = 4 beats -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7n1" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <!-- G# passing — rendered as G natural in melody accid -->
                  <note xml:id="m7n2" dur="4" oct="4" pname="g"/>
                  <note xml:id="m7n3" dur="4" oct="4" pname="a"/>
                  <note xml:id="m7n4" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: B-D (Bm) quarter -->
                  <chord dur="4">
                    <note xml:id="m7r1a" oct="4" pname="b"/>
                    <note xml:id="m7r1b" oct="5" pname="d"/>
                  </chord>
                  <!-- beat 2: A-C# (sub V for E area) quarter -->
                  <chord dur="4">
                    <note xml:id="m7r2a" oct="4" pname="a"/>
                    <note xml:id="m7r2b" oct="4" pname="c" accid.ges="s"/>
                  </chord>
                  <!-- beat 3: F#-A (iii) quarter -->
                  <chord dur="4">
                    <note xml:id="m7r3a" oct="4" pname="f" accid.ges="s"/>
                    <note xml:id="m7r3b" oct="4" pname="a"/>
                  </chord>
                  <!-- beat 4: B-F# (Bm "34" 2nd inv) quarter -->
                  <chord dur="4">
                    <note xml:id="m7r4a" oct="4" pname="b"/>
                    <note xml:id="m7r4b" oct="5" pname="f" accid.ges="s"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: B2-F#3-B3-D4 (Bm "333") half -->
                  <chord dur="2">
                    <note xml:id="m7l1a" oct="2" pname="b"/>
                    <note xml:id="m7l1b" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m7l1c" oct="3" pname="b"/>
                    <note xml:id="m7l1d" oct="4" pname="d"/>
                  </chord>
                  <!-- beat 3: F#2-C#3-F#3-A3 (iii "334") half -->
                  <chord dur="2">
                    <note xml:id="m7l2a" oct="2" pname="f" accid.ges="s"/>
