                    <note xml:id="m10r4b" oct="4" pname="a"/>
                  </chord>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- beat 1: B2-F#3-B3 (Bm) half -->
                  <chord dur="2">
                    <note xml:id="m10l1a" oct="2" pname="b"/>
                    <note xml:id="m10l1b" oct="3" pname="f" accid.ges="s"/>
                    <note xml:id="m10l1c" oct="3" pname="b"/>
                  </chord>
                  <!-- beat 3: G2-D3-G3-B3 (IV) half -->
                  <chord dur="2">
                    <note xml:id="m10l2a" oct="2" pname="g"/>
                    <note xml:id="m10l2b" oct="3" pname="d"/>
                    <note xml:id="m10l2c" oct="3" pname="g"/>
                    <note xml:id="m10l2d" oct="3" pname="b"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="2">④</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- m11: Bm d, C#ø7 c/2 B/2, Bb ^A, Bm B -->
            <!-- Melody: D5(1) C#5(0.5) B4(0.5) A#4(1) B4(1) = 4 beats -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m11n1" dur="4" oct="5" pname="d"/>
                  <note xml:id="m11n2" dur="8" oct="5" pname="c" accid.ges="s"/>
                  <note xml:id="m11n3" dur="8" oct="4" pname="b"/>
                  <note xml:id="m11n4" dur="4" oct="4" pname="a" accid="s"/>
                  <note xml:id="m11n5" dur="4" oct="4" pname="b"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- beat 1: B-D (Bm) quarter -->
                  <chord dur="4">
                    <note xml:id="m11r1a" oct="4" pname="b"/>
                    <note xml:id="m11r1b" oct="5" pname="d"/>
                  </chord>
                  <!-- beat 2: C#-E (viiø7 partial) quarter -->
                  <chord dur="4">
                    <note xml:id="m11r2a" oct="4" pname="c" accid.ges="s"/>
                    <note xml:id="m11r2b" oct="4" pname="e"/>
                  </chord>
                  <!-- beat 3: B-D (Bm sub Bb) quarter -->
                  <chord dur="4">
                    <note xml:id="m11r3a" oct="4" pname="b"/>
                    <note xml:id="m11r3b" oct="5" pname="d"/>
                  </chord>
                  <!-- beat 4: B-F# (Bm "34") quarter -->
