                </layer>
                <layer n="2">
                  <note pname="a" oct="1" dur="4" stem.dir="down"/>
                  <note pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note pname="a" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑥</harm>
            </measure>

            <!-- MEASURE 5: G G C C → ⑤ ⑤ ① ① -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note pname="g" oct="4" dur="2"/>
                  <note pname="e" oct="4" dur="4"/>
                  <note pname="c" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- G: use "43" 1st inv — B4 E5; C: "33" — C5 E5 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- G: G2 D3 G3 B3; C: C3 G3 C4 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="1" dur="2" stem.dir="down"/>
                  <note pname="c" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- MEASURE 6: G Dm A(→vi) A → ⑤ ② ⑥ ⑥ -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note pname="g" oct="4" dur="4"/>
                  <note pname="f" oct="4" dur="4"/>
                  <note pname="e" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <!-- A→vi (Am): A4 C5 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="d" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note pname="d" oct="1" dur="4" stem.dir="down"/>
                  <note pname="a" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">②</harm>
              <harm staff="1" tstamp="3">⑥</harm>
            </measure>

            <!-- MEASURE 7: G G C G → ⑤ ⑤ ① ⑤ -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note pname="b" oct="4" dur="2"/>
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- "333" V7 for richness -->
                  <chord dur="2" stem.dir="up">
                    <note pname="f" oct="5"/>
                    <note pname="d" oct="5"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="1" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤7</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- MEASURE 8: C Dm E(→iii) Am → ① ② ③ ⑥ -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="a" oct="4" dur="4"/>
                  <accid accid="s" pname="g" oct="4"/>
