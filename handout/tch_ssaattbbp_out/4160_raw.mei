                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="a" oct="1" dur="2" stem.dir="down"/>
                  <note pname="e" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥</harm>
              <harm staff="1" tstamp="3">③</harm>
            </measure>

            <!-- MEASURE 4: Am G Am Am → ⑥ ⑤ ⑥ ⑥ -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="g" oct="4" dur="4"/>
                  <note pname="a" oct="4" dur="4"/>
                  <note pname="e" oct="4" dur="4"/>
                </layer>
