              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="b" oct="2"/>
                    <note pname="f" oct="3"/>
                    <note pname="d" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="b" oct="1" dur="4" stem.dir="down"/>
                  <note pname="c" oct="1" dur="4" stem.dir="down"/>
                  <note pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note pname="e" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">③</harm>
            </measure>

            <!-- MEASURE 11: Am Dm Am Am → ⑥ ② ⑥ ⑥ -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note pname="a" oct="4" dur="4"/>
                  <note pname="f" oct="4" dur="4"/>
                  <note pname="e" oct="4" dur="4"/>
                  <note pname="c" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="f" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Fuller voicing, 4 notes per chord (climax) -->
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="d" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="a" oct="1" dur="4" stem.dir="down"/>
                  <note pname="d" oct="1" dur="4" stem.dir="down"/>
                  <note pname="a" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥</harm>
              <harm staff="1" tstamp="2">②</harm>
              <harm staff="1" tstamp="3">⑥</harm>
            </measure>

            <!-- MEASURE 12: G Dm Am Am → ⑤ ② ⑥² ⑥ -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note pname="g" oct="4" dur="4" dots="1"/>
                  <note pname="f" oct="4" dur="8"/>
                  <note pname="e" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="4" dots="1" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord dur="8" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="4"/>
                  </chord>
                  <!-- vi² (Am 2nd inversion): E4 A4 C5 "34" -->
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="4"/>
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="4" dots="1" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord dur="8" stem.dir="up">
                    <note pname="d" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="1" dur="4" dots="1" stem.dir="down"/>
                  <note pname="d" oct="1" dur="8" stem.dir="down"/>
                  <note pname="e" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">②</harm>
              <harm staff="1" tstamp="3">⑥²</harm>
            </measure>

            <!-- MEASURE 13: E4 (final) → ③ (root pos, full voicing, pedal E1) -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note pname="e" oct="4" dur="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Full root position iii: E4 G4 B4 -->
                  <chord dur="1" stem.dir="up">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="1" stem.dir="up">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="e" oct="1" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③</harm>
            </measure>

          </section>
        </score>
      </mdiv>
    </body>
  </music>
</mei>
<!--
VOICING PLAN:
- M1 (Em): "33" root iii, light opening — RH: B4 E5, LH: E2 B2 E3
- M2-4 (Am/Em oscillation): RH 2 notes per chord, smooth alternation
- M5 (G→C): "43" 1st inv for G, "33" for C — variety at phrase midpoint
- M7 (G): "333" V7 for richness — F5 D5 B4 LH adds 7th
- M8 (C Dm E Am): 4-chord measure — each hand moves through full progression
- M10 (B° C G Em): chromatic approach — B° uses F♮ (diatonic) for dim quality
- M11-12 (Am Dm): climax — LH expands to 4 notes open voicing
- M12: vi² (Am 2nd inversion) for suspension before final
- M13: root pos iii (Em), pedal E1 — peaceful close

VOICE LEADING HIGHLIGHTS:
- M1→2: RH top note E5 common tone between iii and vi
- M7: V7 (GDFB) anticipates resolution to I in M7 beat 3
- M12: "34" Am 2nd inversion (E A C) creates gentle suspension into final cadence
- Pedal bass tracks root faithfully, pedal harp reinforces each chord change

TEXTURE ARC:
- M1-4: Light, 2-note RH, 3-note LH — opening stillness
- M5-7: Grows to 3-note RH when harmonic rhythm permits, V7 adds richness
- M8: Active motion, 4 different chords → all voices moving
- M9-12: Climax zone — LH expands to 4 notes; 2nd inversions add suspension
- M13: Full close, root position, pedal bass E1 anchors final sonority
-->
