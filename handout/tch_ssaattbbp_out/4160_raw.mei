            <!-- MEASURE 10: B° C G Em → ⑦° ① ⑤ ③ -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note pname="b" oct="4" dur="4"/>
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="b" oct="4" dur="4"/>
