              <staff n="2">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="e" oct="5"/>
                    <note pname="a" oct="4"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="5"/>
                    <note pname="a" oct="4"/>
