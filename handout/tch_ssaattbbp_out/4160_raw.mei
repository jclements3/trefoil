                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- Am: A2 E3 A3; Em: E3 B3; Am again; Em -->
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="e" oct="3"/>
                    <note pname="b" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="e" oct="3"/>
                    <note pname="b" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="a" oct="1" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥</harm>
              <harm staff="1" tstamp="2">③</harm>
              <harm staff="1" tstamp="3">⑥</harm>
              <harm staff="1" tstamp="4">③</harm>
            </measure>

            <!-- MEASURE 3: Am Am E E → ⑥ ⑥ ③ ③  (E→iii diatonic) -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note pname="a" oct="4" dur="2"/>
                  <note pname="b" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <!-- iii (Em): sustain C→B change, RH 1st inv "43" -->
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <!-- E4 common tone between Am and Em -->
