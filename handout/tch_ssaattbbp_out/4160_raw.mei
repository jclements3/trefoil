              <staff n="2">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="e" oct="5"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="4"/>
