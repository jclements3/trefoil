              </staff>
              <staff n="3">
                <layer n="1">
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="d" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="f" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="e" oct="3"/>
                    <note pname="b" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
