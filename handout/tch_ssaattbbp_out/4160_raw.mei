            <!-- MEASURE 9: E E Em Em → ③ ③ ③ ③ (E→iii) -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note pname="b" oct="4" dur="2"/>
                  <note pname="e" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- iii: E4 G4 B4 "33" -->
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
