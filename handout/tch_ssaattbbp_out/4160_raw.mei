<?xml version="1.0" encoding="UTF-8"?>
<!-- 4160: Wilt Thou, O Man, Live Happily — Key: C major, 4/4 -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Wilt Thou, O Man, Live Happily</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>
            <!--
              Chord progression (measure by measure, L=1/4):
              M1: Em Em C G
              M2: Am Em Am E
              M3: Am Am E E
              M4: Am G Am Am
              M5: G G C C
              M6: G Dm A A
              M7: G G C G
              M8: C Dm E Am
              M9: E E Em Em
              M10: B° C G Em
              M11: Am Dm Am Am
              M12: G Dm Am Am
              M13: E E E E (final)

              Diatonic substitutions (key of C):
              Em = iii, C = I, G = V, Am = vi, E = III (chromatic — use iii/Em diatonic sub)
              Dm = ii, B° = vii°, A = VI (chromatic — use vi=Am)
              For chromatic chords (E major, A major, B°) we use diatonic neighbors.

              VOICING PLAN:
              - Opening (M1-4): light "33" triads, RH 2 notes, LH 3 notes
              - Middle (M5-9): "43" 1st inversions for variety; "333" 7ths at emotional peak
              - Climax (M10-12): fuller 4-note LH, "34" 2nd inversions
              - Cadence (M13): root position I, pedal C1

              Circled digits: ① = I(C), ② = ii(Dm), ③ = iii(Em), ④ = IV(F), ⑤ = V(G), ⑥ = vi(Am), ⑦ = vii°(B°)
            -->

            <!-- MEASURE 1: Em Em C G  → ③ ③ ① ⑤ -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <!-- melody: E2 G G -->
                  <note xml:id="m1s1n1" pname="e" oct="4" dur="2"/>
                  <note xml:id="m1s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1s1n3" pname="g" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <!-- RH: Em → C: light opening, 2 notes moving -->
                <layer n="1">
                  <!-- Moving: Em chord tones B4 E5, then C4 E4 for C -->
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <!-- G: B4 D5 -->
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <!-- Sustained: nothing held across chord change here -->
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: Em open voicing, 3 notes -->
                <layer n="1">
                  <!-- Moving Em: E2 B2 E3 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- C major: C3 G3 C4  (beat 3) -->
                  <chord dur="4" stem.dir="up">
                    <note pname="c" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                  <!-- G major: G2 D3 G3 (beat 4) -->
                  <chord dur="4" stem.dir="up">
                    <note pname="g" oct="2"/>
                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <!-- Pedal: E1 held -->
                  <note pname="e" oct="1" dur="2" stem.dir="down"/>
                  <rest dur="2" visible="false"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- MEASURE 2: Am Em Am E → ⑥ ③ ⑥ ③ -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note pname="a" oct="4" dur="4"/>
                  <note pname="b" oct="4" dur="4"/>
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="b" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- Am: A4 C5; Em: B4 E5; Am: A4 C5; Em(E): B4 E5 -->
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord dur="4" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
