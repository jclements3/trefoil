<?xml version="1.0" encoding="UTF-8"?>
<!-- 4104 Christ Arose — Key: C major — 4/4
     No key signature (0 flats/sharps).
     Non-diatonic notes in melody (F#, D# etc.) carry explicit accidentals.
     Harp plays diatonic only in RH/LH.

     Chord sequence from ABC:
     Bar 1:  C C F A         (G G A)  → C(2b) F(1b) — 3 beats written, but pickup bar?
     Actually bar 1 is full: C G2 G ^F A = C(2b) G(1b) G(1b)... re-read:
     "^C"G2 G "^F"A  = C(2 beats) F(1 beat) missing 4th beat?
     Wait: G2 = G half note, G = G quarter, A = quarter → 2+1+1=4 beats, C for first 2 beats, then "^F" on beat 3 means F chord annotation on the A note. So: C(beats 1-2) F(beats 3-4).

     Bar 1: C(h) F(q) on A note... actually "G2 G" = half + quarter = 3 beats melody, "^F"A = 1 beat. Total = 4. Chords: C(3b) F(1b)
     Bar 2: A "^C"G G2 → F(1b beat 1 carry?) C(3b)  Actually: A = quarter, "^C"G = C chord on G, then G2 = G half.
     Let me parse properly:
     "^C"G2 G "^F"A = C:G(half) G(q) F:A(q) — 4 beats. C holds 3 beats? No — "^C" annotates on G, then no new chord until "^F" on A. So: C(beats 1-3) F(beat 4).
     Bar 2: A "^C"G G2 = F(beat 1, carry) C(beats 2-4). Or F:A(q) C:G(q) G(h) = F(1b) C(3b)
     Bar 3: "^G"G2 "^G7"F "^G"A → G(2b) G7(1b) G(1b) → G chord 4 beats
     Bar 4: "^F"A2 "^C"G2 → F(2b) C(2b)
     Bar 5: "^F"A2 "^G"B "^F"c → F(2b) G(1b) F(1b)
     Bar 6: "^C"c G G2 → C(4b)
     Bar 7: "^Am"A2 "^G"G "^D7"^F → Am(2b) G(1b) D7(1b)→substitute G (V): non-diatonic D7→use G(V)
     Bar 8: "^G"G4 → G(4b)
     — verse ends —
     Bar 9: C C3/4 C/4 E G3/4 G/4 → C(4b) [triplet-ish rhythms, simplify to C]
     Bar 10: "^C"c3 c3/4 "^Dm"d/4 → C(3.75b) Dm(0.25b) → C(4b approx)
     Bar 11: "^C"e c "^Dm7"d3/4 "^F"c/4 "^G"B3/4 "^F"A/4 → C(2b) Dm7(0.75b) F(0.25b) G(0.75b) F(0.25b)
             Simplify: C(2b) Dm(1b) G(1b)
     Bar 12: "^C"G3 "^G"B3/4 "^C"c/4 → C(3b) G(0.75b) C(0.25b) → C(3b) G(1b)
     Bar 13: "^G"d d d3/4 "^C"c/4 "^G"d3/4 "^Em"e/4 → G(2.75b) C(0.25b) G(0.75b) Em(0.25b) → G(4b)
     Bar 14: "^Am"c "^F"A "^C"G G3/4 G/4 → Am(1b) F(1b) C(2b)
     Bar 15: "^F"A A "^D7"A3/4 "^D"d/4 d3/4 c/4 → F(2b) D7(1b) D(1b) → F(2b) G(2b) [sub D7→G]
     Bar 16: "^G"B "^Am"c "^G7"d G3/4 G/4 → G(1b) Am(1b) G7(2b)
     Bar 17: "^C"e3 d3/4 c/4 → C(3b) C(1b) → C(4b)
     Bar 18: "^F"f3 "^C"e3/4 "^Dm"d/4 → F(3b) C(0.75b) Dm(0.25b) → F(3b) C(1b)
     Bar 19: "^C"c G e "^G7"d → C(3b) G7(1b)
     Bar 20: "^C"c4 → C(4b) final

     Duration math: simplify ABC dotted quarters and sixteenths to their nominal values.
     "d3/4" = dotted eighth (3/8 of L:1/4 = 3/16 of whole), 'd/4' = 16th note.
     For harp parts, we'll use whole-measure block chords and half-note chords with varied rhythms.
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Christ Arose</title>
      </titleStmt>
      <pubStmt/>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="0">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="0"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="0"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="0"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Verse section (bars 1-8) — hymn stanza -->

            <!-- Bar 1: C(3 beats) F(1 beat)
                 Melody: G(h) G(q) A(q)
                 RH: C: G4-C5 (3 beats) → F: A4-C5 (1 beat)
                 LH: C: C2-G2-E3 (3b) → F: F2-C3-A3 (1b)
                 Pedal: C1(3b) F1(1b)
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="g" oct="4" dur="2"/>
                  <note xml:id="m1s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1s1n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- C: E4-G4 dotted half (3 beats) -->
                  <chord xml:id="m1rh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m1rh1a" pname="e" oct="4"/>
                    <note xml:id="m1rh1b" pname="g" oct="4"/>
                  </chord>
                  <!-- F: A4-C5 quarter -->
                  <chord xml:id="m1rh2" dur="4" stem.dir="up">
                    <note xml:id="m1rh2a" pname="a" oct="4"/>
                    <note xml:id="m1rh2b" pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <!-- C open: C2-G2-E3 dotted half -->
                  <chord xml:id="m1lh1" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m1lh1a" pname="c" oct="2"/>
                    <note xml:id="m1lh1b" pname="g" oct="2"/>
                    <note xml:id="m1lh1c" pname="e" oct="3"/>
                  </chord>
                  <!-- F: F2-C3-A3 quarter -->
                  <chord xml:id="m1lh2" dur="4" stem.dir="up">
                    <note xml:id="m1lh2a" pname="f" oct="2"/>
                    <note xml:id="m1lh2b" pname="c" oct="3"/>
                    <note xml:id="m1lh2c" pname="a" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m1p1" pname="c" oct="1" dur="2" dots="1" stem.dir="down"/>
                  <note xml:id="m1p2" pname="f" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="4">④</harm>
            </measure>

            <!-- Bar 2: F(1b) C(3b)
                 Melody: A(q) G(q) G(h)
                 RH: F: A4-C5(q) → C: G4-E5(3b)
                 LH: F: F2-C3-A3(q) → C: C2-G2-C3-E3(3b)
                 Pedal: F1 C1
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="a" oct="4" dur="4"/>
                  <note xml:id="m2s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m2s1n3" pname="g" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2rh1" dur="4" stem.dir="up">
                    <note xml:id="m2rh1a" pname="a" oct="4"/>
                    <note xml:id="m2rh1b" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m2rh2" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m2rh2a" pname="g" oct="4"/>
                    <note xml:id="m2rh2b" pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2lh1" dur="4" stem.dir="up">
                    <note xml:id="m2lh1a" pname="f" oct="2"/>
                    <note xml:id="m2lh1b" pname="c" oct="3"/>
                    <note xml:id="m2lh1c" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m2lh2" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m2lh2a" pname="c" oct="2"/>
                    <note xml:id="m2lh2b" pname="g" oct="2"/>
                    <note xml:id="m2lh2c" pname="c" oct="3"/>
                    <note xml:id="m2lh2d" pname="e" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m2p1" pname="f" oct="1" dur="4" stem.dir="down"/>
                  <note xml:id="m2p2" pname="c" oct="1" dur="2" dots="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">①</harm>
            </measure>

            <!-- Bar 3: G(4b) [G G7 G]
                 Melody: G(h) F(q) A(q)
                 F# non-diatonic melody note on G chord — kept as melody accidental
                 RH: G: D4-G4(h) then B4-G4(h)  — vary within bar
                 LH: G: G2-D3-G3-B3 whole
                 Pedal: G1 whole
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="g" oct="4" dur="2"/>
                  <!-- G7 annotation: melody F natural (not F#) in this key -->
                  <note xml:id="m3s1n2" pname="f" oct="4" dur="4"/>
                  <note xml:id="m3s1n3" pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <!-- G: D4-B4 half -->
                  <chord xml:id="m3rh1" dur="2" stem.dir="up">
                    <note xml:id="m3rh1a" pname="d" oct="4"/>
                    <note xml:id="m3rh1b" pname="b" oct="4"/>
                  </chord>
                  <!-- G7 texture: B4-F5 half (tritone = G7 flavor, diatonic) -->
                  <chord xml:id="m3rh2" dur="2" stem.dir="up">
                    <note xml:id="m3rh2a" pname="b" oct="4"/>
                    <note xml:id="m3rh2b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3lh1" dur="1" stem.dir="up">
                    <note xml:id="m3lh1a" pname="g" oct="2"/>
                    <note xml:id="m3lh1b" pname="d" oct="3"/>
                    <note xml:id="m3lh1c" pname="g" oct="3"/>
                    <note xml:id="m3lh1d" pname="b" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m3p1" pname="g" oct="1" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- Bar 4: F(2b) C(2b)
                 Melody: A(h) G(h)
                 RH: F: A4-C5 → C: G4-E5
                 LH: F: F2-C3-F3-A3 → C: C2-G2-E3-G3
                 Pedal: F1 C1
            -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m4s1n2" pname="g" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4rh1" dur="2" stem.dir="up">
                    <note xml:id="m4rh1a" pname="a" oct="4"/>
                    <note xml:id="m4rh1b" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m4rh2" dur="2" stem.dir="up">
                    <note xml:id="m4rh2a" pname="g" oct="4"/>
                    <note xml:id="m4rh2b" pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4lh1" dur="2" stem.dir="up">
                    <note xml:id="m4lh1a" pname="f" oct="2"/>
                    <note xml:id="m4lh1b" pname="c" oct="3"/>
                    <note xml:id="m4lh1c" pname="f" oct="3"/>
                    <note xml:id="m4lh1d" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m4lh2" dur="2" stem.dir="up">
                    <note xml:id="m4lh2a" pname="c" oct="2"/>
                    <note xml:id="m4lh2b" pname="g" oct="2"/>
                    <note xml:id="m4lh2c" pname="e" oct="3"/>
                    <note xml:id="m4lh2d" pname="g" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m4p1" pname="f" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m4p2" pname="c" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Bar 5: F(2b) G(1b) F(1b)
                 Melody: A(h) B(q) c(q)
                 RH: F: A4-C5 → G: B4-D5 → F: A4-C5
                 LH: F: F2-C3-A3 → G: G2-D3-B3 → F: F2-C3-A3
                 Pedal: F1 G1 F1
            -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m5s1n2" pname="b" oct="4" dur="4"/>
                  <note xml:id="m5s1n3" pname="c" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5rh1" dur="2" stem.dir="up">
                    <note xml:id="m5rh1a" pname="a" oct="4"/>
                    <note xml:id="m5rh1b" pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m5rh2" dur="4" stem.dir="up">
                    <note xml:id="m5rh2a" pname="b" oct="4"/>
                    <note xml:id="m5rh2b" pname="d" oct="5"/>
                  </chord>
                  <chord xml:id="m5rh3" dur="4" stem.dir="up">
                    <note xml:id="m5rh3a" pname="a" oct="4"/>
                    <note xml:id="m5rh3b" pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5lh1" dur="2" stem.dir="up">
                    <note xml:id="m5lh1a" pname="f" oct="2"/>
                    <note xml:id="m5lh1b" pname="c" oct="3"/>
                    <note xml:id="m5lh1c" pname="a" oct="3"/>
                  </chord>
                  <chord xml:id="m5lh2" dur="4" stem.dir="up">
                    <note xml:id="m5lh2a" pname="g" oct="2"/>
                    <note xml:id="m5lh2b" pname="d" oct="3"/>
                    <note xml:id="m5lh2c" pname="b" oct="3"/>
                  </chord>
                  <chord xml:id="m5lh3" dur="4" stem.dir="up">
                    <note xml:id="m5lh3a" pname="f" oct="2"/>
                    <note xml:id="m5lh3b" pname="c" oct="3"/>
                    <note xml:id="m5lh3c" pname="a" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m5p1" pname="f" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m5p2" pname="g" oct="1" dur="4" stem.dir="down"/>
                  <note xml:id="m5p3" pname="f" oct="1" dur="4" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">④</harm>
            </measure>

            <!-- Bar 6: C(4b)
                 Melody: c(q) G(q) G(h)
                 RH: C: E4-G4(q) then G4-C5(dotted half) — arpeggiate
                 LH: C: C2-G2-C3-E3 whole
                 Pedal: C1 whole
            -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="c" oct="5" dur="4"/>
                  <note xml:id="m6s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m6s1n3" pname="g" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6rh1" dur="4" stem.dir="up">
                    <note xml:id="m6rh1a" pname="e" oct="4"/>
                    <note xml:id="m6rh1b" pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m6rh2" dur="2" dots="1" stem.dir="up">
                    <note xml:id="m6rh2a" pname="g" oct="4"/>
                    <note xml:id="m6rh2b" pname="c" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6lh1" dur="1" stem.dir="up">
                    <note xml:id="m6lh1a" pname="c" oct="2"/>
                    <note xml:id="m6lh1b" pname="g" oct="2"/>
                    <note xml:id="m6lh1c" pname="c" oct="3"/>
                    <note xml:id="m6lh1d" pname="e" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m6p1" pname="c" oct="1" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Bar 7: Am(2b) G(1b) G(1b) [D7→G sub]
                 Melody: A(h) G(q) F#(q) — F# non-diatonic in melody
                 Chords: Am(2b) G(2b) [D7→G]
                 RH: Am: C5-E5 → G: B4-D5
                 LH: Am: A2-E3-A3-C4 → G: G2-D3-G3-B3
                 Pedal: A1(2b) G1(2b)
            -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="a" oct="4" dur="2"/>
                  <note xml:id="m7s1n2" pname="g" oct="4" dur="4"/>
                  <!-- F# non-diatonic melody note -->
                  <note xml:id="m7s1n3" pname="f" oct="4" dur="4" accid="s"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7rh1" dur="2" stem.dir="up">
                    <note xml:id="m7rh1a" pname="c" oct="5"/>
                    <note xml:id="m7rh1b" pname="e" oct="5"/>
                  </chord>
                  <chord xml:id="m7rh2" dur="2" stem.dir="up">
                    <note xml:id="m7rh2a" pname="b" oct="4"/>
                    <note xml:id="m7rh2b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7lh1" dur="2" stem.dir="up">
                    <note xml:id="m7lh1a" pname="a" oct="2"/>
                    <note xml:id="m7lh1b" pname="e" oct="3"/>
                    <note xml:id="m7lh1c" pname="a" oct="3"/>
                    <note xml:id="m7lh1d" pname="c" oct="4"/>
                  </chord>
                  <chord xml:id="m7lh2" dur="2" stem.dir="up">
                    <note xml:id="m7lh2a" pname="g" oct="2"/>
                    <note xml:id="m7lh2b" pname="d" oct="3"/>
                    <note xml:id="m7lh2c" pname="g" oct="3"/>
                    <note xml:id="m7lh2d" pname="b" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note xml:id="m7p1" pname="a" oct="1" dur="2" stem.dir="down"/>
                  <note xml:id="m7p2" pname="g" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Bar 8: G(4b) — anticipation of chorus -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" pname="g" oct="4" dur="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8rh1" dur="1" stem.dir="up">
                    <note xml:id="m8rh1a" pname="b" oct="4"/>
                    <note xml:id="m8rh1b" pname="d" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8lh1" dur="1" stem.dir="up">
