                    <note xml:id="m36s3n7" pname="d" oct="3" />
                    <note xml:id="m36s3n8" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m36s3c3" dur="4">
                    <note xml:id="m36s3n9" pname="g" oct="2" />
                    <note xml:id="m36s3n10" pname="d" oct="3" />
                    <note xml:id="m36s3n11" pname="g" oct="3" />
