<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Come Holy Spirit, Lord Our God</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: G major (1 sharp: F#). Meter: 4/4 -->
          <!-- Non-diatonic chords: C#°→D, A→Em/D (substitute nearest diatonic) -->
          <!-- A7→D7 (V/IV → use D), F#m = diatonic vi of A but in G = iii (E?) -->
          <!-- F#m IS diatonic to G major (degree iii: F#-A-C#? No: in G, iii=Bm.) -->
          <!-- In G major scale: G-A-B-C-D-E-F#. F#m=F#-A-C# (C# non-diatonic in G!) -->
          <!-- Treat F#m → Em (③m substitute). A major → Em or D. -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-8): First verse                              -->
            <!-- ============================================================ -->

            <!-- Measure 1: G(b1-2) C(b3) G(b4)                              -->
            <!-- Melody: D5(2) E5(1) D5(1)                                    -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="5" pname="d" />
                  <note xml:id="m1s1n2" dur="4" oct="5" pname="e" />
                  <note xml:id="m1s1n3" dur="4" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: G=B4-D5 half; C=E4-G4; G=D4-G4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="b" oct="4" />
                    <note xml:id="m1s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4">
                    <note xml:id="m1s2n3" pname="e" oct="4" />
                    <note xml:id="m1s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="d" oct="4" />
                    <note xml:id="m1s2n6" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2-D3-G3-B3 half; C C2-G2-C3-E3; G G2-D3-G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="g" oct="2" />
                    <note xml:id="m1s3n2" pname="d" oct="3" />
                    <note xml:id="m1s3n3" pname="g" oct="3" />
                    <note xml:id="m1s3n4" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4">
                    <note xml:id="m1s3n5" pname="c" oct="2" />
                    <note xml:id="m1s3n6" pname="g" oct="2" />
                    <note xml:id="m1s3n7" pname="c" oct="3" />
                    <note xml:id="m1s3n8" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n9" pname="g" oct="2" />
                    <note xml:id="m1s3n10" pname="d" oct="3" />
                    <note xml:id="m1s3n11" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 2: D(b2-4) [B4(1) D5(1) A4(2)] -->
            <!-- Melody: B4(1) D5(1) A4(2). D=D-F#-A -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m2s1n2" dur="4" oct="5" pname="d" />
                  <note xml:id="m2s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: G=B4-D5 → D=F#4-A4 broken arpeg -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="b" oct="4" />
                    <note xml:id="m2s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="2">
                    <note xml:id="m2s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n6" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G passing then D D2-A2-D3-F#3 half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="g" oct="2" />
                    <note xml:id="m2s3n2" pname="d" oct="3" />
                    <note xml:id="m2s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n4" pname="d" oct="2" />
                    <note xml:id="m2s3n5" pname="a" oct="2" />
                    <note xml:id="m2s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="2">
                    <note xml:id="m2s3n7" pname="d" oct="2" />
                    <note xml:id="m2s3n8" pname="a" oct="2" />
                    <note xml:id="m2s3n9" pname="d" oct="3" />
                    <note xml:id="m2s3n10" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
            </measure>

            <!-- Measure 3: G(b1-3) D(b4) [C#°→D at b4]                     -->
            <!-- Melody: B4(1) G4(1) B4(1) C#5(1). C#° non-diatonic → D.    -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="b" />
                  <!-- C# melody as written — melody may have accidentals -->
                  <note xml:id="m3s1n4" dur="4" oct="5" pname="c" accid="s" />
                </layer>
              </staff>
              <!-- RH: G=D4-G4 dotted half; D=F#4-A4 quarter -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2" dots="1">
                    <note xml:id="m3s2n1" pname="d" oct="4" />
                    <note xml:id="m3s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m3s2n4" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2-D3-G3-B3 dotted half; D D2-A2-D3 qtr -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2" dots="1">
                    <note xml:id="m3s3n1" pname="g" oct="2" />
                    <note xml:id="m3s3n2" pname="d" oct="3" />
                    <note xml:id="m3s3n3" pname="g" oct="3" />
                    <note xml:id="m3s3n4" pname="b" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n5" pname="d" oct="2" />
                    <note xml:id="m3s3n6" pname="a" oct="2" />
                    <note xml:id="m3s3n7" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 4: D(b1-2) G(b3-4) [rest(b3)]                      -->
            <!-- Melody: D5(2) rest(1) D5(1)                                  -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="5" pname="d" />
                  <rest xml:id="m4s1r1" dur="4" />
                  <note xml:id="m4s1n2" dur="4" oct="5" pname="d" />
                </layer>
              </staff>
              <!-- RH: D=A4-D5; G=B4-D5 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="a" oct="4" />
                    <note xml:id="m4s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="2">
                    <note xml:id="m4s2n3" pname="b" oct="4" />
                    <note xml:id="m4s2n4" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2-A2-D3-F#3; G G2-D3-G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="d" oct="2" />
                    <note xml:id="m4s3n2" pname="a" oct="2" />
                    <note xml:id="m4s3n3" pname="d" oct="3" />
                    <note xml:id="m4s3n4" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="2">
                    <note xml:id="m4s3n5" pname="g" oct="2" />
                    <note xml:id="m4s3n6" pname="d" oct="3" />
                    <note xml:id="m4s3n7" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 5: C(b1-2) G(b3-4)                                  -->
            <!-- Melody: E5(2) D5(1) B4(1)                                    -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" oct="5" pname="e" />
                  <note xml:id="m5s1n2" dur="4" oct="5" pname="d" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: C=E4-G4; G=D4-G4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="e" oct="4" />
                    <note xml:id="m5s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="2">
                    <note xml:id="m5s2n3" pname="d" oct="4" />
                    <note xml:id="m5s2n4" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: C C2-G2-C3-E3; G G2-D3-G3-B3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="c" oct="2" />
                    <note xml:id="m5s3n2" pname="g" oct="2" />
                    <note xml:id="m5s3n3" pname="c" oct="3" />
                    <note xml:id="m5s3n4" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="2">
                    <note xml:id="m5s3n5" pname="g" oct="2" />
                    <note xml:id="m5s3n6" pname="d" oct="3" />
                    <note xml:id="m5s3n7" pname="g" oct="3" />
                    <note xml:id="m5s3n8" pname="b" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 6: D(b1-2) Em(b3-4)                                 -->
            <!-- Melody: D5(1) A4(1) G4(1) C5(1)                             -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="5" pname="d" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m6s1n4" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: D=F#4-A4; D=A4-D5; Em=E4-G4; Em=G4-B4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m6s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n3" pname="a" oct="4" />
                    <note xml:id="m6s2n4" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n5" pname="e" oct="4" />
                    <note xml:id="m6s2n6" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c4" dur="4">
                    <note xml:id="m6s2n7" pname="g" oct="4" />
                    <note xml:id="m6s2n8" pname="b" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: D D2-A2-D3; D D2-A2-F#3; Em E2-B2-E3; Em E2-B2-G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="d" oct="2" />
                    <note xml:id="m6s3n2" pname="a" oct="2" />
                    <note xml:id="m6s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="d" oct="2" />
                    <note xml:id="m6s3n5" pname="a" oct="2" />
                    <note xml:id="m6s3n6" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n7" pname="e" oct="2" />
                    <note xml:id="m6s3n8" pname="b" oct="2" />
                    <note xml:id="m6s3n9" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c4" dur="4">
                    <note xml:id="m6s3n10" pname="e" oct="2" />
                    <note xml:id="m6s3n11" pname="b" oct="2" />
                    <note xml:id="m6s3n12" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Measure 7: G(b1) D(b2) Em(b3) D(b4) — fast harmonic rhythm  -->
            <!-- Melody: B4(1) A4(1) G4(0.5)E4(0.5) F#4(1)                   -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m7s1n3" dur="8" oct="4" pname="g" />
                  <note xml:id="m7s1n4" dur="8" oct="4" pname="e" />
                  <note xml:id="m7s1n5" dur="4" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: G=D4-G4; D=F#4-A4; Em=E4-G4; D=F#4-A4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="d" oct="4" />
                    <note xml:id="m7s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m7s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="e" oct="4" />
                    <note xml:id="m7s2n6" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c4" dur="4">
                    <note xml:id="m7s2n7" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m7s2n8" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2-D3-G3; D D2-A2-D3-F#3; Em E2-B2-E3; D D2-A2-D3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="g" oct="2" />
                    <note xml:id="m7s3n2" pname="d" oct="3" />
                    <note xml:id="m7s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="d" oct="2" />
                    <note xml:id="m7s3n5" pname="a" oct="2" />
                    <note xml:id="m7s3n6" pname="d" oct="3" />
                    <note xml:id="m7s3n7" pname="f" oct="3" accid.ges="s" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="4">
                    <note xml:id="m7s3n8" pname="e" oct="2" />
                    <note xml:id="m7s3n9" pname="b" oct="2" />
                    <note xml:id="m7s3n10" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c4" dur="4">
                    <note xml:id="m7s3n11" pname="d" oct="2" />
                    <note xml:id="m7s3n12" pname="a" oct="2" />
                    <note xml:id="m7s3n13" pname="d" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 8: G whole [G2(2) rest(1) G4(1)]                    -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="2" oct="4" pname="g" />
                  <rest xml:id="m8s1r1" dur="4" />
                  <note xml:id="m8s1n2" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: G ascending D4-G4-B4-D5 quarters -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m8s2n1" dur="4" pname="d" oct="4" />
                  <note xml:id="m8s2n2" dur="4" pname="g" oct="4" />
                  <note xml:id="m8s2n3" dur="4" pname="b" oct="4" />
                  <note xml:id="m8s2n4" dur="4" pname="d" oct="5" />
                </layer>
              </staff>
              <!-- LH: G sustained G2-D3-G3-B3 whole -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="1">
                    <note xml:id="m8s3n1" pname="g" oct="2" />
                    <note xml:id="m8s3n2" pname="d" oct="3" />
                    <note xml:id="m8s3n3" pname="g" oct="3" />
                    <note xml:id="m8s3n4" pname="b" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 9-16): Second phrase, more motion              -->
            <!-- ============================================================ -->

            <!-- Measure 9: G(b1-2) C(b3-4)                                  -->
            <!-- Melody: A4(3/2) B4(1/2) C5(2) — dotted rhythms             -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m9s1n2" dur="8" oct="4" pname="b" />
