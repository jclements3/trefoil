            <!-- Measure 36: G(b1) F#°→D(b2) G(b3) D(b4)                    -->
            <!-- ABC: "G"B "F#°"A "G"G/2 E/2 "D"F → B4(1) A4(1) G4(0.5) E4(0.5) F#4(1) -->
            <!-- F#° = F#-A-C non-diatonic → substitute D                    -->
            <measure n="36" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m36s1n1" dur="4" oct="4" pname="b" />
                  <note xml:id="m36s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m36s1n3" dur="8" oct="4" pname="g" />
                  <note xml:id="m36s1n4" dur="8" oct="4" pname="e" />
                  <note xml:id="m36s1n5" dur="4" oct="4" pname="f" accid.ges="s" />
                </layer>
