                    <note xml:id="m36s2n6" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m36s2c4" dur="4">
                    <note xml:id="m36s2n7" pname="a" oct="4" />
                    <note xml:id="m36s2n8" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: G G2-D3-G3-B3; D D2-A2-D3-F#3; G G2-D3-G3; D D2-A2-F#3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m36s3c1" dur="4">
                    <note xml:id="m36s3n1" pname="g" oct="2" />
                    <note xml:id="m36s3n2" pname="d" oct="3" />
