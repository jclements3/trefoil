<?xml version="1.0" encoding="UTF-8"?>
<!-- 4154 Almighty God Your Word Is Cast — pedal harp, key C, 4/4 -->
<!-- Key C: no accidentals in key sig. Any sharps/flats are accidentals. -->
<!-- Scale: C(1) D(2) E(3) F(4) G(5) A(6) B(7) -->
<!-- Chords: I=C, ii=Dm, iii=Em, IV=F, V=G, vi=Am, vii=B° -->
<!-- ABC: G|E F_A C_G Am_c|Dm7_c G_B C_c G|Am_c Em_G Am_A D_#F|G3 B|
         C_c F_A Dm_d G_B|C_c F_A E_B C_G|Dm_A C_c Dm_d G_B|C3 -->
<!-- Pickup: G (one beat) -->
<!-- Non-diatonic: D major (^F = F#) in m.3 b.4 → sub G (V) or just use it as melody accidental, harp stays diatonic -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
