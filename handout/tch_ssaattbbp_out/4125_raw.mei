<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Isaiah, Mighty Seer, In Days of Old</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Eb major: 3 flats (Bb, Eb, Ab) -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="3f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="3f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- Eb major: I=Eb, ii=Fm, iii=Gm, IV=Ab, V=Bb, vi=Cm, vii°=D°  -->
            <!-- Key signature: Bb(accid.ges=f), Eb(accid.ges=f), Ab(ges=f)   -->
            <!-- Non-diatonic: C=III (use iii=Gm sub or V/vi), Gm=iii (diaton) -->
            <!-- G#°=vii° (Ab°=same as G#°), F=IIb (use IV=Ab sub), A°=vii°   -->
            <!-- Cm=vi, Bb=V, Fm=ii, Gm=iii, Eb=I                             -->
            <!-- L:1/4, M:4/4 => 4 quarter beats per bar                       -->
            <!-- ============================================================ -->

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-6): Opening — vi introduction, Eb modal      -->
            <!-- ============================================================ -->

            <!-- Measure 1: Eb Bb Eb — I V I
                 Melody: Bb4(half) Bb4(qtr) G4(qtr)  [ABC: B2 "^Bb"B "^Eb"G]
                 Note: B in Eb key = Bb (accid.ges="f")
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: I "33": G4 Bb4 (half); V "33": F4 Bb4 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="g" oct="4" />
                    <note xml:id="m1s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="2">
                    <note xml:id="m1s2n3" pname="f" oct="4" />
                    <note xml:id="m1s2n4" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m1s2n5" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "334": Eb3 G3 Bb3 Eb4 (half); V "333": Bb3 D4 F4 Ab4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m1s3n2" pname="g" oct="3" />
                    <note xml:id="m1s3n3" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m1s3n4" pname="e" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="2">
                    <note xml:id="m1s3n5" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m1s3n6" pname="d" oct="4" />
                    <note xml:id="m1s3n7" pname="f" oct="4" />
                    <note xml:id="m1s3n8" pname="a" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 2: Cm Eb Bb Eb — vi I V I
                 Melody: E4(qtr) G4(qtr) Bb4(qtr) Bb4(qtr)
                 E in Eb = Eb4 (accid.ges="f")
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="e" accid.ges="f" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: vi "33": Eb4 G4 (qtr); I "33": G4 Bb4 (qtr); V "33": F4 Bb4 (qtr); I "43": Bb4 Eb5 (qtr) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4">
                    <note xml:id="m2s2n1" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m2s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="4">
                    <note xml:id="m2s2n3" pname="g" oct="4" />
                    <note xml:id="m2s2n4" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="4">
                    <note xml:id="m2s2n5" pname="f" oct="4" />
                    <note xml:id="m2s2n6" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m2s2n7" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m2s2c4" dur="4">
                    <note xml:id="m2s2n8" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m2s2n9" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "333": C3 Eb3 G3 Bb3; I "333": Eb3 G3 Bb3 D4; V "334": Bb3 D4 F4; I "33": Eb3 G3 Bb3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4">
                    <note xml:id="m2s3n1" pname="c" oct="3" />
                    <note xml:id="m2s3n2" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n3" pname="g" oct="3" />
                    <note xml:id="m2s3n4" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="4">
                    <note xml:id="m2s3n5" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n6" pname="g" oct="3" />
                    <note xml:id="m2s3n7" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n8" pname="d" oct="4" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="4">
                    <note xml:id="m2s3n9" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n10" pname="d" oct="4" />
                    <note xml:id="m2s3n11" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m2s3c4" dur="4">
                    <note xml:id="m2s3n12" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m2s3n13" pname="g" oct="3" />
                    <note xml:id="m2s3n14" pname="b" oct="3" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 3: C Eb — III(→V sub) I
                 C is non-diatonic (V/vi secondary dom) → use V(Bb) diatonic
                 Melody: C5(half) C5(half—but note c c "^Eb"B2)
                 c=C5(qtr) c=C5(qtr) B=Bb4(half)
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n3" dur="2" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: V "333": F4 Bb4 D5 (half); I "33": G4 Bb4 Eb5 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="f" oct="4" />
                    <note xml:id="m3s2n2" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n3" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="2">
                    <note xml:id="m3s2n4" pname="g" oct="4" />
                    <note xml:id="m3s2n5" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n6" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V "333": Bb3 D4 F4 Ab4 (half); I "334": Eb3 G3 Bb3 Eb4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m3s3n2" pname="d" oct="4" />
                    <note xml:id="m3s3n3" pname="f" oct="4" />
                    <note xml:id="m3s3n4" pname="a" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="2">
                    <note xml:id="m3s3n5" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m3s3n6" pname="g" oct="3" />
                    <note xml:id="m3s3n7" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m3s3n8" pname="e" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 4: Gm Eb Fm — iii I ii
                 Melody: Bb4(half) Bb4(qtr) Ab4(qtr)  [B2 "^Eb"B "^Fm"A]
                 A in Eb = Ab (accid.ges="f")
            -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="2" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m4s1n3" dur="4" oct="4" pname="a" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: iii "33": Bb4 D5 (half); ii "43": Bb4 Eb5 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="2">
                    <note xml:id="m4s2n3" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m4s2n4" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: iii "333": G3 Bb3 D4 F4 (half); ii "333": F3 Ab3 C4 Eb4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="2">
                    <note xml:id="m4s3n1" pname="g" oct="3" />
                    <note xml:id="m4s3n2" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m4s3n3" pname="d" oct="4" />
                    <note xml:id="m4s3n4" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="2">
                    <note xml:id="m4s3n5" pname="f" oct="3" />
                    <note xml:id="m4s3n6" pname="a" oct="3" accid.ges="f" />
                    <note xml:id="m4s3n7" pname="c" oct="4" />
                    <note xml:id="m4s3n8" pname="e" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="3">②m</harm>
            </measure>

            <!-- Measure 5: Bb Cm G#°(vii°) Eb — V vi vii° I
                 Melody: Bb4(qtr) Eb4(qtr) Ab4(qtr) G4(qtr)
                 G#°=Ab° = vii° in Eb (D°: D F Ab — but Ab° = Ab C Eb is not quite right)
                 G#°/Ab° diatonic: in Eb, vii° = D° (D F Ab). Ab° is non-standard.
                 Substitute Ab° → ii(Fm) or IV(Ab major) — use IV(Ab) for smooth voice leading
            -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="e" accid.ges="f" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="a" accid.ges="f" />
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: V "33": F4 Bb4 (qtr); vi "33": Eb4 G4 (qtr); IV "33": Ab4 C5 (qtr); I "33": G4 Bb4 (qtr) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4">
                    <note xml:id="m5s2n1" pname="f" oct="4" />
                    <note xml:id="m5s2n2" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4">
                    <note xml:id="m5s2n3" pname="e" oct="4" accid.ges="f" />
                    <note xml:id="m5s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c3" dur="4">
                    <note xml:id="m5s2n5" pname="a" oct="4" accid.ges="f" />
                    <note xml:id="m5s2n6" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c4" dur="4">
                    <note xml:id="m5s2n7" pname="g" oct="4" />
                    <note xml:id="m5s2n8" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: V "333": Bb3 D4 F4 (qtr); vi "333": C3 Eb3 G3 Bb3 (qtr); IV "333": Ab3 C4 Eb4 (qtr); I "334": Eb3 G3 Bb3 Eb4 (qtr) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4">
                    <note xml:id="m5s3n1" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m5s3n2" pname="d" oct="4" />
                    <note xml:id="m5s3n3" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4">
                    <note xml:id="m5s3n4" pname="c" oct="3" />
                    <note xml:id="m5s3n5" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m5s3n6" pname="g" oct="3" />
                    <note xml:id="m5s3n7" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n8" pname="a" oct="3" accid.ges="f" />
                    <note xml:id="m5s3n9" pname="c" oct="4" />
                    <note xml:id="m5s3n10" pname="e" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m5s3c4" dur="4">
                    <note xml:id="m5s3n11" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m5s3n12" pname="g" oct="3" />
                    <note xml:id="m5s3n13" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m5s3n14" pname="e" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
              <harm staff="1" tstamp="2">⑥m</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 6: Cm7 Bb Eb — vi7 V I (cadential)
                 Melody: F4(qtr) F4(qtr) Eb4(half) [ABC: "^Cm7"F "^Bb"F "^Eb"E2]
                 F in Eb = natural F4, E = Eb4 (ges=f)
            -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="f" />
                  <note xml:id="m6s1n3" dur="2" oct="4" pname="e" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: vi7 "233" 1st inv: Bb4 C5 Eb5 (qtr); V "333": F4 Bb4 D5 (qtr); I "334": G4 Bb4 Eb5 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m6s2n2" pname="c" oct="5" />
                    <note xml:id="m6s2n3" pname="e" oct="5" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n4" pname="f" oct="4" />
                    <note xml:id="m6s2n5" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m6s2n6" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="2">
                    <note xml:id="m6s2n7" pname="g" oct="4" />
                    <note xml:id="m6s2n8" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m6s2n9" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi7 "333": C3 Eb3 G3 Bb3 (qtr); V "333": Bb3 D4 F4 Ab4 (qtr); I "333": Eb3 G3 Bb3 D4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="c" oct="3" />
                    <note xml:id="m6s3n2" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m6s3n3" pname="g" oct="3" />
                    <note xml:id="m6s3n4" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n5" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m6s3n6" pname="d" oct="4" />
                    <note xml:id="m6s3n7" pname="f" oct="4" />
                    <note xml:id="m6s3n8" pname="a" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="2">
                    <note xml:id="m6s3n9" pname="e" oct="3" accid.ges="f" />
                    <note xml:id="m6s3n10" pname="g" oct="3" />
                    <note xml:id="m6s3n11" pname="b" oct="3" accid.ges="f" />
                    <note xml:id="m6s3n12" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7¹</harm>
              <harm staff="1" tstamp="2">⑤7</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 7-12): Development — higher register, climax   -->
            <!-- ============================================================ -->

            <!-- Measure 7: iii V — Gm Bb
                 Melody: Bb4(half) Bb4(qtr) Bb4(qtr) [B2 "^Gm"B "^Bb"B]
            -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="2" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="b" accid.ges="f" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: iii "33": Bb4 D5 (half); V "44" quartal: Bb4 Eb5 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m7s2n2" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="2">
                    <note xml:id="m7s2n3" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m7s2n4" pname="e" oct="5" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: iii "333": G3 Bb3 D4 F4 (half); V "334": Bb3 D4 F4 Bb4 (half) -->
