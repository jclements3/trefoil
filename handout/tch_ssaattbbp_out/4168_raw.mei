                  <!-- ⑤7 D7: F#4 A4 C5 -->
                  <chord dur="4" stem.dir="up">
                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
