                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="c" oct="1" dur="2" stem.dir="down"/>
                  <note pname="d" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- M6: Am A2 C E2 → ② ④ -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note pname="a" oct="4" dur="2"/>
                  <note pname="e" oct="4" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
