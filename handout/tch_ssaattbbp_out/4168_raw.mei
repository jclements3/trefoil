<?xml version="1.0" encoding="UTF-8"?>
<!-- 4168: Jesus, King of Glory — Key: G major, 4/4 -->
<!-- G major: 1 sharp (F#). accid.ges="s" on all F notes. -->
<!-- Long hymn, 24 measures with 3-stanza repeat structure. -->
<!-- Chord progression (simplified, beats 1-4 per measure):
  M1: G D7 G | M2: G G D  | M3: D Am7 D D | M4: D
  M5: C D7 G | M6: Am C   | M7: G Em Am D7 | M8: G
  M9: G Am G#°7(→⑦°) | M10: G#°7(→⑦°) G | M11: Am C Am Am | M12: G [F→diatonic=⑤]
  M13: Am Am7 D D7 | M14: G B | M15: Am D F F | M16: G
  M17-24: repeat of stanza 1 (M1-8) with varied voicings
-->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Jesus, King of Glory</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- M1: G B B D7 A A → ① ⑤7 ① -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note pname="b" oct="4" dur="4"/>
                  <note pname="b" oct="4" dur="4"/>
                  <note pname="a" oct="4" dur="4"/>
                  <note pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note pname="b" oct="4"/>
                    <note pname="d" oct="5"/>
                  </chord>
                  <!-- ⑤7 D7: A4 C5 F#5 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                    <note pname="f" oct="5" accid.ges="s"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="4" dur="1" stem.dir="down"/>
                </layer>
              </staff>
              <staff n="3">
