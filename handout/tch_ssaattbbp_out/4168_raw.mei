              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- M7: G G Em G Am A D7 A → ① ⑥ ② ⑤7 -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note pname="g" oct="4" dur="4"/>
                  <note pname="g" oct="4" dur="4"/>
                  <note pname="a" oct="4" dur="4"/>
                  <note pname="a" oct="4" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
