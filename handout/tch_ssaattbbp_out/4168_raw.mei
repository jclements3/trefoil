                  <chord dur="2" stem.dir="up">
                    <note pname="d" oct="5"/>
                    <note pname="b" oct="4"/>
                  </chord>
                  <!-- ⑥ Em: E4 G4 B4 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
