              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- M12: G G2 F2(→⑤) → ① ⑤ -->
            <measure n="12">
              <staff n="1">
                <layer n="1">
                  <note pname="g" oct="4" dur="2"/>
                  <note pname="f" oct="4" accid.ges="s" dur="2"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
