                    <note pname="f" oct="4" accid.ges="s"/>
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <!-- ② Am: A4 C5 E5 -->
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="4"/>
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" visible="false"/>
