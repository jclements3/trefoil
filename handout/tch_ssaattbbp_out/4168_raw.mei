                    <note pname="c" oct="3"/>
                    <note pname="a" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="e" oct="2"/>
                    <note pname="b" oct="2"/>
                    <note pname="g" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="f" oct="1" accid.ges="s" dur="2" stem.dir="down"/>
                  <note pname="e" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°</harm>
              <harm staff="1" tstamp="3">⑥</harm>
            </measure>

            <!-- M11: Am c c C e e → ② ④ -->
            <measure n="11">
              <staff n="1">
                <layer n="1">
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="c" oct="5" dur="4"/>
                  <note pname="e" oct="5" dur="4"/>
                  <note pname="e" oct="5" dur="4"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
