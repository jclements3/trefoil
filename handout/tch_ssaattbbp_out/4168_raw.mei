            <!-- M9: G#°7(→⑦°) d d Am c c → ⑦° ② -->
            <!-- G#°7 is not diatonic in G major — use ⑦° (F#°) as substitute -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note pname="d" oct="5" dur="4"/>
                  <note pname="d" oct="5" dur="4"/>
