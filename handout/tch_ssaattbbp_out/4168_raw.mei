            <!-- M4: D A4 → ⑤ full hold -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note pname="a" oct="4" dur="1"/>
                </layer>
              </staff>
              <staff n="2">
                <layer n="1">
