                    <note pname="f" oct="2" accid.ges="s"/>
                    <note pname="c" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="a" oct="2"/>
                    <note pname="e" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="f" oct="1" accid.ges="s" dur="2" stem.dir="down"/>
                  <note pname="a" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦°</harm>
              <harm staff="1" tstamp="3">②</harm>
            </measure>

            <!-- M10: G#°7(→⑦°) B2 E2 → ⑦° ⑥ -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note pname="b" oct="4" dur="2"/>
                  <note pname="e" oct="4" dur="2"/>
                </layer>
