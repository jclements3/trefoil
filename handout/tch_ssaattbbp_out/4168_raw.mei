                  <!-- ⑥ Em: G4 B4 E5 -->
                  <chord dur="4" stem.dir="up">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4"/>
                    <note pname="e" oct="5"/>
                  </chord>
                  <!-- ② Am: A4 C5 -->
