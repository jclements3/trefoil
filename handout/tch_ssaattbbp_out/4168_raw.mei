                    <note pname="d" oct="3"/>
                    <note pname="g" oct="3"/>
                    <note pname="b" oct="3"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note pname="d" oct="3"/>
                    <note pname="a" oct="3"/>
                    <note pname="f" oct="3" accid.ges="s"/>
                    <note pname="c" oct="4"/>
                  </chord>
                </layer>
                <layer n="2">
                  <note pname="g" oct="1" dur="2" stem.dir="down"/>
                  <note pname="d" oct="1" dur="2" stem.dir="down"/>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤7</harm>
            </measure>

            <!-- M2: G G2 D2 → ① ⑤ -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note pname="g" oct="4" dur="2"/>
                  <note pname="d" oct="4" dur="2"/>
