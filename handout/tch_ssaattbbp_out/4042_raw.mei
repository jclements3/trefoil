<?xml version="1.0" encoding="UTF-8"?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>O Lord, How Shall I Meet Thee</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB+P</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12"/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Eb major: 3 flats (Bb, Eb, Ab). 4/4 time. Pickup of 2 beats. -->
          <!-- accid.ges="f" on all B, E, A notes (key signature). -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="3f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="3f"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="3f"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="3f"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ================================================================ -->
            <!-- Pickup: Eb E2 = 2 beats (half note in 4/4)                      -->
            <!-- ABC: "^Eb"E2 — Eb4 quarter×2                                    -->
            <!-- ================================================================ -->
            <measure n="0" type="pickup">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m0s1n1" pname="e" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m0s1n2" pname="e" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Eb G4 — pickup, single note -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m0r1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m0r2" pname="b" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <!-- LH: Eb Eb2 Bb2 Eb3 — sparse pickup chord -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m0l1" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Opening period — Eb, C, Bb, Eb               -->
            <!-- ================================================================ -->

            <!-- Measure 1: G C A, Bb B, Eb B — Eb(G), C(A), Bb(B), Eb(B) -->
            <!-- ABC: G "^C"A "^Bb"B "^Eb"B -->
            <measure n="1">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m1s1n2" pname="a" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m1s1n3" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m1s1n4" pname="b" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Eb Bb4 Eb5; C G4 C5; Bb F4 Bb4; Eb Bb4 Eb5 (return) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1r1" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <!-- C major (III in Eb — natural major): G4 C5 -->
                  <chord xml:id="m1r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <!-- Bb: F4 Bb4 -->
                  <chord xml:id="m1r3" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <!-- Eb: Bb4 Eb5 -->
                  <chord xml:id="m1r4" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Eb Eb2 Bb2 Eb3 G3; C C2 G2 C3 E3 (nat); Bb Bb2 F3 Bb3 D4; Eb Eb2 Bb2 Eb3 G3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1l1" dur="4">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <!-- C: C2 G2 C3 E3 nat -->
                  <chord xml:id="m1l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- Bb: Bb2 F3 Bb3 D4 -->
                  <chord xml:id="m1l3" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <!-- Eb: Eb2 Bb2 Eb3 G3 -->
                  <chord xml:id="m1l4" dur="4">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">③</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 2: Fm A2 Cm G, C A — Fm(A2=Ab half), Cm(G), C(A) -->
            <!-- ABC: "^Fm"A2 "^Cm"G "^C"A -->
            <measure n="2">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" pname="a" oct="4" dur="2" accid.ges="f"/>
                  <note xml:id="m2s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m2s1n3" pname="a" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Fm C5 Eb5; Cm Eb4 G4; C E4 G4 (nat E) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2r1" dur="2">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2r2" dur="4">
                    <note pname="e" oct="4" accid.ges="f"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <chord xml:id="m2r3" dur="4">
                    <note pname="e" oct="4"/>
                    <note pname="g" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Fm F2 C3 F3 Ab3; Cm C2 G2 C3 Eb3; C C2 G2 C3 E3 nat -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m2l3" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">③</harm>
            </measure>

            <!-- Measure 3: Eb G E, Fm F, Bb F — Eb(G E), Fm(F), Bb(F) -->
            <!-- ABC: "^Eb"G E "^Fm"F "^Bb"F -->
            <measure n="3">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m3s1n2" pname="e" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m3s1n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m3s1n4" pname="f" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: Eb Bb4 Eb5; Fm Ab4 C5; Bb F4 Bb4 -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3r1" dur="2">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m3r2" dur="4">
                    <note pname="a" oct="4" accid.ges="f"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <chord xml:id="m3r3" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Eb Eb2 Bb2 Eb3 G3; Fm F2 C3 F3 Ab3; Bb Bb2 F3 Bb3 D4 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3l1" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m3l2" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m3l3" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">⑤</harm>
            </measure>

            <!-- Measure 4: Eb E2 E2 — Eb(E4 whole bar) -->
            <!-- ABC: "^Eb"E2 E2 -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" pname="e" oct="4" dur="1" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Eb "43" 1st inv G4 Bb4 — relaxed, let LH carry harmony -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4r1" dur="1">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Eb "334" Eb2 Bb2 Eb3 G3 — full whole note anchor -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4l1" dur="1">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Repeat of opening period                    -->
            <!-- ================================================================ -->

            <!-- Measure 5: same as m.1 (G C A Bb B Eb B) -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m5s1n2" pname="a" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m5s1n3" pname="b" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m5s1n4" pname="b" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: varied — Eb Eb5 G5; C G4 Eb5; Bb D5 F5; Eb Bb4 Eb5 — higher register -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5r1" dur="4">
                    <note pname="e" oct="5" accid.ges="f"/>
                    <note pname="g" oct="5"/>
                  </chord>
                  <chord xml:id="m5r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m5r3" dur="4">
                    <note pname="d" oct="5"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <chord xml:id="m5r4" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: same as m.1 but Eb uses "333" Δ for variety -->
              <staff n="3">
                <layer n="1">
                  <!-- Eb "333" Δ: Eb2 G2 Bb2 D4 — include maj7 -->
                  <chord xml:id="m5l1" dur="4">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="g" oct="2"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="d" oct="3"/>
                  </chord>
                  <!-- C: C2 G2 C3 E3 nat -->
                  <chord xml:id="m5l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                  <!-- Bb: Bb2 F3 Bb3 D4 -->
                  <chord xml:id="m5l3" dur="4">
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                  <!-- Eb: Eb2 Bb2 Eb3 G3 -->
                  <chord xml:id="m5l4" dur="4">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①Δ</harm>
              <harm staff="1" tstamp="2">③</harm>
              <harm staff="1" tstamp="3">⑤</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 6: same as m.2 (Fm A2 Cm G C A) -->
            <measure n="6">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" pname="a" oct="4" dur="2" accid.ges="f"/>
                  <note xml:id="m6s1n2" pname="g" oct="4" dur="4"/>
                  <note xml:id="m6s1n3" pname="a" oct="4" dur="4" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: different — Fm Eb5 F5; Cm G4 Eb5; C C5 E5 nat -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6r1" dur="2">
                    <note pname="e" oct="5" accid.ges="f"/>
                    <note pname="f" oct="5"/>
                  </chord>
                  <chord xml:id="m6r2" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m6r3" dur="4">
                    <note pname="c" oct="5"/>
                    <note pname="e" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: same as m.2 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6l1" dur="2">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m6l2" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m6l3" dur="4">
                    <note pname="c" oct="2"/>
                    <note pname="g" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="e" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
              <harm staff="1" tstamp="4">③</harm>
            </measure>

            <!-- Measure 7: same as m.3 (Eb G E, Fm F, Bb F) -->
            <measure n="7">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" pname="g" oct="4" dur="4"/>
                  <note xml:id="m7s1n2" pname="e" oct="4" dur="4" accid.ges="f"/>
                  <note xml:id="m7s1n3" pname="f" oct="4" dur="4"/>
                  <note xml:id="m7s1n4" pname="f" oct="4" dur="4"/>
                </layer>
              </staff>
              <!-- RH: varied — Eb G4 Bb4; Fm F4 Ab4; Bb "44" Bb4 Eb5 F5 quartal -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m7r2" dur="4">
                    <note pname="f" oct="4"/>
                    <note pname="a" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m7r3" dur="4">
                    <note pname="b" oct="4" accid.ges="f"/>
                    <note pname="e" oct="5" accid.ges="f"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: same as m.3 but Bb uses "43" 1st inv: D3 F3 Bb3 -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7l1" dur="2">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                  <chord xml:id="m7l2" dur="4">
                    <note pname="f" oct="2"/>
                    <note pname="c" oct="3"/>
                    <note pname="f" oct="3"/>
                    <note pname="a" oct="3" accid.ges="f"/>
                  </chord>
                  <!-- Bb "43" 1st inv: D2 F3 Bb3 -->
                  <chord xml:id="m7l3" dur="4">
                    <note pname="d" oct="2"/>
                    <note pname="f" oct="3"/>
                    <note pname="b" oct="3" accid.ges="f"/>
                    <note pname="d" oct="4"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">⑤¹</harm>
            </measure>

            <!-- Measure 8: Eb E2 B2 — Eb(E4 half), Eb(B=Bb4 half) -->
            <!-- ABC: "^Eb"E2 B2 — Eb: first half, then Bb in melody -->
            <measure n="8">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" pname="e" oct="4" dur="2" accid.ges="f"/>
                  <note xml:id="m8s1n2" pname="b" oct="4" dur="2" accid.ges="f"/>
                </layer>
              </staff>
              <!-- RH: Eb G4 Bb4; then Eb5 G5 — voice rises -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8r1" dur="2">
                    <note pname="g" oct="4"/>
                    <note pname="b" oct="4" accid.ges="f"/>
                  </chord>
                  <chord xml:id="m8r2" dur="2">
                    <note pname="e" oct="5" accid.ges="f"/>
                    <note pname="g" oct="5"/>
                  </chord>
                </layer>
              </staff>
              <!-- LH: Eb "334" Eb2 Bb2 Eb3 G3 — steady tonic pedal -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8l1" dur="1">
                    <note pname="e" oct="2" accid.ges="f"/>
                    <note pname="b" oct="2" accid.ges="f"/>
                    <note pname="e" oct="3" accid.ges="f"/>
                    <note pname="g" oct="3"/>
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- ================================================================ -->
            <!-- PHRASE 3 (mm. 9-12): Middle section — C, G#°, Eb, Bb, C, Bb    -->
            <!-- Chromatic chords: G#° (= G#dim = vii°/v, non-diatonic). Sub: Eb -->
            <!-- ================================================================ -->

            <!-- Measure 9: C c, G#° d, Eb e, Bb d -->
            <!-- ABC: "^C"c "^G#°"d "^Eb"e "^Bb"d -->
            <!-- G#° is non-diatonic (viio of iv). Diatonic sub: use Cm (vi°=dim sub) or Eb. -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" pname="c" oct="5" dur="4"/>
                  <!-- d = Eb4 in ABC octave with ˅ (no: d is D5) -->
                  <!-- d = D5 in ABC -->
                  <note xml:id="m9s1n2" pname="d" oct="5" dur="4"/>
                  <!-- e = Eb5 (key signature) -->
                  <note xml:id="m9s1n3" pname="e" oct="5" dur="4" accid.ges="f"/>
                  <!-- d = D5 -->
                  <note xml:id="m9s1n4" pname="d" oct="5" dur="4"/>
                </layer>
              </staff>
              <!-- RH: C G4 C5; G#°→Eb Bb4 Eb5; Eb G5 Bb5 — climax approach! -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9r1" dur="4">
                    <note pname="g" oct="4"/>
                    <note pname="c" oct="5"/>
                  </chord>
                  <!-- G#° sub with Cm chord tones (C Eb G) : Eb4 G4 -->
                  <chord xml:id="m9r2" dur="4">
                    <note pname="e" oct="4" accid.ges="f"/>
                    <note pname="g" oct="4"/>
                  </chord>
                  <!-- Eb: G5 Bb5 — high register, climax! -->
                  <chord xml:id="m9r3" dur="4">
