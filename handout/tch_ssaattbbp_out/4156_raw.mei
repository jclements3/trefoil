<?xml version="1.0" encoding="UTF-8"?>
<!-- 4156 Lamp of Our Feet — pedal harp, key G, 3/4 -->
<!-- Key G: 1 sharp — F#. accid.ges="s" on all F notes -->
<!-- Scale: G(1) A(2) B(3) C(4) D(5) E(6) F#(7) -->
<!-- Chords: I=G, ii=Am, iii=Bm, IV=C, V=D, vi=Em, vii=F#° -->
<!-- ABC (3/4, L=1/4, 14 bars):
  m1: G_B B B
  m2: Am_A2 G_B
  m3: Am_c2 D_F
  m4: G_G3
  m5: D_D D_D D_D
  m6: G_B2 A7_A
  m7: D_A3
  m8: Am_c F#ø7_c G#_B (G#=Ab enharmonic → IV sub or iii? In G key: G# is non-diatonic; use C/IV)
  m9: Am_A2 A_G
  m10: D_F2 C#_E (C# non-diatonic → D/V sub)
  m11: D_D3
  m12: G_D C_E G_G
  m13: G_B2 D7_A
  m14: G_G3
-->
<!-- F#ø7 = F# half-dim: F# A C E — use vi=Em sub or V=D -->
<!-- G# = Ab enharmonic in G key = non-diatonic → use IV=C -->
<!-- C# non-diatonic → sub D (V) -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Lamp of Our Feet</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <scoreDef meter.count="3" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" key.sig="1s">
                <keySig sig="1s"/>
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" key.sig="1s">
                  <keySig sig="1s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="1s">
                  <keySig sig="1s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- Measure 1: G — melody B B B -->
