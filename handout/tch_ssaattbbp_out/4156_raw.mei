            <!-- Measure 13: G, D7 — melody B2 A -->
            <measure n="13">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m13n1" dur="2" oct="4" pname="b"/>
                  <note xml:id="m13n2" dur="4" oct="4" pname="a"/>
