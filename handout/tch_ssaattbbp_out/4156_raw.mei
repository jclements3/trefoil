                  <note xml:id="m1rh3" dur="4" oct="4" pname="g" stem.dir="up"/>
                </layer>
                <layer n="2">
                  <rest dur="2" visible="false"/>
                  <rest dur="4" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
