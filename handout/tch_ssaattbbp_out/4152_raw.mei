            <!-- Measure 4: A7, D, Em, Em7 — melody E F G3/2 G/2 -->
            <measure n="4">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4n1" dur="4" oct="4" pname="e"/>
                  <note xml:id="m4n2" dur="4" oct="4" pname="f" accid.ges="s"/>
