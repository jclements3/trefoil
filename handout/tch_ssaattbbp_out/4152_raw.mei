<?xml version="1.0" encoding="UTF-8"?>
<!-- 4152 Thou, Who at Thy First Eucharist — pedal harp, key D, 4/4 -->
<!-- Key D: 2 sharps — F# and C#. accid.ges="s" on all F and C notes -->
<!-- Scale: D(1) E(2) F#(3) G(4) A(5) B(6) C#(7) -->
<!-- Chords: I=D, ii=Em, iii=F#m, IV=G, V=A, vi=Bm, vii=C#° -->
<!-- ABC: F|F3/2 D/2 D Em_E|F3/2 F/2 F A7_G|A3 F|A7_E D_F Em_G3/2 Em7_G/2|
         A7_G D_F A F|A3 D_F|F3/2 D/2 D Em_E|F3/2 Bm_F/2 F Em7_G|A3 F|
         G B D_A E7_#G3/2_#G/2|F#m_A Bm7_B A_c E7_B|A3 A|
         D_d A7_G D_F|G_B B d B|A3 A|A7_G D_F A7_E Bm_D|
         G3/2 Em_G/2 D_F A7_E|D3 -->
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="4.0.1">
  <meiHead>
    <fileDesc>
      <titleStmt><title>Thou, Who at Thy First Eucharist</title></titleStmt>
      <pubStmt><unpub/></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
