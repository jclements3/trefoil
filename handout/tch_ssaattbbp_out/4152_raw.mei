            <!-- Measure 10: G, E7(→Em) — melody B A G#3/2 G#/2 -->
            <!-- E7 is non-diatonic: use Em (ii) as substitute -->
            <measure n="10">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10n1" dur="4" oct="4" pname="b"/>
                  <note xml:id="m10n2" dur="4" oct="4" pname="a"/>
                  <note xml:id="m10n3" dur="4d" oct="4" pname="g" accid="s"/>
