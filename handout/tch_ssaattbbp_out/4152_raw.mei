            <!-- Measure 9: D — melody A3 F# -->
            <measure n="9">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9n1" dur="2" oct="4" pname="a"/>
                  <note xml:id="m9n2" dur="4" oct="4" pname="a"/>
