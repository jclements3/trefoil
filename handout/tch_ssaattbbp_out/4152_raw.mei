                <layer n="2">
                  <rest dur="1" visible="false"/>
                </layer>
              </staff>
              <staff n="3">
                <!-- LH: G2 D3 G3 B3 → E2 B2 E3 G3 -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m10lh1" oct="2" pname="g"/>
