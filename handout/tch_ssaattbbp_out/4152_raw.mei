                </layer>
              </staff>
              <staff n="2">
                <!-- RH: D4 G4 → E4 G#4 (chromatic passing — melody only) -->
                <!-- Harp stays diatonic: stay on G4 B4 for Em -->
                <layer n="1">
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m10rh1" oct="4" pname="d"/>
                    <note xml:id="m10rh2" oct="4" pname="g"/>
                  </chord>
                  <chord dur="2" stem.dir="up">
                    <note xml:id="m10rh3" oct="4" pname="e"/>
                    <note xml:id="m10rh4" oct="4" pname="b"/>
