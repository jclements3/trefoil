                  <note xml:id="m3lh2" dur="4" oct="2" pname="a" stem.dir="up"/>
                  <note xml:id="m3lh3" dur="4" oct="3" pname="d" stem.dir="up"/>
                  <note xml:id="m3lh4" dur="4" oct="3" pname="a" stem.dir="up"/>
