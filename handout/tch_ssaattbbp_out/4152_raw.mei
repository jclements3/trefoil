            <!-- Measure 5: A7, D, A — melody G F A F -->
            <measure n="5">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5n1" dur="4" oct="4" pname="g"/>
                  <note xml:id="m5n2" dur="4" oct="4" pname="f" accid.ges="s"/>
                  <note xml:id="m5n3" dur="4" oct="4" pname="a"/>
                  <note xml:id="m5n4" dur="4" oct="4" pname="f" accid.ges="s"/>
