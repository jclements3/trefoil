                    <note xml:id="m4lh5" oct="2" pname="e"/>
                    <note xml:id="m4lh6" oct="2" pname="b"/>
                    <note xml:id="m4lh7" oct="3" pname="d"/>
                    <note xml:id="m4lh8" oct="3" pname="g"/>
