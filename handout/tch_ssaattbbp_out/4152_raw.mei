                  <keySig sig="2s"/>
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" key.sig="2s">
                  <keySig sig="2s"/>
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

