                  <note xml:id="m7n2" dur="8" oct="4" pname="d"/>
                  <note xml:id="m7n3" dur="4" oct="4" pname="d"/>
                  <note xml:id="m7n4" dur="4" oct="4" pname="e"/>
                </layer>
              </staff>
              <staff n="2">
