<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Holy Spirit, Ever Dwelling</title>
        <title type="subtitle">Harp Arrangement -- SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- G major: 1 sharp (F#) -->
          <!-- Source M:8/4 split into 4/4 pairs for readability -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- G major: I=G, ii=Am, iii=Bm, IV=C, V=D, vi=Em, vii°=F#°     -->
            <!-- Non-diatonic chords in ABC: Eb→vi(Em), F#ø7=vii°7(diatonic)  -->
            <!-- F#7=secondary dominant → substitute V(D) diatonic             -->
            <!-- Each source 8/4 bar → 2 MEI measures of 4/4                  -->
            <!-- ============================================================ -->

            <!-- ============================================================ -->
            <!-- SOURCE BAR 1 (mm. 1-2): vi vi→I vi
                 ABC: "^Em"E2 E2/3 F2/3 G2/3 "^Eb"F2 "^C"E2
                 = Em(2 beats) passing(1 beat) vi(2 beats) C(2 beats) E4(1 beat)
                 Beat 1-2: vi, beats 3: chromatic pass, beats 4-5: vi (Eb→Em),
                 beats 6-7: IV, beat 8: Em
                 Simplified pairs: m1: vi→IV (4 beats each), m2: vi→IV (4 beats)
            -->

            <!-- Measure 1: vi(2) pass(1) Eb→vi(2) IV(2) — split across 4 beats:
                 beats 1-2: Em (vi), beats 3-4: Em (vi, treat Eb as vi)
                 Melody: E4(half) triplet-passing E4 F4 G4 (1 beat total)
                 Let's simplify melody: E4(half) E4(qtr-triplet)→F4→G4(qtr) for 4 beats approx
                 For MEI clarity: E4(2) + 1beat + 1beat = hard due to triplets
                 Use: E4(half) E4(qtr) F4(qtr) for 4 beats (drop triplet notation)
            -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="2" oct="4" pname="e" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: vi "33": B4 D5 (whole) — held across passing notes -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="1">
                    <note xml:id="m1s2n1" pname="b" oct="4" />
                    <note xml:id="m1s2n2" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "334": E3 G3 B3 E4 — open root position -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="1">
                    <note xml:id="m1s3n1" pname="e" oct="3" />
                    <note xml:id="m1s3n2" pname="g" oct="3" />
                    <note xml:id="m1s3n3" pname="b" oct="3" />
                    <note xml:id="m1s3n4" pname="e" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- Measure 2: beats 5-8 of source bar 1: Eb(→vi) F(→IV) C(IV) E4
                 Melody: G4(qtr) F4(half) E4(qtr) [approx beats 3-8]
                 Chords: vi (beat 5, Eb=vi substitution), IV (beat 6-7: C), vi (beat 8: Em)
                 Use: beats 1-2: vi, beats 3-4: IV
            -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m2s1n2" dur="2" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: vi "43": G4 B4 (half); IV "33": G4 B4 (common tone!); C4 → IV: F4 A4 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n1" pname="g" oct="4" />
                    <note xml:id="m2s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="2">
                    <note xml:id="m2s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m2s2n4" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "333": E3 G3 B3 D4 (half); IV "334": C3 E3 G3 C4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n1" pname="e" oct="3" />
                    <note xml:id="m2s3n2" pname="g" oct="3" />
                    <note xml:id="m2s3n3" pname="b" oct="3" />
                    <note xml:id="m2s3n4" pname="d" oct="4" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="2">
                    <note xml:id="m2s3n5" pname="c" oct="3" />
                    <note xml:id="m2s3n6" pname="e" oct="3" />
                    <note xml:id="m2s3n7" pname="g" oct="3" />
                    <note xml:id="m2s3n8" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- SOURCE BAR 2 (mm. 3-4): F#ø7→vi→Am
                 ABC: "^F#ø7"F2 "^Eb"F2/3 G2/3 A2/3 "^Em"G3/2 F/2 E2
                 F#ø7=vii°7, Eb→vi, Em=vi
            -->

            <!-- Measure 3: F#ø7 (vii°7) → vi
                 Melody: F#4(half) passing(1 beat) G4(qtr) A4(qtr)
            -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="2" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n3" dur="4" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: vii°7 "333": F#4 A4 C5; vi "33": B4 D5 (half each) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="2">
                    <note xml:id="m3s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m3s2n2" pname="a" oct="4" />
                    <note xml:id="m3s2n3" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="2">
                    <note xml:id="m3s2n4" pname="b" oct="4" />
                    <note xml:id="m3s2n5" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vii°7 "333": F#3 A3 C4 E4 (half); vi "333": E3 G3 B3 D4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="2">
                    <note xml:id="m3s3n1" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m3s3n2" pname="a" oct="3" />
                    <note xml:id="m3s3n3" pname="c" oct="4" />
                    <note xml:id="m3s3n4" pname="e" oct="4" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="2">
                    <note xml:id="m3s3n5" pname="e" oct="3" />
                    <note xml:id="m3s3n6" pname="g" oct="3" />
                    <note xml:id="m3s3n7" pname="b" oct="3" />
                    <note xml:id="m3s3n8" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑦ø7</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- Measure 4: vi → IV (continued from bar 2)
                 Melody: G4 dotted-half F4(qtr) E4(half) — approx
                 Use: G3/2 F/2 E2 = G4(1.5) F4(0.5) E4(2) = 4 beats
            -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m4s1n2" dur="8" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m4s1n3" dur="2" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: vi "43": G4 B4 (half); vi "33": B4 D5 (half) — sustained inner line -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="2">
                    <note xml:id="m4s2n1" pname="g" oct="4" />
                    <note xml:id="m4s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="2">
                    <note xml:id="m4s2n3" pname="b" oct="4" />
                    <note xml:id="m4s2n4" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "334": E3 G3 B3 E4 (whole) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="1">
                    <note xml:id="m4s3n1" pname="e" oct="3" />
                    <note xml:id="m4s3n2" pname="g" oct="3" />
                    <note xml:id="m4s3n3" pname="b" oct="3" />
                    <note xml:id="m4s3n4" pname="e" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- SOURCE BAR 3 (mm. 5-6): G D C vi
                 ABC: "^G"B2 "^D"A2/3 B2/3 "^C"c2/3 "^Eb"B3/2 A/2 "^Em"G2
                 = I(2 beats) V(1 beat) IV(1 beat) vi(3 beats) vi(2 beats)
            -->

            <!-- Measure 5: I → V (beats 1-4 of source bar 3)
                 Melody: B4(half) A4 B4 passing C5 (1 beat total) = B4(2) + passing (2)
            -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="2" oct="4" pname="b" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: I "33": D5 G5 (half); V "33": D5 F#5 (half) — stepwise motion -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="d" oct="5" />
                    <note xml:id="m5s2n2" pname="g" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="2">
                    <note xml:id="m5s2n3" pname="d" oct="5" />
                    <note xml:id="m5s2n4" pname="f" oct="5" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I "334": G3 B3 D4 G4 (half); V "333": D3 F#3 A3 C4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="g" oct="3" />
                    <note xml:id="m5s3n2" pname="b" oct="3" />
                    <note xml:id="m5s3n3" pname="d" oct="4" />
                    <note xml:id="m5s3n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="2">
                    <note xml:id="m5s3n5" pname="d" oct="3" />
                    <note xml:id="m5s3n6" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m5s3n7" pname="a" oct="3" />
                    <note xml:id="m5s3n8" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 6: IV → vi (beats 5-8 of source bar 3)
                 Melody: C5(qtr) B4(dotted-half) A4(qtr) G4(half)
                 c2/3 B3/2 A/2 G2 — approx 4 beats
            -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m6s1n2" dur="4" dots="1" oct="4" pname="b" />
                  <note xml:id="m6s1n3" dur="8" oct="4" pname="a" />
                  <note xml:id="m6s1n4" dur="2" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: IV "33": C5 E5 (half); vi "43": G4 B4 D5 (half) — descent -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="2">
                    <note xml:id="m6s2n1" pname="c" oct="5" />
                    <note xml:id="m6s2n2" pname="e" oct="5" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="2">
                    <note xml:id="m6s2n3" pname="g" oct="4" />
                    <note xml:id="m6s2n4" pname="b" oct="4" />
                    <note xml:id="m6s2n5" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: IV "334": C3 E3 G3 C4 (half); vi "334": E3 G3 B3 E4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="2">
                    <note xml:id="m6s3n1" pname="c" oct="3" />
                    <note xml:id="m6s3n2" pname="e" oct="3" />
                    <note xml:id="m6s3n3" pname="g" oct="3" />
                    <note xml:id="m6s3n4" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="2">
                    <note xml:id="m6s3n5" pname="e" oct="3" />
                    <note xml:id="m6s3n6" pname="g" oct="3" />
                    <note xml:id="m6s3n7" pname="b" oct="3" />
                    <note xml:id="m6s3n8" pname="e" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="3">⑥m</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- SOURCE BAR 4 (mm. 7-8): ii V vi
                 ABC: "^Am"A3/2 G/2 "^F#7"F2 "^Em"E4
                 Am=ii, F#7→V(D diatonic substitute), Em=vi
            -->

            <!-- Measure 7: ii → V
                 Melody: A4(dotted-half approx 2 beats) G4 F#4 half
                 A3/2 G/2 F2 = A4(1.5) G4(0.5) F#4(2) = 4 beats
            -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" dots="1" oct="4" pname="a" />
                  <note xml:id="m7s1n2" dur="8" oct="4" pname="g" />
                  <note xml:id="m7s1n3" dur="2" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: ii "43": C4 E4 A4 (half); V "333": D4 F#4 A4 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="2">
                    <note xml:id="m7s2n1" pname="c" oct="4" />
                    <note xml:id="m7s2n2" pname="e" oct="4" />
                    <note xml:id="m7s2n3" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="2">
                    <note xml:id="m7s2n4" pname="d" oct="4" />
                    <note xml:id="m7s2n5" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m7s2n6" pname="a" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: ii "333": A3 C4 E4 G4 (half); V "333": D3 F#3 A3 C4 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="2">
                    <note xml:id="m7s3n1" pname="a" oct="3" />
                    <note xml:id="m7s3n2" pname="c" oct="4" />
                    <note xml:id="m7s3n3" pname="e" oct="4" />
                    <note xml:id="m7s3n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="2">
                    <note xml:id="m7s3n5" pname="d" oct="3" />
                    <note xml:id="m7s3n6" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m7s3n7" pname="a" oct="3" />
                    <note xml:id="m7s3n8" pname="c" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">②m</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 8: vi whole — E4(whole) -->
            <measure n="8" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m8s1n1" dur="1" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: vi "334": B4 D5 F#5 B5 — full high range vi voicing -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m8s2c1" dur="2">
                    <note xml:id="m8s2n1" pname="b" oct="4" />
                    <note xml:id="m8s2n2" pname="d" oct="5" />
                    <note xml:id="m8s2n3" pname="f" oct="5" accid.ges="s" />
                  </chord>
                  <chord xml:id="m8s2c2" dur="2">
                    <note xml:id="m8s2n4" pname="g" oct="4" />
                    <note xml:id="m8s2n5" pname="b" oct="4" />
                    <note xml:id="m8s2n6" pname="e" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "333": E3 G3 B3 D4 whole -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m8s3c1" dur="1">
                    <note xml:id="m8s3n1" pname="e" oct="3" />
                    <note xml:id="m8s3n2" pname="g" oct="3" />
                    <note xml:id="m8s3n3" pname="b" oct="3" />
                    <note xml:id="m8s3n4" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- SOURCE BARS 5-8 (mm. 9-16): Repeat of bars 1-4 (same melody) -->
            <!-- Varied voicings — 7th chords and inversions throughout        -->
            <!-- ============================================================ -->

            <!-- Measure 9 (= bar 5, repeat of bar 1): vi whole, richer -->
            <measure n="9" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m9s1n1" dur="2" oct="4" pname="e" />
                  <note xml:id="m9s1n2" dur="4" oct="4" pname="e" />
                  <note xml:id="m9s1n3" dur="4" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: vi "333": B4 D5 F#5 — 3-note richer -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m9s2c1" dur="1">
                    <note xml:id="m9s2n1" pname="b" oct="4" />
                    <note xml:id="m9s2n2" pname="d" oct="5" />
                    <note xml:id="m9s2n3" pname="f" oct="5" accid.ges="s" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi "333": E3 G3 B3 D4 whole -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m9s3c1" dur="1">
                    <note xml:id="m9s3n1" pname="e" oct="3" />
                    <note xml:id="m9s3n2" pname="g" oct="3" />
                    <note xml:id="m9s3n3" pname="b" oct="3" />
                    <note xml:id="m9s3n4" pname="d" oct="4" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m7</harm>
            </measure>

            <!-- Measure 10: vi → IV (repeat of m2) — 7th variant -->
            <measure n="10" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m10s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m10s1n2" dur="2" oct="4" pname="f" accid.ges="s" />
                  <note xml:id="m10s1n3" dur="4" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: vi "44" quartal: E4 A4 D5 (half); IV "33": G4 C5 (half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m10s2c1" dur="2">
                    <note xml:id="m10s2n1" pname="e" oct="4" />
                    <note xml:id="m10s2n2" pname="a" oct="4" />
                    <note xml:id="m10s2n3" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m10s2c2" dur="2">
