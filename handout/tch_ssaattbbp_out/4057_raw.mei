<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>Hark! The Herald Angels Sing</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt>
        <date isodate="2026-04-12" />
      </pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- Key: F major (1 flat: Bb). Meter: 4/4 -->
          <!-- Diatonic: F G A Bb C D E -->
          <!-- Degrees: I=F, IIm=Gm, IIIm=Am, IV=Bb, V=C, VIm=Dm, VII°=E° -->
          <!-- Non-diatonic: Bø7→Bm7→use ii7(Gm7), FΔ7→I, G7→V(C), Gm→ii, D→VI(Dm sub V/ii), F#m→non-diat→use IIIm(Am) -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1f">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1f" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1f" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1f" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- VERSE 1 (mm. 1-8): "Hark the herald angels sing"            -->
            <!-- ============================================================ -->

            <!-- Measure 1: "^F"C F F3/2 "^C"E/2 -->
            <!-- ABC: C=C4, F=F4, F=F4 dotted quarter, E=E4 eighth -->
            <!-- Chords: F(I) C(V) -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" oct="4" pname="c" />
                  <note xml:id="m1s1n2" dur="4" oct="4" pname="f" />
                  <note xml:id="m1s1n3" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m1s1n4" dur="8" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I F4-A4(half), V E4-G4(quarter dotted), V C4-E4(8th) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="2">
                    <note xml:id="m1s2n1" pname="f" oct="4" />
                    <note xml:id="m1s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="4" dots="1">
                    <note xml:id="m1s2n3" pname="e" oct="4" />
                    <note xml:id="m1s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="8">
                    <note xml:id="m1s2n5" pname="c" oct="4" />
                    <note xml:id="m1s2n6" pname="e" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I F2-C3-F3 (half), V C2-G2-C3 (quarter dotted), C2-E3 (8th passing) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="2">
                    <note xml:id="m1s3n1" pname="f" oct="2" />
                    <note xml:id="m1s3n2" pname="c" oct="3" />
                    <note xml:id="m1s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="4" dots="1">
                    <note xml:id="m1s3n4" pname="c" oct="2" />
                    <note xml:id="m1s3n5" pname="g" oct="2" />
                    <note xml:id="m1s3n6" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="8">
                    <note xml:id="m1s3n7" pname="c" oct="2" />
                    <note xml:id="m1s3n8" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 2: "^F"F A A G -->
            <!-- All F(I): F=F4, A=A4, A=A4, G=G4 -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m2s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m2s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: I ascending F4(8) A4(8) C5(8) A4(8), then F4-C5(half) — flowing -->
              <staff n="2">
                <layer n="1">
                  <note xml:id="m2s2n1" dur="8" pname="f" oct="4" />
                  <note xml:id="m2s2n2" dur="8" pname="a" oct="4" />
                  <note xml:id="m2s2n3" dur="8" pname="c" oct="5" />
                  <note xml:id="m2s2n4" dur="8" pname="a" oct="4" />
                  <chord xml:id="m2s2c1" dur="2">
                    <note xml:id="m2s2n5" pname="f" oct="4" />
                    <note xml:id="m2s2n6" pname="c" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I ascending arpeggio F2(8) C3(8) F3(8) A3(8), then F2-C3-F3-A3 held half -->
              <staff n="3">
                <layer n="1">
                  <note xml:id="m2s3n1" dur="8" pname="f" oct="2" />
                  <note xml:id="m2s3n2" dur="8" pname="c" oct="3" />
                  <note xml:id="m2s3n3" dur="8" pname="f" oct="3" />
                  <note xml:id="m2s3n4" dur="8" pname="a" oct="3" />
                  <chord xml:id="m2s3c1" dur="2">
                    <note xml:id="m2s3n5" pname="f" oct="2" />
                    <note xml:id="m2s3n6" pname="c" oct="3" />
                    <note xml:id="m2s3n7" pname="f" oct="3" />
                    <note xml:id="m2s3n8" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
            </measure>

            <!-- Measure 3: c "^Am"c "^Bb"c3/2 B/2 -->
            <!-- Chords: F(I) Am(iii) Bb(IV) -->
            <!-- Melody: c=C5, c=C5, c=C5 dotted quarter, B=Bb4 eighth -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n2" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n3" dur="4" dots="1" oct="5" pname="c" />
                  <note xml:id="m3s1n4" dur="8" oct="4" pname="b" accid.ges="f" />
                </layer>
              </staff>
              <!-- RH: I C4-F4(4), iii A4-C5(4), IV Bb4-D5(dotted quarter), IV F4-Bb4(8th) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="c" oct="4" />
                    <note xml:id="m3s2n2" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="a" oct="4" />
                    <note xml:id="m3s2n4" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4" dots="1">
                    <note xml:id="m3s2n5" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m3s2n6" pname="d" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c4" dur="8">
                    <note xml:id="m3s2n7" pname="f" oct="4" />
                    <note xml:id="m3s2n8" pname="b" oct="4" accid.ges="f" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I F2-A2-C3 (4), iii A2-E3-A3 (4), IV Bb2-F3-Bb3 (dotted quarter), IV F2-Bb2-F3 (8th) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="f" oct="2" />
                    <note xml:id="m3s3n2" pname="a" oct="2" />
                    <note xml:id="m3s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="a" oct="2" />
                    <note xml:id="m3s3n5" pname="e" oct="3" />
                    <note xml:id="m3s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4" dots="1">
                    <note xml:id="m3s3n7" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n8" pname="f" oct="3" />
                    <note xml:id="m3s3n9" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m3s3c4" dur="8">
                    <note xml:id="m3s3n10" pname="f" oct="2" />
                    <note xml:id="m3s3n11" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m3s3n12" pname="f" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">③m</harm>
              <harm staff="1" tstamp="3">④</harm>
            </measure>

            <!-- Measure 4: "^F"A "^C"G "^F"A2 -->
            <!-- Chords: F(I) C(V) F(I) whole -->
            <!-- Melody: A=A4, G=G4, A=A4 half -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" oct="4" pname="a" />
                  <note xml:id="m4s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m4s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: I F4-A4(4), V G4-C5(4), I A4-C5-F5(half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4">
                    <note xml:id="m4s2n1" pname="f" oct="4" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="4">
                    <note xml:id="m4s2n3" pname="g" oct="4" />
                    <note xml:id="m4s2n4" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="a" oct="4" />
                    <note xml:id="m4s2n6" pname="c" oct="5" />
                    <note xml:id="m4s2n7" pname="f" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: I F2-A2-C3 (4), V C2-G2-C3-E3 (4), I F2-C3-F3-A3 (half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4">
                    <note xml:id="m4s3n1" pname="f" oct="2" />
                    <note xml:id="m4s3n2" pname="a" oct="2" />
                    <note xml:id="m4s3n3" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="4">
                    <note xml:id="m4s3n4" pname="c" oct="2" />
                    <note xml:id="m4s3n5" pname="g" oct="2" />
                    <note xml:id="m4s3n6" pname="c" oct="3" />
                    <note xml:id="m4s3n7" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n8" pname="f" oct="2" />
                    <note xml:id="m4s3n9" pname="c" oct="3" />
                    <note xml:id="m4s3n10" pname="f" oct="3" />
                    <note xml:id="m4s3n11" pname="a" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">①</harm>
            </measure>

            <!-- Measure 5: same as m1 — I C V -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" oct="4" pname="c" />
                  <note xml:id="m5s1n2" dur="4" oct="4" pname="f" />
                  <note xml:id="m5s1n3" dur="4" dots="1" oct="4" pname="f" />
                  <note xml:id="m5s1n4" dur="8" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: I F4-C5(half), V E4-G4-C5(dotted quarter), C4(8th) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="2">
                    <note xml:id="m5s2n1" pname="f" oct="4" />
                    <note xml:id="m5s2n2" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="4" dots="1">
                    <note xml:id="m5s2n3" pname="e" oct="4" />
                    <note xml:id="m5s2n4" pname="g" oct="4" />
                    <note xml:id="m5s2n5" pname="c" oct="5" />
                  </chord>
                  <note xml:id="m5s2n6" dur="8" pname="e" oct="4" />
                </layer>
              </staff>
              <!-- LH: I F2-C3-F3 (half), V C2-G2-C3 (dotted quarter), C2-E3 (8th) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="2">
                    <note xml:id="m5s3n1" pname="f" oct="2" />
                    <note xml:id="m5s3n2" pname="c" oct="3" />
                    <note xml:id="m5s3n3" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="4" dots="1">
                    <note xml:id="m5s3n4" pname="c" oct="2" />
                    <note xml:id="m5s3n5" pname="g" oct="2" />
                    <note xml:id="m5s3n6" pname="c" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="8">
                    <note xml:id="m5s3n7" pname="c" oct="2" />
                    <note xml:id="m5s3n8" pname="e" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="3">⑤</harm>
            </measure>

            <!-- Measure 6: "^Dm"F "^F"A "^Bø7"A G -->
            <!-- Dm(vi) F(I) Bø7→ii7(Gm7) -->
            <!-- Melody: F=F4, A=A4, A=A4, G=G4 -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" oct="4" pname="f" />
                  <note xml:id="m6s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n3" dur="4" oct="4" pname="a" />
                  <note xml:id="m6s1n4" dur="4" oct="4" pname="g" />
                </layer>
              </staff>
              <!-- RH: vi D4-F4-A4(4), I C4-F4(4), ii7 G4-Bb4(4), ii G4-Bb4-D5(4) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4">
                    <note xml:id="m6s2n1" pname="d" oct="4" />
                    <note xml:id="m6s2n2" pname="f" oct="4" />
                    <note xml:id="m6s2n3" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="4">
                    <note xml:id="m6s2n4" pname="c" oct="4" />
                    <note xml:id="m6s2n5" pname="f" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="4">
                    <note xml:id="m6s2n6" pname="g" oct="4" />
                    <note xml:id="m6s2n7" pname="b" oct="4" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s2c4" dur="4">
                    <note xml:id="m6s2n8" pname="g" oct="4" />
                    <note xml:id="m6s2n9" pname="b" oct="4" accid.ges="f" />
                    <note xml:id="m6s2n10" pname="d" oct="5" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: vi D2-A2-D3 (4), I F2-C3-F3 (4), ii7 G2-D3-Bb3 (4), ii G2-D3-G3 (4) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4">
                    <note xml:id="m6s3n1" pname="d" oct="2" />
                    <note xml:id="m6s3n2" pname="a" oct="2" />
                    <note xml:id="m6s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="4">
                    <note xml:id="m6s3n4" pname="f" oct="2" />
                    <note xml:id="m6s3n5" pname="c" oct="3" />
                    <note xml:id="m6s3n6" pname="f" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="4">
                    <note xml:id="m6s3n7" pname="g" oct="2" />
                    <note xml:id="m6s3n8" pname="d" oct="3" />
                    <note xml:id="m6s3n9" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m6s3c4" dur="4">
                    <note xml:id="m6s3n10" pname="g" oct="2" />
                    <note xml:id="m6s3n11" pname="d" oct="3" />
                    <note xml:id="m6s3n12" pname="g" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑥m</harm>
              <harm staff="1" tstamp="2">①</harm>
              <harm staff="1" tstamp="3">②m7</harm>
            </measure>

            <!-- Measure 7: "^Am"c "^G"G "^C"G3/2 E/2 -->
            <!-- Am(iii) G→diatonic V sub→V C(IV) -->
            <!-- Melody: c=C5, G=G4, G=G4 dotted quarter, E=E4 eighth -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="5" pname="c" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="g" />
                  <note xml:id="m7s1n3" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m7s1n4" dur="8" oct="4" pname="e" />
                </layer>
              </staff>
              <!-- RH: iii C4-E4-A4(4), V G4-C5(4), IV G4-C5(dotted quarter), IV E4-G4(8th) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="c" oct="4" />
                    <note xml:id="m7s2n2" pname="e" oct="4" />
                    <note xml:id="m7s2n3" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n4" pname="g" oct="4" />
                    <note xml:id="m7s2n5" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4" dots="1">
                    <note xml:id="m7s2n6" pname="g" oct="4" />
                    <note xml:id="m7s2n7" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m7s2c4" dur="8">
                    <note xml:id="m7s2n8" pname="e" oct="4" />
                    <note xml:id="m7s2n9" pname="g" oct="4" />
                  </chord>
                </layer>
              </staff>
              <!-- LH: iii A2-E3-A3 (4), V C2-G2-C3-E3 (4), IV Bb2-F3-Bb3 (dotted quarter), IV F2-C3 (8th) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="a" oct="2" />
                    <note xml:id="m7s3n2" pname="e" oct="3" />
                    <note xml:id="m7s3n3" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="c" oct="2" />
                    <note xml:id="m7s3n5" pname="g" oct="2" />
                    <note xml:id="m7s3n6" pname="c" oct="3" />
                    <note xml:id="m7s3n7" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c3" dur="4" dots="1">
                    <note xml:id="m7s3n8" pname="b" oct="2" accid.ges="f" />
                    <note xml:id="m7s3n9" pname="f" oct="3" />
                    <note xml:id="m7s3n10" pname="b" oct="3" accid.ges="f" />
                  </chord>
                  <chord xml:id="m7s3c4" dur="8">
                    <note xml:id="m7s3n11" pname="f" oct="2" />
                    <note xml:id="m7s3n12" pname="c" oct="3" />
                  </chord>
                </layer>
              </staff>
              <harm staff="1" tstamp="1">③m</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">④</harm>
