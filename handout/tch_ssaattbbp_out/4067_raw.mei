<?xml version='1.0' encoding='utf-8'?>
<mei xmlns="http://www.music-encoding.org/ns/mei" meiversion="5.0">
  <meiHead>
    <fileDesc>
      <titleStmt>
        <title>See Amid the Winter's Snow</title>
        <title type="subtitle">Harp Arrangement — SSAATTBB + Pedal</title>
      </titleStmt>
      <pubStmt><date isodate="2026-04-12" /></pubStmt>
    </fileDesc>
  </meiHead>
  <music>
    <body>
      <mdiv>
        <score>
          <!-- G major: F# = accid.ges="s" on every F -->
          <scoreDef meter.count="4" meter.unit="4" key.sig="1s">
            <staffGrp symbol="bracket" barthru="true">
              <staffDef n="1" lines="5" clef.shape="G" clef.line="2" label="Melody">
                <keySig sig="1s" />
              </staffDef>
              <staffGrp symbol="brace">
                <staffDef n="2" lines="5" clef.shape="G" clef.line="2" label="RH">
                  <keySig sig="1s" />
                </staffDef>
                <staffDef n="3" lines="5" clef.shape="F" clef.line="4" label="LH">
                  <keySig sig="1s" />
                </staffDef>
              </staffGrp>
            </staffGrp>
          </scoreDef>
          <section>

            <!-- ============================================================ -->
            <!-- PHRASE 1 (mm. 1-4): Opening — tender, light texture         -->
            <!-- ============================================================ -->

            <!-- Measure 1: 4 beats. G→Am→Bm. Melody: G4(dotted-qtr) A4(8) G4(qtr) F#4(qtr) -->
            <!-- Duration: 1.5 + 0.5 + 1 + 1 = 4 beats OK -->
            <measure n="1" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m1s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m1s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m1s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m1s1n4" dur="4" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: D4-G4(I open), D4-A4(ii), D4-F#4(iii) — arpeggiated ascent -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m1s2c1" dur="4" dots="1">
                    <note xml:id="m1s2n1" pname="d" oct="4" />
                    <note xml:id="m1s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c2" dur="8">
                    <note xml:id="m1s2n3" pname="e" oct="4" />
                    <note xml:id="m1s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c3" dur="4">
                    <note xml:id="m1s2n5" pname="e" oct="4" />
                    <note xml:id="m1s2n6" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m1s2c4" dur="4">
                    <note xml:id="m1s2n7" pname="d" oct="4" />
                    <note xml:id="m1s2n8" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: G2-D3(I), A2-E3(ii), B2-F#3-B3(iii) — open 5ths then triad -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m1s3c1" dur="4" dots="1">
                    <note xml:id="m1s3n1" pname="g" oct="2" />
                    <note xml:id="m1s3n2" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c2" dur="8">
                    <note xml:id="m1s3n3" pname="a" oct="2" />
                    <note xml:id="m1s3n4" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c3" dur="4">
                    <note xml:id="m1s3n5" pname="a" oct="2" />
                    <note xml:id="m1s3n6" pname="e" oct="3" />
                    <note xml:id="m1s3n7" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m1s3c4" dur="4">
                    <note xml:id="m1s3n8" pname="b" oct="2" />
                    <note xml:id="m1s3n9" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m1s3n10" pname="b" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">②m</harm>
              <harm staff="1" tstamp="3">②m</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Measure 2: 4 beats. C→G. Melody: E4(dotted-qtr) D4(8) D4(half) -->
            <!-- Duration: 1.5 + 0.5 + 2 = 4 beats OK -->
            <measure n="2" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m2s1n1" dur="4" dots="1" oct="4" pname="e" />
                  <note xml:id="m2s1n2" dur="8" oct="4" pname="d" />
                  <note xml:id="m2s1n3" dur="2" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: E4-G4(IV→vi color), D4-G4(I sus4), D4-F#4(I) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m2s2c1" dur="4" dots="1">
                    <note xml:id="m2s2n1" pname="e" oct="4" />
                    <note xml:id="m2s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c2" dur="8">
                    <note xml:id="m2s2n3" pname="d" oct="4" />
                    <note xml:id="m2s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m2s2c3" dur="2">
                    <note xml:id="m2s2n5" pname="d" oct="4" />
                    <note xml:id="m2s2n6" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C3-G3-C4(IV), G2-D3-G3(I half) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m2s3c1" dur="4" dots="1">
                    <note xml:id="m2s3n1" pname="c" oct="3" />
                    <note xml:id="m2s3n2" pname="g" oct="3" />
                    <note xml:id="m2s3n3" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m2s3c2" dur="8">
                    <note xml:id="m2s3n4" pname="g" oct="2" />
                    <note xml:id="m2s3n5" pname="d" oct="3" />
                    <note xml:id="m2s3n6" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m2s3c3" dur="2">
                    <note xml:id="m2s3n7" pname="g" oct="2" />
                    <note xml:id="m2s3n8" pname="d" oct="3" />
                    <note xml:id="m2s3n9" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2.5">①</harm>
            </measure>

            <!-- Measure 3: 4 beats. C→G. Melody: G4(4) A4(4) c5(4) B4(4) -->
            <measure n="3" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m3s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m3s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m3s1n3" dur="4" oct="5" pname="c" />
                  <note xml:id="m3s1n4" dur="4" oct="4" pname="b" />
                </layer>
              </staff>
              <!-- RH: E4-G4(IV6), F#4-A4(V1st inv), G4-C5(I-IV), D5-B4(I) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m3s2c1" dur="4">
                    <note xml:id="m3s2n1" pname="e" oct="4" />
                    <note xml:id="m3s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c2" dur="4">
                    <note xml:id="m3s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m3s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m3s2c3" dur="4">
                    <note xml:id="m3s2n5" pname="g" oct="4" />
                    <note xml:id="m3s2n6" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m3s2c4" dur="4">
                    <note xml:id="m3s2n7" pname="g" oct="4" />
                    <note xml:id="m3s2n8" pname="b" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C3-G3-C4(IV), D2-A2-D3(V), C3-G3(IV), G2-D3-G3-B3(I full) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m3s3c1" dur="4">
                    <note xml:id="m3s3n1" pname="c" oct="3" />
                    <note xml:id="m3s3n2" pname="g" oct="3" />
                    <note xml:id="m3s3n3" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m3s3c2" dur="4">
                    <note xml:id="m3s3n4" pname="d" oct="2" />
                    <note xml:id="m3s3n5" pname="a" oct="2" />
                    <note xml:id="m3s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m3s3c3" dur="4">
                    <note xml:id="m3s3n7" pname="c" oct="3" />
                    <note xml:id="m3s3n8" pname="g" oct="3" />
                    <note xml:id="m3s3n9" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m3s3c4" dur="4">
                    <note xml:id="m3s3n10" pname="g" oct="2" />
                    <note xml:id="m3s3n11" pname="d" oct="3" />
                    <note xml:id="m3s3n12" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2">⑤</harm>
              <harm staff="1" tstamp="3">④</harm>
              <harm staff="1" tstamp="4">①</harm>
            </measure>

            <!-- Measure 4: 4 beats. D. Melody: B4(dotted-qtr) A4(8) A4(half) -->
            <!-- Duration: 1.5 + 0.5 + 2 = 4 beats OK -->
            <measure n="4" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m4s1n1" dur="4" dots="1" oct="4" pname="b" />
                  <note xml:id="m4s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m4s1n3" dur="2" oct="4" pname="a" />
                </layer>
              </staff>
              <!-- RH: F#4-A4(V), D4-F#4(V root), A4-D5(V sus open) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m4s2c1" dur="4" dots="1">
                    <note xml:id="m4s2n1" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m4s2n2" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m4s2c2" dur="8">
                    <note xml:id="m4s2n3" pname="d" oct="4" />
                    <note xml:id="m4s2n4" pname="f" oct="4" accid.ges="s" />
                  </chord>
                  <chord xml:id="m4s2c3" dur="2">
                    <note xml:id="m4s2n5" pname="a" oct="4" />
                    <note xml:id="m4s2n6" pname="d" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: D2-A2-D3 dotted-qtr + 8th, D2-A2-F#3(V triad) half -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m4s3c1" dur="4" dots="1">
                    <note xml:id="m4s3n1" pname="d" oct="2" />
                    <note xml:id="m4s3n2" pname="a" oct="2" />
                    <note xml:id="m4s3n3" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c2" dur="8">
                    <note xml:id="m4s3n4" pname="d" oct="2" />
                    <note xml:id="m4s3n5" pname="a" oct="2" />
                    <note xml:id="m4s3n6" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m4s3c3" dur="2">
                    <note xml:id="m4s3n7" pname="d" oct="2" />
                    <note xml:id="m4s3n8" pname="a" oct="2" />
                    <note xml:id="m4s3n9" pname="f" oct="3" accid.ges="s" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">⑤</harm>
            </measure>

            <!-- ============================================================ -->
            <!-- PHRASE 2 (mm. 5-8): Repeat of opening phrase                -->
            <!-- ============================================================ -->

            <!-- Measure 5: same as m.1 — G→Am→Bm, but with richer LH -->
            <measure n="5" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m5s1n1" dur="4" dots="1" oct="4" pname="g" />
                  <note xml:id="m5s1n2" dur="8" oct="4" pname="a" />
                  <note xml:id="m5s1n3" dur="4" oct="4" pname="g" />
                  <note xml:id="m5s1n4" dur="4" oct="4" pname="f" accid.ges="s" />
                </layer>
              </staff>
              <!-- RH: G4-B4(I), A4-C5(ii), G4-B4(I), F#4-A4(iii) — fuller -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m5s2c1" dur="4" dots="1">
                    <note xml:id="m5s2n1" pname="g" oct="4" />
                    <note xml:id="m5s2n2" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c2" dur="8">
                    <note xml:id="m5s2n3" pname="a" oct="4" />
                    <note xml:id="m5s2n4" pname="c" oct="5" />
                  </chord>
                  <chord xml:id="m5s2c3" dur="4">
                    <note xml:id="m5s2n5" pname="g" oct="4" />
                    <note xml:id="m5s2n6" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m5s2c4" dur="4">
                    <note xml:id="m5s2n7" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m5s2n8" pname="a" oct="4" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: G2-D3-G3(I), A2-E3-A3(ii), G2-B2-D3(I), B2-F#3-B3(iii) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m5s3c1" dur="4" dots="1">
                    <note xml:id="m5s3n1" pname="g" oct="2" />
                    <note xml:id="m5s3n2" pname="d" oct="3" />
                    <note xml:id="m5s3n3" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c2" dur="8">
                    <note xml:id="m5s3n4" pname="a" oct="2" />
                    <note xml:id="m5s3n5" pname="e" oct="3" />
                    <note xml:id="m5s3n6" pname="a" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c3" dur="4">
                    <note xml:id="m5s3n7" pname="g" oct="2" />
                    <note xml:id="m5s3n8" pname="b" oct="2" />
                    <note xml:id="m5s3n9" pname="d" oct="3" />
                  </chord>
                  <chord xml:id="m5s3c4" dur="4">
                    <note xml:id="m5s3n10" pname="b" oct="2" />
                    <note xml:id="m5s3n11" pname="f" oct="3" accid.ges="s" />
                    <note xml:id="m5s3n12" pname="b" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">①</harm>
              <harm staff="1" tstamp="2.5">②m</harm>
              <harm staff="1" tstamp="3">①</harm>
              <harm staff="1" tstamp="4">③m</harm>
            </measure>

            <!-- Measure 6: C→G. Same as m.2 but with more notes in LH -->
            <measure n="6" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m6s1n1" dur="4" dots="1" oct="4" pname="e" />
                  <note xml:id="m6s1n2" dur="8" oct="4" pname="d" />
                  <note xml:id="m6s1n3" dur="2" oct="4" pname="d" />
                </layer>
              </staff>
              <!-- RH: E4-G4, D4-G4, D4-F#4(half) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m6s2c1" dur="4" dots="1">
                    <note xml:id="m6s2n1" pname="e" oct="4" />
                    <note xml:id="m6s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c2" dur="8">
                    <note xml:id="m6s2n3" pname="d" oct="4" />
                    <note xml:id="m6s2n4" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m6s2c3" dur="2">
                    <note xml:id="m6s2n5" pname="d" oct="4" />
                    <note xml:id="m6s2n6" pname="f" oct="4" accid.ges="s" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: C3-E3-G3-C4(IV full), G2-B2-D3-G3(I full) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m6s3c1" dur="4" dots="1">
                    <note xml:id="m6s3n1" pname="c" oct="3" />
                    <note xml:id="m6s3n2" pname="e" oct="3" />
                    <note xml:id="m6s3n3" pname="g" oct="3" />
                    <note xml:id="m6s3n4" pname="c" oct="4" />
                  </chord>
                  <chord xml:id="m6s3c2" dur="8">
                    <note xml:id="m6s3n5" pname="g" oct="2" />
                    <note xml:id="m6s3n6" pname="d" oct="3" />
                    <note xml:id="m6s3n7" pname="g" oct="3" />
                  </chord>
                  <chord xml:id="m6s3c3" dur="2">
                    <note xml:id="m6s3n8" pname="g" oct="2" />
                    <note xml:id="m6s3n9" pname="b" oct="2" />
                    <note xml:id="m6s3n10" pname="d" oct="3" />
                    <note xml:id="m6s3n11" pname="g" oct="3" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <harm staff="1" tstamp="1">④</harm>
              <harm staff="1" tstamp="2.5">①</harm>
            </measure>

            <!-- Measure 7: Em→G→C. Melody: G4(4) A4(4) B4(4) c5(4) -->
            <measure n="7" right="single">
              <staff n="1">
                <layer n="1">
                  <note xml:id="m7s1n1" dur="4" oct="4" pname="g" />
                  <note xml:id="m7s1n2" dur="4" oct="4" pname="a" />
                  <note xml:id="m7s1n3" dur="4" oct="4" pname="b" />
                  <note xml:id="m7s1n4" dur="4" oct="5" pname="c" />
                </layer>
              </staff>
              <!-- RH: E4-G4(vi), F#4-A4(V1st), G4-B4(I), A4-C5(ii→IV) -->
              <staff n="2">
                <layer n="1">
                  <chord xml:id="m7s2c1" dur="4">
                    <note xml:id="m7s2n1" pname="e" oct="4" />
                    <note xml:id="m7s2n2" pname="g" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c2" dur="4">
                    <note xml:id="m7s2n3" pname="f" oct="4" accid.ges="s" />
                    <note xml:id="m7s2n4" pname="a" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c3" dur="4">
                    <note xml:id="m7s2n5" pname="g" oct="4" />
                    <note xml:id="m7s2n6" pname="b" oct="4" />
                  </chord>
                  <chord xml:id="m7s2c4" dur="4">
                    <note xml:id="m7s2n7" pname="a" oct="4" />
                    <note xml:id="m7s2n8" pname="c" oct="5" />
                  </chord>
                </layer>
                <layer n="2">
                  <rest dur="1" />
                </layer>
              </staff>
              <!-- LH: E2-B2-E3(vi), D2-A2-D3(V), G2-D3-G3(I), C3-G3-C4(IV) -->
              <staff n="3">
                <layer n="1">
                  <chord xml:id="m7s3c1" dur="4">
                    <note xml:id="m7s3n1" pname="e" oct="2" />
                    <note xml:id="m7s3n2" pname="b" oct="2" />
                    <note xml:id="m7s3n3" pname="e" oct="3" />
                  </chord>
                  <chord xml:id="m7s3c2" dur="4">
                    <note xml:id="m7s3n4" pname="d" oct="2" />
                    <note xml:id="m7s3n5" pname="a" oct="2" />
