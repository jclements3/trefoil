V:2 name="Soprano II" clef=treble
V:3 name="Alto I"     clef=treble
V:4 name="Alto II"    clef=treble
V:5 name="Tenor I"    clef=treble middle=B3 transpose=-12
V:6 name="Tenor II"   clef=treble middle=B3 transpose=-12
V:7 name="Baritone"   clef=bass
V:8 name="Bass I"     clef=bass
K: F
%
% Ranges reminder (concert pitch):
%   V1 S1:  C4-A5   V2 S2:  A3-F5
%   V3 A1:  F3-D5   V4 A2:  D3-B4
%   V5 T1:  B2-G4   V6 T2:  G2-E4
%   V7 Bar: E2-C4   V8 B1:  C2-A3
% In F major key: F G A Bb C D E (no accidentals except Bb)
% Tenor clef notation: written pitch sounds an octave lower.
%   Written C5 (c in ABC) = concert C4; written C4 (C in ABC) = concert C3
%   T1 range concert B2-G4: written B3-G5
%   T2 range concert G2-E4: written G3-E5
%   Bar concert E2-C4: written in bass clef, no transposition
%   B1 concert C2-A3: written in bass clef
%
% ===== PICKUP BAR =====
% S1 + B1 alone; sparse opening texture
[V:1] [Q:1/4=100] F/4A/4 |
[V:2] z/ |
[V:3] z/ |
[V:4] z/ |
[V:5] z/ |
[V:6] z/ |
[V:7] z/ |
[V:8] F,/ |
%
% ===== VERSE PHRASE 1 =====
% Bar 1: F major. Full 8 voices enter.
% Harmony: I (F)
% S1: c c/ d c/   (soprano melody, original)
% S2: A A/ B A/   (third below S1, diatonic Bb as B in F key = Bb)
% A1: F F/ F F/   (oblique, chord tone, independent)
% A2: C C/ D C/   (inner voice, contrary motion to A1, diatonic)
% T1 (written, sounds 8vb): A A/ B A/  concert: A3 A3/ Bb3 A3/ — in T1 range ok
% T2 (written): F F/ F F/  concert: F3 — in T2 range ok
% Bar: A, A,/ B, A,/  concert: A2 — in Baritone range ok
% B1: F, F,/ F, F,/   concert: F2 — in B1 range ok
[V:1] c c/ d c/ |
[V:2] A A/ B A/ |
[V:3] F F/ F F/ |
[V:4] C C/ D C/ |
[V:5] A A/ B A/ |
[V:6] F F/ F F/ |
[V:7] A, A,/ B, A,/ |
[V:8] F, F,/ F, F,/ |
