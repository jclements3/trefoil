% Bar-B1: A3-A2=7th, B2-G2=3rd, F#3-D3=3rd, C#3-A2=3rd  No unisons ✓
%
% B1: A2 | D3 G2 D3 A2 | same | D3 G2 F#2 G2 | D3
%   bass: A,,2 | D, G,, D,2 A,,2 | same | D, G,, F,,2 G,,2 | D,4
[V:8] A,,2 | D, G,, D,2 A,,2 | D, G,, D,2 A,,2 | D, G,, F,,2 G,,2 | D,4 ||
