%   A2: F#3 | F#3 A3 D4 A3 | C#4 E4 A3 G3 | F#3 E3 D3 D3 | D3
%       A1>A2 throughout (no crossing) ✓  A2 min D3: lowest=D3 ✓
%
% ════════════════════════════════════════════════════════
% SECTION 1b  —  Second time: full 8 voices  (mp)
% TTBB enters — homophonic texture, choirs a registral 10th apart
% ════════════════════════════════════════════════════════
%
[V:1] D2 | F A d2 A2 | B d A2 G2 | F D D2 C2 | D4 ||
[V:2] B,2 | D F B2 F2 | G B F2 E2 | D B, A,2 A,2 | B,4 ||
[V:3] G,2 | A, D F2 D2 | E G D2 C2 | A, G, F,2 E2 | D4 ||
[V:4] F,2 | F, A, D2 A,2 | C E A,2 G,2 | F, E, D,2 D,2 | D,4 ||
%
% T1 written in 8vb treble (concert = written - P8):
%   concert F3 A3 D4 D4 | D4 D4 D4 A3 | A3 B3 F#3 G3 | F3
%   written F4 A4 D5 D5  | D5 D5 D5 A4 | A4 B4 F#4 G4 | F4
[V:5] F2 | A d d2 d2 | d d d2 A2 | A B F2 G2 | F4 ||
%
% T2 written 8vb:
%   concert D3 F#3 B3 B3 | B3 B3 B3 F#3 | F#3 G3 D3 E3 | D3
%   written D4 F4  B4 B4  | B4 B4 B4 F4  | F4  G4 D4 E4 | D4
[V:6] D2 | F B B2 B2 | B B B2 F2 | F G D2 E2 | D4 ||
% T1-T2: parallel thirds throughout ✓
%
% Bar concert (a 3rd or 5th above B1; avoids T2-Bar unisons):
%   F#3 | A3 F#3 F#3 F#3 | B2 D3 F#3 A3 | A3 B2 C#3 C#3 | F#3
%   bass-clef: F,2 | A, F, F,2 F,2 | B,, D, F,2 A,2 | A, B,, C,2 C,2 | F,4
[V:7] F,2 | A, F, F,2 F,2 | B,, D, F,2 A,2 | A, B,, C,2 C,2 | F,4 ||
