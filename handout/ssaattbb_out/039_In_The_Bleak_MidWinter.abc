[V:8] D,2 D,2                 |
%
% ─── BAR 15 — Climax; full cadential gesture with intro markers ───
[V:1] !sintro!.(.(G A) G3/2) F/ |
[V:2] .(.(E F) E3/2) D/        |
[V:3] .(.(C D) C3/2) A,/       |
[V:4] .(.(A, B,) A,3/2) F,/    |
[V:5] .(.(G A) G3/2) F/        |
[V:6] .(.(E F) E3/2) D/        |
[V:7] D,2 (E,3/2 A,/)          |
[V:8] B,,2 (C,3/2 F,/)         |
%
% ─── BAR 16 — Final F major; wide-spaced resolution (S1=F4, B1=C2) ───
[V:1] F3 !eintro!|]
[V:2] D3|]
[V:3] C3|]
[V:4] A,3|]
[V:5] A3|]
[V:6] F3|]
[V:7] E,,3|]
[V:8] C,,3|]
