% ── Pickup to Phrase 2 ── TTBB only (antiphonal response)
%             T1(c)=A3  T2(c)=F3  Bar(c)=A2  B1(c)=F3
%
[V:1] z |
[V:2] z |
[V:3] z |
[V:4] z |
[V:5] a |
[V:6] f |
[V:7] A, |
[V:8] F |
