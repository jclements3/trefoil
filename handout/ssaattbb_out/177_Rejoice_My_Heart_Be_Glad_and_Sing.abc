% ── Bar 7 ── F/C  Gm/Bb  F  Bb; call-and-response outer voices
%             S1=C5 D5 C5 C5   S2=A4 Bb4 A4 A4
%             A1=F4 F4 G4 F4/2E4/2  A2=D4 D4 Eb4 D4/2C4/2
%             T1(c)=A3 Bb3 Bb3 A3   T2(c)=F3 G3 G3 F3
%             Bar(c)=C3 D3 D3 C3    B1(c)=F3 D3 Eb3 F3
