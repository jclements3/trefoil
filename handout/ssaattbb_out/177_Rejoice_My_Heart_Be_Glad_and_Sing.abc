% ── Bar 6 ── Eb  Bb/D  F  Gm; S1 at climax Eb5, descending
%             S1=Eb5 D5 C5 Bb4  S2=C5 Bb4 A4 G4
%             A1=G4 F4 Eb4 D4   A2=Eb4 D4 C4 Bb3
%             T1(c)=G3 Bb3 A3 G3  T2(c)=Eb3 G3 F3 Eb3
%             Bar(c)=Bb2 D3 C3 Bb2  B1(c)=C3 Eb3 F3 G3
