%             S1=Bb4 C5 D5 Bb4  S2=G4 A4 Bb4 G4
%             A1=D4 F4 F4 D4    A2=Bb3 D4 Eb4 Bb3
%             T1(c)=Bb3 A3 Bb3 G3  T2(c)=G3 F3 G3 Eb3
