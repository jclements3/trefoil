K: A
%
% NOTE on ABC pitch: C=C4 (middle C), c=C5, C,=C3, C,,=C2
% Tenor voices use transpose=-12; written pitch sounds 1 octave lower.
%   To sound C4, write c (=C5). To sound A3, write A (=A4).
% Baritone/Bass use bass clef: C,=C3, C,,=C2, A,,=A2, E,,=E2
%
% ── PHRASE 1 (bars 1–4): SSAA only; TTBB rests ───────────────────────────
%
