[V:1] z/ G c G A E F D C2 |
% S2: z/+E A E F C D B,+G2=9.5 ✓
[V:2] z/ E A E F C D B, G2 |
% A1: z/+C E C D A, B, G,+E2=9.5 ✓
[V:3] z/ C E C D A, B, G, E2 |
% A2: z/+A, C A, B, G, E, D,+C2=9.5 ✓
[V:4] z/ A, C A, B, G, E, D, C2 |
% T1: z/+C E D B, G, A, F,+C,2=9.5 ✓
[V:5] z/ C E D B, G, A, F, C,2 |
% T2: z/+A, C B, G, E, F, D,+A,,2=9.5 ✓
[V:6] z/ A, C B, G, E, F, D, A,,2 |
% Bar: z/+E, G, F, D, B,, C, A,,+F,,2=9.5 ✓
[V:7] z/ E, G, F, D, B,, C, A,, F,,2 |
% B1 original: z/+C, A,, E, F, C, D, G,,+C,2=9.5 ✓
[V:8] z/ C, A,, E, F, C, D, G,, C,2 |
%
% =====================================================================
% BAR 8  (9.5 beats — first step-descent passage)
% S: z/ G G3 F E D C2
% A: x/ D E3 D C B, C2  [B, = B natural, diatonic OK]
% T: z/ G, G,3 A, G, G, E,2
% B: x/ B,, C,3 F, G, G,, C,2
% Structure: z/+G+G3+F+E+D+C2 = 0.5+1+3+1+1+1+2=9.5 ✓
% Call-and-response: S1 descends (call); inner voices step; B1 grounds.
% =====================================================================
%
[V:1] z/ G G3 F E D C2 |
% S2: step descent third below S1: z/+E+F3+D+C+B,+A,2=9.5 ✓
[V:2] z/ E F3 D C B, A,2 |
% A1: inner melody: z/+B,+C3+B,+A,+G,+E2=9.5 ✓
[V:3] z/ B, C3 B, A, G, E2 |
% A2: below A1: z/+G,+A,3+G,+F,+E,+C2=9.5 ✓
[V:4] z/ G, A,3 G, F, E, C2 |
% T1 (concert): original tenor: z/+G,+G,3+A,+G,+G,+E,2=9.5 ✓
[V:5] z/ G, G,3 A, G, G, E,2 |
% T2: third below T1: z/+E,+F,3+D,+E,+E,+C,2=9.5 ✓
[V:6] z/ E, F,3 D, E, E, C,2 |
% Bar: inner bass: z/+B,,+C,3+A,,+G,,+F,,+E,,2=9.5 ✓
[V:7] z/ B,, C,3 A,, G,, F,, E,,2 |
% B1 original: z/+B,,+C,3+F,+G,+G,,+C,2=9.5 ✓
[V:8] z/ B,, C,3 F, G, G,, C,2 |
%
% =====================================================================
% BAR 9  (9.5 beats — repeat of step-descent phrase)
% S: z/ G G3 F E D C2
% A: x/ E D3 C C B, C2  [B, diatonic OK]
% T: z/ C B,3 A, G, G, E,2  [_B,->B, natural]
% B: x/ C, G,,3 A,, C, G,, C,2
% Stretto: T1 imitates S1 descent from one beat later.
% =====================================================================
%
[V:1] z/ G G3 F E D C2 |
[V:2] z/ E F3 D C B, A,2 |
% A1: z/+C+D3+C+B,+A,+G,2=9.5 ✓
[V:3] z/ C D3 C B, A, G,2 |
% A2: z/+A,+B,3+A,+G,+F,+E,2=9.5 ✓
