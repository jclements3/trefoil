%% ──────────────────────────────────────────────────────
%% SECTION B  bars 9–12  (D5 climax)
%% Texture: antiphonal SSAA (bars 9–10) with TTBB response;
%%          full 8 together bars 11–12
%% S1 high D5–E5 is the climax; B1 reaches G2–D2 low
%% Harmony: I | I | I–IV | I–V
%% ──────────────────────────────────────────────────────
%%
%% Bar 9  G major  S1: D5 E5 D5  (d e d in ABC)
%% S2: B4 C5 B4    A1: G4 A4 G4   A2: D4 E4 D4
%% T1 sounding: G3 A3 G3  (written G4 A4 G4)
%% T2 sounding: D3 E3 D3  (written D4 E4 D4)
%% Bar: G3 A3 G3   B1: G2 G2 G2
%%
%% Bar 10  G major  S1: D5 B4 D5 D5 D5
%% S2: B4 G4 B4 B4 B4   A1: G4 D4 G4 G4 G4   A2: D4 B3 D4 D4 D4
%% T1 sounding: B3 G3 B3  T2 sounding: G3 D3 G3
%% Bar: D3 G3 D3   B1: G2 G2 G2
%%
%% Bar 11  same as bar 9
%%
%% Bar 12  V cadence  S1: D5 B4 A4
%% S2: B4 G4 E4    A1: G4 D4 C4   A2: D4 B3 A3
%% T1 sounding: G3 D3 C3  T2 sounding: D3 B2 A2
%% Bar: A3 G3 D3   B1: D2 G2 D2
%%
[V:1]  d3 e2 d | d2 B d3    | d3 e2 d   | d2 B A3   |
[V:2]  B3 c2 B | B2 G B3    | B3 c2 B   | B2 G E3   |
[V:3]  G3 A2 G | G2 D G3    | G3 A2 G   | G2 D C3   |
[V:4]  D3 E2 D | D2 B, D3   | D3 E2 D   | D2 B, A,3 |
[V:5]  G3 A2 G | B3 G2 B    | G3 A2 G   | G3 D2 C   |
[V:6]  D3 E2 D | G,3 D2 G,  | D3 E2 D   | D3 B,2 A, |
[V:7]  G,3 A,2 G,| D,3 G,2 D,| G,3 A,2 G,| A,3 G,2 D,|
