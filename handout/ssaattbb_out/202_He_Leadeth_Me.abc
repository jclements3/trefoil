X: 202
T: He Leadeth Me
C: Words: Joseph H. Gilmore, 1862.
C: Music: William B. Bradbury, 1864. Arr. for SSAATTBB by Claude, 2026.
C: Original copyright: public domain. Open Hymnal Project, 2007 Revision.
S: Music source: "The Golden Censer", 1864 Hymn 105.
M: 4/4
L: 1/4
Q: 1/4=100
K: D
%%staves [(1 2) (3 4) (5 6) (7 8)]
V:1 name="Soprano I"  clef=treble
V:2 name="Soprano II" clef=treble
V:3 name="Alto I"     clef=treble
V:4 name="Alto II"    clef=treble
V:5 name="Tenor I"    clef=treble middle=B3 transpose=-12
V:6 name="Tenor II"   clef=treble middle=B3 transpose=-12
V:7 name="Baritone"   clef=bass
V:8 name="Bass I"     clef=bass
%%
%% ── Verse 1 ──────────────────────────────────────────────
%% S1/S2 carry melody/harmony; TTBB enters on beat 1 of bar 1.
%% Texture: SSAA melody + sustained TTBB (4+4 opening).
%%
[V:1] A | F3/2 E/ D A | B G G B | A3/2 F/ F E/D/ | F F E |
[V:2] F | D3/2 A,/ A, D | D D D G | F3/2 D/ D C | D D C |
[V:3] A, | A,3/2 G,/ F, F, | G, B, B, D | D3/2 B,/ A, G, | A, B, A, |
[V:4] F, | F,3/2 E,/ D, D, | G, G, G, B, | D3/2 G,/ F, E, | F, F, E, |
[V:5] A | A3/2 G/ F F | G B, B, D | D3/2 A/ A G/F/ | A A A |
[V:6] A, | G,3/2 G,/ G, A, | G, G, G, B, | A,3/2 A,/ A, G, | G, A, G, |
[V:7] F, | A,3/2 G,/ F, F, | G, B, B, G, | A,3/2 F,/ F, E, | F, A, A, |
[V:8] D, | D,3/2 D,/ D, D, | G, G, G, G, | D,3/2 D,/ D, D, | A, A, A, |
%%
%% ── Verse 2 ──────────────────────────────────────────────
%% Antiphonal: SSAA sings first half of each bar, TTBB answers.
%% S1 ornaments at cadence; B1 stays grounded.
%%
[V:1] A | F3/2 E/ D A | B G d c/B/ | A F F/E/ D/E/ | F3/2 E/ !fermata!D |
[V:2] C | D3/2 A,/ A, D | D G G G | F D D/C/ B,/C/ | D3/2 C/ D |
[V:3] A, | A,3/2 G,/ F, F, | G, B, B, D | D A, B, A, | D3/2 C/ D |
[V:4] E, | F,3/2 E,/ D, D, | G, G, G, B, | D B, G, F, | A,3/2 G,/ F, |
[V:5] A | A3/2 G/ F F | G B, B, D | D A B F | A3/2 G/ !invertedfermata!F |
[V:6] A, | G,3/2 G,/ A, A, | G, G, G, B, | A, G, G, G, | G,3/2 G,/ G, |
[V:7] A, | F,3/2 E,/ D, F, | B, G, B, B, | F, F, G, G, | F,3/2 E,/ F, |
[V:8] A, | D,3/2 D,/ D, D, | G, G, G, G, | D, D, B, B, | A,3/2 A,/ D, |
%%
%% ── Refrain A ──────────────────────────────────────────────
%% Full 8-voice homophony; S1 leads at top, B1 anchors low.
%% SSAA and TTBB in block-chord texture; maximum spread.
%%
[V:1] A | A d c d | d c/B/ A B | A F F/E/ D/E/ | F F E |
[V:2] F | F F E A | A G F G | F D D/C/ B,/C/ | D D C |
[V:3] D | D F E F | F E D E | D A, B, A, | A, B, A, |
[V:4] D | D D C D | D C B, C | A, F, G, F, | F, G, F, |
[V:5] A | D A A C | D D D D | D A B F | A A A |
[V:6] A, | A, G, G, A, | A, G, G, B, | A, G, G, A, | G, A, B, |
[V:7] F, | F, A, A, G, | F, G, D, D, | A, F, G, F, | F, A, A, |
[V:8] D, | D, F, A, G, | F, G, D, D, | D, D, B, B, | A, A, A, |
%%
%% ── Refrain B (final, with intro markers) ─────────────────
%% Builds to climax: S1 reaches d'(D5); B1 drops to D,(D2).
%% Stretto between S1/T1 at "He leadeth me" motive.
%% Final cadence: 4-3 suspension S2→S2, Bar 7-6 → 5.
%%
[V:1] A | A d c e | d c/B/ A !sintro!B | A F F/E/ D/E/ | F3/2 E/ !fermata!D !eintro!|]
[V:2] C | F D E A | A G F G | F D D/C/ B,/C/ | D3/2 C/ D |]
[V:3] F, | D F E G | F E D E | D B, B, A, | A,3/2 G,/ F, |]
[V:4] D, | A, D C E | D C B, C | A, F, G, F, | F,3/2 E,/ D, |]
[V:5] G | F A A C | D D D D | D A B F | A3/2 G/ !invertedfermata!F |]
[V:6] G, | G, G, G, A, | A, G, G, B, | A, G, G, G, | G,3/2 G,/ G, |]
[V:7] A, | D, F, A, G, | F, G, D, D, | A, F, G, F, | A,3/2 G,/ D, |]
[V:8] D, | D, F, A, G, | F, G, D, D, | D, D, B, B, | A,3/2 A,/ D, |]
